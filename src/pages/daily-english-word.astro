---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const t = {
  ko: {
    title: '오늘의 영단어 | ManyTool',
    desc: '매일 고정된 영단어 1개를 뜻과 예문으로 학습하는 페이지입니다.',
    h1: '오늘의 영단어',
    sub: '새로고침해도 오늘 단어는 고정됩니다.',
    copy: '복사',
    copied: '복사됨',
    faqQ: 'Q. 하루 단어가 계속 바뀌나요?',
    faqA: 'A. 같은 날짜에는 고정되고, 다음 날짜에만 변경됩니다.'
  },
  en: {
    title: 'Daily English Word | ManyTool',
    desc: 'Learn one fixed English word per day with meaning and example sentence.',
    h1: 'Daily English Word',
    sub: 'The daily word stays fixed until the date changes.',
    copy: 'Copy',
    copied: 'Copied',
    faqQ: 'Q. Does the word change on refresh?',
    faqA: 'A. No. It is fixed for the current date.'
  },
  ja: {
    title: '今日の英単語 | ManyTool',
    desc: '毎日1つの英単語を意味と例文で学べます。',
    h1: '今日の英単語',
    sub: 'リロードしても当日の単語は固定です。',
    copy: 'コピー',
    copied: 'コピー完了',
    faqQ: 'Q. 更新のたびに単語は変わりますか？',
    faqA: 'A. いいえ。当日は固定で、日付変更時のみ変わります。'
  }
}[locale];
---

<Layout title={t.title} description={t.desc}>
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-3xl font-black">{t.h1}</h1>
    <p class="mt-2 text-slate-700">{t.sub}</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5">
      <h2 id="word" class="text-3xl font-black text-slate-900">-</h2>
      <p id="pron" class="mt-1 text-slate-500">-</p>
      <p id="meaning" class="mt-3 text-lg font-semibold text-slate-800">-</p>
      <p id="example" class="mt-2 rounded-lg bg-slate-100 px-3 py-2 text-slate-700">-</p>
      <button id="copy-btn" class="mt-3 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold">{t.copy}</button>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-bold">FAQ</h2>
      <p class="mt-2">{t.faqQ}</p>
      <p>{t.faqA}</p>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline define:vars={{ copiedText: t.copied }}>
    const roots = [
      ['adapt', '/əˈdæpt/', '적응하다'],
      ['clarify', '/ˈklærəfaɪ/', '명확히 하다'],
      ['focus', '/ˈfoʊkəs/', '집중하다'],
      ['improve', '/ɪmˈpruːv/', '개선하다'],
      ['balance', '/ˈbæləns/', '균형'],
      ['insight', '/ˈɪnsaɪt/', '통찰'],
      ['consistency', '/kənˈsɪstənsi/', '일관성'],
      ['curiosity', '/ˌkjʊriˈɑːsəti/', '호기심'],
      ['momentum', '/moʊˈmentəm/', '추진력'],
      ['resilient', '/rɪˈzɪliənt/', '회복력 있는'],
      ['practical', '/ˈpræktɪkəl/', '실용적인'],
      ['efficient', '/ɪˈfɪʃənt/', '효율적인'],
      ['discipline', '/ˈdɪsəplɪn/', '규율'],
      ['priority', '/praɪˈɔːrəti/', '우선순위'],
      ['creative', '/kriˈeɪtɪv/', '창의적인'],
      ['steady', '/ˈstedi/', '꾸준한']
    ];
    const contexts = [
      'in work',
      'in study',
      'in teamwork',
      'in planning',
      'in communication',
      'for growth',
      'for daily life',
      'for projects',
      'for habits',
      'for better results'
    ];
    const patterns = [
      'Use %w% %c%.',
      '%w% helps you move forward %c%.',
      'Build %w% step by step %c%.',
      'Small %w% makes a big difference %c%.',
      'Practice %w% every day %c%.'
    ];
    const tones = [
      'with focus',
      'with calm',
      'with consistency',
      'with confidence',
      'with patience',
      'with clarity',
      'with intention',
      'with discipline',
      'with curiosity',
      'with momentum'
    ];

    const words = [];
    for (const root of roots) {
      for (const context of contexts) {
        for (const pattern of patterns) {
          for (const tone of tones) {
            words.push({
              word: root[0],
              pron: root[1],
              meaning: root[2],
              ex: `${pattern.replace('%w%', root[0]).replace('%c%', context)} ${tone}.`
            });
          }
        }
      }
    }

    const now = new Date();
    const kst = new Date(now.getTime() + 9 * 60 * 60 * 1000);
    const key = `${kst.getUTCFullYear()}-${kst.getUTCMonth() + 1}-${kst.getUTCDate()}`;
    let hash = 0;
    for (let i = 0; i < key.length; i += 1) hash = (hash * 31 + key.charCodeAt(i)) >>> 0;
    const pick = words[hash % words.length];

    const wordEl = document.getElementById('word');
    const pronEl = document.getElementById('pron');
    const meaningEl = document.getElementById('meaning');
    const exampleEl = document.getElementById('example');
    const copyBtn = document.getElementById('copy-btn');

    if (wordEl) wordEl.textContent = pick.word;
    if (pronEl) pronEl.textContent = pick.pron;
    if (meaningEl) meaningEl.textContent = pick.meaning;
    if (exampleEl) exampleEl.textContent = pick.ex;

    copyBtn?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(`${pick.word} ${pick.pron} - ${pick.meaning} / ${pick.ex}`);
      if (copyBtn instanceof HTMLButtonElement) copyBtn.textContent = copiedText;
    });
  </script>
</Layout>
