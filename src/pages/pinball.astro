---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="핀볼 게임 | FunHub" description="웹에서 즐기는 미니 핀볼 게임">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">핀볼 게임</h1>
    <p class="mt-3 text-slate-700">패들을 좌우로 움직여 공을 떨어뜨리지 마세요. 벽 충돌마다 점수가 올라갑니다.</p>

    <section class="mt-4 rounded-xl border border-slate-200 bg-white p-4">
      <div class="mb-3 flex items-center justify-between text-sm">
        <p>점수: <span id="pinball-score" class="font-bold">0</span></p>
        <button id="pinball-reset" class="rounded-md border border-slate-300 px-3 py-1">다시 시작</button>
      </div>
      <canvas id="pinball-canvas" width="720" height="420" class="w-full rounded-lg bg-slate-900"></canvas>
      <p class="mt-2 text-xs text-slate-500">조작: ← → 또는 A D</p>
    </section>

    <Recommend />
  </main>
  <Footer />

  <script is:inline>
    const canvas = document.getElementById('pinball-canvas');
    const scoreEl = document.getElementById('pinball-score');
    const resetEl = document.getElementById('pinball-reset');
    if (!(canvas instanceof HTMLCanvasElement)) {
      throw new Error('Canvas not found');
    }
    const ctx = canvas.getContext('2d');
    if (!ctx) throw new Error('2D context not available');

    const W = canvas.width;
    const H = canvas.height;

    let paddleX = W / 2 - 55;
    const paddleY = H - 30;
    const paddleW = 110;
    const paddleH = 12;
    const paddleSpeed = 7;

    let ballX = W / 2;
    let ballY = H / 2;
    let vx = 3.2;
    let vy = -3.1;
    const r = 8;

    let left = false;
    let right = false;
    let score = 0;

    const resetGame = () => {
      paddleX = W / 2 - 55;
      ballX = W / 2;
      ballY = H / 2;
      vx = (Math.random() > 0.5 ? 1 : -1) * 3.2;
      vy = -3.1;
      score = 0;
      if (scoreEl) scoreEl.textContent = '0';
    };

    const draw = () => {
      ctx.clearRect(0, 0, W, H);

      ctx.fillStyle = '#0f172a';
      ctx.fillRect(0, 0, W, H);

      ctx.fillStyle = '#38bdf8';
      ctx.fillRect(paddleX, paddleY, paddleW, paddleH);

      ctx.beginPath();
      ctx.arc(ballX, ballY, r, 0, Math.PI * 2);
      ctx.fillStyle = '#fbbf24';
      ctx.fill();

      if (left) paddleX -= paddleSpeed;
      if (right) paddleX += paddleSpeed;
      if (paddleX < 0) paddleX = 0;
      if (paddleX + paddleW > W) paddleX = W - paddleW;

      ballX += vx;
      ballY += vy;

      if (ballX - r <= 0 || ballX + r >= W) {
        vx *= -1;
        score += 1;
      }
      if (ballY - r <= 0) {
        vy *= -1;
        score += 1;
      }

      const hitPaddle = ballY + r >= paddleY && ballY + r <= paddleY + paddleH && ballX >= paddleX && ballX <= paddleX + paddleW;
      if (hitPaddle) {
        vy = -Math.abs(vy);
        const hitPos = (ballX - (paddleX + paddleW / 2)) / (paddleW / 2);
        vx = hitPos * 4.2;
        score += 3;
      }

      if (ballY - r > H) {
        resetGame();
      }

      if (scoreEl) scoreEl.textContent = String(score);
      requestAnimationFrame(draw);
    };

    window.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft' || e.key.toLowerCase() === 'a') left = true;
      if (e.key === 'ArrowRight' || e.key.toLowerCase() === 'd') right = true;
    });

    window.addEventListener('keyup', (e) => {
      if (e.key === 'ArrowLeft' || e.key.toLowerCase() === 'a') left = false;
      if (e.key === 'ArrowRight' || e.key.toLowerCase() === 'd') right = false;
    });

    resetEl?.addEventListener('click', resetGame);

    resetGame();
    draw();
  </script>
</Layout>
