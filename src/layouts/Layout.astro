---
import '../styles/global.css';
import AdSense from '../components/AdSense.astro';
import SiteProviders from '../components/providers/SiteProviders';
import globalCssUrl from '../styles/global.css?url';
import { createTranslator, detectLocale, stripLocale, withLocalePath } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
  noindex?: boolean;
}

const {
  title = 'ManyTool | 무료 온라인 도구 모음',
  description = 'ManyTool은 무료 온라인 도구, 테스트, 게임, 지도, 쇼핑몰 보조 툴을 제공하는 웹 기반 툴 플랫폼입니다.',
  image = '/og-image.png',
  keywords,
  noindex = false
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const ogImage = new URL(image, Astro.site ?? Astro.url.origin).toString();
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const locale = detectLocale(Astro.url.pathname);
const t = await createTranslator(locale);
const htmlLang = locale === 'ko' ? 'ko' : locale === 'ja' ? 'ja' : 'en';
const ogLocale = locale === 'ko' ? 'ko_KR' : locale === 'ja' ? 'ja_JP' : 'en_US';
const pathNoLocale = stripLocale(Astro.url.pathname);
const koHref = new URL(pathNoLocale, siteUrl).toString();
const enHref = new URL(pathNoLocale === '/' ? '/en' : `/en${pathNoLocale}`, siteUrl).toString();
const jaHref = new URL(pathNoLocale === '/' ? '/ja' : `/ja${pathNoLocale}`, siteUrl).toString();
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? 'G-J48EQSQQD8';
const gtmId = 'GTM-NX7VHS5V';
const clarityId = 'vwq6krnuzx';
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const naverSiteVerification = import.meta.env.PUBLIC_NAVER_SITE_VERIFICATION ?? 'ab286ec18ea2904617f2827146d5b7fb2b5389cc';
const adsenseClient = 'ca-pub-1009841039120964';
const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();
const apiBase = rawApiBase.replace(/\/+$/, '');
const localeTitlePrefix = locale === 'ko' ? '' : locale === 'en' ? '[EN] ' : '[JA] ';
const localeDescSuffix = t('layout.descriptionSuffix');
const normalizedPathLabel = pathNoLocale === '/' ? 'main' : pathNoLocale.replace(/\//g, ' ').trim();
const segments = pathNoLocale.split('/').filter(Boolean);
const topSlug = segments[segments.length - 1] ?? '';
const freeLabelMap: Record<string, string> = {
  'today-fortune': t('layout.freeBodyLabel.todayFortune'),
  'name-meaning': t('layout.freeBodyLabel.nameMeaning'),
  'name-compatibility': t('layout.freeBodyLabel.nameCompatibility'),
  'love-compatibility': t('layout.freeBodyLabel.loveCompatibility')
};
const freeBodyLabel = locale === 'ko' ? freeLabelMap[topSlug] : undefined;
const freeAutoPaths = new Set(['/', '/tools', '/games', '/tests', '/maps', '/online-tools']);
const shouldAutoFreeLabel = locale === 'ko' && (Boolean(freeBodyLabel) || freeAutoPaths.has(pathNoLocale));
const baseTitle = `${localeTitlePrefix}${title}`;
const resolvedTitle = shouldAutoFreeLabel && !baseTitle.includes('무료')
  ? `무료 ${baseTitle}`
  : baseTitle;
const resolvedDescription = `${description}${localeDescSuffix}${locale === 'ko' ? '' : ` (path: ${normalizedPathLabel})`}`;
const defaultKeywords = '무료 온라인 도구, 웹툴, 온라인 툴, 무료 테스트, 브라우저 게임, 지도 도구, 쇼핑몰 보조 툴, 스마트스토어 툴';
const keywordsBase = keywords ?? defaultKeywords;
const resolvedKeywords = shouldAutoFreeLabel && !keywordsBase.includes('무료')
  ? `무료, ${keywordsBase}`
  : keywordsBase;
const labelMap: Record<string, string> = {
  about: '소개',
  contact: '문의',
  privacy: '개인정보 처리방침',
  terms: '이용약관',
  'refund-policy': '환불정책',
  'editorial-policy': '콘텐츠 운영 원칙',
  'content-disclaimer': '면책 고지',
  'animal-test': '동물상 테스트',
  'personal-color': '퍼스널컬러 테스트',
  'ai-personal-color': 'AI 퍼스널컬러 자가진단',
  'ai-manseryeok': 'AI 만세력 사주팔자 정밀분석',
  sandbox: '샌드박스',
  'species-war': '종 vs 종 샌드박스',
  'magic-book': '마법책',
  pinball: '핀볼',
  'random-food': '랜덤 음식 추천',
  'name-meaning': '이름풀이',
  'name-compatibility': '이름궁합',
  'today-fortune': '오늘의 운세',
  'fortune-cookie-2026': '올해 포츈쿠키',
  'reaction-test': '반응속도 테스트',
  'mbti-test': 'MBTI 테스트',
  'love-compatibility': '연애 궁합',
  'ladder-game': '사다리타기',
  maps: '지도',
  fishbread: '붕어빵 지도',
  'hidden-cafe': '숨은 카페 지도',
  'local-eats': '지역 맛집 지도',
  en: 'English',
  ja: '日本語'
};

const breadcrumbs = [
  { name: t('common.home'), href: withLocalePath(locale, '/') },
  ...segments.map((seg, idx) => {
    const path = `/${segments.slice(0, idx + 1).join('/')}`;
    const localizedPath = withLocalePath(locale, path);
    return {
      name: labelMap[seg] ?? seg,
      href: localizedPath
    };
  })
];

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ManyTool',
  url: siteUrl,
  inLanguage: locale === 'ko' ? 'ko-KR' : locale === 'ja' ? 'ja-JP' : 'en-US',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};

const softwareApplicationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'ManyTool',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Web',
  description: t('layout.softwareDescription'),
  url: siteUrl
};

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ManyTool',
  url: siteUrl,
  logo: new URL('/logo.png', siteUrl).toString()
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: t('layout.faq.q1'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t('layout.faq.a1')
      }
    },
    {
      '@type': 'Question',
      name: t('layout.faq.q2'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t('layout.faq.a2')
      }
    },
    {
      '@type': 'Question',
      name: t('layout.faq.q3'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t('layout.faq.a3')
      }
    },
    {
      '@type': 'Question',
      name: t('layout.faq.q4'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t('layout.faq.a4')
      }
    }
  ]
};

const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: resolvedTitle,
  description: resolvedDescription,
  url: canonical,
  isPartOf: {
    '@type': 'WebSite',
    name: 'ManyTool',
    url: siteUrl
  },
  inLanguage: locale === 'ko' ? 'ko-KR' : locale === 'ja' ? 'ja-JP' : 'en-US'
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: crumb.name,
    item: new URL(crumb.href, siteUrl).toString()
  }))
};

const sidebarText = {
  title: t('layout.sidebar.title'),
  subtitle: t('layout.sidebar.subtitle'),
  donate: t('layout.sidebar.donate'),
  donateHint: t('layout.sidebar.donateHint'),
  donateLoading: t('layout.sidebar.donateLoading'),
  donateUnavailable: t('layout.sidebar.donateUnavailable'),
  open: t('layout.sidebar.open'),
  close: t('layout.sidebar.close'),
  links: [
    { href: withLocalePath(locale, '/'), label: t('common.home') },
    { href: withLocalePath(locale, '/ai-image-generator'), label: t('layout.sidebar.aiImage') },
    {
      href: withLocalePath(locale, '/ai-personal-color'),
      label: locale === 'ko' ? 'AI 퍼스널컬러 자가진단' : locale === 'ja' ? 'AIパーソナルカラー診断' : 'AI Personal Color Analysis'
    },
    {
      href: withLocalePath(locale, '/ai-manseryeok'),
      label: locale === 'ko' ? 'AI 사주팔자 정밀분석' : locale === 'ja' ? 'AI四柱推命精密分析' : 'Korean Saju Palja'
    },
    {
      href: withLocalePath(locale, '/name-premium'),
      label: locale === 'ko' ? 'AI 프리미엄 이름분석 개명추천' : locale === 'ja' ? 'AIプレミアム名前分析・改名推薦' : 'AI Premium Name Analysis'
    },
    { href: withLocalePath(locale, '/ai-calorie-calculator'), label: t('layout.sidebar.aiCalorie') },
    { href: withLocalePath(locale, '/ai-id-photo'), label: t('layout.sidebar.aiIdPhoto') },
    {
      href: withLocalePath(locale, '/tools/product-detail-studio'),
      label: locale === 'ko' ? 'AI 상세페이지 생성기' : locale === 'ja' ? 'AI商品詳細ページ生成' : 'AI Product Detail Studio'
    }
  ]
};

const disabledSidebarPaths = new Set(['/ai-id-photo', '/ai-passport-photo', '/ai-headshot']);
const isDisabledSidebarLink = (href: string) => disabledSidebarPaths.has((href.replace(/^\/(en|ja)(?=\/|$)/, '') || '/'));
---

<!doctype html>
<html lang={htmlLang} suppressHydrationWarning>
  <head>
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
    {clarityId && (
      <script is:inline define:vars={{ clarityId }}>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", clarityId);
      </script>
    )}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" as="style" href={globalCssUrl} />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="keywords" content={resolvedKeywords} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="max-snippet" content="-1" />
    <meta name="max-image-preview" content="large" />
    <meta name="max-video-preview" content="-1" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ManyTool" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="author" content="ManyTool" />
    <meta name="google-adsense-account" content={adsenseClient} />
    <link rel="alternate" hrefLang="ko-KR" href={koHref} />
    <link rel="alternate" hrefLang="en" href={enHref} />
    <link rel="alternate" hrefLang="ja" href={jaHref} />
    <link rel="alternate" hrefLang="x-default" href={koHref} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    {naverSiteVerification && <meta name="naver-site-verification" content={naverSiteVerification} />}
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(webPageJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
      crossorigin="anonymous"
    ></script>
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script
          is:inline
          define:vars={{ gaId }}
        >
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="bg-slate-50 text-slate-900">
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <SiteProviders client:load />
    <aside
      id="manytool-sidebar"
      class="fixed left-0 top-0 z-[70] hidden h-screen w-[288px] -translate-x-0 flex-col border-r border-slate-200 bg-white/95 shadow-[0_24px_80px_rgba(15,23,42,0.16)] backdrop-blur transition-transform duration-300 lg:flex"
      aria-label="ManyTool sidebar"
      data-open="true"
    >
      <div class="flex items-center border-b border-slate-200 px-4 py-4">
        <div>
          <p class="text-base font-black tracking-tight text-slate-950">{sidebarText.title}</p>
          <p class="mt-1 text-xs font-medium uppercase tracking-[0.18em] text-slate-400">{sidebarText.subtitle}</p>
        </div>
      </div>

      <nav class="flex-1 overflow-y-auto px-3 py-4">
        <ul class="space-y-2">
          {sidebarText.links.map((link) => (
            <li>
              <a
                href={isDisabledSidebarLink(link.href) ? undefined : link.href}
                aria-disabled={isDisabledSidebarLink(link.href) ? 'true' : 'false'}
                class:list={[
                  'flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-semibold transition',
                  isDisabledSidebarLink(link.href)
                    ? 'cursor-not-allowed bg-slate-100 text-slate-400'
                    : Astro.url.pathname === link.href
                      ? 'bg-slate-950 text-white'
                      : 'bg-slate-50 text-slate-700 hover:bg-slate-100'
                ]}
              >
                <span>{link.label}</span>
                {isDisabledSidebarLink(link.href) ? (
                  <span class="rounded-full border border-slate-200 bg-white px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500">
                    {t('common.soon')}
                  </span>
                ) : null}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="border-t border-slate-200 p-4">
        <div class="rounded-[24px] bg-gradient-to-br from-amber-50 via-rose-50 to-sky-50 p-4">
          <p class="text-sm font-bold text-slate-950">{sidebarText.donate}</p>
          <p class="mt-2 text-xs leading-5 text-slate-600">{sidebarText.donateHint}</p>
          <button
            id="manytool-donate-button"
            type="button"
            class="mt-4 w-full rounded-2xl bg-slate-950 px-4 py-3 text-sm font-bold text-white transition hover:bg-slate-800"
          >
            {sidebarText.donate}
          </button>
          <p id="manytool-donate-message" class="mt-2 text-xs text-slate-500"></p>
        </div>
      </div>
      <button
        id="manytool-sidebar-toggle"
        type="button"
        class="absolute right-0 top-1/2 z-10 hidden h-11 w-11 translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white text-lg text-slate-700 shadow-[0_12px_30px_rgba(15,23,42,0.16)] lg:flex"
        aria-expanded="true"
        aria-label={sidebarText.close}
      >
        ‹
      </button>
    </aside>

    <div id="manytool-shell" class="transition-[padding] duration-300 lg:pl-[288px]">
      {pathNoLocale !== '/' && (
        <nav aria-label="Breadcrumb" class="mx-auto max-w-5xl px-4 pt-3 text-xs text-slate-500">
          <ol class="flex flex-wrap items-center gap-1">
            {breadcrumbs.map((crumb, idx) => (
              <li class="flex items-center gap-1">
                {idx > 0 && <span>/</span>}
                <a href={crumb.href} class="hover:text-slate-700 hover:underline">{crumb.name}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}
      {freeBodyLabel && (
        <div class="mx-auto max-w-5xl px-4 pt-3">
          <p class="inline-flex rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
            {freeBodyLabel}
          </p>
        </div>
      )}
      <AdSense slotName="글로벌 본문 상단" />
      <slot />
      <AdSense slotName="글로벌 본문 하단" />
    </div>

    <script is:inline define:vars={{ apiBase, locale, donateText: sidebarText }}>
      const sidebarEl = document.getElementById('manytool-sidebar');
      const shellEl = document.getElementById('manytool-shell');
      const toggleEl = document.getElementById('manytool-sidebar-toggle');
      const donateButtonEl = document.getElementById('manytool-donate-button');
      const donateMessageEl = document.getElementById('manytool-donate-message');
      const sidebarStorageKey = 'manytool.sidebar.open';
      const defaultSidebarOpen = true;

      const applySidebarState = (isOpen) => {
        if (!sidebarEl || !toggleEl || !shellEl) return;
        sidebarEl.dataset.open = isOpen ? 'true' : 'false';
        sidebarEl.classList.toggle('-translate-x-[260px]', !isOpen);
        sidebarEl.classList.toggle('translate-x-0', isOpen);
        shellEl.classList.toggle('lg:pl-[288px]', isOpen);
        shellEl.classList.toggle('lg:pl-[28px]', !isOpen);
        toggleEl.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        toggleEl.setAttribute('aria-label', isOpen ? donateText.close : donateText.open);
        toggleEl.textContent = isOpen ? '‹' : '›';
      };

      const savedSidebarState = typeof window !== 'undefined'
        ? window.localStorage.getItem(sidebarStorageKey)
        : null;
      applySidebarState(savedSidebarState === null ? defaultSidebarOpen : savedSidebarState === 'true');

      toggleEl?.addEventListener('click', () => {
        const nextOpen = sidebarEl?.dataset.open !== 'true';
        applySidebarState(nextOpen);
        window.localStorage.setItem(sidebarStorageKey, nextOpen ? 'true' : 'false');
      });

      donateButtonEl?.addEventListener('click', async () => {
        if (!apiBase) {
          if (donateMessageEl) donateMessageEl.textContent = donateText.donateUnavailable;
          return;
        }

        donateButtonEl.disabled = true;
        donateButtonEl.textContent = donateText.donateLoading;
        if (donateMessageEl) donateMessageEl.textContent = '';

        try {
          const configResponse = await fetch(`${apiBase}/config`);
          const configPayload = await configResponse.json().catch(() => null);
          const donationReady = Boolean(configPayload?.paymentProducts?.donation);
          if (!configResponse.ok || !donationReady) {
            throw new Error(donateText.donateUnavailable);
          }

          const currentUrl = window.location.href;
          const checkoutResponse = await fetch(`${apiBase}/checkout`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              productType: 'donation',
              amount: 100,
              currency: 'USD',
              successUrl: currentUrl,
              returnUrl: currentUrl
            })
          });

          const checkoutPayload = await checkoutResponse.json().catch(() => null);
          if (!checkoutResponse.ok || !checkoutPayload) {
            throw new Error(checkoutPayload?.error || donateText.donateUnavailable);
          }

          if (checkoutPayload.checkoutUrl) {
            window.location.href = checkoutPayload.checkoutUrl;
            return;
          }

          if (donateMessageEl) donateMessageEl.textContent = donateText.donateUnavailable;
        } catch (error) {
          if (donateMessageEl) {
            donateMessageEl.textContent = error instanceof Error ? error.message : donateText.donateUnavailable;
          }
          donateButtonEl.disabled = false;
          donateButtonEl.textContent = donateText.donate;
        }
      });
    </script>
  </body>
</html>
