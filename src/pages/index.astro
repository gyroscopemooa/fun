---
import Layout from '../layouts/Layout.astro';
import AdSense from '../components/AdSense.astro';
import SponsorBanner from '../components/SponsorBanner.astro';
import Recommend from '../components/Recommend.astro';
import Footer from '../components/Footer.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';
const localePrefix = locale === 'ko' ? '' : `/${locale}`;
const withLocale = (path: string) => `${localePrefix}${path}`.replace(/\/{2,}/g, '/');

const t = {
  ko: {
    tabs: ['전체', '게임', '도구', '아트', '기타'],
    searchPlaceholder: '원하는 기능을 검색해보세요',
    heroTitle: '재미 도구 모음',
    heroDesc: '카드에서 바로 시작하세요.',
    noResult: '검색 결과가 없습니다.',
    guideTitle: 'ManyTool 사용 가이드',
    guideP1: 'ManyTool은 짧은 시간에 바로 사용할 수 있는 기능형 페이지를 중심으로 구성됩니다.',
    guideP2: '테스트, 게임, 지도, 랜덤 도구를 카드에서 바로 열고, 하단 추천 링크를 통해 연관 기능으로 이동할 수 있습니다.',
    faqTitle: '자주 묻는 질문',
    faqQ1: 'Q. ManyTool은 무료인가요?',
    faqA1: 'A. 현재 제공되는 기능은 무료로 이용할 수 있습니다.',
    faqQ2: 'Q. 지도 정보가 다를 수도 있나요?',
    faqA2: 'A. 제보 기반 정보가 포함될 수 있어, 방문 전 최신 운영 여부 확인을 권장합니다.',
    faqQ3: 'Q. 정책 페이지는 어디에서 확인하나요?',
    faqA3: 'A. 페이지 하단 푸터(개인정보/약관/운영원칙/면책고지)에서 확인할 수 있습니다.'
  },
  en: {
    tabs: ['All', 'Games', 'Tools', 'Art', 'Etc'],
    searchPlaceholder: 'Search tools',
    heroTitle: 'Playful Tools',
    heroDesc: 'Start directly from cards.',
    noResult: 'No results found.',
    guideTitle: 'ManyTool Guide',
    guideP1: 'ManyTool is built for fast, practical pages you can use immediately.',
    guideP2: 'Open tests, games, maps, and random tools directly from cards.',
    faqTitle: 'FAQ',
    faqQ1: 'Q. Is ManyTool free?',
    faqA1: 'A. Yes, current features are free.',
    faqQ2: 'Q. Can map information be outdated?',
    faqA2: 'A. Some spots are user-submitted, so please verify before visiting.',
    faqQ3: 'Q. Where are policy pages?',
    faqA3: 'A. Check the footer links for Privacy, Terms, Editorial, and Disclaimer.'
  },
  ja: {
    tabs: ['全体', 'ゲーム', 'ツール', 'アート', 'その他'],
    searchPlaceholder: 'ツールを検索',
    heroTitle: '楽しいツール集',
    heroDesc: 'カードからすぐ開始できます。',
    noResult: '検索結果がありません。',
    guideTitle: 'ManyTool ガイド',
    guideP1: 'ManyToolはすぐ使える実用ページを中心に構成されています。',
    guideP2: 'テスト、ゲーム、マップ、ランダムツールをカードから直接開けます。',
    faqTitle: 'よくある質問',
    faqQ1: 'Q. ManyToolは無料ですか？',
    faqA1: 'A. 現在の機能は無料です。',
    faqQ2: 'Q. 地図情報が異なる場合はありますか？',
    faqA2: 'A. ユーザー投稿情報を含むため、訪問前の確認をおすすめします。',
    faqQ3: 'Q. ポリシーページはどこですか？',
    faqA3: 'A. フッターのプライバシー/利用規約/運営方針/免責事項をご確認ください。'
  }
}[locale];

const cards = [
  { href: '/animal-test', title: '동물상 테스트', desc: '사진으로 동물상 분석', icon: '🐾', iconClass: 'bg-sky-100 text-sky-700' },
  { href: '/pinball', title: '핀볼 게임', desc: '가볍게 즐기는 미니게임', icon: '🎮', iconClass: 'bg-emerald-100 text-emerald-700' },
  { href: '/personal-color', title: '퍼스널컬러', desc: '얼굴 기반 색상 추천', icon: '🎨', iconClass: 'bg-amber-100 text-amber-700' },
  { href: '/magic-book', title: '마법책', desc: '랜덤 문구 뽑기', icon: '✨', iconClass: 'bg-fuchsia-100 text-fuchsia-700' },
  { href: '/reaction-test', title: '반응속도', desc: '클릭 속도 측정', icon: '⚡', iconClass: 'bg-rose-100 text-rose-700' },
  { href: '/mbti-test', title: 'MBTI 테스트', desc: '성향 빠른 확인', icon: '🧠', iconClass: 'bg-indigo-100 text-indigo-700' },
  { href: '/maps/fishbread', title: '전국 붕어빵 지도', desc: '지역별 붕어빵 빠른 탐색', icon: '🗺️', iconClass: 'bg-cyan-100 text-cyan-700' },
  { href: '/name-meaning', title: '이름풀이', desc: '이름으로 성향 키워드 보기', icon: '📝', iconClass: 'bg-blue-100 text-blue-700' },
  { href: '/name-compatibility', title: '이름궁합', desc: '두 이름 궁합 점수 확인', icon: '💕', iconClass: 'bg-pink-100 text-pink-700' },
  { href: '/maps/hidden-cafe', title: '숨은 카페 지도', desc: '조용한 카페 탐색', icon: '☕', iconClass: 'bg-orange-100 text-orange-700' },
  { href: '/maps/local-eats', title: '지역 맛집 지도', desc: '동네 인기 맛집', icon: '🍜', iconClass: 'bg-red-100 text-red-700' },
  { href: '/love-compatibility', title: '연애 궁합', desc: '두 사람 궁합 테스트', icon: '💜', iconClass: 'bg-violet-100 text-violet-700' },
  { href: '/random-food', title: '랜덤 음식', desc: '오늘 메뉴 추천', icon: '🎲', iconClass: 'bg-yellow-100 text-yellow-700' },
  { href: '/today-fortune', title: '오늘의 운세', desc: '오늘 운세 랜덤 확인', icon: '🔮', iconClass: 'bg-purple-100 text-purple-700' },
  { href: '/fortune-cookie-2026', title: '올해 포츈쿠키', desc: '2026년 키워드 뽑기', icon: '🥠', iconClass: 'bg-amber-100 text-amber-700' },
  { href: '/ladder-game', title: '사다리타기', desc: '랜덤 당첨 뽑기', icon: '🪜', iconClass: 'bg-lime-100 text-lime-700' }
  ,{ href: '/tools/scoreboard', title: '스트리머 점수판', desc: 'OBS용 실시간 스코어보드', icon: '📊', iconClass: 'bg-teal-100 text-teal-700' }
].map((card) => ({ ...card, href: withLocale(card.href) }));

const rows = [cards.slice(0, 8), cards.slice(4, 12), cards.slice(8, 16)];
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ManyTool은 어떤 사이트인가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '테스트, 미니게임, 지도, 랜덤 추천 기능을 한 곳에서 제공하는 도구형 포털입니다.'
      }
    },
    {
      '@type': 'Question',
      name: '회원가입이 필요한가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '대부분 기능은 회원가입 없이 바로 사용할 수 있습니다.'
      }
    },
    {
      '@type': 'Question',
      name: '광고 및 제휴 문의는 어디서 하나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Contact 페이지를 통해 공식 메일로 문의할 수 있습니다.'
      }
    }
  ]
};
---

<Layout title="ManyTool | 카드형 포털" description="테스트, 게임, 지도, 랜덤 도구를 카드로 탐색하는 메인 페이지">
  <main class="min-h-screen bg-slate-100">
    <div class="mx-auto max-w-6xl">
      <header class="flex items-center justify-between border-b border-sky-100 px-4 py-3 lg:px-10">
        <a href={withLocale('/')} class="flex items-center gap-3">
          <img src="/favicon.svg" alt="ManyTool 로고" class="h-8 w-8 rounded-lg bg-sky-100 p-1" loading="eager" decoding="async" />
          <h2 class="text-lg font-bold tracking-tight text-slate-900 sm:text-xl">ManyTool</h2>
        </a>
      </header>

      <section class="px-4 py-5 lg:px-10">
        <div class="max-w-md">
          <input
            id="tool-search"
            class="w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none focus:border-sky-400"
            placeholder={t.searchPlaceholder}
            type="text"
          />
        </div>

        <div class="mt-5">
          <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{t.heroTitle}</h1>
          <p class="mt-1 text-slate-500">{t.heroDesc}</p>
        </div>

        <div class="mt-4 flex gap-2 overflow-x-auto pb-2">
          {t.tabs.map((tab, idx) => (
            <button
              class:list={[
                'whitespace-nowrap rounded-full px-4 py-2 text-sm font-medium',
                idx === 0
                  ? 'bg-sky-500 text-white'
                  : 'border border-sky-100 bg-white text-slate-600'
              ]}
            >
              {tab}
            </button>
          ))}
        </div>
      </section>

      <section class="space-y-4 px-4 pb-4 lg:px-10">
        {rows.map((row, idx) => (
          <div class="flex items-center gap-2" data-slider data-row={idx} data-row-wrap>
            <button class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-sky-100 bg-white text-lg text-sky-500" data-nav="prev" aria-label="이전 카드">‹</button>
            <div class="flex-1 overflow-hidden">
              <div class="flex snap-x snap-mandatory gap-3 overflow-x-auto scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" data-track>
                {[0, 1, 2].flatMap((dup) =>
                  row.map((card) => (
                  <a
                    href={card.href}
                    data-card
                    data-dup={dup}
                    data-search={`${card.title} ${card.desc}`.toLowerCase()}
                    class="min-w-[72vw] snap-start rounded-xl border border-sky-100 bg-white p-4 transition hover:shadow-sm sm:min-w-[210px] lg:min-w-[230px]"
                  >
                    <div class:list={['flex h-10 w-10 items-center justify-center rounded-lg text-base', card.iconClass]}>{card.icon}</div>
                    <h2 class="mt-3 text-base font-bold tracking-tight text-slate-900">{card.title}</h2>
                    <p class="mt-1 text-xs leading-relaxed text-slate-500">{card.desc}</p>
                  </a>
                )))}
              </div>
            </div>
            <button class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-sky-100 bg-white text-lg text-sky-500" data-nav="next" aria-label="다음 카드">›</button>
          </div>
        ))}
      </section>
      <p id="search-empty" class="hidden px-4 pb-4 text-sm text-slate-500 lg:px-10">{t.noResult}</p>

      <section class="px-4 pb-2 lg:px-10">
        <article class="rounded-xl border border-slate-200 bg-white p-5">
          <h2 class="text-xl font-semibold">{t.guideTitle}</h2>
          <p class="mt-2 text-slate-700">
            {t.guideP1}
          </p>
          <p class="mt-2 text-slate-700">
            {t.guideP2}
          </p>
        </article>
      </section>

      <section class="px-4 pb-2 lg:px-10">
        <article class="rounded-xl border border-slate-200 bg-white p-5">
          <h2 class="text-xl font-semibold">{t.faqTitle}</h2>
          <div class="mt-3 space-y-3 text-slate-700">
            <div>
              <h3 class="font-semibold text-slate-900">{t.faqQ1}</h3>
              <p>{t.faqA1}</p>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900">{t.faqQ2}</h3>
              <p>{t.faqA2}</p>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900">{t.faqQ3}</h3>
              <p>{t.faqA3}</p>
            </div>
          </div>
        </article>
      </section>

      <AdSense slotName="Header 아래" />
      <AdSense slotName="본문 상단" />
      <SponsorBanner position="본문 중간" />
      <AdSense slotName="본문 중간" />

      <section class="px-4 pb-10 lg:px-10">
        <Recommend />
        <AdSense slotName="추천 콘텐츠 위" />
      </section>
    </div>
    <Footer />

  </main>

  <script is:inline>
    const sliderRows = document.querySelectorAll('[data-slider]');
    const searchInput = document.getElementById('tool-search');
    const emptyEl = document.getElementById('search-empty');

    sliderRows.forEach((rowEl) => {
      const track = rowEl.querySelector('[data-track]');
      const prevBtn = rowEl.querySelector('[data-nav="prev"]');
      const nextBtn = rowEl.querySelector('[data-nav="next"]');

      if (!track || !prevBtn || !nextBtn) return;
      const step = () => {
        const firstCard = track.querySelector('a');
        if (!firstCard) return 240;
        const cardWidth = firstCard.getBoundingClientRect().width;
        return Math.round(cardWidth + 12);
      };
      const jump = () => Math.max(Math.round(step() * 2.8), Math.round(track.clientWidth * 0.85));

      const setWidth = () => Math.max(0, Math.floor(track.scrollWidth / 3));

      const normalizeLoop = () => {
        const loopWidth = setWidth();
        if (loopWidth <= 0) return;
        const min = 2;
        const max = loopWidth * 2 - 2;
        if (track.scrollLeft >= max) {
          track.scrollLeft -= loopWidth;
        } else if (track.scrollLeft < min) {
          track.scrollLeft += loopWidth;
        }
      };

      const slideNext = () => {
        const amount = jump();
        track.scrollLeft += amount;
        normalizeLoop();
      };

      const slidePrev = () => {
        const amount = jump();
        track.scrollLeft -= amount;
        normalizeLoop();
      };

      prevBtn.addEventListener('click', slidePrev);
      nextBtn.addEventListener('click', slideNext);
      track.addEventListener('scroll', normalizeLoop);

      track.scrollLeft = setWidth();
    });

    const applySearch = () => {
      if (!searchInput) return;
      const keyword = searchInput.value.trim().toLowerCase();
      const url = new URL(window.location.href);
      if (keyword) {
        url.searchParams.set('q', keyword);
      } else {
        url.searchParams.delete('q');
      }
      window.history.replaceState({}, '', url.toString());
      let visibleTotal = 0;

      sliderRows.forEach((rowEl) => {
        const cards = rowEl.querySelectorAll('[data-card]');
        let rowVisible = 0;

        cards.forEach((cardEl) => {
          const haystack = cardEl.getAttribute('data-search') ?? '';
          const isPrimary = cardEl.getAttribute('data-dup') === '0';
          const matched = (keyword === '' || haystack.includes(keyword)) && (keyword === '' || isPrimary);
          cardEl.classList.toggle('hidden', !matched);
          if (matched) rowVisible += 1;
        });

        rowEl.classList.toggle('hidden', rowVisible === 0);
        visibleTotal += rowVisible;
      });

      if (emptyEl) {
        emptyEl.classList.toggle('hidden', visibleTotal > 0);
      }
    };

    const initialQ = new URL(window.location.href).searchParams.get('q');
    if (searchInput && initialQ) {
      searchInput.value = initialQ;
    }
    searchInput?.addEventListener('input', applySearch);
    applySearch();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
</Layout>
