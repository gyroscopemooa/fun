---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const apiBase = import.meta.env.PUBLIC_NODE_API_BASE ?? 'http://127.0.0.1:8787';
---

<Layout
  title="AI 사진 운영 요약 | ManyTool"
  description="AI 증명사진 최근 작업, 경고, 추세, fallback, 품질 재시도 결과를 한 화면에서 확인하는 운영 페이지"
  noindex={true}
>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8">
    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">Ops Summary</p>
          <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-900">AI 사진 운영 요약</h1>
          <p class="mt-2 text-sm text-slate-600">
            최근 생성 결과, 저품질 경고, provider fallback, 품질 재시도 전후 점수를 한 화면에서 확인합니다.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="ops-refresh" type="button" class="rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-slate-800">새로고침</button>
          <button id="ops-copy-summary" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">요약 복사</button>
          <button id="ops-download-summary" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">요약 저장</button>
          <button id="ops-download-json" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">JSON 저장</button>
        </div>
      </div>

      <div class="mt-5 grid gap-3 md:grid-cols-2 xl:grid-cols-7">
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">상태</p>
          <select id="ops-status" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="all">전체</option>
            <option value="completed">completed</option>
            <option value="failed">failed</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">툴</p>
          <select id="ops-tool" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="all">전체</option>
            <option value="id_photo">id_photo</option>
            <option value="passport_photo">passport_photo</option>
            <option value="headshot">headshot</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">개수</p>
          <select id="ops-limit" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="8">8</option>
            <option value="12" selected>12</option>
            <option value="20">20</option>
            <option value="40">40</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">기간</p>
          <select id="ops-period" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="1">최근 1시간</option>
            <option value="24" selected>최근 24시간</option>
            <option value="168">최근 7일</option>
            <option value="0">전체</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">경고만</p>
          <select id="ops-flagged" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="false" selected>전체 포함</option>
            <option value="true">경고만 보기</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">fallback만</p>
          <select id="ops-fallback-only" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="false" selected>전체 포함</option>
            <option value="true">fallback만 보기</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">provider</p>
          <select id="ops-provider" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="all" selected>전체</option>
            <option value="local_sharp">local_sharp</option>
            <option value="remove_bg">remove_bg</option>
            <option value="photoroom">photoroom</option>
          </select>
        </label>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <button data-preset="all" type="button" class="ops-preset rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">전체 보기</button>
        <button data-preset="flagged" type="button" class="ops-preset rounded-full border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100">경고만</button>
        <button data-preset="fallback" type="button" class="ops-preset rounded-full border border-sky-200 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:bg-sky-100">fallback만</button>
        <button data-preset="failed" type="button" class="ops-preset rounded-full border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-900 transition hover:bg-rose-100">실패만</button>
      </div>

      <p id="ops-status-text" class="mt-4 text-sm text-slate-500">최근 운영 데이터를 불러오는 중입니다.</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <a id="ops-open-debug" href="/tools/ai-photo-debug" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">현재 필터 디버그</a>
        <button id="ops-copy-view-link" type="button" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">현재 뷰 링크 복사</button>
      </div>
    </section>

    <section id="ops-stats" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4"></section>

    <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-xl font-black text-slate-900">운영 인사이트</h2>
      <p class="mt-1 text-sm text-slate-600">가장 자주 터지는 문제와 품질 재시도 효과를 빠르게 요약합니다.</p>
      <div id="ops-insights" class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4"></div>
    </section>

    <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-xl font-black text-slate-900">시간대별 mini trend</h2>
      <p class="mt-1 text-sm text-slate-600">최근 작업 기준으로 실패, 경고, fallback이 몰린 시간대를 빠르게 봅니다.</p>
      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" class="ops-mini-trend-tab rounded-full border border-slate-300 bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white transition hover:border-slate-900" data-mini-trend-tab="risk">risk</button>
        <button type="button" class="ops-mini-trend-tab rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900" data-mini-trend-tab="failed">failed</button>
        <button type="button" class="ops-mini-trend-tab rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900" data-mini-trend-tab="flagged">flagged</button>
        <button type="button" class="ops-mini-trend-tab rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-900 hover:text-slate-900" data-mini-trend-tab="fallback">fallback</button>
      </div>
      <div id="ops-mini-trend" class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4"></div>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">툴별 추세</h2>
        <p class="mt-1 text-sm text-slate-600">현재 필터 기준으로 어떤 툴이 계속 문제인지 빠르게 봅니다.</p>
        <div id="ops-trends" class="mt-4 grid gap-3"></div>
      </article>

      <div class="grid gap-6">
        <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-xl font-black text-slate-900">경고 툴 집계</h2>
          <div id="ops-alert-tools" class="mt-4 grid gap-3"></div>
        </article>
        <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-xl font-black text-slate-900">경고 provider 집계</h2>
          <div id="ops-alert-providers" class="mt-4 grid gap-3"></div>
        </article>
      </div>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-2">
      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">툴별 원인 drill-down</h2>
        <p class="mt-1 text-sm text-slate-600">어떤 툴에서 어떤 플래그가 반복되는지 바로 봅니다.</p>
        <div id="ops-tool-drilldown" class="mt-4 grid gap-3"></div>
        <div id="ops-tool-debug-links" class="mt-4 flex flex-wrap gap-2"></div>
        <div class="mt-4 flex flex-wrap gap-2">
          <button id="ops-download-tool-drilldown" type="button" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">tool drill-down 저장</button>
          <button id="ops-download-tool-drilldown-csv" type="button" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">tool drill-down CSV</button>
        </div>
      </article>
      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">provider별 원인 drill-down</h2>
        <p class="mt-1 text-sm text-slate-600">fallback, 저품질, 저동일성 같은 원인을 provider 기준으로 묶어 봅니다.</p>
        <div id="ops-provider-drilldown" class="mt-4 grid gap-3"></div>
        <div id="ops-provider-debug-links" class="mt-4 flex flex-wrap gap-2"></div>
        <div class="mt-4 flex flex-wrap gap-2">
          <button id="ops-download-provider-drilldown" type="button" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">provider drill-down 저장</button>
          <button id="ops-download-provider-drilldown-csv" type="button" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">provider drill-down CSV</button>
        </div>
      </article>
    </section>

    <section id="ops-drilldown-preview" class="mt-6 hidden rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-black text-slate-900">drill-down 대표 job 미리보기</h2>
          <p id="ops-drilldown-preview-label" class="mt-1 text-sm text-slate-600">선택한 그룹의 대표 job을 바로 확인합니다.</p>
        </div>
        <a id="ops-drilldown-preview-link" href="/tools/ai-photo-debug" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">디버그 열기</a>
      </div>
      <div class="mt-4 grid gap-4 xl:grid-cols-[1fr_1fr_0.8fr]">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">원본</p>
          <div class="mt-2 overflow-hidden rounded-xl bg-slate-100">
            <img id="ops-drilldown-preview-original" alt="원본" class="h-64 w-full object-cover" />
          </div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">추천 후보</p>
          <div class="mt-2 overflow-hidden rounded-xl bg-slate-100">
            <img id="ops-drilldown-preview-result" alt="추천 후보" class="h-64 w-full object-cover" />
          </div>
        </div>
        <div id="ops-drilldown-preview-meta" class="grid gap-3"></div>
      </div>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
      <article class="rounded-3xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
        <h2 class="text-xl font-black text-amber-950">최근 경고 작업</h2>
        <p class="mt-1 text-sm text-amber-900">저품질, 저동일성, fallback, 실패 작업만 모아서 봅니다.</p>
        <div id="ops-latest-flagged" class="mt-4 grid gap-3"></div>
      </article>

      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">관리 링크</h2>
        <p class="mt-1 text-sm text-slate-600">운영과 디버그 화면으로 바로 이동합니다.</p>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          <a id="ops-open-admin" href="/tools/ai-photo-admin" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-slate-300 hover:bg-white">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Admin</p>
            <p class="mt-2 text-base font-black text-slate-900">관리자 허브</p>
          </a>
          <a href="/tools/ai-photo-debug" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-slate-300 hover:bg-white">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Debug</p>
            <p class="mt-2 text-base font-black text-slate-900">단일 job 디버그</p>
          </a>
        </div>
      </article>
    </section>

    <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-xl font-black text-slate-900">최근 작업</h2>
      <p class="mt-1 text-sm text-slate-600">원본/추천 결과, 품질 재시도 전후, 후보 결정 흐름을 함께 봅니다.</p>
      <div id="ops-list" class="mt-4 grid gap-4"></div>
    </section>
  </main>
  <Footer />
  <script is:inline src="/scripts/ai-photo-view-context.js"></script>
  <script define:vars={{ apiBase }} is:inline>
    const API_BASE = apiBase;
    const statusTextEl = document.getElementById('ops-status-text');
    const statsEl = document.getElementById('ops-stats');
    const trendsEl = document.getElementById('ops-trends');
    const alertToolsEl = document.getElementById('ops-alert-tools');
    const alertProvidersEl = document.getElementById('ops-alert-providers');
    const latestFlaggedEl = document.getElementById('ops-latest-flagged');
    const listEl = document.getElementById('ops-list');
    const insightsEl = document.getElementById('ops-insights');
    const miniTrendEl = document.getElementById('ops-mini-trend');
    const toolDrilldownEl = document.getElementById('ops-tool-drilldown');
    const providerDrilldownEl = document.getElementById('ops-provider-drilldown');
    const toolDebugLinksEl = document.getElementById('ops-tool-debug-links');
    const providerDebugLinksEl = document.getElementById('ops-provider-debug-links');
    const downloadToolDrilldownBtn = document.getElementById('ops-download-tool-drilldown');
    const downloadToolDrilldownCsvBtn = document.getElementById('ops-download-tool-drilldown-csv');
    const downloadProviderDrilldownBtn = document.getElementById('ops-download-provider-drilldown');
    const downloadProviderDrilldownCsvBtn = document.getElementById('ops-download-provider-drilldown-csv');
    const drilldownPreviewEl = document.getElementById('ops-drilldown-preview');
    const drilldownPreviewLabelEl = document.getElementById('ops-drilldown-preview-label');
    const drilldownPreviewLinkEl = document.getElementById('ops-drilldown-preview-link');
    const drilldownPreviewOriginalEl = document.getElementById('ops-drilldown-preview-original');
    const drilldownPreviewResultEl = document.getElementById('ops-drilldown-preview-result');
    const drilldownPreviewMetaEl = document.getElementById('ops-drilldown-preview-meta');
    const refreshBtn = document.getElementById('ops-refresh');
    const openDebugLink = document.getElementById('ops-open-debug');
    const openAdminLink = document.getElementById('ops-open-admin');
    const copyViewLinkBtn = document.getElementById('ops-copy-view-link');
    const copySummaryBtn = document.getElementById('ops-copy-summary');
    const downloadSummaryBtn = document.getElementById('ops-download-summary');
    const downloadJsonBtn = document.getElementById('ops-download-json');
    const presetButtons = Array.from(document.querySelectorAll('.ops-preset'));
    const miniTrendTabs = Array.from(document.querySelectorAll('.ops-mini-trend-tab'));
    const pageParams = new URLSearchParams(window.location.search);
    const viewContextUtils = window.AIPhotoViewContext;

    const filters = {
      status: document.getElementById('ops-status'),
      tool: document.getElementById('ops-tool'),
      limit: document.getElementById('ops-limit'),
      period: document.getElementById('ops-period'),
      flagged: document.getElementById('ops-flagged'),
      fallbackOnly: document.getElementById('ops-fallback-only'),
      provider: document.getElementById('ops-provider')
    };

    let latestRecentPayload = null;
    let latestAlertsPayload = null;
    let latestDerivedOpsData = null;
    let miniTrendMode = 'risk';
    let activePreviewKey = pageParams.get('previewKey')?.trim() ?? '';
    let pendingInitialPreviewKey = activePreviewKey;

    const setStatus = (text) => {
      if (statusTextEl instanceof HTMLElement) statusTextEl.textContent = text;
    };

    const formatNumber = (value, digits = 1) => {
      if (typeof value !== 'number' || Number.isNaN(value)) return '-';
      return value.toFixed(digits);
    };

    const formatPercent = (value) => `${formatNumber(value, 1)}%`;

    const formatDate = (value) => {
      if (!value) return '-';
      const parsed = new Date(value);
      if (Number.isNaN(parsed.getTime())) return String(value);
      return parsed.toLocaleString('ko-KR');
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const createMetricCard = (label, value, tone = 'slate', options = {}) => `
      <article class="rounded-2xl border border-${tone}-200 bg-${tone}-50 p-4 ${options.interactive ? 'cursor-pointer transition hover:border-' + tone + '-300 hover:bg-white' : ''}" ${options.dataAttrs ?? ''}>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-${tone}-500">${label}</p>
        <p class="mt-2 text-2xl font-black text-${tone}-950">${escapeHtml(value)}</p>
        ${options.hint ? `<p class="mt-2 text-xs text-${tone}-700">${escapeHtml(options.hint)}</p>` : ''}
      </article>
    `;

    const createTrendCard = (item) => `
      <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(item.toolType)}</p>
            <p class="mt-1 text-lg font-black text-slate-900">${escapeHtml(item.total)}건</p>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600">실패 ${escapeHtml(item.failed)}</span>
        </div>
        <div class="mt-3 grid gap-2 sm:grid-cols-2">
          <div class="rounded-xl bg-white px-3 py-2">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">평균 규격 점수</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${formatNumber(item.avgQualityScore)}</p>
          </div>
          <div class="rounded-xl bg-white px-3 py-2">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">평균 동일성 점수</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${formatNumber(item.avgIdentityScore)}</p>
          </div>
        </div>
      </article>
    `;

    const createAlertRow = (label, count, total, tone = 'amber') => {
      const percent = total > 0 ? (count / total) * 100 : 0;
      return `
        <article class="rounded-2xl border border-${tone}-200 bg-${tone}-50 p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="text-sm font-bold text-${tone}-950">${escapeHtml(label)}</p>
            <span class="text-sm font-black text-${tone}-950">${escapeHtml(count)}건</span>
          </div>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-white/80">
            <div class="h-full rounded-full bg-${tone}-500" style="width:${Math.max(6, percent)}%"></div>
          </div>
          <p class="mt-2 text-xs text-${tone}-900">전체 경고 중 ${formatPercent(percent)}</p>
        </article>
      `;
    };

    const createProviderSummaryCard = (item, totalAlerts = 0) => {
      const percent = totalAlerts > 0 ? (item.total / totalAlerts) * 100 : 0;
      const fallbackCount = item.flags.find(([flag]) => flag === 'provider_fallback')?.[1] ?? 0;
      return `
        <article class="rounded-2xl border border-rose-200 bg-rose-50 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-black text-rose-950">${escapeHtml(item.key)}</p>
              <p class="mt-1 text-xs text-rose-900">전체 경고 중 ${formatPercent(percent)}</p>
            </div>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-rose-900">${item.total}건</span>
          </div>
          <div class="mt-3 grid gap-2 sm:grid-cols-2">
            <div class="rounded-xl bg-white px-3 py-2">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">top quality</p>
              <p class="mt-1 text-xs font-bold text-slate-900">${escapeHtml(summarizeGroupReason(item.topQualityReason))}</p>
            </div>
            <div class="rounded-xl bg-white px-3 py-2">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">top identity</p>
              <p class="mt-1 text-xs font-bold text-slate-900">${escapeHtml(summarizeGroupReason(item.topIdentityReason))}</p>
            </div>
            <div class="rounded-xl bg-white px-3 py-2">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">fallback</p>
              <p class="mt-1 text-sm font-bold text-slate-900">${fallbackCount}</p>
            </div>
            <div class="rounded-xl bg-white px-3 py-2">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">related jobs</p>
              <p class="mt-1 text-sm font-bold text-slate-900">${item.relatedJobIds?.length ?? 0}</p>
            </div>
          </div>
          ${item.debugUrl ? `
            <div class="mt-3">
              <a href="${escapeHtml(item.debugUrl)}" class="inline-flex rounded-full border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold text-rose-900 transition hover:border-rose-400">
                대표 job debug
              </a>
            </div>
          ` : ''}
        </article>
      `;
    };

    const groupFlags = (items, keySelector) => {
      const grouped = new Map();
      const groupItemRisk = (item) => (
        (item?.status === 'failed' ? 4 : 0)
        + ((Array.isArray(item?.flags) && item.flags.length) ? 2 : 0)
        + ((Array.isArray(item?.flags) && item.flags.includes('provider_fallback')) ? 1 : 0)
      );
      for (const item of items) {
        const key = keySelector(item) ?? 'unknown';
        const bucket = grouped.get(key) ?? {
          total: 0,
          flags: new Map(),
          qualityReasons: new Map(),
          identityReasons: new Map(),
          relatedJobs: [],
          representativeJobId: null,
          representativeJobCreatedAt: null,
          representativeJobRisk: -1
        };
        bucket.total += 1;
        for (const flag of item.flags ?? []) {
          bucket.flags.set(flag, (bucket.flags.get(flag) ?? 0) + 1);
        }
        for (const issue of item.qualityIssueCodes ?? []) {
          const label = issueCodeLabel(issue);
          bucket.qualityReasons.set(label, (bucket.qualityReasons.get(label) ?? 0) + 1);
        }
        const identitySummary = item.identitySummary ?? null;
        for (const variant of identitySummary?.rejectedVariants ?? []) {
          const label = `rejected ${variant}`;
          bucket.identityReasons.set(label, (bucket.identityReasons.get(label) ?? 0) + 1);
        }
        for (const variant of identitySummary?.regeneratedVariants ?? []) {
          const label = `regenerated ${variant}`;
          bucket.identityReasons.set(label, (bucket.identityReasons.get(label) ?? 0) + 1);
        }
        if (!bucket.identityReasons.size && identitySummary?.recommendedVariant) {
          const label = `recommended ${identitySummary.recommendedVariant}`;
          bucket.identityReasons.set(label, (bucket.identityReasons.get(label) ?? 0) + 1);
        }
        const itemCreatedAt = item?.createdAt ? new Date(item.createdAt).getTime() : 0;
        bucket.relatedJobs.push({ id: item.id ?? null, createdAt: itemCreatedAt });
        bucket.relatedJobs.sort((a, b) => (b.createdAt ?? 0) - (a.createdAt ?? 0));
        bucket.relatedJobs = bucket.relatedJobs.filter((job, index, jobs) => (
          job.id
          && jobs.findIndex((candidate) => candidate.id === job.id) === index
        )).slice(0, 4);
        const itemRisk = groupItemRisk(item);
        if (
          itemRisk > bucket.representativeJobRisk
          || (itemRisk === bucket.representativeJobRisk && (bucket.representativeJobCreatedAt ?? 0) < itemCreatedAt)
        ) {
          bucket.representativeJobId = item.id ?? null;
          bucket.representativeJobCreatedAt = itemCreatedAt;
          bucket.representativeJobRisk = itemRisk;
        }
        grouped.set(key, bucket);
      }
      return [...grouped.entries()]
        .map(([key, bucket]) => ({
          key,
          total: bucket.total,
          flags: [...bucket.flags.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5),
          topQualityReason: [...bucket.qualityReasons.entries()].sort((a, b) => b[1] - a[1])[0] ?? null,
          topIdentityReason: [...bucket.identityReasons.entries()].sort((a, b) => b[1] - a[1])[0] ?? null,
          representativeJobId: bucket.representativeJobId,
          relatedJobIds: bucket.relatedJobs.map((job) => job.id).filter(Boolean)
        }))
        .sort((a, b) => b.total - a.total);
    };

    const currentDrilldownFilterSummary = () => (
      `status=${filters.status instanceof HTMLSelectElement ? filters.status.value : 'all'}, tool=${filters.tool instanceof HTMLSelectElement ? filters.tool.value : 'all'}, provider=${filters.provider instanceof HTMLSelectElement ? filters.provider.value : 'all'}, flagged=${filters.flagged instanceof HTMLSelectElement ? filters.flagged.value : 'true'}, fallbackOnly=${filters.fallbackOnly instanceof HTMLSelectElement ? filters.fallbackOnly.value : 'false'}`
    );

    const buildDebugUrl = (jobId = '', options = {}) => {
      const { includeOpsView = true } = options;
      const params = new URLSearchParams();
      if (jobId) params.set('jobId', jobId);
      if (includeOpsView) params.set('opsView', getCurrentViewUrl());
      const query = params.toString();
      return query ? `/tools/ai-photo-debug?${query}` : '/tools/ai-photo-debug';
    };

    const getNormalizedPreviewKey = (entryPreviewKey = '', fallbackType = 'tool', fallbackKey = '') => {
      if (entryPreviewKey) return entryPreviewKey;
      if (!fallbackKey) return '';
      return `${fallbackType}:${fallbackKey}`;
    };

    const getDrilldownGroupsFromPayload = (alertsPayload, type) => {
      const alertItems = Array.isArray(alertsPayload?.items) ? alertsPayload.items : [];
      return groupFlags(alertItems, (item) => (
        type === 'tool'
          ? item.toolType
          : (item.provider ?? item.resolvedProvider)
      )).map((group) => ({
        ...group,
        groupType: type,
        previewKey: `${type}:${group.key}`,
        debugUrl: group.representativeJobId ? buildDebugUrl(group.representativeJobId) : null
      }));
    };

    const getDrilldownGroups = (type) => getDrilldownGroupsFromPayload(latestAlertsPayload, type);

    const getDerivedDrilldownGroups = (type, derivedData = latestDerivedOpsData) => {
      if (type === 'tool') return derivedData?.toolDrilldown ?? getDrilldownGroups(type);
      return derivedData?.providerDrilldown ?? getDrilldownGroups(type);
    };

    const summarizeGroupReason = (entry) => (
      entry ? formatReasonEntry(entry[0], entry[1]) : 'none'
    );

    const DRILLDOWN_LEGACY_COLUMN_ALIASES = 'flag->signalCode;flagCount->signalCount;previewKey->viewPreviewKey;key->groupKey;type->drilldownType';

    const getDrilldownExportMeta = (type, exportedAt = new Date().toISOString()) => {
      const viewSummary = getCurrentViewContextSummary();
      return {
        schemaVersion: 'ai-photo-view-context.v1',
        surface: `ops-${type}-drilldown`,
        exportedAt,
        viewContextUrl: getCurrentViewUrl(),
        viewContextSummary: viewContextUtils?.formatViewContextSummary(viewSummary) ?? currentDrilldownFilterSummary(),
        drilldownType: type,
        drilldownFilters: currentDrilldownFilterSummary(),
        legacyColumnAliases: DRILLDOWN_LEGACY_COLUMN_ALIASES
      };
    };

    const buildDrilldownExport = (type) => {
      const groups = getDerivedDrilldownGroups(type);
      if (!groups.length) return '';
      const meta = getDrilldownExportMeta(type);
      return [
        `AI photo ops ${type} drill-down`,
        `[schema]`,
        `schemaVersion: ${meta.schemaVersion}`,
        `surface: ${meta.surface}`,
        `exportedAt: ${meta.exportedAt}`,
        `legacyColumnAliases: ${meta.legacyColumnAliases}`,
        `[viewContext]`,
        `url: ${meta.viewContextUrl}`,
        `summary: ${meta.viewContextSummary}`,
        `[drilldown]`,
        `drilldownType: ${meta.drilldownType}`,
        `drilldownFilters: ${meta.drilldownFilters}`,
        '',
        ...groups.map((group) => {
          const flags = group.flags.length
            ? group.flags.map(([flag, count]) => `${flag}:${count}`).join(', ')
            : 'none';
          return `groupKey=${group.key}\ttotal=${group.total}\tsignalCounts=${flags}\ttopQualityReason=${summarizeGroupReason(group.topQualityReason)}\ttopIdentityReason=${summarizeGroupReason(group.topIdentityReason)}\tviewPreviewKey=${getNormalizedPreviewKey(group.previewKey, type, group.key)}\trepresentativeJobId=${group.representativeJobId ?? 'none'}\tdebugUrl=${group.debugUrl ?? 'none'}\trelatedJobIds=${(group.relatedJobIds ?? []).join(',') || 'none'}`;
        })
      ].join('\n');
    };

    const escapeCsv = (value) => {
      const text = String(value ?? '');
      if (text.includes('"') || text.includes(',') || text.includes('\n')) {
        return `"${text.replaceAll('"', '""')}"`;
      }
      return text;
    };

    const buildDrilldownCsvExport = (type) => {
      const groups = getDerivedDrilldownGroups(type);
      if (!groups.length) return '';
      const meta = getDrilldownExportMeta(type);
      return [
        ['meta', 'schemaVersion', meta.schemaVersion],
        ['meta', 'surface', meta.surface],
        ['meta', 'exportedAt', meta.exportedAt],
        ['meta', 'viewContextUrl', meta.viewContextUrl],
        ['meta', 'viewContextSummary', meta.viewContextSummary],
        ['meta', 'drilldownType', meta.drilldownType],
        ['meta', 'drilldownFilters', meta.drilldownFilters],
        ['meta', 'legacyColumnAliases', meta.legacyColumnAliases],
        [],
        ['drilldownType', 'groupKey', 'viewPreviewKey', 'total', 'signalCode', 'signalCount', 'topQualityReason', 'topIdentityReason', 'representativeJobId', 'debugUrl', 'relatedJobIds'],
        ...groups.flatMap((group) => (
          group.flags.length
            ? group.flags.map(([flag, count]) => [type, group.key, getNormalizedPreviewKey(group.previewKey, type, group.key), group.total, flag, count, summarizeGroupReason(group.topQualityReason), summarizeGroupReason(group.topIdentityReason), group.representativeJobId ?? '', group.debugUrl ?? '', (group.relatedJobIds ?? []).join(',')])
            : [[type, group.key, getNormalizedPreviewKey(group.previewKey, type, group.key), group.total, 'none', 0, summarizeGroupReason(group.topQualityReason), summarizeGroupReason(group.topIdentityReason), group.representativeJobId ?? '', group.debugUrl ?? '', (group.relatedJobIds ?? []).join(',')]]
        ))
      ].map((row) => row.map(escapeCsv).join(',')).join('\n');
    };

    const setDirectFilterControls = ({ toolType = 'all', provider = 'all', fallbackOnly = false, flaggedOnly = true, status = 'all' }) => {
      if (filters.tool instanceof HTMLSelectElement) filters.tool.value = toolType;
      if (filters.provider instanceof HTMLSelectElement) filters.provider.value = provider;
      if (filters.fallbackOnly instanceof HTMLSelectElement) filters.fallbackOnly.value = fallbackOnly ? 'true' : 'false';
      if (filters.flagged instanceof HTMLSelectElement) filters.flagged.value = flaggedOnly ? 'true' : 'false';
      if (filters.status instanceof HTMLSelectElement) filters.status.value = status;
    };

    const applyDirectFilter = ({ toolType = 'all', provider = 'all', fallbackOnly = false, flaggedOnly = true, status = 'all' }) => {
      setDirectFilterControls({ toolType, provider, fallbackOnly, flaggedOnly, status });
      loadOps();
    };

    const parsePreviewKey = (previewKey, fallbackType = 'tool', fallbackKey = '') => {
      const [previewType, ...previewKeyParts] = String(previewKey ?? '').split(':');
      const previewValue = previewKeyParts.join(':');
      return {
        type: previewValue ? previewType : fallbackType,
        key: previewValue || fallbackKey
      };
    };

    const applyPreviewKeyFilter = (type, key) => {
      if (type === 'tool') {
        applyDirectFilter({ toolType: key, provider: 'all', fallbackOnly: false, flaggedOnly: true, status: 'all' });
        return;
      }
      applyDirectFilter({
        toolType: 'all',
        provider: key,
        fallbackOnly: key === 'local_sharp',
        flaggedOnly: true,
        status: 'all'
      });
    };

    const syncPreviewKeyFilters = (type, key) => {
      if (type === 'tool') {
        setDirectFilterControls({ toolType: key, provider: 'all', fallbackOnly: false, flaggedOnly: true, status: 'all' });
        return;
      }
      setDirectFilterControls({
        toolType: 'all',
        provider: key,
        fallbackOnly: key === 'local_sharp',
        flaggedOnly: true,
        status: 'all'
      });
    };

    const getCurrentViewParams = () => {
      const params = new URLSearchParams();
      const status = filters.status instanceof HTMLSelectElement ? filters.status.value : 'all';
      const toolType = filters.tool instanceof HTMLSelectElement ? filters.tool.value : 'all';
      const provider = filters.provider instanceof HTMLSelectElement ? filters.provider.value : 'all';
      const limit = filters.limit instanceof HTMLSelectElement ? filters.limit.value : '12';
      const period = filters.period instanceof HTMLSelectElement ? filters.period.value : '24';
      const flaggedOnly = filters.flagged instanceof HTMLSelectElement ? filters.flagged.value === 'true' : false;
      const fallbackOnly = filters.fallbackOnly instanceof HTMLSelectElement ? filters.fallbackOnly.value === 'true' : false;
      params.set('limit', limit);
      if (status !== 'all') params.set('status', status);
      if (toolType !== 'all') params.set('toolType', toolType);
      if (provider !== 'all') params.set('provider', provider);
      if (period !== '0') params.set('sinceHours', period);
      if (flaggedOnly) params.set('flaggedOnly', 'true');
      if (fallbackOnly) params.set('fallbackOnly', 'true');
      if (miniTrendMode !== 'risk') params.set('miniTrend', miniTrendMode);
      if (activePreviewKey) params.set('previewKey', activePreviewKey);
      return params;
    };

    const getCurrentViewUrl = () => {
      const nextUrl = new URL(window.location.href);
      nextUrl.search = getCurrentViewParams().toString();
      return nextUrl.toString();
    };

    const getCurrentViewContextSummary = () => viewContextUtils?.withDefaultContext({
      status: filters.status instanceof HTMLSelectElement ? filters.status.value : 'all',
      tool: filters.tool instanceof HTMLSelectElement ? filters.tool.value : 'all',
      provider: filters.provider instanceof HTMLSelectElement ? filters.provider.value : 'all',
      limit: filters.limit instanceof HTMLSelectElement ? filters.limit.value : '12',
      sinceHours: filters.period instanceof HTMLSelectElement ? filters.period.value : '24',
      flaggedOnly: filters.flagged instanceof HTMLSelectElement ? filters.flagged.value === 'true' : false,
      fallbackOnly: filters.fallbackOnly instanceof HTMLSelectElement ? filters.fallbackOnly.value === 'true' : false,
      miniTrend: miniTrendMode,
      previewKey: activePreviewKey || null
    }) ?? ({
      status: filters.status instanceof HTMLSelectElement ? filters.status.value : 'all',
      tool: filters.tool instanceof HTMLSelectElement ? filters.tool.value : 'all',
      provider: filters.provider instanceof HTMLSelectElement ? filters.provider.value : 'all',
      limit: filters.limit instanceof HTMLSelectElement ? filters.limit.value : '12',
      sinceHours: filters.period instanceof HTMLSelectElement ? filters.period.value : '24',
      flaggedOnly: filters.flagged instanceof HTMLSelectElement ? filters.flagged.value === 'true' : false,
      fallbackOnly: filters.fallbackOnly instanceof HTMLSelectElement ? filters.fallbackOnly.value === 'true' : false,
      miniTrend: miniTrendMode,
      previewKey: activePreviewKey || null
    });

    const syncCurrentViewInUrl = () => {
      window.history.replaceState({}, '', getCurrentViewUrl());
    };

    const hydrateControlsFromUrl = () => {
      if (filters.status instanceof HTMLSelectElement) {
        const status = pageParams.get('status');
        if (status) filters.status.value = status;
      }
      if (filters.tool instanceof HTMLSelectElement) {
        const toolType = pageParams.get('toolType');
        if (toolType) filters.tool.value = toolType;
      }
      if (filters.provider instanceof HTMLSelectElement) {
        const provider = pageParams.get('provider');
        if (provider) filters.provider.value = provider;
      }
      if (filters.limit instanceof HTMLSelectElement) {
        const limit = pageParams.get('limit');
        if (limit) filters.limit.value = limit;
      }
      if (filters.period instanceof HTMLSelectElement) {
        const sinceHours = pageParams.get('sinceHours');
        if (sinceHours !== null) {
          filters.period.value = sinceHours;
        }
      }
      if (filters.flagged instanceof HTMLSelectElement) {
        filters.flagged.value = pageParams.get('flaggedOnly') === 'true' ? 'true' : filters.flagged.value;
      }
      if (filters.fallbackOnly instanceof HTMLSelectElement) {
        filters.fallbackOnly.value = pageParams.get('fallbackOnly') === 'true' ? 'true' : filters.fallbackOnly.value;
      }
      const initialMiniTrendMode = pageParams.get('miniTrend');
      if (initialMiniTrendMode) {
        miniTrendMode = initialMiniTrendMode;
      }
    };

    const isPreviewKeyFilterActive = (type, key) => {
      const status = filters.status instanceof HTMLSelectElement ? filters.status.value : 'all';
      const tool = filters.tool instanceof HTMLSelectElement ? filters.tool.value : 'all';
      const provider = filters.provider instanceof HTMLSelectElement ? filters.provider.value : 'all';
      const flagged = filters.flagged instanceof HTMLSelectElement ? filters.flagged.value : 'false';
      const fallbackOnly = filters.fallbackOnly instanceof HTMLSelectElement ? filters.fallbackOnly.value : 'false';
      if (status !== 'all' || flagged !== 'true') return false;
      if (type === 'tool') {
        return tool === key && provider === 'all' && fallbackOnly === 'false';
      }
      return tool === 'all' && provider === key && fallbackOnly === (key === 'local_sharp' ? 'true' : 'false');
    };

    const resolvePreviewKeyEntry = (previewKey, fallbackType = 'tool', fallbackKey = '', derivedData = latestDerivedOpsData) => {
      const { type, key } = parsePreviewKey(previewKey, fallbackType, fallbackKey);
      if (!key) return null;
      const normalizedPreviewKey = getNormalizedPreviewKey(previewKey, type, key);
      const indexedEntry = derivedData?.drilldownIndex?.[normalizedPreviewKey];
      if (indexedEntry) {
        return {
          ...indexedEntry,
          groupType: indexedEntry.groupType ?? type,
          key: indexedEntry.key ?? key,
          previewKey: indexedEntry.previewKey ?? normalizedPreviewKey
        };
      }
      const fallbackGroup = getDerivedDrilldownGroups(type, derivedData).find((group) => group.key === key);
      if (!fallbackGroup) return null;
      return {
        ...fallbackGroup,
        groupType: fallbackGroup.groupType ?? type,
        previewKey: fallbackGroup.previewKey ?? normalizedPreviewKey
      };
    };

    const scoreTone = (score) => {
      if (score >= 90) return 'emerald';
      if (score >= 80) return 'sky';
      if (score >= 70) return 'amber';
      return 'rose';
    };

    const clampScore = (value) => Math.max(0, Math.min(100, Number(value ?? 0) || 0));

    const compactPreviewScoreBar = (label, score, tone = 'slate', detail = '') => `
      <div class="rounded-xl border border-slate-200 bg-white p-3">
        <div class="flex items-center justify-between gap-3">
          <p class="text-xs font-semibold text-slate-600">${escapeHtml(label)}</p>
          <p class="text-sm font-black text-slate-900">${formatNumber(score)}</p>
        </div>
        <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-100">
          <div class="h-full rounded-full bg-${tone}-500" style="width:${Math.max(4, clampScore(score))}%"></div>
        </div>
        ${detail ? `<p class="mt-2 text-[11px] text-slate-500">${escapeHtml(detail)}</p>` : ''}
      </div>
    `;

    const issueCodeLabel = (code) => {
      if (code === 'center_alignment_out_of_bounds') return 'center misaligned';
      if (code === 'face_ratio_out_of_bounds') return 'face ratio off';
      if (code === 'top_head_margin_out_of_bounds') return 'headroom off';
      if (code === 'eye_line_out_of_bounds') return 'eye line off';
      if (code === 'resolution_below_minimum') return 'resolution low';
      return code ?? 'unknown';
    };

    const formatReasonEntry = (label = '', count = null, fallbackLabel = 'none') => {
      if (!label) return fallbackLabel;
      return typeof count === 'number' ? `${label} (${count})` : label;
    };

    const formatReasonList = (values = [], fallbackLabel = 'none', limit = 3) => {
      const normalized = values.filter(Boolean).slice(0, limit);
      return normalized.length ? normalized.join(', ') : fallbackLabel;
    };

    const summarizeQualityReason = (item) => {
      const issues = Array.isArray(item?.qualityIssueCodes) ? item.qualityIssueCodes : [];
      if (!issues.length) return item?.qualitySummary ?? 'quality stable';
      return formatReasonList(issues.map(issueCodeLabel), 'quality stable');
    };

    const summarizeIdentityReason = (item) => {
      const summary = item?.identitySummary ?? null;
      if (summary?.rejectedVariants?.length) {
        return formatReasonList(summary.rejectedVariants.map((variant) => `rejected ${variant}`), 'identity stable', 2);
      }
      if (summary?.regeneratedVariants?.length) {
        return formatReasonList(summary.regeneratedVariants.map((variant) => `regenerated ${variant}`), 'identity stable', 2);
      }
      if (summary?.recommendedVariant) {
        return `recommended ${summary.recommendedVariant}`;
      }
      return 'identity stable';
    };

    const renderProcessingSignalChips = (item) => {
      const resolvedProvider = item?.flags?.includes('provider_fallback')
        ? `local_sharp fallback from ${item?.resolvedProvider ?? 'unknown'}`
        : (item?.resolvedProvider ?? item?.provider ?? 'unknown');
      const callMode = item?.pipelineReport?.externalBackgroundCall ? 'external' : 'local';
      const cacheHits = ['aligned', 'cutout', 'flattened'].filter((key) => Boolean(item?.cache?.[key]));
      const cacheLabel = cacheHits.length ? `cache:${cacheHits.join('+')}` : 'cache:miss';
      return [
        `<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">provider ${escapeHtml(resolvedProvider)}</span>`,
        `<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">${escapeHtml(callMode)}</span>`,
        `<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">${escapeHtml(cacheLabel)}</span>`
      ].join('');
    };

    const summarizeInsights = (recentPayload, alertsPayload, drilldownGroups = null) => {
      const items = Array.isArray(recentPayload?.items) ? recentPayload.items : [];
      const alertItems = Array.isArray(alertsPayload?.items) ? alertsPayload.items : [];
      const toolTrends = Array.isArray(recentPayload?.toolTrends) ? recentPayload.toolTrends : [];

      const retryItems = items.filter((item) => typeof item.qualityScoreBeforeRetry === 'number' && typeof item.qualityScore === 'number');
      const avgRetryGain = retryItems.length
        ? retryItems.reduce((sum, item) => sum + (item.qualityScore - item.qualityScoreBeforeRetry), 0) / retryItems.length
        : null;

      const flagCounts = new Map();
      for (const item of alertItems) {
        for (const flag of item.flags ?? []) {
          flagCounts.set(flag, (flagCounts.get(flag) ?? 0) + 1);
        }
      }
      const topFlagEntry = [...flagCounts.entries()].sort((a, b) => b[1] - a[1])[0] ?? null;
      const worstTool = [...toolTrends].sort((a, b) => b.failed - a.failed)[0] ?? null;
      const fallbackCount = items.filter((item) => (item.flags ?? []).includes('provider_fallback')).length;
      const qualityReasonCounts = new Map();
      const identityReasonCounts = new Map();

      for (const item of alertItems) {
        for (const issue of item.qualityIssueCodes ?? []) {
          const label = issueCodeLabel(issue);
          qualityReasonCounts.set(label, (qualityReasonCounts.get(label) ?? 0) + 1);
        }
        for (const variant of item.identitySummary?.rejectedVariants ?? []) {
          const label = `rejected ${variant}`;
          identityReasonCounts.set(label, (identityReasonCounts.get(label) ?? 0) + 1);
        }
        for (const variant of item.identitySummary?.regeneratedVariants ?? []) {
          const label = `regenerated ${variant}`;
          identityReasonCounts.set(label, (identityReasonCounts.get(label) ?? 0) + 1);
        }
      }

      const topQualityReason = [...qualityReasonCounts.entries()].sort((a, b) => b[1] - a[1])[0] ?? null;
      const topIdentityReason = [...identityReasonCounts.entries()].sort((a, b) => b[1] - a[1])[0] ?? null;
      const largestRelatedCluster = [...(drilldownGroups ?? [])]
        .sort((a, b) => (b.relatedJobIds?.length ?? 0) - (a.relatedJobIds?.length ?? 0))[0] ?? null;

      return [
        {
          label: '가장 많은 경고',
          value: topFlagEntry ? `${topFlagEntry[0]} (${topFlagEntry[1]}건)` : '없음',
          tone: topFlagEntry ? 'amber' : 'slate'
        },
        {
          label: '실패가 가장 많은 툴',
          value: worstTool ? `${worstTool.toolType} (${worstTool.failed}건)` : '없음',
          tone: worstTool && worstTool.failed > 0 ? 'rose' : 'slate'
        },
        {
          label: '평균 재시도 개선폭',
          value: avgRetryGain === null ? '데이터 없음' : `+${formatNumber(avgRetryGain)}`,
          tone: avgRetryGain !== null && avgRetryGain > 0 ? 'emerald' : 'slate'
        },
        {
          label: 'fallback 비율',
          value: items.length ? formatPercent((fallbackCount / items.length) * 100) : '0.0%',
          tone: fallbackCount > 0 ? 'sky' : 'slate'
        },
        {
          label: 'top quality issue',
          value: topQualityReason ? formatReasonEntry(topQualityReason[0], topQualityReason[1], '없음') : '없음',
          tone: topQualityReason ? 'amber' : 'slate'
        },
        {
          label: 'top identity signal',
          value: topIdentityReason ? formatReasonEntry(topIdentityReason[0], topIdentityReason[1], '없음') : '없음',
          tone: topIdentityReason ? 'rose' : 'slate'
        },
        {
          label: 'largest related-job cluster',
          value: largestRelatedCluster ? `${largestRelatedCluster.key} (${largestRelatedCluster.relatedJobIds?.length ?? 0} jobs)` : '?놁쓬',
          tone: largestRelatedCluster && (largestRelatedCluster.relatedJobIds?.length ?? 0) > 1 ? 'sky' : 'slate',
          clusterType: largestRelatedCluster?.groupType ?? null,
          clusterKey: largestRelatedCluster?.key ?? null,
          previewKey: getNormalizedPreviewKey(largestRelatedCluster?.previewKey ?? '', largestRelatedCluster?.groupType ?? 'tool', largestRelatedCluster?.key ?? ''),
          representativeJobId: largestRelatedCluster?.representativeJobId ?? null,
          debugUrl: largestRelatedCluster?.representativeJobId ? buildDebugUrl(largestRelatedCluster.representativeJobId) : null
        }
      ];
    };

    const renderStats = (payload, alertsPayload) => {
      if (!(statsEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.items) ? payload.items : [];
      const alertItems = Array.isArray(alertsPayload?.items) ? alertsPayload.items : [];
      const failed = items.filter((item) => item.status === 'failed').length;
      const fallback = items.filter((item) => Array.isArray(item.flags) && item.flags.includes('provider_fallback')).length;
      const avgQuality = items.length ? items.reduce((sum, item) => sum + (typeof item.qualityScore === 'number' ? item.qualityScore : 0), 0) / items.length : 0;
      const avgIdentity = items.length ? items.reduce((sum, item) => sum + (typeof item.identityScore === 'number' ? item.identityScore : 0), 0) / items.length : 0;

      statsEl.innerHTML = [
        createMetricCard('총 작업', items.length, 'slate'),
        createMetricCard('실패 작업', failed, failed ? 'rose' : 'slate'),
        createMetricCard('경고 작업', alertItems.length, alertItems.length ? 'amber' : 'slate'),
        createMetricCard('fallback 작업', fallback, fallback ? 'sky' : 'slate'),
        createMetricCard('평균 규격 점수', formatNumber(avgQuality), scoreTone(avgQuality)),
        createMetricCard('평균 동일성 점수', formatNumber(avgIdentity), scoreTone(avgIdentity)),
        createMetricCard('필터 기간', payload?.filters?.sinceHours ? `${payload.filters.sinceHours}시간` : '전체', 'slate'),
        createMetricCard('경고/전체 비율', items.length ? formatPercent((alertItems.length / items.length) * 100) : '0.0%', 'amber')
      ].join('');
    };

    const renderTrends = (payload) => {
      if (!(trendsEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.toolTrends) ? payload.toolTrends : [];
      trendsEl.innerHTML = items.length
        ? items.map(createTrendCard).join('')
        : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-5 text-sm text-slate-500">표시할 추세 데이터가 없습니다.</p>';
    };

    const renderAlerts = (payload, derivedData = latestDerivedOpsData) => {
      const items = Array.isArray(payload?.items) ? payload.items : [];
      const toolCounts = payload?.byTool ?? {};
      const providerCounts = payload?.byProvider ?? {};

      if (alertToolsEl instanceof HTMLElement) {
        const entries = Object.entries(toolCounts);
        alertToolsEl.innerHTML = entries.length
          ? entries.map(([label, count]) => createAlertRow(label, count, items.length, 'amber')).join('')
          : '<p class="rounded-2xl border border-dashed border-amber-200 bg-white p-4 text-sm text-amber-900">경고 작업이 없습니다.</p>';
      }

      if (alertProvidersEl instanceof HTMLElement) {
        const entries = Object.entries(providerCounts);
        const providerSummaries = derivedData?.providerSummaries ?? [];
        alertProvidersEl.innerHTML = entries.length
          ? entries.map(([label, count]) => createAlertRow(label, count, items.length, 'rose')).join('')
          : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-500">provider 경고 데이터가 없습니다.</p>';
      }

      if (latestFlaggedEl instanceof HTMLElement) {
        latestFlaggedEl.innerHTML = items.length
          ? items.slice(0, 6).map((item) => `
              <article class="rounded-2xl border border-amber-200 bg-white p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">${escapeHtml(item.toolType)}</p>
                    <p class="mt-1 text-sm font-black text-slate-900">${escapeHtml(item.id)}</p>
                  </div>
                  <a href="${escapeHtml(buildDebugUrl(item.id))}" class="rounded-lg bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-200">디버그</a>
                </div>
                <p class="mt-2 text-xs text-slate-500">${formatDate(item.createdAt)}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  ${(item.flags ?? []).map((flag) => `<span class="rounded-full bg-amber-50 px-2.5 py-1 text-[11px] font-semibold text-amber-900">${escapeHtml(flag)}</span>`).join('')}
                </div>
              </article>
            `).join('')
          : '<p class="rounded-2xl border border-dashed border-amber-200 bg-white p-4 text-sm text-amber-900">최근 경고 작업이 없습니다.</p>';
      }
    };

    const renderProviderSummaries = (payload, derivedData = latestDerivedOpsData) => {
      if (!(alertProvidersEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.items) ? payload.items : [];
      const providerCounts = payload?.byProvider ?? {};
      const entries = Object.entries(providerCounts);
      const providerSummaries = derivedData?.providerSummaries ?? [];
      alertProvidersEl.innerHTML = providerSummaries.length
        ? providerSummaries.map((item) => createProviderSummaryCard(item, items.length)).join('')
        : entries.length
          ? entries.map(([label, count]) => createAlertRow(label, count, items.length, 'rose')).join('')
          : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-500">provider 경고 데이터가 없습니다.</p>';
    };

    const buildDerivedOpsData = (recentPayload, alertsPayload) => {
      const items = Array.isArray(recentPayload?.items) ? recentPayload.items : [];
      const toolDrilldown = getDrilldownGroupsFromPayload(alertsPayload, 'tool');
      const providerDrilldown = getDrilldownGroupsFromPayload(alertsPayload, 'provider');
      const providerSummaries = [...providerDrilldown]
        .sort((a, b) => {
          const riskA = (a.flags.find(([flag]) => flag === 'provider_fallback')?.[1] ?? 0) * 3 + (a.relatedJobIds?.length ?? 0) + a.total;
          const riskB = (b.flags.find(([flag]) => flag === 'provider_fallback')?.[1] ?? 0) * 3 + (b.relatedJobIds?.length ?? 0) + b.total;
          return riskB - riskA || b.total - a.total;
        })
        .slice(0, 4)
        .map((group) => ({
          ...group,
          previewKey: getNormalizedPreviewKey(group.previewKey, 'provider', group.key)
        }));
      const drilldownIndex = [...toolDrilldown, ...providerDrilldown]
        .reduce((acc, group) => {
          if (group.previewKey) {
            acc[group.previewKey] = {
              groupType: group.groupType ?? null,
              key: group.key,
              previewKey: group.previewKey,
              total: group.total,
              topQualityIssue: summarizeGroupReason(group.topQualityReason),
              topIdentitySignal: summarizeGroupReason(group.topIdentityReason),
              representativeJobId: group.representativeJobId ?? null,
              debugUrl: group.debugUrl ?? null,
              relatedJobIds: group.relatedJobIds ?? []
            };
          }
          return acc;
        }, {});
      return {
        insights: summarizeInsights(recentPayload, alertsPayload, [...toolDrilldown, ...providerDrilldown]),
        miniTrend: summarizeMiniTrend(items),
        toolDrilldown,
        providerDrilldown,
        providerSummaries,
        drilldownIndex
      };
    };

    const renderInsights = (recentPayload, alertsPayload, derivedData = latestDerivedOpsData) => {
      if (!(insightsEl instanceof HTMLElement)) return;
      const insights = derivedData?.insights ?? summarizeInsights(recentPayload, alertsPayload);
      insightsEl.innerHTML = insights
        .map((item) => createMetricCard(item.label, item.value, item.tone, item.label === 'largest related-job cluster' && item.clusterType && item.clusterKey
          ? {
              interactive: true,
              hint: 'click to open drill-down',
              dataAttrs: `data-insight-cluster="true" data-preview-key="${escapeHtml(getNormalizedPreviewKey(item.previewKey, item.clusterType ?? 'tool', item.clusterKey ?? ''))}" data-cluster-type="${escapeHtml(item.clusterType)}" data-cluster-key="${escapeHtml(item.clusterKey)}"`
            }
          : {}
        ))
        .join('');
    };

    const summarizeMiniTrend = (items) => {
      const buckets = new Map();
      const miniTrendItemRisk = (item) => (
        (item?.status === 'failed' ? 4 : 0)
        + ((Array.isArray(item?.flags) && item.flags.length) ? 2 : 0)
        + ((Array.isArray(item?.flags) && item.flags.includes('provider_fallback')) ? 1 : 0)
      );
      items.forEach((item) => {
        const parsed = item?.createdAt ? new Date(item.createdAt) : null;
        if (!parsed || Number.isNaN(parsed.getTime())) return;
        const hourKey = `${parsed.getMonth() + 1}/${parsed.getDate()} ${String(parsed.getHours()).padStart(2, '0')}:00`;
        const bucket = buckets.get(hourKey) ?? {
          label: hourKey,
          total: 0,
          failed: 0,
          flagged: 0,
          fallback: 0,
          qualityReasons: new Map(),
          identityReasons: new Map(),
          representativeJobId: null,
          representativeJobCreatedAt: null,
          representativeJobRisk: -1
        };
        bucket.total += 1;
        if (item.status === 'failed') bucket.failed += 1;
        if (Array.isArray(item.flags) && item.flags.length) bucket.flagged += 1;
        if (Array.isArray(item.flags) && item.flags.includes('provider_fallback')) bucket.fallback += 1;
        for (const issue of item.qualityIssueCodes ?? []) {
          const label = issueCodeLabel(issue);
          bucket.qualityReasons.set(label, (bucket.qualityReasons.get(label) ?? 0) + 1);
        }
        for (const variant of item.identitySummary?.rejectedVariants ?? []) {
          const label = `rejected ${variant}`;
          bucket.identityReasons.set(label, (bucket.identityReasons.get(label) ?? 0) + 1);
        }
        for (const variant of item.identitySummary?.regeneratedVariants ?? []) {
          const label = `regenerated ${variant}`;
          bucket.identityReasons.set(label, (bucket.identityReasons.get(label) ?? 0) + 1);
        }
        const itemRisk = miniTrendItemRisk(item);
        const itemCreatedAt = parsed.getTime();
        if (
          itemRisk > bucket.representativeJobRisk
          || (itemRisk === bucket.representativeJobRisk && (bucket.representativeJobCreatedAt ?? 0) < itemCreatedAt)
        ) {
          bucket.representativeJobId = item.id ?? null;
          bucket.representativeJobCreatedAt = itemCreatedAt;
          bucket.representativeJobRisk = itemRisk;
        }
        buckets.set(hourKey, bucket);
      });
      return [...buckets.values()]
        .map((bucket) => ({
          ...bucket,
          topQualityReason: [...bucket.qualityReasons.entries()].sort((a, b) => b[1] - a[1])[0]?.[0] ?? null,
          topIdentityReason: [...bucket.identityReasons.entries()].sort((a, b) => b[1] - a[1])[0]?.[0] ?? null,
          debugUrl: bucket.representativeJobId ? buildDebugUrl(bucket.representativeJobId) : null
        }))
        .sort((a, b) => {
          const riskA = a.failed * 4 + a.flagged * 2 + a.fallback;
          const riskB = b.failed * 4 + b.flagged * 2 + b.fallback;
          return riskB - riskA || b.total - a.total;
        })
        .slice(0, 4);
    };

    const renderMiniTrend = (payload, derivedData = latestDerivedOpsData) => {
      if (!(miniTrendEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.items) ? payload.items : [];
      const sourceTrendItems = derivedData?.miniTrend ?? summarizeMiniTrend(items);
      const trendItems = [...sourceTrendItems].sort((a, b) => {
        if (miniTrendMode === 'failed') return b.failed - a.failed || b.total - a.total;
        if (miniTrendMode === 'flagged') return b.flagged - a.flagged || b.total - a.total;
        if (miniTrendMode === 'fallback') return b.fallback - a.fallback || b.total - a.total;
        const riskA = a.failed * 4 + a.flagged * 2 + a.fallback;
        const riskB = b.failed * 4 + b.flagged * 2 + b.fallback;
        return riskB - riskA || b.total - a.total;
      }).slice(0, 4);
      miniTrendTabs.forEach((button) => {
        const active = button.getAttribute('data-mini-trend-tab') === miniTrendMode;
        button.classList.toggle('bg-slate-900', active);
        button.classList.toggle('text-white', active);
        button.classList.toggle('border-slate-900', active);
        button.classList.toggle('bg-white', !active);
        button.classList.toggle('text-slate-700', !active);
        button.classList.toggle('border-slate-300', !active);
      });
      miniTrendEl.innerHTML = trendItems.length
        ? trendItems.map((item) => {
            const severity = item.failed > 0 ? 'rose' : item.flagged > 1 ? 'amber' : item.fallback > 0 ? 'sky' : 'slate';
            return `
              <article class="rounded-2xl border border-${severity}-200 bg-${severity}-50 p-4">
                <div class="flex items-center justify-between gap-3">
                  <p class="text-sm font-black text-${severity}-950">${escapeHtml(item.label)}</p>
                  <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-${severity}-900">총 ${item.total}</span>
                </div>
                <div class="mt-3 grid gap-2 sm:grid-cols-3">
                  <div class="rounded-xl bg-white px-3 py-2">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">실패</p>
                    <p class="mt-1 text-sm font-bold text-slate-900">${item.failed}</p>
                  </div>
                  <div class="rounded-xl bg-white px-3 py-2">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">경고</p>
                    <p class="mt-1 text-sm font-bold text-slate-900">${item.flagged}</p>
                  </div>
                  <div class="rounded-xl bg-white px-3 py-2">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">fallback</p>
                    <p class="mt-1 text-sm font-bold text-slate-900">${item.fallback}</p>
                  </div>
                </div>
                <div class="mt-3 space-y-1 text-xs text-slate-600">
                  <p><span class="font-semibold text-slate-900">quality:</span> ${escapeHtml(item.topQualityReason ?? 'none')}</p>
                  <p><span class="font-semibold text-slate-900">identity:</span> ${escapeHtml(item.topIdentityReason ?? 'none')}</p>
                </div>
                ${item.debugUrl ? `
                  <div class="mt-3">
                    <a href="${escapeHtml(item.debugUrl)}" class="inline-flex rounded-full border border-${severity}-300 bg-white px-3 py-1.5 text-xs font-semibold text-${severity}-900 transition hover:border-${severity}-400">
                      대표 job debug
                    </a>
                  </div>
                ` : ''}
              </article>
            `;
          }).join('')
        : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-500">표시할 시간대 데이터가 없습니다.</p>';
    };

    const getRepresentativeJobId = (type, key, derivedGroup = null) => {
      const resolvedGroup = derivedGroup ?? getDerivedDrilldownGroups(type).find((group) => group.key === key);
      if (resolvedGroup?.representativeJobId) return resolvedGroup.representativeJobId;
      const recentItems = Array.isArray(latestRecentPayload?.items) ? latestRecentPayload.items : [];
      const alertItems = Array.isArray(latestAlertsPayload?.items) ? latestAlertsPayload.items : [];
      const combined = [...recentItems, ...alertItems];
      const match = combined.find((item) => {
        if (type === 'tool') return item.toolType === key;
        return (item.provider ?? item.resolvedProvider) === key;
      });
      return match?.id ?? null;
    };

    const getRepresentativeJob = (type, key, derivedGroup = null) => {
      const representativeJobId = getRepresentativeJobId(type, key, derivedGroup);
      const recentItems = Array.isArray(latestRecentPayload?.items) ? latestRecentPayload.items : [];
      const alertItems = Array.isArray(latestAlertsPayload?.items) ? latestAlertsPayload.items : [];
      const combined = [...recentItems, ...alertItems];
      if (representativeJobId) {
        const matchedById = combined.find((item) => item.id === representativeJobId);
        if (matchedById) return matchedById;
      }
      return combined.find((item) => {
        if (type === 'tool') return item.toolType === key;
        return (item.provider ?? item.resolvedProvider) === key;
      }) ?? null;
    };

    const getRelatedJobs = (type, key, excludeId = null, derivedGroup = null) => {
      const recentItems = Array.isArray(latestRecentPayload?.items) ? latestRecentPayload.items : [];
      const alertItems = Array.isArray(latestAlertsPayload?.items) ? latestAlertsPayload.items : [];
      const combined = [...recentItems, ...alertItems];
      const resolvedGroup = derivedGroup ?? getDerivedDrilldownGroups(type).find((group) => group.key === key);
      const relatedJobIds = (resolvedGroup?.relatedJobIds ?? []).filter((jobId) => jobId && jobId !== excludeId);
      if (relatedJobIds.length) {
        return relatedJobIds
          .map((jobId) => combined.find((item) => item.id === jobId))
          .filter(Boolean)
          .slice(0, 4);
      }
      const seen = new Set();
      return combined
        .filter((item) => {
          if (!item?.id || item.id === excludeId || seen.has(item.id)) return false;
          const matches = type === 'tool'
            ? item.toolType === key
            : (item.provider ?? item.resolvedProvider) === key;
          if (matches) seen.add(item.id);
          return matches;
        })
        .slice(0, 4);
    };

    const hideDrilldownPreview = () => {
      if (!(drilldownPreviewEl instanceof HTMLElement)) return;
      drilldownPreviewEl.classList.add('hidden');
    };

    const renderDrilldownPreview = (type, key, derivedGroup = null) => {
      if (!(drilldownPreviewEl instanceof HTMLElement)) return;
      const item = getRepresentativeJob(type, key, derivedGroup);
      if (!item) {
        hideDrilldownPreview();
        return;
      }

      drilldownPreviewEl.classList.remove('hidden');
      if (drilldownPreviewLabelEl instanceof HTMLElement) {
        drilldownPreviewLabelEl.textContent = `${type === 'tool' ? '툴' : 'provider'} ${key} 그룹의 대표 job ${item.id}`;
      }
      if (drilldownPreviewLinkEl instanceof HTMLAnchorElement) {
        drilldownPreviewLinkEl.href = buildDebugUrl(item.id);
      }
      if (drilldownPreviewOriginalEl instanceof HTMLImageElement) {
        drilldownPreviewOriginalEl.src = item.originalUrl ?? '';
      }
      if (drilldownPreviewResultEl instanceof HTMLImageElement) {
        drilldownPreviewResultEl.src = item.recommendedImageUrl ?? '';
      }
      if (drilldownPreviewMetaEl instanceof HTMLElement) {
        const retryDelta = typeof item.qualityScoreBeforeRetry === 'number' && typeof item.qualityScore === 'number'
          ? item.qualityScore - item.qualityScoreBeforeRetry
          : null;
        const recommendedVariant = Array.isArray(item.candidateBreakdown)
          ? item.candidateBreakdown.find((candidate) => candidate.recommended)
          : null;
        const rejectedVariants = Array.isArray(item.rejectedVariantBreakdown)
          ? item.rejectedVariantBreakdown.slice(0, 2)
          : [];
        const previewScoreBars = [
          recommendedVariant
            ? compactPreviewScoreBar(
                `recommended ${recommendedVariant.variantId ?? recommendedVariant.variant ?? '-'}`,
                recommendedVariant.score ?? recommendedVariant.estimatedScore ?? 0,
                'emerald',
                `identity ${formatNumber(recommendedVariant.identityScore ?? 0)} / quality ${formatNumber(recommendedVariant.qualityScore ?? 0)}`
              )
            : '<p class="rounded-xl border border-dashed border-slate-300 bg-white p-3 text-sm text-slate-500">recommended none</p>',
          ...rejectedVariants.map((candidate, index) => compactPreviewScoreBar(
            `rejected ${candidate.variantId ?? candidate.variant ?? index + 1}`,
            candidate.score ?? candidate.estimatedScore ?? 0,
            'rose',
            `identity ${formatNumber(candidate.identityScore ?? 0)} / quality ${formatNumber(candidate.qualityScore ?? 0)}`
          ))
        ].join('');
        const relatedJobs = getRelatedJobs(type, key, item.id, derivedGroup);
        const qualityReason = summarizeQualityReason(item);
        const identityReason = summarizeIdentityReason(item);
        const retryToneClass = retryDelta !== null && retryDelta > 0
          ? 'text-emerald-700'
          : retryDelta !== null && retryDelta < 0
            ? 'text-rose-700'
            : 'text-slate-900';
        const retrySummary = retryDelta === null
          ? 'no retry data'
          : `${item.finalQualityRetryTriggered ? 'retry used' : 'retry skipped'} / ${retryDelta > 0 ? '+' : ''}${formatNumber(retryDelta)}`;
        drilldownPreviewMetaEl.innerHTML = `
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">job</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${escapeHtml(item.id)}</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">tool / provider</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${escapeHtml(item.toolType)} / ${escapeHtml(item.provider)}</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">quality / identity</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${formatNumber(item.qualityScore)} / ${formatNumber(item.identityScore)}</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">retry delta</p>
            <p class="mt-1 text-sm font-bold ${retryToneClass}">${retrySummary}</p>
            <p class="mt-1 text-xs text-slate-500">before ${formatNumber(item.qualityScoreBeforeRetry)} -> after ${formatNumber(item.qualityScore)}</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">flags</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${escapeHtml((item.flags ?? []).join(', ') || 'none')}</p>
            <p class="mt-2 text-xs text-slate-500">quality: ${escapeHtml(qualityReason)}</p>
            <p class="mt-1 text-xs text-slate-500">identity: ${escapeHtml(identityReason)}</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 md:col-span-2 xl:col-span-1">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">recommended vs rejected</p>
            <div class="mt-2 flex flex-wrap gap-2">
              ${recommendedVariant ? `<span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-900">recommended ${escapeHtml(recommendedVariant.variant)} / ${formatNumber(recommendedVariant.score)}</span>` : '<span class="rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-700">recommended none</span>'}
              ${rejectedVariants.length
                ? rejectedVariants.map((candidate) => `<span class="rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-900">rejected ${escapeHtml(candidate.variant)} / ${formatNumber(candidate.score)}</span>`).join('')
                : '<span class="rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-700">rejected none</span>'}
            </div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 md:col-span-2 xl:col-span-1">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">score compare</p>
            <div class="mt-3 grid gap-3">
              ${previewScoreBars}
            </div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 md:col-span-2 xl:col-span-1">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">related jobs</p>
            <div class="mt-3 grid gap-2">
              ${relatedJobs.length
                ? relatedJobs.map((related) => `
                    <div class="flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-3 py-2">
                      <div class="min-w-0">
                        <p class="truncate text-xs font-bold text-slate-900">${escapeHtml(related.id)}</p>
                        <p class="mt-1 text-[11px] text-slate-500">${escapeHtml(related.status ?? 'unknown')} / ${formatDate(related.createdAt)}</p>
                      </div>
                      <a href="${escapeHtml(buildDebugUrl(related.id))}" class="shrink-0 rounded-full border border-slate-300 bg-slate-50 px-3 py-1 text-[11px] font-semibold text-slate-700 transition hover:bg-slate-100">debug</a>
                    </div>
                  `).join('')
                : '<p class="rounded-xl border border-dashed border-slate-300 bg-white p-3 text-sm text-slate-500">related jobs none</p>'}
            </div>
          </div>
        `;
      }
    };

    const openPreviewKey = (previewKey, fallbackType = 'tool', fallbackKey = '', options = {}) => {
      const { alignFilter = false } = options;
      const resolvedEntry = resolvePreviewKeyEntry(previewKey, fallbackType, fallbackKey);
      if (!resolvedEntry?.key) {
        activePreviewKey = '';
        syncCurrentViewInUrl();
        hideDrilldownPreview();
        return false;
      }
      activePreviewKey = getNormalizedPreviewKey(resolvedEntry.previewKey, resolvedEntry.groupType ?? fallbackType, resolvedEntry.key);
      renderDrilldownPreview(resolvedEntry.groupType ?? fallbackType, resolvedEntry.key, resolvedEntry);
      syncCurrentViewInUrl();
      if (alignFilter && !isPreviewKeyFilterActive(resolvedEntry.groupType ?? fallbackType, resolvedEntry.key)) {
        applyPreviewKeyFilter(resolvedEntry.groupType ?? fallbackType, resolvedEntry.key);
      }
      return true;
    };

    const clearPreviewKeySelection = () => {
      activePreviewKey = '';
      pendingInitialPreviewKey = '';
      syncCurrentViewInUrl();
    };

    const renderDrilldownPreviewByKey = (previewKey, fallbackType = 'tool', fallbackKey = '') => {
      openPreviewKey(previewKey, fallbackType, fallbackKey);
    };

    const renderDrilldown = (alertsPayload, derivedData = latestDerivedOpsData) => {
      const toolGroups = getDerivedDrilldownGroups('tool', derivedData);
      const providerGroups = getDerivedDrilldownGroups('provider', derivedData);

      const renderGroup = (groups, target, emptyText) => {
        if (!(target instanceof HTMLElement)) return;
        target.innerHTML = groups.length
          ? groups.map((group) => `
              <button
                type="button"
                class="ops-drilldown w-full rounded-2xl border border-slate-200 bg-slate-50 p-4 text-left transition hover:border-slate-300 hover:bg-white"
                data-group-key="${escapeHtml(group.key)}"
                data-group-type="${target === toolDrilldownEl ? 'tool' : 'provider'}"
                data-preview-key="${escapeHtml(getNormalizedPreviewKey(group.previewKey, target === toolDrilldownEl ? 'tool' : 'provider', group.key))}"
              >
                <div class="flex items-center justify-between gap-3">
                  <p class="text-sm font-black text-slate-900">${escapeHtml(group.key)}</p>
                  <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700">${group.total}건</span>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                  ${group.flags.length
                    ? group.flags.map(([flag, count]) => `<span class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold text-slate-700 shadow-sm">${escapeHtml(flag)} · ${count}</span>`).join('')
                    : '<span class="text-xs text-slate-500">플래그 없음</span>'}
                </div>
                <div class="mt-3 grid gap-1 text-[11px] text-slate-500">
                  <p>top quality issue: ${escapeHtml(summarizeGroupReason(group.topQualityReason))}</p>
                  <p>top identity signal: ${escapeHtml(summarizeGroupReason(group.topIdentityReason))}</p>
                  <p>related jobs: ${group.relatedJobIds?.length ?? 0}</p>
                </div>
              </button>
            `).join('')
          : `<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-500">${emptyText}</p>`;
      };

      renderGroup(toolGroups, toolDrilldownEl, '표시할 툴별 경고 원인이 없습니다.');
      renderGroup(providerGroups, providerDrilldownEl, '표시할 provider별 경고 원인이 없습니다.');
      if (toolDebugLinksEl instanceof HTMLElement) {
        toolDebugLinksEl.innerHTML = toolGroups.length
          ? toolGroups.map((group) => {
              return group.debugUrl
                ? `<a href="${escapeHtml(group.debugUrl)}" class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:bg-sky-100">${escapeHtml(group.key)} 대표 job 디버그</a>`
                : '';
            }).join('')
          : '';
      }

      if (providerDebugLinksEl instanceof HTMLElement) {
        providerDebugLinksEl.innerHTML = providerGroups.length
          ? providerGroups.map((group) => {
              return group.debugUrl
                ? `<a href="${escapeHtml(group.debugUrl)}" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">${escapeHtml(group.key)} 대표 job 디버그</a>`
                : '';
            }).join('')
          : '';
      }
    };

    const variantChip = (item, type) => {
      const tone = type === 'rejected' ? 'rose' : type === 'recommended' ? 'emerald' : type === 'regenerated' ? 'amber' : 'sky';
      const label = type === 'rejected' ? '제외' : type === 'recommended' ? '추천' : item.regenerated ? '재생성' : '후보';
      return `
        <span class="rounded-full bg-${tone}-50 px-2.5 py-1 text-[11px] font-semibold text-${tone}-900">
          ${escapeHtml(label)} ${escapeHtml(item.variantId ?? item.id ?? '-')} · ${formatNumber(item.score ?? item.estimatedScore ?? 0)}
        </span>
      `;
    };

    const scoreBar = (item, type) => {
      const score = Math.max(0, Math.min(100, Number(item.score ?? item.estimatedScore ?? 0)));
      const tone = type === 'rejected' ? 'rose' : type === 'recommended' ? 'emerald' : item.regenerated ? 'amber' : 'sky';
      const label = type === 'rejected' ? '제외' : type === 'recommended' ? '추천' : item.regenerated ? '재생성' : '후보';
      return `
        <div class="rounded-xl border border-slate-200 bg-white p-3">
          <div class="flex items-center justify-between gap-3">
            <p class="text-xs font-semibold text-slate-600">${escapeHtml(label)} · ${escapeHtml(item.variantId ?? item.id ?? '-')}</p>
            <p class="text-sm font-black text-slate-900">${formatNumber(score)}</p>
          </div>
          <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-${tone}-500" style="width:${Math.max(4, score)}%"></div>
          </div>
          <div class="mt-2 flex flex-wrap gap-2 text-[11px] text-slate-500">
            <span>동일성 ${formatNumber(item.identityScore ?? 0)}</span>
            <span>규격 ${formatNumber(item.qualityScore ?? 0)}</span>
          </div>
        </div>
      `;
    };

    const renderList = (payload) => {
      if (!(listEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.items) ? payload.items : [];
      listEl.innerHTML = items.length
        ? items.map((item) => {
            const recommended = Array.isArray(item.candidateBreakdown)
              ? item.candidateBreakdown.find((candidate) => candidate.recommended)
              : null;
            const qualityReason = summarizeQualityReason(item);
            const identityReason = summarizeIdentityReason(item);
            const candidateBars = [
              ...(item.candidateBreakdown ?? []).map((candidate) => scoreBar(candidate, candidate.recommended ? 'recommended' : candidate.regenerated ? 'regenerated' : 'candidate')),
              ...(item.rejectedVariantBreakdown ?? []).map((candidate) => scoreBar(candidate, 'rejected'))
            ].join('');

            return `
              <article class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(item.toolType)} · ${escapeHtml(item.provider)}</p>
                    <h3 class="mt-1 text-lg font-black text-slate-900">${escapeHtml(item.id)}</h3>
                    <p class="mt-1 text-sm text-slate-500">${formatDate(item.createdAt)}</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <a href="${escapeHtml(buildDebugUrl(item.id))}" class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white transition hover:bg-slate-800">디버그</a>
                    ${(item.flags ?? []).map((flag) => `<span class="rounded-full bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm">${escapeHtml(flag)}</span>`).join('')}
                  </div>
                </div>

                <div class="mt-4 grid gap-4 xl:grid-cols-[0.95fr_1.05fr]">
                  <div class="grid gap-4">
                    <div class="grid gap-4 sm:grid-cols-2">
                      <div class="rounded-2xl border border-slate-200 bg-white p-3">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">원본</p>
                        <div class="mt-2 overflow-hidden rounded-xl bg-slate-100">
                          ${item.originalUrl ? `<img src="${escapeHtml(item.originalUrl)}" alt="원본" class="h-64 w-full object-cover" loading="lazy" />` : '<div class="flex h-64 items-center justify-center text-sm text-slate-400">원본 없음</div>'}
                        </div>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-3">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">추천 후보</p>
                        <div class="mt-2 overflow-hidden rounded-xl bg-slate-100">
                          ${item.recommendedImageUrl ? `<img src="${escapeHtml(item.recommendedImageUrl)}" alt="추천 후보" class="h-64 w-full object-cover" loading="lazy" />` : '<div class="flex h-64 items-center justify-center text-sm text-slate-400">추천 후보 없음</div>'}
                        </div>
                      </div>
                    </div>

                    <div class="grid gap-3 md:grid-cols-4">
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">규격 점수</p>
                        <p class="mt-2 text-xl font-black text-slate-900">${formatNumber(item.qualityScore)}</p>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">동일성 점수</p>
                        <p class="mt-2 text-xl font-black text-slate-900">${formatNumber(item.identityScore)}</p>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">crop profile</p>
                        <p class="mt-2 text-sm font-bold text-slate-900">${escapeHtml(item.cropProfile ?? '-')}</p>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">pose / suit</p>
                        <p class="mt-2 text-sm font-bold text-slate-900">${escapeHtml(item.poseProfile ?? '-')} / ${escapeHtml(item.suitTemplate ?? '-')}</p>
                      </div>
                    </div>

                    ${(item.finalQualityRetryTriggered || typeof item.qualityScoreBeforeRetry === 'number') ? `
                      <div class="rounded-2xl border border-amber-200 bg-amber-50 p-4">
                        <div class="flex items-center justify-between gap-3">
                          <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">품질 재시도</p>
                            <p class="mt-1 text-sm font-bold text-amber-950">${item.finalQualityRetryTriggered ? '최종 재프레이밍이 실행되었습니다.' : '재시도는 실행되지 않았습니다.'}</p>
                          </div>
                          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-amber-900">${escapeHtml(item.finalQualityRetryProfile ?? 'n/a')}</span>
                        </div>
                        <div class="mt-4 grid gap-3 sm:grid-cols-2">
                          <div class="rounded-xl bg-white p-3">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">재시도 전</p>
                            <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(item.qualityScoreBeforeRetry)}</p>
                          </div>
                          <div class="rounded-xl bg-white p-3">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">현재 점수</p>
                            <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(item.qualityScore)}</p>
                          </div>
                        </div>
                      </div>
                    ` : ''}
                  </div>

                  <div class="grid gap-4">
                    <div class="rounded-2xl border border-slate-200 bg-white p-4">
                      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">품질 요약</p>
                      <p class="mt-2 text-sm font-bold text-slate-900">${escapeHtml(item.qualitySummary ?? '요약 없음')}</p>
                      <div class="mt-3 flex flex-wrap gap-2">
                        ${renderProcessingSignalChips(item)}
                      </div>
                      <p class="mt-2 text-xs text-slate-500">quality reason: ${escapeHtml(qualityReason)}</p>
                      <p class="mt-1 text-xs text-slate-500">identity reason: ${escapeHtml(identityReason)}</p>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4">
                      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">후보 추적</p>
                      <div class="mt-3 flex flex-wrap gap-2">
                        ${recommended ? variantChip(recommended, 'recommended') : ''}
                        ${(item.candidateBreakdown ?? []).filter((candidate) => !candidate.recommended).map((candidate) => variantChip(candidate, candidate.regenerated ? 'regenerated' : 'candidate')).join('')}
                        ${(item.rejectedVariantBreakdown ?? []).map((candidate) => variantChip(candidate, 'rejected')).join('')}
                      </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4">
                      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">점수 비교</p>
                      <div class="mt-3 grid gap-3">
                        ${candidateBars || '<p class="text-sm text-slate-500">후보 점수 데이터가 없습니다.</p>'}
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            `;
          }).join('')
        : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-500">표시할 작업이 없습니다.</p>';
    };

    const buildOpsSummary = () => {
      const recent = latestRecentPayload;
      const alerts = latestAlertsPayload;
      const items = Array.isArray(recent?.items) ? recent.items : [];
      const alertItems = Array.isArray(alerts?.items) ? alerts.items : [];
      const derivedData = latestDerivedOpsData ?? buildDerivedOpsData(recent, alerts);
      const exportPayload = buildOpsExportPayload();
      const insights = derivedData.insights;
      const miniTrends = derivedData.miniTrend;
      const providerSummaries = derivedData.providerSummaries ?? [];
      const drilldownIndex = Object.values(derivedData.drilldownIndex ?? {});
      const currentViewUrl = exportPayload.viewContext?.url ?? getCurrentViewUrl();
      const viewSummary = exportPayload.viewContext?.summary ?? getCurrentViewContextSummary();
      const lines = [
        'AI 사진 운영 요약',
        `생성 시각: ${new Date().toLocaleString('ko-KR')}`,
        `필터: status=${recent?.filters?.status ?? 'all'}, tool=${recent?.filters?.toolType ?? 'all'}, limit=${recent?.filters?.limit ?? '-'}, period=${recent?.filters?.sinceHours ?? 'all'}h, flagged=${recent?.filters?.flaggedOnly ?? false}, fallbackOnly=${recent?.filters?.fallbackOnly ?? false}`,
        `총 작업: ${items.length}`,
        `경고 작업: ${alertItems.length}`
      ];

      lines[1] = `exportedAt: ${exportPayload.exportedAt ?? exportPayload.exportMeta?.exportedAt ?? new Date().toISOString()}`;
      lines.splice(2, 0, `surface: ${exportPayload.surface ?? 'ops'}`);
      lines.push(`currentView: ${currentViewUrl}`);
      lines.push('', '[schema]');
      lines.push(`- schemaVersion: ${exportPayload.schemaVersion ?? 'ai-photo-view-context.v1'}`);
      lines.push(`- surface: ${exportPayload.surface ?? 'ops'}`);
      lines.push(`- canonicalViewContext: ${exportPayload.legacy ? 'viewContext (legacy fields preserved)' : 'viewContext'}`);
      lines.push('', '[viewContext]');
      lines.push(`- url: ${currentViewUrl}`);
      lines.push(`- summary: ${viewContextUtils?.formatViewContextSummary(viewSummary) ?? 'status=all, tool=all, provider=all, limit=12, sinceHours=24, flaggedOnly=false, fallbackOnly=false, miniTrend=risk, previewKey=none'}`);
      lines.push('', '[exportMeta]');
      lines.push(`- source: ${exportPayload.exportMeta?.source ?? 'ops'}`);
      lines.push(`- exportedAt: ${exportPayload.exportMeta?.exportedAt ?? new Date().toISOString()}`);

      (recent?.toolTrends ?? []).forEach((item) => {
        lines.push(`- ${item.toolType}: total=${item.total}, failed=${item.failed}, avgQuality=${formatNumber(item.avgQualityScore)}, avgIdentity=${formatNumber(item.avgIdentityScore)}`);
      });

      if (insights.length) {
        lines.push('', '[insights]');
        insights.forEach((item) => {
          const clusterPreviewKey = getNormalizedPreviewKey(item.previewKey, item.clusterType ?? 'tool', item.clusterKey ?? '');
          const clusterMeta = item.label === 'largest related-job cluster' && clusterPreviewKey
            ? ` / cluster=${clusterPreviewKey}`
            : '';
          const debugMeta = item.label === 'largest related-job cluster' && item.debugUrl
            ? ` / debug=${item.debugUrl}`
            : '';
          lines.push(`- ${item.label}: ${item.value}${clusterMeta}${debugMeta}`);
        });
      }

      if (miniTrends.length) {
        lines.push('', '[mini trend]');
        miniTrends.forEach((item) => {
          lines.push(`- ${item.label}: total=${item.total}, failed=${item.failed}, flagged=${item.flagged}, fallback=${item.fallback}, quality=${item.topQualityReason ?? 'none'}, identity=${item.topIdentityReason ?? 'none'}, debug=${item.debugUrl ?? 'none'}`);
        });
      }

      if (providerSummaries.length) {
        lines.push('', '[provider summaries]');
        providerSummaries.forEach((item) => {
          const fallbackCount = item.flags.find(([flag]) => flag === 'provider_fallback')?.[1] ?? 0;
          lines.push(`- ${item.previewKey}: total=${item.total}, fallback=${fallbackCount}, quality=${summarizeGroupReason(item.topQualityReason)}, identity=${summarizeGroupReason(item.topIdentityReason)}, related=${item.relatedJobIds?.length ?? 0}, debug=${item.debugUrl ?? 'none'}`);
        });
      }

      if (drilldownIndex.length) {
        lines.push('', '[drilldown index]');
        drilldownIndex.forEach((item) => {
          lines.push(`- ${item.previewKey}: total=${item.total}, quality=${item.topQualityIssue}, identity=${item.topIdentitySignal}, debug=${item.debugUrl ?? 'none'}, related=${item.relatedJobIds?.length ?? 0}`);
        });
      }

      alertItems.slice(0, 10).forEach((item) => {
        lines.push(`- alert ${item.id}: ${item.toolType} / ${item.provider} / flags=${(item.flags ?? []).join(', ')} / quality=${summarizeQualityReason(item)} / identity=${summarizeIdentityReason(item)}`);
      });

      return lines.join('\n');
    };

    const buildOpsExportPayload = () => {
      const recent = latestRecentPayload;
      const alerts = latestAlertsPayload;
      const derivedData = latestDerivedOpsData ?? buildDerivedOpsData(recent, alerts);
      const exportedAt = new Date().toISOString();
      const currentViewUrl = getCurrentViewUrl();
      const viewContext = viewContextUtils?.createViewContext(currentViewUrl, getCurrentViewContextSummary()) ?? {
        url: currentViewUrl,
        summary: getCurrentViewContextSummary()
      };
      return viewContextUtils?.createExportEnvelope('ops', {
        exportedAt,
        recent,
        alerts,
        derived: derivedData,
        currentViewUrl,
        viewContext,
        legacy: viewContextUtils?.createLegacyFields({
          currentViewUrl
        }),
        exportMeta: viewContextUtils?.createExportMeta('ops', exportedAt) ?? {
          source: 'ops',
          exportedAt
        }
      }) ?? {
        schemaVersion: 'ai-photo-view-context.v1',
        surface: 'ops',
        exportedAt,
        recent,
        alerts,
        derived: derivedData,
        currentViewUrl,
        viewContext,
        legacy: viewContextUtils?.createLegacyFields({
          currentViewUrl
        }),
        exportMeta: viewContextUtils?.createExportMeta('ops', exportedAt) ?? {
          source: 'ops',
          exportedAt
        }
      };
    };

    const downloadJson = () => {
      const text = JSON.stringify(buildOpsExportPayload(), null, 2);
      viewContextUtils?.downloadTextFile(`ai-photo-ops-${Date.now()}.json`, text, 'application/json');
    };

    const buildQuery = () => {
      const params = new URLSearchParams();
      const status = filters.status instanceof HTMLSelectElement ? filters.status.value : 'all';
      const toolType = filters.tool instanceof HTMLSelectElement ? filters.tool.value : 'all';
      const provider = filters.provider instanceof HTMLSelectElement ? filters.provider.value : 'all';
      const limit = filters.limit instanceof HTMLSelectElement ? filters.limit.value : '12';
      const period = filters.period instanceof HTMLSelectElement ? filters.period.value : '24';
      const flaggedOnly = filters.flagged instanceof HTMLSelectElement ? filters.flagged.value === 'true' : false;
      const fallbackOnly = filters.fallbackOnly instanceof HTMLSelectElement ? filters.fallbackOnly.value === 'true' : false;

      params.set('limit', limit);
      if (status !== 'all') params.set('status', status);
      if (toolType !== 'all') params.set('toolType', toolType);
      if (provider !== 'all') params.set('provider', provider);
      if (period !== '0') params.set('sinceHours', period);
      if (flaggedOnly) params.set('flaggedOnly', 'true');
      if (fallbackOnly) params.set('fallbackOnly', 'true');
      return params;
    };

    const getPrimaryDebugUrl = () => {
      const recentItems = Array.isArray(latestRecentPayload?.items) ? latestRecentPayload.items : [];
      const alertItems = Array.isArray(latestAlertsPayload?.items) ? latestAlertsPayload.items : [];
      const target = recentItems[0] ?? alertItems[0] ?? null;
      return buildDebugUrl(target?.id ?? '');
    };

    const getAdminUrl = () => {
      const params = new URLSearchParams();
      params.set('opsView', getCurrentViewUrl());
      return `/tools/ai-photo-admin?${params.toString()}`;
    };

    const syncDebugLink = () => {
      if (!(openDebugLink instanceof HTMLAnchorElement)) return;
      const recentItems = Array.isArray(latestRecentPayload?.items) ? latestRecentPayload.items : [];
      const alertItems = Array.isArray(latestAlertsPayload?.items) ? latestAlertsPayload.items : [];
      const hasTarget = Boolean((recentItems[0] ?? alertItems[0])?.id);
      const href = getPrimaryDebugUrl();
      openDebugLink.href = href;
      openDebugLink.classList.toggle('opacity-50', !hasTarget);
      openDebugLink.classList.toggle('pointer-events-none', !hasTarget);
      openDebugLink.setAttribute('aria-disabled', hasTarget ? 'false' : 'true');
    };

    const syncAdminLink = () => {
      if (!(openAdminLink instanceof HTMLAnchorElement)) return;
      openAdminLink.href = getAdminUrl();
    };

    const applyPreset = (preset) => {
      clearPreviewKeySelection();
      if (filters.status instanceof HTMLSelectElement) filters.status.value = 'all';
      if (filters.flagged instanceof HTMLSelectElement) filters.flagged.value = 'false';
      if (filters.fallbackOnly instanceof HTMLSelectElement) filters.fallbackOnly.value = 'false';
      if (filters.provider instanceof HTMLSelectElement) filters.provider.value = 'all';

      if (preset === 'flagged' && filters.flagged instanceof HTMLSelectElement) {
        filters.flagged.value = 'true';
      }
      if (preset === 'fallback' && filters.fallbackOnly instanceof HTMLSelectElement) {
        filters.fallbackOnly.value = 'true';
      }
      if (preset === 'failed' && filters.status instanceof HTMLSelectElement) {
        filters.status.value = 'failed';
      }
      loadOps();
    };

    const loadOps = async () => {
      setStatus('운영 데이터를 불러오는 중입니다.');
      const query = buildQuery();
      try {
        const [recentRes, alertsRes] = await Promise.all([
          fetch(`${API_BASE}/jobs/recent?${query.toString()}`),
          fetch(`${API_BASE}/jobs/alerts?${query.toString()}`)
        ]);
        if (!recentRes.ok || !alertsRes.ok) throw new Error('운영 데이터를 불러오지 못했습니다.');
        const recentPayload = await recentRes.json();
        const alertsPayload = await alertsRes.json();
        const derivedData = buildDerivedOpsData(recentPayload, alertsPayload);
        latestRecentPayload = recentPayload;
        latestAlertsPayload = alertsPayload;
        latestDerivedOpsData = derivedData;
        renderStats(recentPayload, alertsPayload);
        renderInsights(recentPayload, alertsPayload, derivedData);
        renderMiniTrend(recentPayload, derivedData);
        renderTrends(recentPayload);
        renderAlerts(alertsPayload, derivedData);
        renderProviderSummaries(alertsPayload, derivedData);
        renderDrilldown(alertsPayload, derivedData);
        renderList(recentPayload);
        syncDebugLink();
        syncAdminLink();
        syncCurrentViewInUrl();
        if (activePreviewKey) {
          openPreviewKey(activePreviewKey, 'tool', '');
          pendingInitialPreviewKey = '';
        } else {
          hideDrilldownPreview();
        }
        setStatus(`최근 ${Array.isArray(recentPayload.items) ? recentPayload.items.length : 0}건, 경고 ${Array.isArray(alertsPayload.items) ? alertsPayload.items.length : 0}건을 불러왔습니다.`);
      } catch (error) {
        latestRecentPayload = null;
        latestAlertsPayload = null;
        latestDerivedOpsData = null;
        hideDrilldownPreview();
        syncDebugLink();
        setStatus(error instanceof Error ? error.message : '운영 데이터를 불러오지 못했습니다.');
      }
    };

    refreshBtn?.addEventListener('click', () => loadOps());
    Object.values(filters).forEach((element) => element?.addEventListener('change', () => {
      clearPreviewKeySelection();
      loadOps();
    }));
    presetButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const preset = button.getAttribute('data-preset') ?? 'all';
        applyPreset(preset);
      });
    });
    miniTrendTabs.forEach((button) => {
      button.addEventListener('click', () => {
        miniTrendMode = button.getAttribute('data-mini-trend-tab') ?? 'risk';
        renderMiniTrend(latestRecentPayload, latestDerivedOpsData);
      });
    });
    document.addEventListener('click', (event) => {
      const insightTarget = event.target instanceof HTMLElement ? event.target.closest('[data-insight-cluster="true"]') : null;
      if (insightTarget instanceof HTMLElement) {
        const previewKey = insightTarget.getAttribute('data-preview-key') ?? '';
        const { type, key } = parsePreviewKey(
          previewKey,
          insightTarget.getAttribute('data-cluster-type') ?? 'tool',
          insightTarget.getAttribute('data-cluster-key') ?? ''
        );
        if (key) {
          openPreviewKey(previewKey, type, key);
          applyPreviewKeyFilter(type, key);
        }
        return;
      }
      const target = event.target instanceof HTMLElement ? event.target.closest('.ops-drilldown') : null;
      if (!(target instanceof HTMLElement)) return;
      const previewKey = target.getAttribute('data-preview-key') ?? '';
      const { type, key } = parsePreviewKey(
        previewKey,
        target.getAttribute('data-group-type') ?? 'tool',
        target.getAttribute('data-group-key') ?? 'all'
      );
      openPreviewKey(previewKey, type, key);
      applyPreviewKeyFilter(type, key);
    });

    copySummaryBtn?.addEventListener('click', async () => {
      const summary = buildOpsSummary();
      try {
        await viewContextUtils?.copyText(summary);
        setStatus('운영 요약을 클립보드에 복사했습니다.');
      } catch {
        setStatus('클립보드 복사에 실패했습니다.');
      }
    });

    copyViewLinkBtn?.addEventListener('click', async () => {
      try {
        await viewContextUtils?.copyText(getCurrentViewUrl());
        setStatus('현재 뷰 링크를 클립보드에 복사했습니다.');
      } catch {
        setStatus('현재 뷰 링크 복사에 실패했습니다.');
      }
    });

    downloadSummaryBtn?.addEventListener('click', () => {
      viewContextUtils?.downloadTextFile(`ai-photo-ops-summary-${Date.now()}.txt`, buildOpsSummary());
      setStatus('운영 요약을 텍스트 파일로 저장했습니다.');
    });

    downloadJsonBtn?.addEventListener('click', () => {
      downloadJson();
      setStatus('운영 JSON을 저장했습니다.');
    });

    downloadToolDrilldownBtn?.addEventListener('click', () => {
      const text = buildDrilldownExport('tool');
      if (!text) {
        setStatus('tool drill-down으로 저장할 경고 데이터가 없습니다.');
        return;
      }
      viewContextUtils?.downloadTextFile(`ai-photo-tool-drilldown-${Date.now()}.txt`, text);
      setStatus('tool drill-down 요약을 저장했습니다.');
    });

    downloadProviderDrilldownBtn?.addEventListener('click', () => {
      const text = buildDrilldownExport('provider');
      if (!text) {
        setStatus('provider drill-down으로 저장할 경고 데이터가 없습니다.');
        return;
      }
      viewContextUtils?.downloadTextFile(`ai-photo-provider-drilldown-${Date.now()}.txt`, text);
      setStatus('provider drill-down 요약을 저장했습니다.');
    });

    downloadToolDrilldownCsvBtn?.addEventListener('click', () => {
      const csv = buildDrilldownCsvExport('tool');
      if (!csv) {
        setStatus('tool drill-down CSV로 저장할 경고 데이터가 없습니다.');
        return;
      }
      viewContextUtils?.downloadTextFile(`ai-photo-tool-drilldown-${Date.now()}.csv`, csv);
      setStatus('tool drill-down CSV를 저장했습니다.');
    });

    downloadProviderDrilldownCsvBtn?.addEventListener('click', () => {
      const csv = buildDrilldownCsvExport('provider');
      if (!csv) {
        setStatus('provider drill-down CSV로 저장할 경고 데이터가 없습니다.');
        return;
      }
      viewContextUtils?.downloadTextFile(`ai-photo-provider-drilldown-${Date.now()}.csv`, csv);
      setStatus('provider drill-down CSV를 저장했습니다.');
    });

    hydrateControlsFromUrl();

    if (pendingInitialPreviewKey) {
      const initialPreview = parsePreviewKey(pendingInitialPreviewKey, 'tool', '');
      if (initialPreview.key) {
        syncPreviewKeyFilters(initialPreview.type ?? 'tool', initialPreview.key);
      } else {
        clearPreviewKeySelection();
      }
    }

    loadOps();
  </script>
</Layout>
