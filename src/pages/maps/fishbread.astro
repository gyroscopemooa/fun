---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import AdSense from '../../components/AdSense.astro';
import Recommend from '../../components/Recommend.astro';
import Footer from '../../components/Footer.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';
const t = {
  ko: {
    title: '붕어빵 지도(붕어빵 맵) | ManyTool',
    desc: '붕어빵 맵: 지도 기반 붕어빵 벤더 탐색/제보 페이지',
    pageTitle: '전국 붕어빵 지도 · 붕어빵 맵',
    search: '지역/가게명 검색',
    list: '제보 목록',
    add: '제보 추가',
    report: '새 제보 등록',
    mapHint: '먼저 지도에서 위치를 클릭하면 좌표가 자동 입력됩니다.'
  },
  en: {
    title: 'Fishbread Map | ManyTool',
    desc: 'Map-based fishbread vendor explorer and report page',
    pageTitle: 'Nationwide Fishbread Map',
    search: 'Search region/vendor',
    list: 'Reports',
    add: 'Add Report',
    report: 'Report New Vendor',
    mapHint: 'Pick a location on the map first to auto-fill coordinates.'
  },
  ja: {
    title: 'たい焼きマップ | ManyTool',
    desc: '地図ベースのたい焼きスポット探索・投稿ページ',
    pageTitle: '全国たい焼きマップ',
    search: '地域/店舗検索',
    list: '投稿一覧',
    add: '投稿追加',
    report: '新規投稿',
    mapHint: '先に地図をタップすると座標が自動入力されます。'
  }
}[locale];
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
const adminEmails = import.meta.env.PUBLIC_FISHBREAD_ADMIN_EMAILS ?? '';
const seoKeywords = locale === 'ko'
  ? '붕어빵 지도, 붕어빵 맵, 붕어빵 파는곳, 붕어빵 위치, 길거리 음식 지도'
  : locale === 'en'
    ? 'fishbread map, bungeoppang map, fish-shaped pastry locations'
    : 'たい焼きマップ, たい焼き 地図, たい焼き 場所';
---

<Layout title={t.title} description={t.desc} keywords={seoKeywords}>
  <Header />

  <main class="bg-amber-50 text-slate-900">
    <section class="mx-auto max-w-6xl px-4 pb-4 pt-4">
      <div class="mb-4 flex items-center justify-between rounded-2xl border border-amber-200 bg-white px-4 py-3">
        <div class="flex items-center gap-3">
          <div class="rounded-lg bg-amber-500 px-2 py-1 text-white">🐟</div>
          <h1 class="text-lg font-bold tracking-tight md:text-xl">{t.pageTitle}</h1>
        </div>
        <p id="selected-region" class="rounded-full bg-amber-100 px-3 py-1 text-sm font-semibold text-amber-700">전체</p>
      </div>

      <div class="grid gap-4 lg:grid-cols-[360px_1fr]">
        <aside class="order-2 rounded-2xl border border-slate-200 bg-white lg:order-1">
          <div class="border-b border-slate-100 p-4">
            <input id="vendor-search" class="w-full rounded-xl border border-slate-200 bg-slate-100 px-4 py-2.5 text-sm" placeholder={t.search} type="text" />
          </div>

          <div class="border-b border-slate-100 p-4">
            <div class="mb-3 flex items-center justify-between">
              <h2 class="text-lg font-bold">{t.list}</h2>
              <button id="region-all" class="text-sm font-semibold text-amber-600">전체</button>
            </div>
            <div class="flex gap-2 overflow-x-auto pb-1 text-xs">
              <button class="rounded-full bg-amber-500 px-3 py-1.5 font-semibold text-white">All</button>
              <button class="rounded-full bg-slate-100 px-3 py-1.5">팥</button>
              <button class="rounded-full bg-slate-100 px-3 py-1.5">슈크림</button>
              <button class="rounded-full bg-slate-100 px-3 py-1.5">피자</button>
            </div>
          </div>

          <div id="vendor-list" class="max-h-[420px] space-y-3 overflow-y-auto p-4 lg:max-h-[520px]"></div>

          <div class="border-t border-slate-100 bg-slate-50 p-4">
            <h3 class="text-sm font-bold">{t.add}</h3>
            <input id="spot-name" class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="가게명" type="text" />
            <input id="spot-region" class="mt-2 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm" placeholder="지역(지도/버튼 선택)" type="text" readonly />
            <input id="spot-flavor" class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="대표 메뉴 (예: 팥/슈크림)" type="text" />
            <input id="spot-detail" class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="상세 위치 (예: OO역 2번 출구)" type="text" />
            <input id="spot-latlng" class="mt-2 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-xs text-slate-500" placeholder="지도 클릭 시 좌표 자동 입력" type="text" readonly />
            <p class="mt-2 text-xs text-slate-500">{t.mapHint}</p>
            <button id="spot-add" class="mt-3 w-full rounded-xl bg-amber-500 py-2.5 font-bold text-white disabled:cursor-not-allowed disabled:bg-slate-300" disabled>{t.report}</button>
            <p class="mt-2 text-xs text-slate-500">비회원 제보/댓글은 등록 즉시 공개됩니다.</p>
            <p class="mt-1 text-xs text-slate-500">비추천이 100개 더 많을 시 자동 삭제됩니다.</p>
          </div>

        </aside>

        <section class="order-1 rounded-2xl border border-slate-200 bg-white p-3 lg:order-2">
          <div id="fishbread-map" class="h-[340px] w-full rounded-xl border border-slate-200 sm:h-[420px] md:h-[620px]"></div>

          <div class="mt-3 flex flex-wrap gap-2">
            <button data-region="서울" class="map-region">서울</button>
            <button data-region="경기" class="map-region">경기</button>
            <button data-region="인천" class="map-region">인천</button>
            <button data-region="강원" class="map-region">강원</button>
            <button data-region="충남" class="map-region">충남</button>
            <button data-region="충북" class="map-region">충북</button>
            <button data-region="대전" class="map-region">대전</button>
            <button data-region="전북" class="map-region">전북</button>
            <button data-region="광주" class="map-region">광주</button>
            <button data-region="전남" class="map-region">전남</button>
            <button data-region="경북" class="map-region">경북</button>
            <button data-region="대구" class="map-region">대구</button>
            <button data-region="경남" class="map-region">경남</button>
            <button data-region="울산" class="map-region">울산</button>
            <button data-region="부산" class="map-region">부산</button>
            <button data-region="제주" class="map-region">제주</button>
          </div>
        </section>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-4 pb-8 pt-2">
      <AdSense slotName="본문 중간" />
      <Recommend />
    </section>
  </main>
  <Footer />
  <button id="admin-dock" class="fixed bottom-4 right-4 z-[999] hidden rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs text-slate-700 shadow">관리</button>
  <div id="admin-shell" class="fixed bottom-16 right-4 z-[999] hidden w-[320px] rounded-xl border border-slate-200 bg-white p-4 shadow-xl">
    <div class="flex items-center justify-between">
      <h3 class="text-sm font-bold">관리자</h3>
      <button id="admin-toggle" class="rounded-md border border-slate-300 px-2 py-1 text-xs">닫기</button>
    </div>
    <div id="admin-panel" class="mt-2">
      <p id="admin-state" class="text-xs text-slate-500">로그아웃 상태</p>
      <div class="mt-2 grid gap-2">
        <input id="admin-email" class="rounded-md border border-slate-300 px-3 py-2 text-xs" placeholder="이메일" type="email" />
        <input id="admin-password" class="rounded-md border border-slate-300 px-3 py-2 text-xs" placeholder="비밀번호" type="password" />
      </div>
      <div class="mt-2 flex gap-2">
        <button id="admin-login" class="rounded-md bg-slate-900 px-3 py-1.5 text-xs text-white">로그인</button>
        <button id="admin-logout" class="rounded-md border border-slate-300 px-3 py-1.5 text-xs">로그아웃</button>
      </div>
      <div id="admin-moderation" class="mt-3 hidden">
        <p class="text-xs font-semibold text-slate-700">승인 대기 제보</p>
        <div id="pending-report-list" class="mt-2 max-h-36 space-y-2 overflow-y-auto"></div>
        <p class="mt-3 text-xs font-semibold text-slate-700">승인 대기 댓글</p>
        <div id="pending-comment-list" class="mt-2 max-h-36 space-y-2 overflow-y-auto"></div>
      </div>
    </div>
  </div>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>

  <script
    type="module"
    is:inline
    define:vars={{ supabaseUrl, supabaseAnonKey, adminEmails }}
  >
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const SUPABASE_URL = supabaseUrl;
    const SUPABASE_ANON_KEY = supabaseAnonKey;
    const ADMIN_EMAILS = adminEmails
      .split(',')
      .map((v) => v.trim().toLowerCase())
      .filter(Boolean);
    const DEVICE_KEY = 'manytool_fishbread_device_v1';
    const LOCAL_VOTE_KEY = 'manytool_fishbread_vote_ids_v1';
    const REGION_COORD = {
      서울: { lat: 37.5665, lng: 126.978, zoom: 11 },
      경기: { lat: 37.4138, lng: 127.5183, zoom: 9 },
      인천: { lat: 37.4563, lng: 126.7052, zoom: 11 },
      강원: { lat: 37.8228, lng: 128.1555, zoom: 9 },
      충남: { lat: 36.5184, lng: 126.8, zoom: 9 },
      충북: { lat: 36.8, lng: 127.7, zoom: 9 },
      대전: { lat: 36.3504, lng: 127.3845, zoom: 11 },
      전북: { lat: 35.7175, lng: 127.153, zoom: 9 },
      광주: { lat: 35.1595, lng: 126.8526, zoom: 11 },
      전남: { lat: 34.8161, lng: 126.463, zoom: 9 },
      경북: { lat: 36.4919, lng: 128.8889, zoom: 9 },
      대구: { lat: 35.8714, lng: 128.6014, zoom: 11 },
      경남: { lat: 35.4606, lng: 128.2132, zoom: 9 },
      울산: { lat: 35.5384, lng: 129.3114, zoom: 11 },
      부산: { lat: 35.1796, lng: 129.0756, zoom: 11 },
      제주: { lat: 33.4996, lng: 126.5312, zoom: 10 }
    };

    const searchEl = document.getElementById('vendor-search');
    const selectedRegionEl = document.getElementById('selected-region');
    const regionInputEl = document.getElementById('spot-region');
    const listEl = document.getElementById('vendor-list');
    const addBtn = document.getElementById('spot-add');
    const nameEl = document.getElementById('spot-name');
    const flavorEl = document.getElementById('spot-flavor');
    const detailEl = document.getElementById('spot-detail');
    const latlngEl = document.getElementById('spot-latlng');
    const adminDockEl = document.getElementById('admin-dock');
    const adminToggleEl = document.getElementById('admin-toggle');
    const adminShellEl = document.getElementById('admin-shell');
    const adminPanelEl = document.getElementById('admin-panel');
    const adminStateEl = document.getElementById('admin-state');
    const adminEmailEl = document.getElementById('admin-email');
    const adminPasswordEl = document.getElementById('admin-password');
    const adminLoginEl = document.getElementById('admin-login');
    const adminLogoutEl = document.getElementById('admin-logout');
    const adminModerationEl = document.getElementById('admin-moderation');
    const pendingReportListEl = document.getElementById('pending-report-list');
    const pendingCommentListEl = document.getElementById('pending-comment-list');

    const supabaseReady = Boolean(SUPABASE_URL && SUPABASE_ANON_KEY);
    const supabase = supabaseReady ? createClient(SUPABASE_URL, SUPABASE_ANON_KEY) : null;
    const state = { vendors: [], pendingReports: [], pendingComments: [] };
    let currentUser = null;
    let adminGranted = false;
    let votedIds = new Set();
    let selectedRegion = '전체';
    let selectedLat = null;
    let selectedLng = null;
    let map;
    let markersLayer;

    const updateAddButtonState = () => {
      if (!(addBtn instanceof HTMLButtonElement)) return;
      addBtn.disabled = !(typeof selectedLat === 'number' && typeof selectedLng === 'number');
    };

    const score = (v) => v.up - v.down;
    const hashDevice = (value) => {
      let hash = 5381;
      for (let i = 0; i < value.length; i += 1) {
        hash = (hash * 33) ^ value.charCodeAt(i);
      }
      return (hash >>> 0).toString(36);
    };
    const ensureDeviceId = () => {
      const raw = localStorage.getItem(DEVICE_KEY);
      if (raw) return raw;
      const id = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
      localStorage.setItem(DEVICE_KEY, id);
      return id;
    };
    const loadVotedIds = () => {
      try {
        const raw = localStorage.getItem(LOCAL_VOTE_KEY);
        const parsed = raw ? JSON.parse(raw) : [];
        return new Set(Array.isArray(parsed) ? parsed : []);
      } catch {
        return new Set();
      }
    };
    const saveVotedIds = () => {
      localStorage.setItem(LOCAL_VOTE_KEY, JSON.stringify([...votedIds]));
    };
    const isAdmin = () => adminGranted;
    const refreshAdminGranted = async () => {
      if (!supabase || !currentUser?.email) {
        adminGranted = false;
        return;
      }
      const email = currentUser.email.toLowerCase();
      if (ADMIN_EMAILS.includes(email)) {
        adminGranted = true;
        return;
      }
      const { data } = await supabase
        .from('fishbread_admins')
        .select('email')
        .eq('email', email)
        .maybeSingle();
      adminGranted = Boolean(data?.email);
    };
    const updateAdminUiState = () => {
      if (adminStateEl) {
        adminStateEl.textContent = isAdmin()
          ? `관리자 로그인: ${currentUser?.email || ''}`
          : '로그아웃 상태';
      }
      if (adminModerationEl) {
        adminModerationEl.classList.toggle('hidden', !isAdmin());
      }
    };

    const filteredVendors = () => {
      const q = searchEl instanceof HTMLInputElement ? searchEl.value.trim().toLowerCase() : '';
      return state.vendors
        .filter((v) => selectedRegion === '전체' || v.region === selectedRegion)
        .filter((v) => q === '' || `${v.name} ${v.region} ${v.flavor}`.toLowerCase().includes(q))
        .sort((a, b) => score(b) - score(a));
    };

    const renderList = (items) => {
      if (!listEl) return;
      if (items.length === 0) {
        listEl.innerHTML = '<p class="rounded-xl bg-slate-100 px-3 py-3 text-sm text-slate-600">조건에 맞는 제보가 없습니다.</p>';
        return;
      }

      listEl.innerHTML = items.map((v) => `
        <article class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <div class="flex items-start justify-between gap-2">
            <div>
              <h3 class="font-bold">${v.name}</h3>
              <p class="text-xs text-slate-500">${v.region} · ${v.flavor}${v.detail ? ` · ${v.detail}` : ''}</p>
            </div>
            <p class="text-xs font-semibold text-amber-600">신뢰 ${score(v)}</p>
          </div>
          <div class="mt-2 flex gap-2">
            <button data-act="up" data-id="${v.id}" class="rounded-md border border-slate-300 px-2 py-1 text-xs ${votedIds.has(v.id) ? 'opacity-50' : ''}" ${votedIds.has(v.id) ? 'disabled' : ''}>추천 ${v.up}</button>
            <button data-act="down" data-id="${v.id}" class="rounded-md border border-slate-300 px-2 py-1 text-xs ${votedIds.has(v.id) ? 'opacity-50' : ''}" ${votedIds.has(v.id) ? 'disabled' : ''}>비추천 ${v.down}</button>
            ${isAdmin() ? `<button data-act="delete" data-id="${v.id}" class="rounded-md border border-rose-500 px-2 py-1 text-xs text-rose-700">삭제</button>` : ''}
          </div>
          <div class="mt-2 rounded-md bg-white p-2">
            <ul class="space-y-1 text-xs text-slate-600">
              ${v.comments.slice(-2).map((c) => `<li>- ${c.body}</li>`).join('') || '<li>- 댓글 없음</li>'}
            </ul>
            <div class="mt-2 flex gap-2">
              <input data-input="comment" data-id="${v.id}" class="flex-1 rounded border border-slate-300 px-2 py-1 text-xs" placeholder="정확/부정확 댓글" />
              <button data-act="comment" data-id="${v.id}" class="rounded bg-slate-900 px-2 py-1 text-xs text-white">등록</button>
            </div>
          </div>
        </article>`).join('');
    };

    const initMap = () => {
      if (typeof window === 'undefined' || !window.L || map) return;
      map = window.L.map('fishbread-map').setView([36.5, 127.8], 7);
      window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);
      markersLayer = window.L.layerGroup().addTo(map);
    };

    const renderMap = (items) => {
      if (!map || !markersLayer || !window.L) return;
      markersLayer.clearLayers();

      items.forEach((v) => {
        const coord = (typeof v.lat === 'number' && typeof v.lng === 'number')
          ? { lat: v.lat, lng: v.lng }
          : REGION_COORD[v.region];
        if (!coord) return;
        window.L
          .marker([coord.lat, coord.lng])
          .bindPopup(`<strong>${v.name}</strong><br/>${v.region} · ${v.flavor}${v.detail ? `<br/>${v.detail}` : ''}`)
          .addTo(markersLayer);
      });

      if (selectedRegion !== '전체' && REGION_COORD[selectedRegion]) {
        const c = REGION_COORD[selectedRegion];
        map.setView([c.lat, c.lng], c.zoom);
      }

      if (typeof selectedLat === 'number' && typeof selectedLng === 'number') {
        window.L
          .circleMarker([selectedLat, selectedLng], {
            radius: 8,
            color: '#f59e0b',
            weight: 2,
            fillColor: '#f59e0b',
            fillOpacity: 0.35
          })
          .bindPopup('선택된 제보 위치')
          .addTo(markersLayer);
      }
    };

    const render = () => {
      const items = filteredVendors();
      renderList(items);
      renderMap(items);
      renderPending();
    };

    const renderPending = () => {
      if (!pendingReportListEl || !pendingCommentListEl) return;
      if (!isAdmin()) {
        pendingReportListEl.innerHTML = '';
        pendingCommentListEl.innerHTML = '';
        return;
      }
      pendingReportListEl.innerHTML = state.pendingReports.length
        ? state.pendingReports.map((v) => `
          <article class="rounded-md border border-slate-200 bg-slate-50 p-2">
            <p class="text-xs font-semibold">${v.name} (${v.region})</p>
            <div class="mt-1 flex gap-1">
              <button data-admin="approve-report" data-id="${v.id}" class="rounded border border-emerald-500 px-2 py-0.5 text-[11px] text-emerald-700">승인</button>
              <button data-admin="delete-report" data-id="${v.id}" class="rounded border border-rose-500 px-2 py-0.5 text-[11px] text-rose-700">삭제</button>
            </div>
          </article>`).join('')
        : '<p class="text-xs text-slate-500">대기 없음</p>';

      pendingCommentListEl.innerHTML = state.pendingComments.length
        ? state.pendingComments.map((c) => `
          <article class="rounded-md border border-slate-200 bg-slate-50 p-2">
            <p class="text-xs">${c.body}</p>
            <div class="mt-1 flex gap-1">
              <button data-admin="approve-comment" data-id="${c.id}" class="rounded border border-emerald-500 px-2 py-0.5 text-[11px] text-emerald-700">승인</button>
              <button data-admin="delete-comment" data-id="${c.id}" class="rounded border border-rose-500 px-2 py-0.5 text-[11px] text-rose-700">삭제</button>
            </div>
          </article>`).join('')
        : '<p class="text-xs text-slate-500">대기 없음</p>';
    };

    const loadApprovedReports = async () => {
      if (!supabase) return;
      const { data: reports, error: reportsError } = await supabase
        .from('fishbread_reports')
        .select('id,name,region,flavor,detail,lat,lng,up_count,down_count,created_at')
        .eq('status', 'approved')
        .order('created_at', { ascending: false })
        .limit(300);
      if (reportsError) throw reportsError;

      const ids = (reports || []).map((v) => v.id);
      const { data: comments, error: commentsError } = ids.length
        ? await supabase
            .from('fishbread_comments')
            .select('id,report_id,body,created_at')
            .eq('status', 'approved')
            .in('report_id', ids)
            .order('created_at', { ascending: true })
        : { data: [], error: null };
      if (commentsError) throw commentsError;

      const commentMap = (comments || []).reduce((acc, cur) => {
        if (!acc[cur.report_id]) acc[cur.report_id] = [];
        acc[cur.report_id].push({ id: cur.id, body: cur.body });
        return acc;
      }, {});

      state.vendors = (reports || []).map((v) => ({
        id: v.id,
        name: v.name,
        region: v.region,
        flavor: v.flavor || '팥',
        detail: v.detail || '',
        lat: v.lat,
        lng: v.lng,
        up: v.up_count || 0,
        down: v.down_count || 0,
        comments: commentMap[v.id] || []
      }));
    };

    const loadPendingForAdmin = async () => {
      if (!supabase || !isAdmin()) return;
      const [{ data: pendingReports, error: pErr }, { data: pendingComments, error: cErr }] = await Promise.all([
        supabase
          .from('fishbread_reports')
          .select('id,name,region,created_at')
          .eq('status', 'pending')
          .order('created_at', { ascending: false })
          .limit(100),
        supabase
          .from('fishbread_comments')
          .select('id,report_id,body,created_at')
          .eq('status', 'pending')
          .order('created_at', { ascending: false })
          .limit(100)
      ]);
      if (pErr) throw pErr;
      if (cErr) throw cErr;
      state.pendingReports = pendingReports || [];
      state.pendingComments = pendingComments || [];
    };

    const reloadAll = async () => {
      try {
        if (!supabaseReady) {
          if (listEl) {
            listEl.innerHTML = '<p class="rounded-xl bg-rose-50 px-3 py-3 text-sm text-rose-700">Supabase 환경 변수가 없어 지도 데이터를 불러올 수 없습니다.</p>';
          }
          return;
        }
        await loadApprovedReports();
        if (isAdmin()) {
          await loadPendingForAdmin();
        } else {
          state.pendingReports = [];
          state.pendingComments = [];
        }
        render();
      } catch (error) {
        if (listEl) {
          listEl.innerHTML = '<p class="rounded-xl bg-rose-50 px-3 py-3 text-sm text-rose-700">데이터를 불러오지 못했습니다. 잠시 후 다시 시도해 주세요.</p>';
        }
      }
    };

    const setRegion = (region) => {
      selectedRegion = region;
      if (selectedRegionEl) selectedRegionEl.textContent = region;
      if (regionInputEl instanceof HTMLInputElement) regionInputEl.value = region === '전체' ? '' : region;
      render();
    };

    const nearestRegion = (lat, lng) => {
      const entries = Object.entries(REGION_COORD);
      let best = '서울';
      let bestDist = Number.POSITIVE_INFINITY;
      entries.forEach(([name, c]) => {
        const d = (lat - c.lat) ** 2 + (lng - c.lng) ** 2;
        if (d < bestDist) {
          bestDist = d;
          best = name;
        }
      });
      return best;
    };

    document.querySelectorAll('[data-region]').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!(btn instanceof HTMLButtonElement)) return;
        const region = btn.dataset.region;
        if (region) setRegion(region);
      });
    });
    document.getElementById('region-all')?.addEventListener('click', () => setRegion('전체'));

    listEl?.addEventListener('click', async (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      const act = target.dataset.act;
      const id = target.dataset.id;
      if (!act || !id) return;

      const item = state.vendors.find((v) => v.id === id);
      if (!item) return;

      if (act === 'up' || act === 'down') {
        if (votedIds.has(id) || !supabase) return;
        const deviceHash = hashDevice(ensureDeviceId());
        const voteType = act === 'up' ? 'up' : 'down';
        const { data, error } = await supabase.rpc('submit_fishbread_vote', {
          p_report_id: id,
          p_vote_type: voteType,
          p_device_hash: deviceHash
        });
        if (error) {
          const msg = `${error.message || ''}`.toLowerCase();
          if (msg.includes('up_count') && msg.includes('ambiguous')) {
            alert('투표 SQL 함수가 구버전입니다. Supabase SQL Editor에서 sql/fishbread_vote_patch.sql 을 다시 전체 실행해 주세요.');
          } else if (msg.includes('submit_fishbread_vote') || msg.includes('function')) {
            alert('투표 기능 SQL이 누락되었습니다. sql/fishbread_vote_patch.sql 을 Supabase SQL Editor에서 실행해 주세요.');
          } else {
            alert(`투표 처리 실패: ${error.message}`);
          }
          return;
        }
        const result = Array.isArray(data) ? data[0] : data;
        if (!result?.applied) {
          votedIds.add(id);
          saveVotedIds();
          render();
          alert('이미 투표한 제보입니다.');
          return;
        }
        item.up = Number(result.up_count || item.up);
        item.down = Number(result.down_count || item.down);
        votedIds.add(id);
        saveVotedIds();
        render();
        return;
      }
      if (act === 'delete') {
        if (!supabase || !isAdmin()) return;
        const ok = window.confirm('이 제보를 삭제할까요?');
        if (!ok) return;
        const { error } = await supabase.from('fishbread_reports').delete().eq('id', id);
        if (error) {
          alert(`삭제 실패: ${error.message}`);
          return;
        }
        await reloadAll();
        return;
      }

      if (act === 'comment') {
        const input = listEl.querySelector(`input[data-input="comment"][data-id="${id}"]`);
        if (input instanceof HTMLInputElement) {
          const text = input.value.trim();
          if (text && supabase) {
            let { error } = await supabase.from('fishbread_comments').insert({
              report_id: id,
              body: text,
              status: 'approved'
            });
            if (error) {
              const fallback = await supabase.from('fishbread_comments').insert({
                report_id: id,
                body: text,
                status: 'pending'
              });
              error = fallback.error;
              if (!error) {
                input.value = '';
                alert('댓글 등록 완료 (현재 DB 정책상 승인대기).');
                return;
              }
            }
            if (error) {
              alert(`댓글 등록 실패: ${error.message}`);
              return;
            }
            input.value = '';
            alert('댓글이 등록되었습니다.');
          }
        }
      }
    });

    addBtn?.addEventListener('click', async () => {
      const name = nameEl instanceof HTMLInputElement ? nameEl.value.trim() : '';
      const region = regionInputEl instanceof HTMLInputElement ? regionInputEl.value.trim() : '';
      const flavor = flavorEl instanceof HTMLInputElement ? flavorEl.value.trim() : '';
      const detail = detailEl instanceof HTMLInputElement ? detailEl.value.trim() : '';
      if (!name || !region) return;
      if (!(typeof selectedLat === 'number' && typeof selectedLng === 'number')) return;
      if (!supabase) return;
      let { error } = await supabase.from('fishbread_reports').insert({
        name,
        region,
        flavor: flavor || '팥',
        detail,
        lat: selectedLat,
        lng: selectedLng,
        status: 'approved'
      });
      if (error) {
        const fallback = await supabase.from('fishbread_reports').insert({
          name,
          region,
          flavor: flavor || '팥',
          detail,
          lat: selectedLat,
          lng: selectedLng,
          status: 'pending'
        });
        error = fallback.error;
        if (!error) {
          if (nameEl instanceof HTMLInputElement) nameEl.value = '';
          if (flavorEl instanceof HTMLInputElement) flavorEl.value = '';
          if (detailEl instanceof HTMLInputElement) detailEl.value = '';
          if (latlngEl instanceof HTMLInputElement) latlngEl.value = '';
          selectedLat = null;
          selectedLng = null;
          updateAddButtonState();
          alert('제보 등록 완료 (현재 DB 정책상 승인대기).');
          return;
        }
      }
      if (error) {
        alert(`제보 등록 실패: ${error.message}`);
        return;
      }

      if (nameEl instanceof HTMLInputElement) nameEl.value = '';
      if (flavorEl instanceof HTMLInputElement) flavorEl.value = '';
      if (detailEl instanceof HTMLInputElement) detailEl.value = '';
      if (latlngEl instanceof HTMLInputElement) latlngEl.value = '';
      selectedLat = null;
      selectedLng = null;
      updateAddButtonState();
      alert('제보가 등록되었습니다.');
      await reloadAll();
    });

    searchEl?.addEventListener('input', render);
    adminDockEl?.addEventListener('click', () => {
      adminShellEl?.classList.toggle('hidden');
    });
    adminToggleEl?.addEventListener('click', () => {
      adminShellEl?.classList.add('hidden');
    });
    const unlockAdminPanel = () => {
      adminDockEl?.classList.remove('hidden');
      adminShellEl?.classList.add('hidden');
    };
    try {
      const params = new URLSearchParams(window.location.search);
      const unlocked = localStorage.getItem('manytool_admin_panel') === '1';
      if (params.get('admin') === '1') {
        localStorage.setItem('manytool_admin_panel', '1');
      }
      if (params.get('admin') === '0') {
        localStorage.removeItem('manytool_admin_panel');
        adminDockEl?.classList.add('hidden');
        adminShellEl?.classList.add('hidden');
      }
      if (params.get('admin') === '1' || unlocked) {
        unlockAdminPanel();
      }
    } catch {}

    adminLoginEl?.addEventListener('click', async () => {
      if (!supabase) return;
      const email = adminEmailEl instanceof HTMLInputElement ? adminEmailEl.value.trim() : '';
      const password = adminPasswordEl instanceof HTMLInputElement ? adminPasswordEl.value : '';
      if (!email || !password) return;
      const { error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) {
        alert('관리자 로그인 실패');
        return;
      }
      const { data } = await supabase.auth.getUser();
      currentUser = data?.user || null;
      await refreshAdminGranted();
      updateAdminUiState();
      await reloadAll();
    });

    adminLogoutEl?.addEventListener('click', async () => {
      if (!supabase) return;
      await supabase.auth.signOut();
      currentUser = null;
      adminGranted = false;
      updateAdminUiState();
      await reloadAll();
    });

    adminModerationEl?.addEventListener('click', async (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement) || !supabase || !isAdmin()) return;
      const action = target.dataset.admin;
      const id = target.dataset.id;
      if (!action || !id) return;

      if (action === 'approve-report') {
        await supabase
          .from('fishbread_reports')
          .update({ status: 'approved', approved_at: new Date().toISOString() })
          .eq('id', id);
      }
      if (action === 'delete-report') {
        await supabase.from('fishbread_reports').delete().eq('id', id);
      }
      if (action === 'approve-comment') {
        await supabase.from('fishbread_comments').update({ status: 'approved' }).eq('id', id);
      }
      if (action === 'delete-comment') {
        await supabase.from('fishbread_comments').delete().eq('id', id);
      }
      await reloadAll();
    });

    const boot = () => {
      initMap();
      votedIds = loadVotedIds();
      map?.on('click', (e) => {
        const { lat, lng } = e.latlng;
        selectedLat = Number(lat.toFixed(6));
        selectedLng = Number(lng.toFixed(6));
        const region = nearestRegion(selectedLat, selectedLng);
        setRegion(region);
        if (latlngEl instanceof HTMLInputElement) latlngEl.value = `${selectedLat}, ${selectedLng}`;
        updateAddButtonState();
      });
      setRegion('전체');
      updateAddButtonState();
      const syncAuth = async () => {
        if (!supabase) {
          updateAdminUiState();
          await reloadAll();
          return;
        }
        const { data } = await supabase.auth.getSession();
        currentUser = data?.session?.user || null;
        await refreshAdminGranted();
        updateAdminUiState();
        await reloadAll();
      };
      syncAuth();
      supabase?.auth.onAuthStateChange(async (_event, session) => {
        currentUser = session?.user || null;
        await refreshAdminGranted();
        updateAdminUiState();
        await reloadAll();
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  </script>

  <style>
    .map-region {
      border: 1px solid #cbd5e1;
      border-radius: 9999px;
      background: #ffffff;
      font-size: 0.75rem;
      line-height: 1;
      padding: 0.35rem 0.65rem;
    }
  </style>
</Layout>
