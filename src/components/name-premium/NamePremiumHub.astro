---
const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();
---

<section class="relative overflow-hidden bg-[#fbf5f0] text-[#2f2a28]">
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap');
  </style>

  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -left-24 top-16 h-64 w-64 rounded-full bg-[#ff709f]/18 blur-3xl"></div>
    <div class="absolute right-0 top-20 h-72 w-72 rounded-full bg-[#fff176]/25 blur-3xl"></div>
    <div class="absolute bottom-20 left-1/3 h-56 w-56 rounded-full bg-[#7fe6db]/20 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-[1180px] px-4 pb-20 pt-10 sm:px-6 lg:px-8" style="font-family: 'Be Vietnam Pro', 'Pretendard', sans-serif;">
    <nav class="rounded-full border border-white/60 bg-white/72 px-5 py-4 shadow-[0_20px_40px_rgba(48,46,43,0.06)] backdrop-blur">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="text-lg font-bold italic text-[#a7295a]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">The Ethereal Boutique</div>
        <div class="rounded-full bg-[#a7295a] px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-white">Premium Name Analysis</div>
      </div>
    </nav>

    <section class="grid gap-10 pt-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-start">
      <div>
        <p class="inline-flex rounded-full bg-[#7fe6db]/60 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.2em] text-[#005a54]">ManyTool AI Naming Hub</p>
        <h1 class="mt-6 max-w-3xl text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">
          이름풀이, 개명추천, 개명풀이를
          <span class="block text-[#a7295a] italic">한 번에 보는 프리미엄 허브</span>
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[#5f5a57] sm:text-lg">
          성명학 기반 오격과 한자 데이터를 공통 엔진으로 묶고, ManyTool AI 도사 평가까지 같은 화면에서 이어서 보여줍니다.
        </p>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          <article class="rounded-[32px] bg-[#f6f0ea] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#ff709f]/20 text-[#a7295a]">01</div>
            <h2 class="text-xl font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">실제 API 연결</h2>
            <p class="mt-3 text-sm leading-7 text-[#5f5a57]">
              이 페이지는 `name-premium/analyze`, `name-premium/recommend` API와 연결되어 실제 획수, 오격, 81수 기준으로 계산합니다.
            </p>
          </article>
          <article class="rounded-[32px] bg-[#fff7cb] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#fff176] text-[#655d00]">02</div>
            <h2 class="text-xl font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">한 서비스 흐름</h2>
            <p class="mt-3 text-sm leading-7 text-[#5f5a57]">
              이름 입력 후 곧바로 분석, 추천 6개, 추천 이름 상세 풀이까지 내려가며 확인할 수 있게 구성했습니다.
            </p>
          </article>
        </div>
      </div>

      <div class="relative">
        <div class="absolute inset-x-8 top-6 h-full rounded-[40px] bg-white/45 blur-2xl"></div>
        <section id="premium-form" class="relative rounded-[36px] bg-white/84 p-5 shadow-[0_28px_80px_rgba(48,46,43,0.08)] backdrop-blur sm:p-7">
          <div data-loading-overlay class="pointer-events-none absolute inset-0 z-20 hidden items-center justify-center rounded-[36px] bg-[#fbf5f0]/88 p-6 backdrop-blur-sm">
            <div class="w-full max-w-md rounded-[30px] bg-white px-6 py-7 text-center shadow-[0_24px_60px_rgba(48,46,43,0.12)]">
              <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#a7295a]/10">
                <div class="h-7 w-7 animate-spin rounded-full border-[3px] border-[#f0d8e2] border-t-[#a7295a]"></div>
              </div>
              <p class="mt-5 text-[11px] font-bold uppercase tracking-[0.22em] text-[#a7295a]">Premium Analysis Running</p>
              <h3 class="mt-3 text-2xl font-extrabold tracking-tight text-[#2f2a28]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-loading-title>분석 준비 중</h3>
              <p class="mt-3 text-sm leading-7 text-[#5f5a57]" data-loading-text>오격, 81수, 추천 후보와 AI 도사 평가를 순서대로 정리하고 있습니다.</p>
            </div>
          </div>
          <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(240px,0.8fr)]">
            <article class="rounded-[30px] bg-[#fdf7f3] p-5">
              <div class="mb-4 flex items-center gap-2 text-sm font-bold text-[#a7295a]">
                <span>✦</span>
                <span>정보 입력</span>
              </div>

              <div class="mb-4 rounded-[24px] border border-[#ead8d2] bg-white/75 px-4 py-4 text-sm leading-7 text-[#6d6360]">
                <p class="font-bold text-[#2f2a28]">사용법</p>
                <p class="mt-2">이름만 입력해도 시작할 수 있습니다. 한자, 생년월일, 성별은 선택사항이며 넣을수록 결과가 더 풍성해집니다.</p>
              </div>

              <p class="mb-4 text-xs leading-6 text-[#847a75]">양력·음력, 생년월일, 성별은 현재 보조 프로필 정보이며 핵심 계산은 한자 이름 기반 성명학 엔진으로 처리됩니다.</p>
              <form id="name-premium-form" class="space-y-4">
                <label class="block rounded-[24px] bg-white/88 p-4 ring-1 ring-[#b1aca8]/16">
                  <span class="mb-3 flex items-center justify-between gap-3">
                    <span class="text-sm font-bold text-[#2f2a28]">이름</span>
                    <span class="rounded-full bg-[#a7295a] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-white">필수</span>
                  </span>
                  <input name="displayName" placeholder="김민지" class="w-full rounded-[18px] border-0 bg-[#fffaf7] px-5 py-4 text-sm shadow-inner shadow-[#ead8d2]/60 outline-none ring-1 ring-[#b1aca8]/15 transition focus:bg-white focus:ring-2 focus:ring-[#a7295a]/30" />
                </label>

                <label class="block rounded-[24px] bg-white/88 p-4 ring-1 ring-[#b1aca8]/16">
                  <span class="mb-3 flex items-center justify-between gap-3">
                    <span class="text-sm font-bold text-[#2f2a28]">한자</span>
                    <span class="rounded-full bg-[#f6f0ea] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-[#7a6f6a]">선택</span>
                  </span>
                  <input name="hanjaName" placeholder="金民智" maxlength="3" class="w-full rounded-[18px] border-0 bg-[#fffaf7] px-5 py-4 text-sm shadow-inner shadow-[#ead8d2]/60 outline-none ring-1 ring-[#b1aca8]/15 transition focus:bg-white focus:ring-2 focus:ring-[#a7295a]/30" />
                  <p class="mt-3 text-xs leading-6 text-[#7a6f6a]">한자를 넣으면 오격, 81수, 개명추천, 상세 풀이까지 정밀하게 계산합니다.</p>
                </label>

                <label class="block rounded-[24px] bg-white/88 p-4 ring-1 ring-[#b1aca8]/16">
                  <span class="mb-3 flex items-center justify-between gap-3">
                    <span class="text-sm font-bold text-[#2f2a28]">생년월일</span>
                    <span class="rounded-full bg-[#f6f0ea] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-[#7a6f6a]">선택</span>
                  </span>
                  <input name="birthDate" type="date" class="w-full rounded-[18px] border-0 bg-[#fffaf7] px-5 py-4 text-sm shadow-inner shadow-[#ead8d2]/60 outline-none ring-1 ring-[#b1aca8]/15 transition focus:bg-white focus:ring-2 focus:ring-[#a7295a]/30" />
                </label>

                <div class="grid gap-4 sm:grid-cols-2">
                  <div class="rounded-[24px] bg-white/88 p-4 ring-1 ring-[#b1aca8]/16">
                    <div class="mb-3 flex items-center justify-between gap-3">
                      <span class="text-sm font-bold text-[#2f2a28]">양력 / 음력</span>
                      <span class="rounded-full bg-[#f6f0ea] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-[#7a6f6a]">선택</span>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                      <label class="cursor-pointer">
                        <input type="radio" name="calendarType" value="solar" class="peer sr-only" checked />
                        <span class="flex items-center justify-center rounded-[18px] bg-[#fffaf7] px-4 py-4 text-sm font-semibold text-[#5f5a57] ring-1 ring-[#b1aca8]/15 transition peer-checked:bg-[#7fe6db] peer-checked:text-[#003e39] peer-checked:ring-0">양력</span>
                      </label>
                      <label class="cursor-pointer">
                        <input type="radio" name="calendarType" value="lunar" class="peer sr-only" />
                        <span class="flex items-center justify-center rounded-[18px] bg-[#fffaf7] px-4 py-4 text-sm font-semibold text-[#5f5a57] ring-1 ring-[#b1aca8]/15 transition peer-checked:bg-[#7fe6db] peer-checked:text-[#003e39] peer-checked:ring-0">음력</span>
                      </label>
                    </div>
                  </div>

                  <div class="rounded-[24px] bg-white/88 p-4 ring-1 ring-[#b1aca8]/16">
                    <div class="mb-3 flex items-center justify-between gap-3">
                      <span class="text-sm font-bold text-[#2f2a28]">성별</span>
                      <span class="rounded-full bg-[#f6f0ea] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-[#7a6f6a]">선택</span>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                      <label class="cursor-pointer">
                        <input type="radio" name="gender" value="female" class="peer sr-only" checked />
                        <span class="flex items-center justify-center rounded-[18px] bg-[#fffaf7] px-4 py-4 text-sm font-semibold text-[#5f5a57] ring-1 ring-[#b1aca8]/15 transition peer-checked:bg-[#a7295a] peer-checked:text-white peer-checked:ring-0">여성</span>
                      </label>
                      <label class="cursor-pointer">
                        <input type="radio" name="gender" value="male" class="peer sr-only" />
                        <span class="flex items-center justify-center rounded-[18px] bg-[#fffaf7] px-4 py-4 text-sm font-semibold text-[#5f5a57] ring-1 ring-[#b1aca8]/15 transition peer-checked:bg-[#a7295a] peer-checked:text-white peer-checked:ring-0">남성</span>
                      </label>
                    </div>
                  </div>
                </div>

                <button type="button" data-action="suite" class="w-full rounded-[22px] bg-[linear-gradient(135deg,#a7295a,#c83b74)] px-4 py-4 text-sm font-bold text-white shadow-[0_20px_35px_rgba(167,41,90,0.26)] transition hover:-translate-y-0.5 hover:shadow-[0_24px_40px_rgba(167,41,90,0.3)] disabled:translate-y-0 disabled:cursor-wait disabled:opacity-60">
                  통합 분석 시작
                </button>
              </form>
            </article>

            <article class="space-y-4">
              <div class="rounded-[30px] bg-[#fffdfb] p-5 shadow-inner shadow-[#f1e6df]/70">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">Current Analysis</p>
                <h2 class="mt-4 text-4xl font-extrabold tracking-tight" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-current-name>이름 입력 대기</h2>
                <p class="mt-2 text-sm text-[#5f5a57]" data-current-hanja>(한자 입력 대기)</p>

                <div class="mt-6 rounded-[24px] bg-[#7fe6db]/30 px-5 py-4">
                  <div class="flex items-center justify-between gap-3">
                    <div>
                      <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-[#005a54]">Harmony Score</p>
                      <p class="mt-2 text-4xl font-extrabold text-[#005a54]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-current-score>--</p>
                    </div>
                    <div class="rounded-full bg-white px-4 py-2 text-xs font-bold text-[#005a54]" data-current-grade>입력 대기</div>
                  </div>
                </div>

                <div class="mt-6 space-y-3">
                  <div class="rounded-[22px] bg-[#f6f0ea] p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#5f5a57]">현재 진행</p>
                    <p class="mt-2 text-sm leading-7 text-[#5f5a57]" data-current-summary>버튼을 누르면 이름풀이, 개명추천, 개명풀이 결과가 아래에 순서대로 채워집니다.</p>
                  </div>
                  <div class="rounded-[22px] bg-[#fff7cb] p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#655d00]">AI 도사 평가</p>
                    <p class="mt-2 text-sm leading-7 text-[#5f5a57]" data-dosa-evaluation>이름을 입력하면 ManyTool AI 도사가 현재 이름의 첫인상과 구조 평가를 같이 정리합니다.</p>
                  </div>
                </div>
              </div>

              <div class="rounded-[30px] bg-[#302e2b] p-5 text-white shadow-[0_20px_40px_rgba(48,46,43,0.1)]">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#f6d672]">연결 상태</p>
                <ul class="mt-4 space-y-2 text-sm leading-7 text-white/78">
                  <li>API: `name-premium/analyze`, `name-premium/recommend` 실제 사용</li>
                  <li>엔진: 획수, 오격, 81수, 한자 메타 기반</li>
                  <li>성명학: 현재 단성 기준 MVP, 사주급 확장은 다음 단계</li>
                </ul>
                <div class="mt-4 rounded-[20px] bg-white/8 px-4 py-4 text-xs leading-6 text-white/70">
                  선택 입력값은 현재 결과 설명과 향후 사주 연동 확장용으로 쓰이며, 추천 점수 자체는 성씨/이름 한자 획수와 81수 기준으로 계산됩니다.
                </div>
              </div>
            </article>
          </div>
        </section>
      </div>
    </section>

    <section class="mt-14">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
        <section class="rounded-[36px] bg-[#f6f0ea] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.05)]">
          <div data-panel="analysis">
            <div class="grid gap-5 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
              <article class="rounded-[28px] bg-white p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">이름풀이</p>
                <h3 class="mt-3 text-3xl font-extrabold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-analysis-name>분석 결과 대기</h3>
                <p class="mt-3 text-sm leading-7 text-[#5f5a57]" data-analysis-explanation>통합 분석을 누르면 오격과 81수 기준의 이름풀이가 여기에 표시됩니다.</p>
              </article>
              <article class="rounded-[28px] bg-[#ede7e2] p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#5f5a57]">오격 상세</p>
                <div class="mt-4 grid gap-3 sm:grid-cols-2" data-analysis-grid>
                  <div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5f5a57]">천격, 인격, 지격, 외격, 총격 결과가 여기에 채워집니다.</div>
                </div>
              </article>
            </div>
          </div>

          <div data-panel="recommendation" class="mt-6">
            <div class="mb-4 flex items-center justify-between gap-3">
              <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#005a54]">개명추천 6선</p>
              <p class="text-xs text-[#6d6360]">추천 이유와 한자 풀이를 같이 제공합니다.</p>
            </div>
            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-recommend-list>
              <article class="rounded-[28px] bg-white p-6 text-sm text-[#5f5a57]">통합 분석을 시작하면 개명 후보 카드가 여기에 채워집니다.</article>
            </div>
          </div>

          <div data-panel="report" class="mt-6">
            <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)]">
              <article class="rounded-[28px] bg-white p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">개명풀이</p>
                <h3 class="mt-3 text-3xl font-extrabold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-report-name>상세 풀이 대기</h3>
                <p class="mt-3 text-sm leading-7 text-[#5f5a57]" data-report-explanation>분석된 이름 또는 추천 후보 기준의 상세 풀이가 여기에 표시됩니다.</p>
              </article>
              <article class="rounded-[28px] bg-[#fff7cb] p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#655d00]">한자 해석</p>
                <div class="mt-4 space-y-3" data-report-points>
                  <div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5f5a57]">각 글자의 뜻, 획수, 키워드가 여기서 정리됩니다.</div>
                </div>
              </article>
            </div>
          </div>
        </section>

        <aside class="space-y-6">
          <section class="overflow-hidden rounded-[32px] bg-white shadow-[0_20px_40px_rgba(48,46,43,0.05)]">
            <div class="grid min-h-[220px] gap-0 md:grid-cols-[1.2fr_0.8fr]">
              <div class="flex flex-col justify-end bg-[linear-gradient(135deg,rgba(255,112,159,0.14),rgba(255,241,118,0.2))] p-6">
                <div class="rounded-[24px] bg-[#302e2b]/78 p-5 text-white backdrop-blur">
                  <p class="text-sm font-bold">프리미엄 이름 서비스</p>
                  <p class="mt-2 text-sm leading-7 text-white/75">이름풀이에서 멈추지 않고, 개명추천 6개와 추천 이유, 후보 상세 풀이까지 한 서비스 안에서 이어집니다.</p>
                </div>
              </div>
              <div class="flex items-center justify-center bg-[#fff7cb] p-6">
                <div class="space-y-3 text-center">
                  <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#fff176] text-[#655d00]">名</div>
                  <p class="text-lg font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">성명학 배치 사전</p>
                  <p class="text-sm leading-7 text-[#5f5a57]">MVP 단계지만 실제 오격과 한자 데이터 기반으로 일관된 기준을 유지합니다.</p>
                </div>
              </div>
            </div>
          </section>

          <section class="rounded-[32px] bg-[#a7295a] px-7 py-8 text-white shadow-[0_20px_40px_rgba(48,46,43,0.08)]">
            <h3 class="text-3xl font-extrabold tracking-tight" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">Need a deeper aura?</h3>
            <p class="mt-4 text-sm leading-7 text-white/80">지금은 성명학 중심 허브입니다. 다음 단계로 사주 부족 오행 보완형 추천을 붙이면 더 강한 프리미엄 서비스로 확장할 수 있습니다.</p>
            <a href="/ai-manseryeok" class="mt-6 inline-flex rounded-full bg-white px-5 py-3 text-sm font-bold text-[#a7295a] transition hover:scale-[0.98]">사주 결과와 연결하기</a>
          </section>
        </aside>
      </div>
    </section>
  </div>
</section>

<script is:inline define:vars={{ rawApiBase }}>
  const API_BASE = (rawApiBase || (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost' ? 'http://127.0.0.1:8787' : '')).replace(/\/+$/, '');
  const form = document.getElementById('name-premium-form');
  const actionButton = document.querySelector('[data-action="suite"]');
  const currentNameEl = document.querySelector('[data-current-name]');
  const currentHanjaEl = document.querySelector('[data-current-hanja]');
  const currentScoreEl = document.querySelector('[data-current-score]');
  const currentGradeEl = document.querySelector('[data-current-grade]');
  const currentSummaryEl = document.querySelector('[data-current-summary]');
  const dosaEvaluationEl = document.querySelector('[data-dosa-evaluation]');
  const loadingOverlayEl = document.querySelector('[data-loading-overlay]');
  const loadingTitleEl = document.querySelector('[data-loading-title]');
  const loadingTextEl = document.querySelector('[data-loading-text]');
  const analysisNameEl = document.querySelector('[data-analysis-name]');
  const analysisExplanationEl = document.querySelector('[data-analysis-explanation]');
  const analysisGridEl = document.querySelector('[data-analysis-grid]');
  const recommendListEl = document.querySelector('[data-recommend-list]');
  const reportNameEl = document.querySelector('[data-report-name]');
  const reportExplanationEl = document.querySelector('[data-report-explanation]');
  const reportPointsEl = document.querySelector('[data-report-points]');

  const panelTitleMap = {
    heaven: '천격',
    human: '인격',
    earth: '지격',
    outer: '외격',
    total: '총격'
  };

  const setLoading = (isLoading, label = '분석 중') => {
    if (!actionButton) return;
    actionButton.disabled = isLoading;
    actionButton.textContent = isLoading ? `${label}...` : '통합 분석 시작';
    if (loadingOverlayEl) {
      loadingOverlayEl.classList.toggle('hidden', !isLoading);
      loadingOverlayEl.classList.toggle('flex', isLoading);
    }
    if (loadingTitleEl) loadingTitleEl.textContent = isLoading ? label : '분석 준비 중';
    if (loadingTextEl) {
      loadingTextEl.textContent = label.includes('추천')
        ? '이름 후보 6개를 점수순으로 정렬하고 추천 이유와 한자 풀이를 정리하고 있습니다.'
        : '오격, 81수, 현재 이름 설명과 ManyTool AI 도사 평가를 계산하고 있습니다.';
    }
  };

  const setCurrentSummary = (score, grade, explanation) => {
    if (currentScoreEl) currentScoreEl.textContent = score == null ? '--' : String(score);
    if (currentGradeEl) currentGradeEl.textContent = grade || '입력 대기';
    if (currentSummaryEl) currentSummaryEl.textContent = explanation || '결과가 여기에 표시됩니다.';
  };

  const getFormPayload = () => {
    const formData = new FormData(form);
    const displayName = String(formData.get('displayName') || '').trim();
    const hanjaName = String(formData.get('hanjaName') || '').trim().replace(/\s+/g, '');
    const surname = hanjaName.slice(0, 1);
    const given = hanjaName.slice(1).split('').filter(Boolean);
    const birthDate = String(formData.get('birthDate') || '').trim();
    const gender = String(formData.get('gender') || '').trim();
    const calendarType = String(formData.get('calendarType') || 'solar').trim();

    if (currentNameEl) currentNameEl.textContent = displayName || '이름 입력 대기';
    if (currentHanjaEl) currentHanjaEl.textContent = hanjaName ? `(${hanjaName})` : '(한자 입력 대기)';

    return { displayName, hanjaName, surname, given, birthDate, gender, calendarType };
  };

  const buildDosaEvaluation = ({ score, grade, keywords = '', displayName = '' }) => {
    if (score == null) {
      return '입력 후 ManyTool AI 도사가 이름의 분위기와 구조 평가를 같이 정리합니다.';
    }

    const tone = score >= 60
      ? '전체 흐름이 안정적으로 정리된 이름입니다.'
      : score >= 20
        ? '무난한 균형 위에 강점이 보이는 이름입니다.'
        : '구조상 보완 포인트를 함께 보는 편이 좋습니다.';

    const keywordText = keywords ? ` 핵심 인상은 ${keywords} 쪽으로 읽힙니다.` : '';
    const subject = displayName || '현재 이름';
    return `ManyTool AI 도사 기준으로 ${subject}는 ${grade} 흐름으로 분류됩니다. ${tone}${keywordText}`;
  };

  const renderAnalysis = (payload, formPayload) => {
    if (analysisNameEl) analysisNameEl.textContent = payload.input ? `${payload.input.surname}${(payload.input.given || []).join('')}` : '분석 결과';
    if (analysisExplanationEl) analysisExplanationEl.textContent = payload.explanation || '설명이 없습니다.';
    if (analysisGridEl) {
      analysisGridEl.innerHTML = (payload.details || []).map((detail) => `
        <div class="rounded-[22px] bg-white px-4 py-4">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#a7295a]">${panelTitleMap[detail.slot] || detail.slot}</p>
          <p class="mt-2 text-2xl font-extrabold text-[#302e2b]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${detail.number}</p>
          <p class="mt-1 text-sm font-semibold text-[#5f5a57]">${detail.grade}</p>
          <p class="mt-2 text-xs leading-6 text-[#5f5a57]">${detail.summary}</p>
        </div>
      `).join('');
    }

    const combinedKeywords = (payload.parts || [])
      .map((part) => part.meta?.keywords)
      .filter(Boolean)
      .join(', ');

    if (dosaEvaluationEl) {
      dosaEvaluationEl.textContent = buildDosaEvaluation({
        score: payload.score,
        grade: payload.grade,
        keywords: combinedKeywords,
        displayName: formPayload.displayName
      });
    }

    setCurrentSummary(payload.score, payload.grade, payload.explanation);
  };

  const buildRecommendationReason = (item) => {
    const keywordText = item.keywords ? `키워드 ${item.keywords}` : '추천 키워드 보강 중';
    return `${item.grade} 점수 흐름이고, ${keywordText} 방향이 좋아 추천 후보로 올렸습니다.`;
  };

  const buildPartsSummary = (parts) =>
    (parts || [])
      .map((part) => `${part.hanja} ${part.meta?.meaning || '뜻 보강 중'}`)
      .join(' · ');

  const renderRecommendations = (payload) => {
    if (!recommendListEl) return;
    recommendListEl.innerHTML = (payload.recommendations || []).map((item, index) => `
      <article class="rounded-[28px] bg-white p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#a7295a]">Top ${index + 1}</p>
            <h3 class="mt-3 text-4xl font-extrabold text-[#a7295a]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${item.given.join(' ')}</h3>
            <p class="mt-1 text-lg text-[#5f5a57]">${item.name}</p>
          </div>
          <div class="rounded-full bg-[#f6f0ea] px-4 py-2 text-[10px] font-bold uppercase tracking-[0.15em] text-[#5f5a57]">${item.grade}</div>
        </div>
        <div class="mt-5 space-y-3 text-sm leading-7 text-[#5f5a57]">
          <p><span class="font-bold text-[#2f2a28]">추천 이유</span><br />${buildRecommendationReason(item)}</p>
          <p><span class="font-bold text-[#2f2a28]">한자 풀이</span><br />${buildPartsSummary(item.parts)}</p>
        </div>
        <div class="mt-5 flex items-center justify-between border-t border-[#b1aca8]/15 pt-4 text-sm font-bold text-[#a7295a]">
          <span>Score ${item.score}</span>
          <button type="button" class="rounded-full border border-[#a7295a]/15 px-3 py-1 text-xs" data-use-recommend='${JSON.stringify(item.given)}'>이 이름으로 풀이</button>
        </div>
      </article>
    `).join('');

    recommendListEl.querySelectorAll('[data-use-recommend]').forEach((button) => {
      button.addEventListener('click', async () => {
        const given = JSON.parse(button.getAttribute('data-use-recommend') || '[]');
        const hanjaInput = form?.querySelector('[name="hanjaName"]');
        const current = getFormPayload();
        if (hanjaInput) hanjaInput.value = `${current.surname}${given.join('')}`;
        await runAnalysis();
        document.querySelector('[data-panel="report"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  };

  const renderReport = (payload) => {
    if (reportNameEl) reportNameEl.textContent = payload.input ? `${payload.input.surname}${(payload.input.given || []).join('')}` : '상세 풀이';
    if (reportExplanationEl) reportExplanationEl.textContent = payload.explanation || '설명이 없습니다.';
    if (reportPointsEl) {
      reportPointsEl.innerHTML = (payload.parts || []).map((part) => `
        <div class="rounded-[22px] bg-white px-4 py-4">
          <p class="text-lg font-extrabold text-[#302e2b]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${part.hanja}</p>
          <p class="mt-2 text-sm text-[#5f5a57]">${part.meta?.reading || '-'} · ${part.meta?.meaning || '뜻 정보 없음'} · ${part.strokes || '-'}획</p>
          <p class="mt-2 text-xs leading-6 text-[#5f5a57]">${part.meta?.keywords || '키워드 정보 없음'}</p>
        </div>
      `).join('');
    }
    setCurrentSummary(payload.score, payload.grade, payload.explanation);
  };

  const renderNameOnlyState = (formPayload) => {
    if (analysisNameEl) analysisNameEl.textContent = formPayload.displayName;
    if (analysisExplanationEl) {
      analysisExplanationEl.textContent = '이름만 입력된 상태입니다. 한자를 넣으면 성명학 기반 오격과 획수 해석까지 이어집니다.';
    }
    if (analysisGridEl) {
      analysisGridEl.innerHTML = '<div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5f5a57]">한자를 입력하면 오격 계산과 81수 해석이 여기에 표시됩니다.</div>';
    }
    if (reportNameEl) reportNameEl.textContent = formPayload.displayName;
    if (reportExplanationEl) {
      reportExplanationEl.textContent = '한자가 없어서 개명풀이 상세는 아직 계산하지 않았습니다.';
    }
    if (reportPointsEl) {
      reportPointsEl.innerHTML = '<div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5f5a57]">한자를 입력하면 각 글자의 뜻, 획수, 키워드가 정리됩니다.</div>';
    }
    if (recommendListEl) {
      recommendListEl.innerHTML = '<article class="rounded-[28px] bg-white p-6 text-sm leading-7 text-[#5f5a57]">이름은 입력됐습니다. 개명추천은 한자 입력 후 시작됩니다.</article>';
    }
    if (dosaEvaluationEl) {
      dosaEvaluationEl.textContent = `ManyTool AI 도사 기준으로 ${formPayload.displayName}는 아직 한자 구조가 없어 분위기형 평가만 가능합니다. 한자를 추가하면 더 깊게 읽어드립니다.`;
    }
    setCurrentSummary(null, '기본 입력 완료', '이름은 저장됐습니다. 한자를 추가하면 이름풀이, 개명추천, 개명풀이가 모두 활성화됩니다.');
  };

  const runAnalysis = async () => {
    if (!API_BASE) {
      setCurrentSummary(null, 'API 없음', 'PUBLIC_NODE_API_BASE가 설정되지 않았습니다.');
      return null;
    }

    const formPayload = getFormPayload();
    const { displayName, hanjaName, surname, given } = formPayload;

    if (!displayName) {
      setCurrentSummary(null, '입력 필요', '이름은 필수입니다. 이름을 먼저 입력해 주세요.');
      return null;
    }

    if (!surname || given.length === 0) {
      renderNameOnlyState(formPayload);
      return null;
    }

    if (currentNameEl && displayName) currentNameEl.textContent = displayName;
    if (currentHanjaEl) currentHanjaEl.textContent = `(${hanjaName})`;
    setCurrentSummary(null, '분석 중', '공통 계산 엔진 기준으로 이름풀이를 계산하고 있습니다.');

    const response = await fetch(`${API_BASE}/name-premium/analyze`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ surname, given })
    });
    const payload = await response.json().catch(() => null);
    if (!response.ok || !payload) {
      throw new Error(payload?.error || '분석에 실패했습니다.');
    }

    renderAnalysis(payload, formPayload);
    renderReport(payload);
    return payload;
  };

  const runRecommend = async () => {
    if (!API_BASE) {
      setCurrentSummary(null, 'API 없음', 'PUBLIC_NODE_API_BASE가 설정되지 않았습니다.');
      return null;
    }

    const { displayName, surname } = getFormPayload();
    if (!surname) {
      setCurrentSummary(null, '추천 대기', '개명추천은 한자 입력 후에 시작됩니다.');
      return null;
    }

    if (currentNameEl && displayName) currentNameEl.textContent = displayName;
    setCurrentSummary(null, '추천 중', '현재 구조 기준으로 개명추천 6개를 정리하고 있습니다.');

    const response = await fetch(`${API_BASE}/name-premium/recommend`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ surname, givenLength: 2, topK: 6 })
    });
    const payload = await response.json().catch(() => null);
    if (!response.ok || !payload) {
      throw new Error(payload?.error || '추천에 실패했습니다.');
    }

    renderRecommendations(payload);
    if (payload.recommendations?.[0]) {
      setCurrentSummary(payload.recommendations[0].score, payload.recommendations[0].grade, '이름풀이 아래에서 개명추천 6개와 상세 풀이까지 이어서 확인할 수 있습니다.');
    }
    return payload;
  };

  const runSuite = async () => {
    try {
      setLoading(true, '분석 중');
      await runAnalysis();
      setLoading(true, '추천 중');
      await runRecommend();
      document.querySelector('[data-panel="analysis"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (error) {
      setCurrentSummary(null, '오류', error instanceof Error ? error.message : '처리 중 오류가 발생했습니다.');
    } finally {
      setLoading(false);
    }
  };

  document.querySelectorAll('[data-action="suite"]').forEach((button) => {
    button.addEventListener('click', runSuite);
  });
</script>
