---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | FunHub" description="광고, 제휴, 콘텐츠 협업 문의">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">광고 및 제휴 문의</h1>
    <p class="mt-3 text-slate-700">광고 집행, 제휴, 콘텐츠 협업은 아래 이메일로 문의해 주세요.</p>
    <p class="mt-2 text-slate-800">Email: contact@funhub.example</p>
    <p class="mt-2 text-sm text-slate-500">보통 영업일 기준 1~3일 내 회신합니다.</p>
  </main>
  <Footer />
</Layout>
