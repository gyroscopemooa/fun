---
import { createTranslator, detectLocale, stripLocale, withLocalePath } from '../lib/i18n';

const pathname = Astro.url.pathname;
const locale = detectLocale(pathname);
const strippedPath = stripLocale(pathname);
const t = await createTranslator(locale);

const navItems = [
  { href: '/', label: t('common.home') },
  { href: '/today-fortune', label: t('header.fortune') },
  { href: '/pinball', label: t('header.game') },
  { href: '/maps/fishbread', label: t('header.fishbreadMap') },
  { href: '/contact', label: t('header.contact') }
];

const langLinks = [
  { code: 'ko', href: `${strippedPath}`.replace(/\/{2,}/g, '/') || '/' },
  { code: 'en', href: `/en${strippedPath}`.replace(/\/{2,}/g, '/') || '/en' },
  { code: 'ja', href: `/ja${strippedPath}`.replace(/\/{2,}/g, '/') || '/ja' }
];
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href={withLocalePath(locale, '/')} class="text-xl font-bold tracking-tight">ManyTool</a>
    <div class="flex items-center gap-2">
      <nav class="hidden items-center gap-2 text-sm md:flex">
        {navItems.map((item) => (
          <a class="rounded-md px-2 py-1 whitespace-nowrap hover:bg-slate-100" href={withLocalePath(locale, item.href)}>{item.label}</a>
        ))}
      </nav>
      <div class="flex items-center gap-1 rounded-md border border-slate-200 p-1 text-xs">
        {langLinks.map((lang) => (
          <a
            href={lang.href}
            class:list={[
              'rounded px-2 py-1 font-semibold uppercase',
              lang.code === locale ? 'bg-slate-900 text-white' : 'text-slate-600 hover:bg-slate-100'
            ]}
          >
            {lang.code}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>
