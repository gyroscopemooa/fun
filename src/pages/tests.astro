---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="온라인 테스트 모음 | ManyTool" description="MBTI, 동물상, 궁합 등 테스트 카테고리 페이지입니다.">
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-8">
    <h1 class="text-3xl font-black">테스트 카테고리</h1>
    <p class="mt-3 text-slate-700">MBTI, 동물상, 퍼스널컬러, 궁합 테스트를 한 곳에서 제공합니다.</p>
    <section class="mt-6 rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-bold">추천 테스트</h2>
      <ul class="mt-3 list-disc space-y-1 pl-5 text-slate-700">
        <li><a href="/mbti-test" class="underline">MBTI 테스트</a></li>
        <li><a href="/animal-test" class="underline">동물상 테스트</a></li>
        <li><a href="/love-compatibility" class="underline">연애 궁합 테스트</a></li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
