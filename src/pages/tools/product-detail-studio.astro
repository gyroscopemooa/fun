---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ProductDetailStudio from '../../components/home/ProductDetailStudio';
import Layout from '../../layouts/Layout.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const copy = {
  ko: {
    title: '상세페이지 생성기 | ManyTool',
    description: '상품 사진과 프롬프트를 바탕으로 AI 상세페이지 카피와 HTML 초안을 생성합니다.',
    heading: '상세페이지 생성기',
    body: '상품 정보, 프롬프트, 업로드한 이미지를 바탕으로 헤드라인, 상품 설명, SEO 문구, 복사용 HTML까지 한 번에 생성합니다.'
  },
  en: {
    title: 'Product Detail Studio | ManyTool',
    description: 'Generate AI-powered product detail copy and exportable HTML from uploaded product images.',
    heading: 'Product Detail Studio',
    body: 'Upload product photos, add product info and prompting instructions, then generate structured copy, preview sections, and export-ready HTML.'
  },
  ja: {
    title: '商品詳細ページ生成 | ManyTool',
    description: '商品写真とプロンプトをもとに、AIで商品詳細ページのコピーとHTML下書きを生成します。',
    heading: '商品詳細ページ生成',
    body: '商品情報、プロンプト、アップロード画像を使って、見出し、説明文、SEO文言、貼り付け用HTMLまでまとめて生成します。'
  }
}[locale];
---

<Layout title={copy.title} description={copy.description}>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8">
    <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <h1 class="text-3xl font-black tracking-tight text-slate-900">{copy.heading}</h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600">{copy.body}</p>
    </section>

    <ProductDetailStudio client:load />
  </main>
  <Footer />
</Layout>
