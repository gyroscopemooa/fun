---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSense from '../../components/AdSense.astro';
import Recommend from '../../components/Recommend.astro';
---

<Layout title="붕어빵 위치 지도 | FunHub" description="붕어빵 제보/추천/비추천/댓글 기반 커뮤니티 지도 페이지">
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-2xl font-bold">전국 붕어빵 위치 제보</h1>
    <p class="mt-2 text-slate-700">겨울 시즌에 사용자 제보를 모아 추천/비추천으로 정보 정확도를 관리합니다.</p>

    <AdSense slotName="본문 상단" />

    <section class="mt-6 rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="text-lg font-bold">새 제보 등록</h2>
      <div class="mt-3 grid gap-3 md:grid-cols-2">
        <input id="spot-name" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="가게명 (예: OO붕어빵)" type="text" />
        <input id="spot-region" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="지역 (예: 서울 강남구)" type="text" />
      </div>
      <textarea id="spot-note" class="mt-3 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="메뉴/가격/영업시간 메모" rows="3"></textarea>
      <button id="spot-add" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">제보 추가</button>
    </section>

    <section class="mt-6">
      <h2 class="text-lg font-bold">제보 목록</h2>
      <p class="mt-1 text-sm text-slate-500">추천이 많고 비추천이 적은 순서로 정렬됩니다.</p>
      <div id="spot-list" class="mt-3 space-y-3"></div>
    </section>

    <AdSense slotName="본문 중간" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline>
    const KEY = 'funhub_fishbread_spots_v1';

    const seed = [
      {
        id: 'seed-1',
        name: '강남역 3번출구 붕어빵',
        region: '서울 강남구',
        note: '팥/슈크림, 저녁 시간대 인기',
        up: 6,
        down: 1,
        comments: ['저녁 7시 이후 줄 생김', '슈크림 맛있음']
      },
      {
        id: 'seed-2',
        name: '부산 서면 포장마차 붕어빵',
        region: '부산 부산진구',
        note: '팥 위주, 가격 저렴',
        up: 4,
        down: 0,
        comments: ['주말에도 운영', '따뜻해서 좋아요']
      }
    ];

    const load = () => {
      const raw = localStorage.getItem(KEY);
      if (!raw) {
        localStorage.setItem(KEY, JSON.stringify(seed));
        return [...seed];
      }
      try {
        return JSON.parse(raw);
      } catch {
        localStorage.setItem(KEY, JSON.stringify(seed));
        return [...seed];
      }
    };

    const save = (data) => localStorage.setItem(KEY, JSON.stringify(data));

    const listEl = document.getElementById('spot-list');
    const addBtn = document.getElementById('spot-add');
    const nameEl = document.getElementById('spot-name');
    const regionEl = document.getElementById('spot-region');
    const noteEl = document.getElementById('spot-note');

    let spots = load();

    const score = (s) => s.up - s.down;

    const render = () => {
      const sorted = [...spots].sort((a, b) => score(b) - score(a));

      if (!listEl) return;
      listEl.innerHTML = sorted
        .map(
          (s) => `
          <article class="rounded-xl border border-slate-200 bg-white p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-base font-bold">${s.name}</h3>
                <p class="text-sm text-slate-600">${s.region}</p>
                <p class="mt-1 text-sm text-slate-700">${s.note}</p>
              </div>
              <p class="rounded-md bg-slate-100 px-2 py-1 text-xs">신뢰점수 ${score(s)}</p>
            </div>

            <div class="mt-3 flex flex-wrap gap-2">
              <button data-act="up" data-id="${s.id}" class="rounded-md border border-slate-300 px-3 py-1 text-sm">추천 ${s.up}</button>
              <button data-act="down" data-id="${s.id}" class="rounded-md border border-slate-300 px-3 py-1 text-sm">비추천 ${s.down}</button>
            </div>

            <div class="mt-3 rounded-lg bg-slate-50 p-3">
              <p class="text-sm font-semibold">댓글</p>
              <ul class="mt-1 space-y-1 text-sm text-slate-700">
                ${s.comments.slice(-3).map((c) => `<li>- ${c}</li>`).join('') || '<li>- 아직 댓글 없음</li>'}
              </ul>
              <div class="mt-2 flex gap-2">
                <input data-input="comment" data-id="${s.id}" class="flex-1 rounded-md border border-slate-300 px-2 py-1 text-sm" placeholder="정확/부정확 이유 댓글" />
                <button data-act="comment" data-id="${s.id}" class="rounded-md bg-slate-900 px-3 py-1 text-sm text-white">등록</button>
              </div>
            </div>
          </article>`
        )
        .join('');
    };

    const addSpot = () => {
      const name = nameEl?.value?.trim() ?? '';
      const region = regionEl?.value?.trim() ?? '';
      const note = noteEl?.value?.trim() ?? '';
      if (!name || !region) return;

      spots.push({
        id: `spot-${Date.now()}`,
        name,
        region,
        note,
        up: 0,
        down: 0,
        comments: []
      });

      if (nameEl) nameEl.value = '';
      if (regionEl) regionEl.value = '';
      if (noteEl) noteEl.value = '';

      save(spots);
      render();
    };

    addBtn?.addEventListener('click', addSpot);

    listEl?.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;

      const act = target.dataset.act;
      const id = target.dataset.id;
      if (!act || !id) return;

      const item = spots.find((s) => s.id === id);
      if (!item) return;

      if (act === 'up') item.up += 1;
      if (act === 'down') item.down += 1;
      if (act === 'comment') {
        const input = listEl.querySelector(`input[data-input="comment"][data-id="${id}"]`);
        if (input instanceof HTMLInputElement) {
          const text = input.value.trim();
          if (text) {
            item.comments.push(text);
            input.value = '';
          }
        }
      }

      save(spots);
      render();
    });

    render();
  </script>
</Layout>
