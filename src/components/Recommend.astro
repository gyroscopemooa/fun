---
const items = [
  { href: '/animal-test', label: '동물상 테스트' },
  { href: '/personal-color', label: '퍼스널컬러 테스트' },
  { href: '/mbti-test', label: 'MBTI 테스트' },
  { href: '/love-compatibility', label: '연애 궁합 테스트' },
  { href: '/reaction-test', label: '반응속도 테스트' },
  { href: '/ladder-game', label: '사다리타기' },
  { href: '/maps/hidden-cafe', label: '숨은 카페 지도' },
  { href: '/pinball', label: '핀볼 게임' },
  { href: '/random-food', label: '랜덤 음식 추천' }
];
---

<section class="mt-10">
  <h2 class="mb-3 text-lg font-semibold">추천 콘텐츠</h2>
  <div class="grid gap-3 md:grid-cols-2">
    {items.map((item) => (
      <a href={item.href} class="rounded-lg border border-slate-200 bg-white p-4 hover:border-slate-400">
        {item.label}
      </a>
    ))}
  </div>
</section>
