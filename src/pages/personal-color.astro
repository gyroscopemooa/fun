---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="퍼스널컬러 자가진단 | ManyTool" description="사진 업로드 기반 퍼스널컬러 자가진단. 얼굴 사진으로 계절 톤을 빠르게 추정해보세요.">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">퍼스널컬러 자가진단</h1>
    <p class="mt-3 text-slate-700">얼굴 사진을 올리면 빠르게 봄/여름/가을/겨울 톤을 추정해서 확인할 수 있습니다.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-4 rounded-xl border border-slate-200 bg-white p-5">
      <input id="color-file" accept="image/*" class="block w-full text-sm" type="file" />
      <img id="color-preview" class="mt-3 hidden max-h-72 w-full rounded-lg object-contain" alt="미리보기" loading="lazy" decoding="async" />
      <button id="color-run" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">분석하기</button>
      <p id="color-result" class="mt-3 rounded-md bg-slate-100 px-3 py-3 text-sm text-slate-700">이미지를 올리고 분석 버튼을 눌러주세요.</p>
      <canvas id="color-canvas" class="hidden"></canvas>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-semibold text-slate-900">퍼스널컬러 자가진단이란?</h2>
      <p class="mt-1">이미지의 평균 색온도를 바탕으로 봄/여름/가을/겨울 톤을 재미형으로 안내합니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">사용 방법</h2>
      <p class="mt-1">얼굴 사진 업로드 후 분석하기를 누르면 결과를 바로 확인할 수 있습니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">FAQ</h2>
      <p class="mt-1">Q. 정확한 추천까지 보고 싶어요. A. 아래 AI 퍼스널컬러 분석 페이지에서 더 자세한 추천 결과를 확인할 수 있습니다.</p>
    </section>

    <section class="mt-5 rounded-2xl border border-rose-200 bg-[linear-gradient(135deg,#fff1f2_0%,#fff7ed_55%,#fefce8_100%)] p-5">
      <p class="inline-flex rounded-full bg-white/80 px-3 py-1 text-xs font-semibold text-rose-700">업그레이드 버전</p>
      <h2 class="mt-3 text-xl font-bold text-slate-900">AI 퍼스널컬러 자가진단으로 더 자세한 추천 받기</h2>
      <p class="mt-2 text-sm text-slate-700">단순 톤 추정만 보는 대신, 어울리는 컬러군과 메이크업 톤, 헤어 컬러, 스타일링 방향까지 AI 분석으로 더 자세히 볼 수 있게 준비합니다.</p>
      <a
        href="/ai-personal-color"
        class="mt-4 inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 sm:w-auto"
      >
        AI 퍼스널컬러 자가진단 보러가기
      </a>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline>
    const fileEl = document.getElementById('color-file');
    const previewEl = document.getElementById('color-preview');
    const runEl = document.getElementById('color-run');
    const resultEl = document.getElementById('color-result');
    const canvasEl = document.getElementById('color-canvas');

    let ready = false;

    fileEl?.addEventListener('change', () => {
      const file = fileEl.files?.[0];
      if (!file || !(previewEl instanceof HTMLImageElement)) return;
      previewEl.src = URL.createObjectURL(file);
      previewEl.classList.remove('hidden');
      ready = true;
    });

    runEl?.addEventListener('click', () => {
      if (!ready || !(previewEl instanceof HTMLImageElement) || !(canvasEl instanceof HTMLCanvasElement)) {
        if (resultEl) resultEl.textContent = '먼저 이미지를 업로드해 주세요.';
        return;
      }

      const ctx = canvasEl.getContext('2d');
      if (!ctx) return;

      canvasEl.width = 64;
      canvasEl.height = 64;
      ctx.drawImage(previewEl, 0, 0, 64, 64);
      const data = ctx.getImageData(0, 0, 64, 64).data;

      let sumR = 0;
      let sumG = 0;
      let sumB = 0;
      for (let i = 0; i < data.length; i += 4) {
        sumR += data[i];
        sumG += data[i + 1];
        sumB += data[i + 2];
      }

      const px = data.length / 4;
      const r = sumR / px;
      const g = sumG / px;
      const b = sumB / px;

      const warm = r - b;
      const bright = (r + g + b) / 3;

      let tone = '여름 쿨';
      if (warm > 18 && bright > 150) tone = '봄 웜';
      else if (warm > 18 && bright <= 150) tone = '가을 웜';
      else if (warm <= 18 && bright > 150) tone = '여름 쿨';
      else tone = '겨울 쿨';

      if (resultEl) resultEl.textContent = `분석 결과: ${tone}`;
    });
  </script>
</Layout>
