---
import '../styles/global.css';
import AdSense from '../components/AdSense.astro';
import SiteProviders from '../components/providers/SiteProviders';
import globalCssUrl from '../styles/global.css?url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
  noindex?: boolean;
}

const {
  title = 'ManyTool | 무료 온라인 도구 모음',
  description = 'ManyTool은 무료 온라인 도구, 테스트, 게임, 지도, 쇼핑몰 보조 툴을 제공하는 웹 기반 툴 플랫폼입니다.',
  image = '/og-image.png',
  keywords,
  noindex = false
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const ogImage = new URL(image, Astro.site ?? Astro.url.origin).toString();
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const locale = Astro.url.pathname.startsWith('/en/') || Astro.url.pathname === '/en'
  ? 'en'
  : Astro.url.pathname.startsWith('/ja/') || Astro.url.pathname === '/ja'
    ? 'ja'
    : 'ko';
const htmlLang = locale === 'ko' ? 'ko' : locale === 'ja' ? 'ja' : 'en';
const ogLocale = locale === 'ko' ? 'ko_KR' : locale === 'ja' ? 'ja_JP' : 'en_US';
const pathNoLocale = Astro.url.pathname.replace(/^\/(en|ja)(?=\/|$)/, '') || '/';
const koHref = new URL(pathNoLocale, siteUrl).toString();
const enHref = new URL(pathNoLocale === '/' ? '/en' : `/en${pathNoLocale}`, siteUrl).toString();
const jaHref = new URL(pathNoLocale === '/' ? '/ja' : `/ja${pathNoLocale}`, siteUrl).toString();
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? 'G-J48EQSQQD8';
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const naverSiteVerification = import.meta.env.PUBLIC_NAVER_SITE_VERIFICATION ?? 'ab286ec18ea2904617f2827146d5b7fb2b5389cc';
const adsenseClient = 'ca-pub-1009841039120964';
const localeTitlePrefix = locale === 'ko' ? '' : locale === 'en' ? '[EN] ' : '[JA] ';
const localeDescSuffix = locale === 'ko'
  ? ''
  : locale === 'en'
    ? ' | English version of this page.'
    : ' | 日本語ページです。';
const normalizedPathLabel = pathNoLocale === '/' ? 'main' : pathNoLocale.replace(/\//g, ' ').trim();
const segments = pathNoLocale.split('/').filter(Boolean);
const topSlug = segments[segments.length - 1] ?? '';
const freeLabelMap: Record<string, string> = {
  'today-fortune': '무료 오늘의 운세',
  'name-meaning': '무료 이름풀이',
  'name-compatibility': '무료 이름궁합',
  'love-compatibility': '무료 연애궁합'
};
const freeBodyLabel = locale === 'ko' ? freeLabelMap[topSlug] : undefined;
const freeAutoPaths = new Set(['/', '/tools', '/games', '/tests', '/maps', '/online-tools']);
const shouldAutoFreeLabel = locale === 'ko' && (Boolean(freeBodyLabel) || freeAutoPaths.has(pathNoLocale));
const baseTitle = `${localeTitlePrefix}${title}`;
const resolvedTitle = shouldAutoFreeLabel && !baseTitle.includes('무료')
  ? `무료 ${baseTitle}`
  : baseTitle;
const resolvedDescription = `${description}${localeDescSuffix}${locale === 'ko' ? '' : ` (path: ${normalizedPathLabel})`}`;
const defaultKeywords = '무료 온라인 도구, 웹툴, 온라인 툴, 무료 테스트, 브라우저 게임, 지도 도구, 쇼핑몰 보조 툴, 스마트스토어 툴';
const keywordsBase = keywords ?? defaultKeywords;
const resolvedKeywords = shouldAutoFreeLabel && !keywordsBase.includes('무료')
  ? `무료, ${keywordsBase}`
  : keywordsBase;
const labelMap: Record<string, string> = {
  about: '소개',
  contact: '문의',
  privacy: '개인정보 처리방침',
  terms: '이용약관',
  'editorial-policy': '콘텐츠 운영 원칙',
  'content-disclaimer': '면책 고지',
  'animal-test': '동물상 테스트',
  'personal-color': '퍼스널컬러 테스트',
  'magic-book': '마법책',
  pinball: '핀볼',
  'random-food': '랜덤 음식 추천',
  'name-meaning': '이름풀이',
  'name-compatibility': '이름궁합',
  'today-fortune': '오늘의 운세',
  'fortune-cookie-2026': '올해 포츈쿠키',
  'reaction-test': '반응속도 테스트',
  'mbti-test': 'MBTI 테스트',
  'love-compatibility': '연애 궁합',
  'ladder-game': '사다리타기',
  maps: '지도',
  fishbread: '붕어빵 지도',
  'hidden-cafe': '숨은 카페 지도',
  'local-eats': '지역 맛집 지도',
  en: 'English',
  ja: '日本語'
};

const breadcrumbs = [
  { name: '홈', href: locale === 'ko' ? '/' : `/${locale}` },
  ...segments.map((seg, idx) => {
    const path = `/${segments.slice(0, idx + 1).join('/')}`;
    const localizedPath = locale === 'ko' ? path : `/${locale}${path}`;
    return {
      name: labelMap[seg] ?? seg,
      href: localizedPath
    };
  })
];

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ManyTool',
  url: siteUrl,
  inLanguage: locale === 'ko' ? 'ko-KR' : locale === 'ja' ? 'ja-JP' : 'en-US',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};

const softwareApplicationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'ManyTool',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Web',
  description: '테스트, 게임, 지도, 랜덤 도구를 제공하는 온라인 툴 플랫폼',
  url: siteUrl
};

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ManyTool',
  url: siteUrl,
  logo: new URL('/logo.png', siteUrl).toString()
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ManyTool은 무엇인가?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ManyTool은 온라인 도구, 테스트, 게임, 지도 기능을 제공하는 웹 기반 플랫폼입니다.'
      }
    },
    {
      '@type': 'Question',
      name: '온라인 도구란 무엇인가?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '브라우저에서 설치 없이 바로 사용하는 웹 기반 도구입니다.'
      }
    },
    {
      '@type': 'Question',
      name: 'MBTI 테스트는 무엇인가?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '질문 응답을 기반으로 성격 유형을 분류하는 테스트입니다.'
      }
    },
    {
      '@type': 'Question',
      name: '궁합 테스트는 어떻게 작동하는가?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '입력값 기반 규칙으로 궁합 점수와 결과를 계산해 보여줍니다.'
      }
    }
  ]
};

const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: resolvedTitle,
  description: resolvedDescription,
  url: canonical,
  isPartOf: {
    '@type': 'WebSite',
    name: 'ManyTool',
    url: siteUrl
  },
  inLanguage: locale === 'ko' ? 'ko-KR' : locale === 'ja' ? 'ja-JP' : 'en-US'
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: crumb.name,
    item: new URL(crumb.href, siteUrl).toString()
  }))
};
---

<!doctype html>
<html lang={htmlLang} suppressHydrationWarning>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" as="style" href={globalCssUrl} />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="keywords" content={resolvedKeywords} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="max-snippet" content="-1" />
    <meta name="max-image-preview" content="large" />
    <meta name="max-video-preview" content="-1" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ManyTool" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="author" content="ManyTool" />
    <meta name="google-adsense-account" content={adsenseClient} />
    <link rel="alternate" hrefLang="ko-KR" href={koHref} />
    <link rel="alternate" hrefLang="en" href={enHref} />
    <link rel="alternate" hrefLang="ja" href={jaHref} />
    <link rel="alternate" hrefLang="x-default" href={koHref} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    {naverSiteVerification && <meta name="naver-site-verification" content={naverSiteVerification} />}
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(webPageJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
      crossorigin="anonymous"
    ></script>
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script
          is:inline
          define:vars={{ gaId }}
        >
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="bg-slate-50 text-slate-900">
    <SiteProviders client:load />
    {pathNoLocale !== '/' && (
      <nav aria-label="Breadcrumb" class="mx-auto max-w-5xl px-4 pt-3 text-xs text-slate-500">
        <ol class="flex flex-wrap items-center gap-1">
          {breadcrumbs.map((crumb, idx) => (
            <li class="flex items-center gap-1">
              {idx > 0 && <span>/</span>}
              <a href={crumb.href} class="hover:text-slate-700 hover:underline">{crumb.name}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}
    {freeBodyLabel && (
      <div class="mx-auto max-w-5xl px-4 pt-3">
        <p class="inline-flex rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
          {freeBodyLabel}
        </p>
      </div>
    )}
    <AdSense slotName="글로벌 본문 상단" />
    <slot />
    <AdSense slotName="글로벌 본문 하단" />
  </body>
</html>
