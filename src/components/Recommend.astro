---
import { createTranslator, detectLocale, withLocalePath } from '../lib/i18n';

const pathname = Astro.url.pathname;
const locale = detectLocale(pathname);
const t = await createTranslator(locale);

const labels = {
  title: t('recommend.title'),
  top: t('recommend.top'),
  rankPrefix: t('recommend.rankPrefix')
};

const items = [
  { href: '/animal-test', label: t('recommend.items.animalTest') },
  { href: '/personal-color', label: t('recommend.items.personalColor') },
  { href: '/mbti-test', label: t('recommend.items.mbti') },
  { href: '/love-compatibility', label: t('recommend.items.loveCompatibility') },
  { href: '/name-meaning', label: t('recommend.items.nameMeaning') },
  { href: '/name-compatibility', label: t('recommend.items.nameCompatibility') },
  { href: '/reaction-test', label: t('recommend.items.reactionTest') },
  { href: '/fps-aim-sensitivity', label: t('recommend.items.fpsAim') },
  { href: '/ai-calorie-calculator', label: t('recommend.items.aiCalorie') },
  { href: '/ladder-game', label: t('recommend.items.ladderGame') },
  { href: '/today-fortune', label: t('recommend.items.todayFortune') },
  { href: '/fortune-cookie-2026', label: t('recommend.items.fortuneCookie') },
  { href: '/maps/hidden-cafe', label: t('recommend.items.hiddenCafe') },
  { href: '/maps/solo-dining', label: t('recommend.items.soloDining') },
  { href: '/pinball', label: t('recommend.items.pinball') },
  { href: '/random-food', label: t('recommend.items.randomFood') },
  { href: '/tools/scoreboard', label: t('recommend.items.scoreboard') },
  { href: '/face-shape-test', label: t('recommend.items.faceShape') },
  { href: '/nickname-generator', label: t('recommend.items.nickname') },
  { href: '/chat-random-picker', label: t('recommend.items.chatRandomPicker') },
  { href: '/meme-generator', label: t('recommend.items.memeGenerator') },
  { href: '/random-picker', label: t('recommend.items.randomPicker') },
  { href: '/roulette', label: t('recommend.items.roulette') },
  { href: '/team-split', label: t('recommend.items.teamSplit') },
  { href: '/text-counter', label: t('recommend.items.textCounter') },
  { href: '/daily-english-word', label: t('recommend.items.dailyEnglishWord') },
  { href: '/daily-sentence', label: t('recommend.items.dailySentence') },
  { href: '/streamer-battle', label: t('recommend.items.streamerBattle') },
  { href: '/daily-spanish', label: t('recommend.items.dailySpanish') },
  { href: '/daily-japanese', label: t('recommend.items.dailyJapanese') },
  { href: '/korean-study-today', label: t('recommend.items.koreanStudy') }
].map((item) => ({ href: withLocalePath(locale, item.href), label: item.label }));
---

<section class="mt-10">
  <h2 class="mb-3 text-lg font-semibold">{labels.title}</h2>

  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <p class="text-sm text-slate-500">{labels.top}</p>
    <a id="hot-top-link" href={items[0].href} class="mt-1 block text-lg font-bold text-slate-900 hover:underline">
      {labels.rankPrefix} {items[0].label}
    </a>

    <div id="hot-rank-list" class="mt-4 grid gap-2 md:grid-cols-2">
      {items.map((item, idx) => (
        <a href={item.href} class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm hover:border-slate-400">
          {idx + 1}. {item.label}
        </a>
      ))}
    </div>
  </div>

  <script is:inline define:vars={{ items, labels }}>
    const source = [...items];
    const listEl = document.getElementById('hot-rank-list');
    const topLinkEl = document.getElementById('hot-top-link');

    const getRanked = () =>
      source
        .map((item) => ({ ...item, score: Math.random() + Math.random() }))
        .sort((a, b) => b.score - a.score)
        .slice(0, 8);

    const renderRank = () => {
      const ranked = getRanked();
      if (topLinkEl && ranked[0]) {
        topLinkEl.setAttribute('href', ranked[0].href);
        topLinkEl.textContent = `${labels.rankPrefix} ${ranked[0].label}`;
      }

      if (!listEl) return;
      listEl.innerHTML = ranked
        .map(
          (item, idx) =>
            `<a href="${item.href}" class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm hover:border-slate-400">${idx + 1}. ${item.label}</a>`
        )
        .join('');
    };

    renderRank();
    window.setInterval(renderRank, 4500);
  </script>
</section>
