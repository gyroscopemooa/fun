---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
import PersonalColorResultPanel from '../components/personal-color/PersonalColorResultPanel';

const apiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? 'http://127.0.0.1:8787').replace(/\/+$/, '');
---

<Layout
  title="AI 퍼스널컬러 자가진단 | 사진 업로드·카메라 촬영 분석 | ManyTool"
  description="모바일 카메라 촬영 또는 사진 업로드로 시작하는 AI 퍼스널컬러 자가진단. OpenAI 기반으로 톤 분석, 추천 컬러, 메이크업, 헤어 컬러 가이드를 확인하세요."
  keywords="AI 퍼스널컬러, 퍼스널컬러 자가진단, 카메라 퍼스널컬러, 얼굴 톤 분석, 메이크업 컬러 추천, 퍼스널컬러 추천"
>
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-8 pb-24 md:pb-8">
    <section class="rounded-3xl border border-rose-200 bg-[radial-gradient(circle_at_top_left,#ffe4e6_0%,#fff7ed_34%,#ffffff_74%)] p-6 shadow-sm">
      <p class="inline-flex rounded-full bg-white/85 px-3 py-1 text-xs font-semibold text-rose-700">모바일 촬영 지원</p>
      <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-900">AI 퍼스널컬러 자가진단</h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-700 sm:text-base">
        업로드뿐 아니라 카메라 촬영으로도 바로 시작할 수 있게 만든 유료 분석 페이지입니다. 계절톤, 웜/쿨, 명도, 채도, 대비감을 기준으로 대표 톤과 상세 리포트를 한 번에 정리합니다.
      </p>
      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-white/70 bg-white/85 p-4">
          <p class="text-sm font-bold text-slate-900">시작 방식</p>
          <p class="mt-1 text-sm text-slate-600">사진 업로드 또는 카메라 촬영</p>
        </div>
        <div class="rounded-2xl border border-white/70 bg-white/85 p-4">
          <p class="text-sm font-bold text-slate-900">결과 구성</p>
          <p class="mt-1 text-sm text-slate-600">간단 결과, 상세보기, 차트 리포트</p>
        </div>
        <div class="rounded-2xl border border-white/70 bg-white/85 p-4">
          <p class="text-sm font-bold text-slate-900">결과 전달</p>
          <p class="mt-1 text-sm text-slate-600">결제 이메일 기준 결과 링크 재확인</p>
        </div>
      </div>
    </section>

    <AdSense slotName="본문 상단" />

    <section class="mt-6 grid gap-4 lg:grid-cols-[1.02fr_0.98fr]">
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-bold text-slate-900">1) 사진 준비</h2>
        <p class="mt-2 text-sm text-slate-600">모바일에서는 셀카를 바로 찍고, PC에서는 업로드로 바로 진행할 수 있습니다.</p>

        <div class="mt-4 flex flex-wrap gap-2">
          <label class="inline-flex cursor-pointer items-center justify-center rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white">
            사진 업로드
            <input id="file-input" type="file" accept="image/*" class="hidden" />
          </label>
          <button id="camera-start" class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
            카메라 시작
          </button>
          <button id="camera-capture" class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50" disabled>
            촬영
          </button>
          <button id="reset-all" class="inline-flex items-center justify-center rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700 transition hover:bg-rose-100">
            초기화
          </button>
        </div>

        <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <video id="camera" class="hidden h-80 w-full rounded-xl bg-black object-cover" autoplay playsinline></video>
          <img id="preview" alt="퍼스널컬러 분석용 미리보기" class="hidden h-80 w-full rounded-xl object-contain" />
          <div id="empty-state" class="flex h-80 items-center justify-center rounded-xl border border-dashed border-slate-300 bg-white text-center text-sm text-slate-500">
            정면 얼굴 사진을 준비해 주세요
          </div>
        </div>

        <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-sm font-bold text-slate-900">촬영 가이드</h3>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-700">
            <li>정면 얼굴, 자연광 또는 밝은 조명 권장</li>
            <li>필터가 강한 사진보다 원본에 가까운 사진 권장</li>
            <li>모자, 마스크, 강한 색조 보정은 피하는 편이 좋음</li>
          </ul>
        </div>

        <button id="analyze-button" class="mt-4 w-full rounded-2xl bg-rose-600 px-4 py-4 text-sm font-bold text-white shadow-[0_18px_40px_rgba(225,29,72,0.24)] transition hover:-translate-y-0.5 hover:bg-rose-500 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none" disabled>
          AI 퍼스널컬러 분석 시작
        </button>
        <p id="status" class="mt-3 text-sm text-slate-600">사진을 준비하면 결제 후 바로 분석을 이어서 진행합니다.</p>
        <div id="status-box" class="mt-3 hidden rounded-2xl border p-4 text-sm"></div>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-xl font-bold text-slate-900">2) 결과 리포트</h2>
            <p class="mt-1 text-sm text-slate-600">요약 결과를 먼저 보고, 만족하면 상세보기를 펼쳐 전문 용어와 차트를 같이 확인하는 구조입니다.</p>
          </div>
        </div>
        <div class="mt-4">
          <PersonalColorResultPanel client:load />
        </div>
      </article>
    </section>

    <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-xs font-semibold tracking-[0.16em] text-rose-600">PREVIEW</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-900">실제 결과 화면처럼 미리보기</h2>
          <p class="mt-2 max-w-3xl text-sm text-slate-600">
            얼굴 노출은 최소화하고, 실제 분석 결과처럼 요약 카드와 상세 카드가 함께 보이도록 구성했습니다.
            모바일에서도 첫 화면만 보고 어떤 결과가 나오는지 바로 이해할 수 있는 구조입니다.
          </p>
        </div>
        <a href="/personal-color" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
          무료 자가진단 보기
        </a>
      </div>

      <div class="mt-5 grid gap-4 xl:grid-cols-[0.94fr_1.06fr]">
        <article class="overflow-hidden rounded-[28px] border border-rose-100 bg-[linear-gradient(180deg,#fff7fb_0%,#fff3f4_100%)] p-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs font-semibold tracking-[0.18em] text-rose-500">LIVE PREVIEW</p>
              <h3 class="mt-2 text-xl font-black text-slate-900">모자이크 프리뷰 카드</h3>
            </div>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-rose-600">안전한 예시</span>
          </div>

          <div class="mt-4 rounded-[26px] border border-white/70 bg-white/80 p-3 shadow-sm">
            <div class="relative mx-auto flex h-[320px] max-w-[260px] items-center justify-center overflow-hidden rounded-[24px] bg-[radial-gradient(circle_at_top,#fecdd3_0%,#f8fafc_38%,#e2e8f0_100%)]">
              <div class="absolute inset-x-8 top-8 h-16 rounded-full bg-white/55 blur-xl"></div>
              <div class="absolute inset-x-10 bottom-0 h-28 rounded-t-[42px] bg-[linear-gradient(180deg,#1f2937_0%,#111827_100%)]"></div>
              <div class="absolute top-10 h-16 w-20 rounded-full bg-[linear-gradient(180deg,#8b5e3c_0%,#5b3a29_100%)] opacity-90 blur-[1px]"></div>
              <div class="absolute top-[72px] h-[150px] w-[110px] rounded-[42px] bg-[linear-gradient(180deg,#f5d2c1_0%,#e9b7a5_100%)] opacity-90"></div>
              <div class="absolute top-[124px] left-[calc(50%-34px)] h-5 w-5 animate-[floatY_3.4s_ease-in-out_infinite] rounded-md bg-white/70 backdrop-blur-sm"></div>
              <div class="absolute top-[124px] right-[calc(50%-34px)] h-5 w-5 animate-[floatY_3s_ease-in-out_infinite] rounded-md bg-white/70 backdrop-blur-sm"></div>
              <div class="absolute top-[154px] h-4 w-10 animate-[pulseSoft_2.8s_ease-in-out_infinite] rounded-full bg-white/65"></div>
              <div class="absolute top-[182px] h-3 w-14 rounded-full bg-rose-200/80 blur-[1px]"></div>
              <div class="absolute inset-0 bg-[linear-gradient(90deg,transparent_0%,rgba(255,255,255,0.28)_48%,transparent_100%)] animate-[scanX_5.2s_linear_infinite]"></div>
              <div class="absolute inset-0 backdrop-blur-[10px] [mask-image:linear-gradient(180deg,transparent_0%,black_16%,black_84%,transparent_100%)]"></div>
              <div class="absolute inset-0 bg-[linear-gradient(0deg,rgba(255,255,255,0.18)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.18)_1px,transparent_1px)] bg-[size:18px_18px] opacity-60"></div>
            </div>

            <div class="mt-4 rounded-2xl border border-emerald-100 bg-emerald-50 p-4">
              <p class="text-sm font-bold text-slate-900">대표 결과</p>
              <p class="mt-2 text-2xl font-black text-rose-600">여름 쿨</p>
              <p class="mt-2 text-sm leading-6 text-slate-700">
                부드러운 채도와 맑은 쿨톤 계열이 얼굴의 균형을 살리는 타입으로,
                라이트 그레이, 라벤더, 뮤트 핑크 계열이 안정적으로 어울리는 결과 예시입니다.
              </p>
              <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold">
                <span class="rounded-full bg-white px-3 py-1 text-rose-600">쿨톤</span>
                <span class="rounded-full bg-white px-3 py-1 text-rose-600">중간 명도</span>
                <span class="rounded-full bg-white px-3 py-1 text-rose-600">부드러운 대비</span>
              </div>
            </div>
          </div>
        </article>

        <article class="rounded-[28px] border border-slate-200 bg-[linear-gradient(180deg,#fffdfd_0%,#fff8fa_100%)] p-4">
          <div class="rounded-[24px] border border-rose-100 bg-white/90 p-4 shadow-sm">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold tracking-[0.16em] text-rose-500">RESULT SNAPSHOT</p>
                <h3 class="mt-2 text-xl font-black text-slate-900">간단 결과 + 상세보기 구성</h3>
              </div>
              <span class="rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-600">차트 포함</span>
            </div>

            <div class="mt-4 rounded-3xl border border-rose-100 bg-[linear-gradient(180deg,#fff8fb_0%,#ffffff_100%)] p-4">
              <p class="text-xs font-semibold tracking-[0.16em] text-rose-500">간단 결과</p>
              <h4 class="mt-2 text-2xl font-black text-slate-900">여름 쿨</h4>
              <p class="mt-2 text-sm leading-6 text-slate-700">
                피부가 밝고 부드러운 쿨톤에 가깝고, 라이트한 채도와 맑은 회색 기운이 섞인 컬러가 안정적으로 어울리는 타입입니다.
              </p>
              <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold">
                <span class="rounded-full bg-rose-50 px-3 py-1 text-rose-600">라벤더</span>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">라이트 그레이</span>
                <span class="rounded-full bg-cyan-50 px-3 py-1 text-cyan-700">민트</span>
                <span class="rounded-full bg-rose-50 px-3 py-1 text-rose-600">뮤트 핑크</span>
              </div>
            </div>

            <div class="mt-4 grid gap-4 lg:grid-cols-[0.92fr_1.08fr]">
              <div class="rounded-3xl border border-amber-100 bg-amber-50/80 p-4">
                <div class="flex items-center justify-between">
                  <p class="text-sm font-bold text-slate-900">상세보기</p>
                  <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-500">상세 보기</span>
                </div>
                <div class="mt-4 relative mx-auto h-44 w-44">
                  <div class="absolute inset-0 rounded-full border border-amber-200"></div>
                  <div class="absolute inset-4 rounded-full border border-amber-200"></div>
                  <div class="absolute inset-8 rounded-full border border-amber-200"></div>
                  <div class="absolute left-1/2 top-0 h-full w-px -translate-x-1/2 bg-amber-200"></div>
                  <div class="absolute left-0 top-1/2 h-px w-full -translate-y-1/2 bg-amber-200"></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="h-24 w-24 rotate-45 rounded-[24px] border border-rose-300/60 bg-rose-300/25 shadow-[0_0_0_10px_rgba(251,113,133,0.08)]"></div>
                  </div>
                  <span class="absolute left-1/2 top-1 -translate-x-1/2 text-xs font-semibold text-slate-500">채도</span>
                  <span class="absolute right-0 top-1/2 -translate-y-1/2 text-xs font-semibold text-slate-500">밝기</span>
                  <span class="absolute bottom-0 left-1/2 -translate-x-1/2 text-xs font-semibold text-slate-500">명도</span>
                  <span class="absolute left-0 top-1/2 -translate-y-1/2 text-xs font-semibold text-slate-500">대비</span>
                </div>
              </div>

              <div class="grid gap-3 sm:grid-cols-2">
                <div class="rounded-3xl border border-sky-100 bg-sky-50/80 p-4">
                  <p class="text-sm font-bold text-slate-900">베스트 컬러</p>
                  <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold">
                    <span class="rounded-full bg-white px-3 py-1 text-cyan-700">연한 블루</span>
                    <span class="rounded-full bg-white px-3 py-1 text-rose-600">뮤트 로즈</span>
                    <span class="rounded-full bg-white px-3 py-1 text-slate-600">라이트 그레이</span>
                    <span class="rounded-full bg-white px-3 py-1 text-emerald-700">민트</span>
                  </div>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                  <p class="text-sm font-bold text-slate-900">비추천 컬러</p>
                  <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold">
                    <span class="rounded-full bg-white px-3 py-1 text-amber-700">오렌지</span>
                    <span class="rounded-full bg-white px-3 py-1 text-yellow-700">노란 톤</span>
                    <span class="rounded-full bg-white px-3 py-1 text-red-700">강한 레드</span>
                    <span class="rounded-full bg-white px-3 py-1 text-stone-700">진한 브라운</span>
                  </div>
                </div>
                <div class="rounded-3xl border border-rose-100 bg-rose-50/80 p-4">
                  <p class="text-sm font-bold text-slate-900">메이크업 추천</p>
                  <p class="mt-2 text-sm leading-6 text-slate-700">
                    로즈 핑크 블러셔, 맑은 핑크 립, 부드러운 브라운 아이라인이 안정적인 예시 조합입니다.
                  </p>
                </div>
                <div class="rounded-3xl border border-violet-100 bg-violet-50/80 p-4">
                  <p class="text-sm font-bold text-slate-900">헤어 컬러 가이드</p>
                  <p class="mt-2 text-sm leading-6 text-slate-700">
                    붉은기 적은 애쉬 브라운, 다크 애쉬 계열이 얼굴 톤을 무겁지 않게 받쳐주는 방향입니다.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <style>
    @keyframes floatY {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-4px); }
    }
    @keyframes pulseSoft {
      0%, 100% { opacity: 0.55; transform: scaleX(0.96); }
      50% { opacity: 0.95; transform: scaleX(1.04); }
    }
    @keyframes scanX {
      0% { transform: translateX(-120%); }
      100% { transform: translateX(120%); }
    }
  </style>

  <script is:inline define:vars={{ apiBase }}>
    const API_BASE = apiBase;
    const STORAGE_IMAGE_KEY = 'manytool.aiPersonalColor.image';
    const STORAGE_PENDING_KEY = 'manytool.aiPersonalColor.pendingCheckout';
    const CHECKOUT_AMOUNT = 490;
    const CHECKOUT_CURRENCY = 'USD';

    const fileInput = document.getElementById('file-input');
    const cameraEl = document.getElementById('camera');
    const previewEl = document.getElementById('preview');
    const emptyStateEl = document.getElementById('empty-state');
    const cameraStartBtn = document.getElementById('camera-start');
    const cameraCaptureBtn = document.getElementById('camera-capture');
    const resetBtn = document.getElementById('reset-all');
    const analyzeBtn = document.getElementById('analyze-button');
    const statusEl = document.getElementById('status');
    const statusBoxEl = document.getElementById('status-box');

    let imageDataUrl = '';
    let currentOrderId = null;
    let apiReady = false;
    let productReady = false;
    let stream = null;
    let analyzing = false;

    const query = new URLSearchParams(window.location.search);
    const returnedOrderId = query.get('orderId');
    const requestedJobId = query.get('jobId');

    const pushResult = (analysis) => {
      window.dispatchEvent(new CustomEvent('manytool:ai-personal-color-result', { detail: analysis ?? null }));
    };

    const setStatus = (message, tone = 'neutral') => {
      if (statusEl) statusEl.textContent = message;
      if (!statusBoxEl) return;
      if (!message) {
        statusBoxEl.className = 'mt-3 hidden rounded-2xl border p-4 text-sm';
        statusBoxEl.textContent = '';
        return;
      }
      const toneClass = tone === 'error'
        ? 'border-rose-200 bg-rose-50 text-rose-700'
        : tone === 'success'
          ? 'border-emerald-200 bg-emerald-50 text-emerald-700'
          : 'border-slate-200 bg-slate-50 text-slate-700';
      statusBoxEl.className = `mt-3 rounded-2xl border p-4 text-sm ${toneClass}`;
      statusBoxEl.textContent = message;
    };

    const setAnalyzeEnabled = () => {
      if (!(analyzeBtn instanceof HTMLButtonElement)) return;
      analyzeBtn.disabled = !imageDataUrl || !apiReady || !productReady || analyzing;
    };

    const stopCamera = () => {
      if (stream) {
        stream.getTracks().forEach((track) => track.stop());
        stream = null;
      }
      if (cameraEl instanceof HTMLVideoElement) {
        cameraEl.pause();
        cameraEl.srcObject = null;
        cameraEl.classList.add('hidden');
      }
      if (cameraCaptureBtn instanceof HTMLButtonElement) {
        cameraCaptureBtn.disabled = true;
      }
    };

    const showPreview = (dataUrl) => {
      imageDataUrl = dataUrl || '';
      if (previewEl instanceof HTMLImageElement && imageDataUrl) {
        previewEl.src = imageDataUrl;
        previewEl.classList.remove('hidden');
      }
      emptyStateEl?.classList.toggle('hidden', Boolean(imageDataUrl));
      if (!imageDataUrl && previewEl instanceof HTMLImageElement) {
        previewEl.classList.add('hidden');
        previewEl.removeAttribute('src');
      }
      window.sessionStorage.setItem(STORAGE_IMAGE_KEY, imageDataUrl);
      setAnalyzeEnabled();
    };

    const dataUrlToFile = async (dataUrl, filename = 'personal-color.jpg') => {
      const response = await fetch(dataUrl);
      const blob = await response.blob();
      return new File([blob], filename, { type: blob.type || 'image/jpeg' });
    };

    const fetchConfig = async () => {
      try {
        const response = await fetch(`${API_BASE}/config`);
        if (!response.ok) throw new Error(`config failed: ${response.status}`);
        const payload = await response.json();
        apiReady = Boolean(payload?.readiness?.aiPersonalColorReady);
        productReady = Boolean(payload?.paymentProducts?.ai_personal_color);
        if (!apiReady) {
          setStatus('OpenAI 분석 설정이 아직 준비되지 않았습니다.', 'error');
        } else if (!productReady) {
          setStatus('Polar 상품 연결이 아직 준비되지 않았습니다.', 'error');
        }
      } catch {
        apiReady = false;
        productReady = false;
        setStatus('Node API 연결을 확인하지 못했습니다.', 'error');
      }
      setAnalyzeEnabled();
    };

    const fetchOrder = async (orderId) => {
      if (!orderId) return null;
      const response = await fetch(`${API_BASE}/order/${orderId}`);
      if (!response.ok) return null;
      return response.json();
    };

    const fetchJob = async (jobId) => {
      const response = await fetch(`${API_BASE}/ai-personal-color/job/${jobId}`);
      if (!response.ok) throw new Error(`job fetch failed: ${response.status}`);
      return response.json();
    };

    const requestCheckout = async () => {
      const response = await fetch(`${API_BASE}/checkout`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          productType: 'ai_personal_color',
          amount: CHECKOUT_AMOUNT,
          currency: CHECKOUT_CURRENCY,
          provider: 'polar',
          successUrl: window.location.href.split('?')[0],
          returnUrl: window.location.href.split('?')[0]
        })
      });
      if (!response.ok) throw new Error(`checkout failed: ${response.status}`);
      return response.json();
    };

    const runAnalysis = async () => {
      if (!imageDataUrl || !currentOrderId || analyzing) return;
      analyzing = true;
      setAnalyzeEnabled();
      setStatus('AI 퍼스널컬러 분석 중입니다. 잠시만 기다려 주세요.');

      try {
        const file = await dataUrlToFile(imageDataUrl);
        const formData = new FormData();
        formData.append('image', file);
        formData.append('orderId', currentOrderId);

        const response = await fetch(`${API_BASE}/ai-personal-color/analyze`, {
          method: 'POST',
          body: formData
        });
        const payload = await response.json();
        if (!response.ok) {
          throw new Error(payload?.error || `analysis failed: ${response.status}`);
        }

        pushResult(payload.job.analysis);
        setStatus('분석이 완료되었습니다. 결제 이메일로도 결과 링크가 발송됩니다.', 'success');
        window.sessionStorage.removeItem(STORAGE_PENDING_KEY);
        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.delete('orderId');
        nextUrl.searchParams.set('jobId', payload.job.id);
        window.history.replaceState({}, '', nextUrl.toString());
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '분석에 실패했습니다.', 'error');
      } finally {
        analyzing = false;
        setAnalyzeEnabled();
      }
    };

    const restoreImage = () => {
      const saved = window.sessionStorage.getItem(STORAGE_IMAGE_KEY) || '';
      if (saved) showPreview(saved);
    };

    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        stopCamera();
        showPreview(typeof reader.result === 'string' ? reader.result : '');
        setStatus('사진이 준비되었습니다. 분석 시작을 누르면 결제 후 바로 분석을 이어갑니다.');
      };
      reader.readAsDataURL(file);
    });

    cameraStartBtn?.addEventListener('click', async () => {
      try {
        if (!navigator.mediaDevices?.getUserMedia) {
          throw new Error('이 브라우저에서는 카메라 촬영을 지원하지 않습니다.');
        }
        stopCamera();
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
        if (cameraEl instanceof HTMLVideoElement) {
          cameraEl.srcObject = stream;
          cameraEl.classList.remove('hidden');
        }
        if (previewEl instanceof HTMLImageElement) {
          previewEl.classList.add('hidden');
        }
        emptyStateEl?.classList.add('hidden');
        if (cameraCaptureBtn instanceof HTMLButtonElement) {
          cameraCaptureBtn.disabled = false;
        }
        setStatus('카메라가 준비되었습니다. 원하는 각도에서 촬영을 눌러주세요.');
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '카메라를 시작하지 못했습니다.', 'error');
      }
    });

    cameraCaptureBtn?.addEventListener('click', () => {
      if (!(cameraEl instanceof HTMLVideoElement) || !cameraEl.videoWidth || !cameraEl.videoHeight) return;
      const canvas = document.createElement('canvas');
      canvas.width = cameraEl.videoWidth;
      canvas.height = cameraEl.videoHeight;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      ctx.drawImage(cameraEl, 0, 0, canvas.width, canvas.height);
      const dataUrl = canvas.toDataURL('image/jpeg', 0.92);
      stopCamera();
      showPreview(dataUrl);
      setStatus('촬영이 완료되었습니다. 분석 시작을 누르면 결제 후 자동으로 분석을 이어갑니다.');
    });

    resetBtn?.addEventListener('click', () => {
      stopCamera();
      imageDataUrl = '';
      currentOrderId = null;
      window.sessionStorage.removeItem(STORAGE_IMAGE_KEY);
      window.sessionStorage.removeItem(STORAGE_PENDING_KEY);
      if (fileInput instanceof HTMLInputElement) fileInput.value = '';
      pushResult(null);
      showPreview('');
      setStatus('초기화되었습니다.');
    });

    analyzeBtn?.addEventListener('click', async () => {
      if (!imageDataUrl) {
        setStatus('먼저 사진을 준비해 주세요.', 'error');
        return;
      }
      if (!apiReady || !productReady) {
        setStatus('분석 기능이 아직 준비되지 않았습니다.', 'error');
        return;
      }

      if (!currentOrderId) {
        try {
          setStatus('결제 페이지로 이동합니다.');
          window.sessionStorage.setItem(STORAGE_PENDING_KEY, '1');
          const checkout = await requestCheckout();
          if (checkout?.checkoutUrl) {
            window.location.href = checkout.checkoutUrl;
            return;
          }
          throw new Error('checkout url is missing');
        } catch (error) {
          setStatus(error instanceof Error ? error.message : '결제 요청에 실패했습니다.', 'error');
          return;
        }
      }

      await runAnalysis();
    });

    const bootstrap = async () => {
      pushResult(null);
      restoreImage();
      await fetchConfig();

      if (requestedJobId) {
        try {
          const payload = await fetchJob(requestedJobId);
          if (payload?.job?.analysis) {
            currentOrderId = payload.job.orderId ?? null;
            pushResult(payload.job.analysis);
            setStatus('저장된 분석 결과를 불러왔습니다.', 'success');
          }
        } catch (error) {
          setStatus(error instanceof Error ? error.message : '저장된 결과를 불러오지 못했습니다.', 'error');
        }
        return;
      }

      if (returnedOrderId) {
        const order = await fetchOrder(returnedOrderId);
        if (order?.status === 'paid') {
          currentOrderId = returnedOrderId;
          setStatus('결제가 확인되었습니다. 저장된 사진이 있으면 바로 분석을 이어갑니다.', 'success');
          if (window.sessionStorage.getItem(STORAGE_PENDING_KEY) === '1' && imageDataUrl) {
            await runAnalysis();
          }
        } else if (order?.status === 'pending') {
          setStatus('결제가 아직 완료되지 않았습니다.', 'error');
        }
      }

      setAnalyzeEnabled();
    };

    window.addEventListener('beforeunload', stopCamera);
    void bootstrap();
  </script>
</Layout>
