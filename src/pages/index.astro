---
import Layout from '../layouts/Layout.astro';
import AdSense from '../components/AdSense.astro';
import SponsorBanner from '../components/SponsorBanner.astro';
import Recommend from '../components/Recommend.astro';
import Footer from '../components/Footer.astro';
import { createTranslator, detectLocale, stripLocale, withLocalePath } from '../lib/i18n';

const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();
const apiBase = rawApiBase.replace(/\/+$/, '');

const pathname = Astro.url.pathname;
const locale = detectLocale(pathname);
const tRaw = await createTranslator(locale);
const withLocale = (path: string) => withLocalePath(locale, path);
const strippedPath = stripLocale(pathname);
const langLinks = [
  { code: 'ko', label: '한국어', href: `${strippedPath}`.replace(/\/{2,}/g, '/') || '/' },
  { code: 'en', label: 'English', href: `/en${strippedPath}`.replace(/\/{2,}/g, '/') || '/en' },
  { code: 'ja', label: '日本語', href: `/ja${strippedPath}`.replace(/\/{2,}/g, '/') || '/ja' }
];

const t = {
  tabs: [
    tRaw('home.tabs.all'),
    tRaw('home.tabs.games'),
    tRaw('home.tabs.tools'),
    tRaw('home.tabs.art'),
    tRaw('home.tabs.etc')
  ],
  searchPlaceholder: tRaw('home.searchPlaceholder'),
  heroTitle: tRaw('home.heroTitle'),
  heroDesc: tRaw('home.heroDesc'),
  noResult: tRaw('home.noResult'),
  guideTitle: tRaw('home.guideTitle'),
  guideP1: tRaw('home.guideP1'),
  guideP2: tRaw('home.guideP2'),
  guideDonate: tRaw('home.guideDonate'),
  guideDonateHint: tRaw('home.guideDonateHint'),
  faqTitle: tRaw('home.faqTitle'),
  faqQ1: tRaw('home.faqQ1'),
  faqA1: tRaw('home.faqA1'),
  faqQ2: tRaw('home.faqQ2'),
  faqA2: tRaw('home.faqA2'),
  faqQ3: tRaw('home.faqQ3'),
  faqA3: tRaw('home.faqA3'),
  donateUnavailable: tRaw('home.donateUnavailable'),
  donateLoading: tRaw('home.donateLoading'),
  donateFailed: tRaw('home.donateFailed'),
  prevCard: tRaw('home.prevCard'),
  nextCard: tRaw('home.nextCard'),
  trendingCardsTitle: locale === 'ko' ? '실시간 인기검색어' : locale === 'ja' ? 'リアルタイム人気検索語' : 'Trending Searches',
  trendingCardsDesc: locale === 'ko' ? 'Google Trends (KR)' : locale === 'ja' ? 'Google Trends (KR)' : 'Google Trends (KR)',
  trendingLoading: locale === 'ko' ? '불러오는 중...' : locale === 'ja' ? '読み込み中...' : 'Loading...',
  trendingError: locale === 'ko' ? '인기 키워드를 불러오지 못했습니다.' : locale === 'ja' ? 'キーワードを読み込めませんでした。' : 'Failed to load trends.',
  trendingCta: locale === 'ko' ? '검색 보기' : locale === 'ja' ? '検索を見る' : 'Search',
  trendingMeta: locale === 'ko' ? '실시간 순위' : locale === 'ja' ? 'リアルタイム順位' : 'Live rankings',
  trendingUpdated: locale === 'ko' ? '업데이트' : locale === 'ja' ? '更新' : 'Updated'
};

const cardSeed = [
  { href: '/ai-id-photo', title: 'AI 증명사진', desc: '업로드/촬영으로 후보 3장 생성', icon: '📷', iconClass: 'bg-slate-100 text-slate-700', disabled: true },
  { href: '/ai-passport-photo', title: 'AI 여권사진', desc: '여권 규격 후보 3장 생성', icon: '🛂', iconClass: 'bg-cyan-100 text-cyan-700', disabled: true },
  { href: '/ai-headshot', title: 'AI 프로필사진', desc: '비즈니스/취업용 프로필 생성', icon: '🖌️', iconClass: 'bg-amber-100 text-amber-700', disabled: true },
  { href: '/animal-test', title: '동물상 테스트', desc: '사진으로 동물상 분석', icon: '🐾', iconClass: 'bg-sky-100 text-sky-700' },
  { href: '/pinball', title: '핀볼 게임', desc: '가볍게 즐기는 미니게임', icon: '🎮', iconClass: 'bg-emerald-100 text-emerald-700' },
  { href: '/personal-color', title: '퍼스널컬러', desc: '얼굴 기반 색상 추천', icon: '🎨', iconClass: 'bg-amber-100 text-amber-700' },
  { href: '/magic-book', title: '마법책', desc: '랜덤 문구 뽑기', icon: '✨', iconClass: 'bg-fuchsia-100 text-fuchsia-700' },
  { href: '/reaction-test', title: '반응속도', desc: '클릭 속도 측정', icon: '⚡', iconClass: 'bg-rose-100 text-rose-700' },
  { href: '/fps-aim-sensitivity', title: 'FPS 에임 조절기', desc: '현재 감도 기준 추천', icon: '🎯', iconClass: 'bg-cyan-100 text-cyan-700' },
  { href: '/ai-calorie-calculator', title: 'AI 칼로리 계산기', desc: '음식 사진 칼로리 추정', icon: '🍱', iconClass: 'bg-emerald-100 text-emerald-700' },
  { href: '/mbti-test', title: 'MBTI 테스트', desc: '성향 빠른 확인', icon: '🧠', iconClass: 'bg-indigo-100 text-indigo-700' },
  { href: '/maps/fishbread', title: '전국 붕어빵 지도', desc: '지역별 붕어빵 빠른 탐색', icon: '🗺️', iconClass: 'bg-cyan-100 text-cyan-700' },
  { href: '/maps/solo-dining', title: '혼밥 가능 식당 공유', desc: '혼밥 가능한 식당 제보/탐색', icon: '🍽️', iconClass: 'bg-orange-100 text-orange-700' },
  { href: '/name-meaning', title: '이름풀이', desc: '이름으로 성향 키워드 보기', icon: '📝', iconClass: 'bg-blue-100 text-blue-700' },
  { href: '/name-compatibility', title: '이름궁합', desc: '두 이름 궁합 점수 확인', icon: '💕', iconClass: 'bg-pink-100 text-pink-700' },
  { href: '/maps/hidden-cafe', title: '숨은 카페 지도', desc: '조용한 카페 탐색', icon: '☕', iconClass: 'bg-orange-100 text-orange-700' },
  { href: '/maps/local-eats', title: '지역 맛집 지도', desc: '동네 인기 맛집', icon: '🍜', iconClass: 'bg-red-100 text-red-700' },
  { href: '/love-compatibility', title: '연애 궁합', desc: '두 사람 궁합 테스트', icon: '💜', iconClass: 'bg-violet-100 text-violet-700' },
  { href: '/random-food', title: '랜덤 음식', desc: '오늘 메뉴 추천', icon: '🎲', iconClass: 'bg-yellow-100 text-yellow-700' },
  { href: '/today-fortune', title: '오늘의 운세', desc: '오늘 운세 랜덤 확인', icon: '🔮', iconClass: 'bg-purple-100 text-purple-700' },
  { href: '/fortune-cookie-2026', title: '올해 포츈쿠키', desc: '2026년 키워드 뽑기', icon: '🥠', iconClass: 'bg-amber-100 text-amber-700' },
  { href: '/ladder-game', title: '사다리타기', desc: '랜덤 당첨 뽑기', icon: '🪜', iconClass: 'bg-lime-100 text-lime-700' },
  { href: '/ai-image-generator', title: 'AI 이미지 생성기', desc: '피규어와 바디프로필 스타일 이미지 생성', icon: '🪄', iconClass: 'bg-orange-100 text-orange-700' },
  { href: '/tools/product-detail-studio', title: 'AI 상세페이지 생성기', desc: '사진과 프롬프트로 쇼핑몰 상세페이지 초안 생성', icon: '🛍️', iconClass: 'bg-rose-100 text-rose-700' },
  { href: '/tools/mkv-to-mp4', title: 'MKV to MP4 변환기', desc: '최대 1.5GB MKV를 MP4로 변환', icon: '🎬', iconClass: 'bg-sky-100 text-sky-700' },
  { href: '/tools/scoreboard', title: '스트리머 점수판', desc: 'OBS용 실시간 스코어보드', icon: '📊', iconClass: 'bg-teal-100 text-teal-700' },
  { href: '/face-shape-test', title: '얼굴형테스트', desc: '질문 기반 얼굴형 추정', icon: '🧑', iconClass: 'bg-slate-100 text-slate-700' },
  { href: '/nickname-generator', title: '닉네임생성기', desc: '랜덤 닉네임 자동 생성', icon: '🏷️', iconClass: 'bg-lime-100 text-lime-700' },
  { href: '/chat-random-picker', title: '채팅 랜덤 뽑기', desc: '채팅 참여자 추첨', icon: '💬', iconClass: 'bg-violet-100 text-violet-700' },
  { href: '/meme-generator', title: '밈 생성기', desc: '이미지+텍스트 밈 제작', icon: '🖼️', iconClass: 'bg-cyan-100 text-cyan-700' },
  { href: '/random-picker', title: '랜덤뽑기', desc: '항목 랜덤 추첨', icon: '🎯', iconClass: 'bg-slate-100 text-slate-700' },
  { href: '/roulette', title: '룰렛', desc: '직접 입력 룰렛 돌리기', icon: '🎡', iconClass: 'bg-pink-100 text-pink-700' },
  { href: '/team-split', title: '팀나누기', desc: '랜덤 팀 자동 배정', icon: '👥', iconClass: 'bg-green-100 text-green-700' },
  { href: '/text-counter', title: '글자수세기', desc: '글자/단어/줄/바이트 계산', icon: '🔤', iconClass: 'bg-blue-100 text-blue-700' },
  { href: '/daily-english-word', title: '오늘의 영단어', desc: '매일 1개 영어 단어 학습', icon: '🇺🇸', iconClass: 'bg-sky-100 text-sky-700' },
  { href: '/daily-sentence', title: '하루 영어 한문장', desc: '매일 한 문장 학습', icon: '🗣️', iconClass: 'bg-indigo-100 text-indigo-700' },
  { href: '/streamer-battle', title: '스트리머 대결 툴', desc: '팀 대결 점수 관리', icon: '🏆', iconClass: 'bg-amber-100 text-amber-700' },
  { href: '/daily-spanish', title: '오늘의 스페인어', desc: '매일 1개 스페인어 표현', icon: '🇪🇸', iconClass: 'bg-rose-100 text-rose-700' },
  { href: '/daily-japanese', title: '오늘의 일본어', desc: '매일 1개 일본어 표현', icon: '🇯🇵', iconClass: 'bg-red-100 text-red-700' },
  { href: '/korean-study-today', title: '오늘의 한국어공부', desc: '매일 1개 한국어 포인트', icon: '🇰🇷', iconClass: 'bg-cyan-100 text-cyan-700' }
];

const cardTitleI18n: Record<string, { en: string; ja: string }> = {
  '/ai-id-photo': { en: 'AI ID Photo', ja: 'AI証明写真' },
  '/ai-passport-photo': { en: 'AI Passport Photo', ja: 'AIパスポート写真' },
  '/ai-headshot': { en: 'AI Headshot', ja: 'AIヘッドショット' },
  '/animal-test': { en: 'Animal Face Test', ja: '動物顔テスト' },
  '/pinball': { en: 'Pinball Game', ja: 'ピンボールゲーム' },
  '/personal-color': { en: 'Personal Color Test', ja: 'パーソナルカラーテスト' },
  '/magic-book': { en: 'Magic Book', ja: 'マジックブック' },
  '/reaction-test': { en: 'Reaction Test', ja: '反応速度テスト' },
  '/fps-aim-sensitivity': { en: 'FPS Aim Sensitivity', ja: 'FPSエイム感度調整' },
  '/ai-calorie-calculator': { en: 'AI Calorie Calculator', ja: 'AIカロリー計算機' },
  '/mbti-test': { en: 'MBTI Test', ja: 'MBTIテスト' },
  '/maps/fishbread': { en: 'Fishbread Map', ja: 'たい焼きマップ' },
  '/maps/solo-dining': { en: 'Solo Dining Map', ja: 'ひとりご飯マップ' },
  '/name-meaning': { en: 'Name Meaning', ja: '名前診断' },
  '/name-compatibility': { en: 'Name Match', ja: '名前相性' },
  '/maps/hidden-cafe': { en: 'Hidden Cafe Map', ja: '隠れカフェマップ' },
  '/maps/local-eats': { en: 'Local Restaurant Map', ja: '地域グルメマップ' },
  '/love-compatibility': { en: 'Love Compatibility', ja: '恋愛相性テスト' },
  '/random-food': { en: 'Random Food', ja: 'ランダム料理おすすめ' },
  '/today-fortune': { en: 'Today Fortune', ja: '今日の運勢' },
  '/fortune-cookie-2026': { en: 'Year Fortune Cookie', ja: '今年のフォーチュンクッキー' },
  '/ladder-game': { en: 'Ladder Game', ja: 'あみだくじ' },
  '/ai-image-generator': { en: 'AI Image Generator', ja: 'AI画像生成' },
  '/tools/product-detail-studio': { en: 'AI Product Detail Studio', ja: 'AI商品詳細ページ生成' },
  '/tools/mkv-to-mp4': { en: 'MKV to MP4 Converter', ja: 'MKVからMP4変換' },
  '/tools/scoreboard': { en: 'Streamer Scoreboard', ja: 'ストリーマースコアボード' },
  '/face-shape-test': { en: 'Face Shape Test', ja: '顔型テスト' },
  '/nickname-generator': { en: 'Nickname Generator', ja: 'ニックネーム生成' },
  '/chat-random-picker': { en: 'Chat Random Picker', ja: 'チャット抽選' },
  '/meme-generator': { en: 'Meme Generator', ja: 'ミーム生成' },
  '/random-picker': { en: 'Random Picker', ja: 'ランダム抽選' },
  '/roulette': { en: 'Roulette', ja: 'ルーレット' },
  '/team-split': { en: 'Team Split', ja: 'チーム分け' },
  '/text-counter': { en: 'Text Counter', ja: '文字数カウンター' },
  '/daily-english-word': { en: 'Daily English Word', ja: '今日の英単語' },
  '/daily-sentence': { en: 'Daily English Sentence', ja: '毎日の英語一文' },
  '/streamer-battle': { en: 'Streamer Battle Tool', ja: 'ストリーマー対決ツール' },
  '/daily-spanish': { en: 'Daily Spanish', ja: '今日のスペイン語' },
  '/daily-japanese': { en: 'Daily Japanese', ja: '今日の日本語' },
  '/korean-study-today': { en: 'Daily Korean Study', ja: '今日の韓国語学習' }
};

const cards = cardSeed.map((card) => {
  const i18n = cardTitleI18n[card.href];
  const title = locale === 'ko' || !i18n ? card.title : i18n[locale];
  const desc = locale === 'ko'
    ? card.desc
    : locale === 'en'
      ? `${title} tool`
      : `${title}ツール`;
  return { ...card, title, desc, href: withLocale(card.href), disabled: card.disabled ?? false };
});

const rowCount = 3;
const rowSize = Math.ceil(cards.length / rowCount);
const rows = Array.from({ length: rowCount }, (_, rowIndex) =>
  cards.slice(rowIndex * rowSize, (rowIndex + 1) * rowSize)
).filter((row) => row.length > 0);
---

<Layout
  title="ManyTool | 무료 온라인 도구, 테스트, 게임, 쇼핑몰 툴 모음"
  description="무료 온라인 도구, 테스트, 브라우저 게임, 지도 서비스, 스마트스토어와 쇼핑몰 운영에 활용할 수 있는 도구를 카드형으로 탐색하는 ManyTool 메인 페이지입니다."
  keywords="무료 온라인 도구, 무료 웹툴, 무료 테스트, 무료 게임, 스마트스토어 툴, 쇼핑몰 툴, 상세페이지 생성기, 지도 도구, 랜덤 도구"
>
  <main class="min-h-screen bg-slate-100">
    <div class="mx-auto max-w-6xl">
      <header class="flex items-center justify-between border-b border-sky-100 px-4 py-3 lg:px-10">
        <a href={withLocale('/')} class="flex items-center gap-3">
          <img src="/favicon.svg" alt="ManyTool 로고" class="h-8 w-8 rounded-lg bg-sky-100 p-1" loading="eager" decoding="async" />
          <h2 class="text-lg font-bold tracking-tight text-slate-900 sm:text-xl">ManyTool</h2>
        </a>
        <div class="flex items-center gap-1 rounded-md border border-slate-200 bg-white p-1 text-xs">
          {langLinks.map((lang) => (
            <a
              href={lang.href}
              class:list={[
                'rounded px-2 py-1 font-semibold',
                lang.code === locale ? 'bg-slate-900 text-white' : 'text-slate-600 hover:bg-slate-100'
              ]}
            >
              {lang.label}
            </a>
          ))}
        </div>
      </header>

      <section class="px-4 py-5 lg:px-10">
        <div class="max-w-md">
          <input
            id="tool-search"
            class="w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none focus:border-sky-400"
            placeholder={t.searchPlaceholder}
            type="text"
          />
        </div>

        <div class="mt-5">
          <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{t.heroTitle}</h1>
          <p class="mt-1 text-slate-500">{t.heroDesc}</p>
        </div>

        <div class="mt-4 flex gap-2 overflow-x-auto pb-2">
          {t.tabs.map((tab, idx) => (
            <button
              class:list={[
                'whitespace-nowrap rounded-full px-4 py-2 text-sm font-medium',
                idx === 0
                  ? 'bg-sky-500 text-white'
                  : 'border border-sky-100 bg-white text-slate-600'
              ]}
            >
              {tab}
            </button>
          ))}
        </div>
      </section>

      <div class="px-4 pb-4 lg:px-10">
        <section class="space-y-4">
          {rows.map((row, idx) => (
            <div class="flex items-center gap-2" data-slider data-row={idx} data-row-wrap>
              <button class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-sky-100 bg-white text-lg text-sky-500" data-nav="prev" aria-label={t.prevCard}>‹</button>
              <div class="flex-1 overflow-hidden">
                <div class="flex snap-x snap-mandatory gap-3 overflow-x-auto scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" data-track>
                  {[0, 1, 2].flatMap((dup) =>
                    row.map((card) => (
                    <a
                      href={card.disabled ? undefined : card.href}
                      aria-disabled={card.disabled ? 'true' : 'false'}
                      data-card
                      data-dup={dup}
                      data-disabled={card.disabled ? 'true' : 'false'}
                      data-search={`${card.title} ${card.desc}`.toLowerCase()}
                      class:list={[
                        'min-w-[72vw] snap-start rounded-xl border p-4 transition sm:min-w-[210px] lg:min-w-[230px]',
                        card.disabled
                          ? 'cursor-not-allowed border-slate-200 bg-slate-50 opacity-70'
                          : 'border-sky-100 bg-white hover:shadow-sm'
                      ]}
                    >
                      <div class="flex items-start justify-between gap-3">
                        <div class:list={['flex h-10 w-10 items-center justify-center rounded-lg text-base', card.iconClass]}>{card.icon}</div>
                        {card.disabled ? (
                          <span class="rounded-full border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500">
                            {tRaw('common.soon')}
                          </span>
                        ) : null}
                      </div>
                      <h2 class="mt-3 text-base font-bold tracking-tight text-slate-900">{card.title}</h2>
                      <p class="mt-1 text-xs leading-relaxed text-slate-500">{card.desc}</p>
                    </a>
                  )))}
                </div>
              </div>
              <button class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-sky-100 bg-white text-lg text-sky-500" data-nav="next" aria-label={t.nextCard}>›</button>
            </div>
          ))}
        </section>
      </div>
      <p id="search-empty" class="hidden px-4 pb-4 text-sm text-slate-500 lg:px-10">{t.noResult}</p>

      <section class="px-4 pb-2 lg:px-10">
        <article class="rounded-xl border border-slate-200 bg-white p-5">
          <h2 class="text-xl font-semibold">{t.guideTitle}</h2>
          <p class="mt-2 text-slate-700">
            {t.guideP1}
          </p>
          <p class="mt-2 text-slate-700">
            {t.guideP2}
          </p>
          <div class="mt-5 rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-600">{t.guideDonateHint}</p>
            <button
              id="home-donate-button"
              type="button"
              class="mt-3 w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-slate-800"
            >
              {t.guideDonate}
            </button>
            <p id="home-donate-message" class="mt-2 text-xs text-slate-500"></p>
          </div>
        </article>
      </section>

      <section class="px-4 pb-2 lg:px-10">
        <article class="rounded-xl border border-slate-200 bg-white p-5">
          <h2 class="text-xl font-semibold">{t.faqTitle}</h2>
          <div class="mt-3 space-y-3 text-slate-700">
            <div>
              <h3 class="font-semibold text-slate-900">{t.faqQ1}</h3>
              <p>{t.faqA1}</p>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900">{t.faqQ2}</h3>
              <p>{t.faqA2}</p>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900">{t.faqQ3}</h3>
              <p>{t.faqA3}</p>
            </div>
          </div>
        </article>
      </section>

      <AdSense slotName="Header 아래" />
      <AdSense slotName="본문 상단" />
      <SponsorBanner position="본문 중간" />
      <AdSense slotName="본문 중간" />

      <section class="px-4 pb-10 lg:px-10">
        <Recommend />
        <AdSense slotName="추천 콘텐츠 위" />
      </section>

      <section class="px-4 pb-10 lg:px-10">
        <article class="mx-auto max-w-xl rounded-2xl border border-slate-200 bg-white shadow-sm">
          <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-400">{t.trendingMeta}</p>
              <h2 class="mt-1 text-base font-black tracking-tight text-slate-900">{t.trendingCardsTitle}</h2>
            </div>
            <p class="text-[11px] text-slate-400">{t.trendingCardsDesc}</p>
          </div>
          <div class="px-3 py-2">
            <div id="trending-card-list" class="space-y-1">
              <p id="trending-card-status" class="px-2 py-3 text-sm text-slate-500">{t.trendingLoading}</p>
            </div>
          </div>
          <div class="border-t border-slate-100 px-4 py-2">
            <p id="trending-card-updated" class="text-[11px] text-slate-400"></p>
          </div>
        </article>
      </section>
    </div>
    <Footer />

  </main>

  <script is:inline define:vars={{ apiBase, donateButtonLabel: t.guideDonate, donateText: t }}>
    const sliderRows = document.querySelectorAll('[data-slider]');
    const searchInput = document.getElementById('tool-search');
    const emptyEl = document.getElementById('search-empty');
    const homeDonateButton = document.getElementById('home-donate-button');
    const homeDonateMessage = document.getElementById('home-donate-message');
    const trendingCardListEl = document.getElementById('trending-card-list');
    const trendingCardStatusEl = document.getElementById('trending-card-status');
    const trendingCardUpdatedEl = document.getElementById('trending-card-updated');
    
    const dayKey = () => {
      const now = new Date();
      return `${now.getFullYear()}-${now.getMonth() + 1}-${now.getDate()}`;
    };

    const hash = (text) => {
      let h = 2166136261;
      for (let i = 0; i < text.length; i += 1) {
        h ^= text.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    };

    const mulberry32 = (a) => () => {
      let t = (a += 0x6d2b79f5);
      t = Math.imul(t ^ (t >>> 15), t | 1);
      t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };

    const shuffle = (arr, seedText) => {
      const out = [...arr];
      const rand = mulberry32(hash(seedText));
      for (let i = out.length - 1; i > 0; i -= 1) {
        const j = Math.floor(rand() * (i + 1));
        const tmp = out[i];
        out[i] = out[j];
        out[j] = tmp;
      }
      return out;
    };

    const randomizeRows = () => {
      const key = dayKey();
      sliderRows.forEach((rowEl, rowIndex) => {
        const track = rowEl.querySelector('[data-track]');
        if (!(track instanceof HTMLElement)) return;
        const baseCards = [...track.querySelectorAll('[data-card][data-dup="0"]')];
        if (baseCards.length === 0) return;
        const shuffled = shuffle(baseCards, `${key}:row:${rowIndex}`);
        const nextNodes = [];
        for (let dup = 0; dup < 3; dup += 1) {
          shuffled.forEach((card) => {
            const clone = card.cloneNode(true);
            if (clone instanceof HTMLElement) clone.setAttribute('data-dup', String(dup));
            nextNodes.push(clone);
          });
        }
        track.replaceChildren(...nextNodes);
      });
    };

    randomizeRows();

    sliderRows.forEach((rowEl) => {
      const track = rowEl.querySelector('[data-track]');
      const prevBtn = rowEl.querySelector('[data-nav="prev"]');
      const nextBtn = rowEl.querySelector('[data-nav="next"]');

      if (!track || !prevBtn || !nextBtn) return;
      const step = () => {
        const firstCard = track.querySelector('a');
        if (!firstCard) return 240;
        const cardWidth = firstCard.getBoundingClientRect().width;
        return Math.round(cardWidth + 12);
      };
      const jump = () => Math.max(Math.round(step() * 2.8), Math.round(track.clientWidth * 0.85));

      const setWidth = () => Math.max(0, Math.floor(track.scrollWidth / 3));

      const normalizeLoop = () => {
        const loopWidth = setWidth();
        if (loopWidth <= 0) return;
        const min = 2;
        const max = loopWidth * 2 - 2;
        if (track.scrollLeft >= max) {
          track.scrollLeft -= loopWidth;
        } else if (track.scrollLeft < min) {
          track.scrollLeft += loopWidth;
        }
      };

      const slideNext = () => {
        const amount = jump();
        track.scrollLeft += amount;
        normalizeLoop();
      };

      const slidePrev = () => {
        const amount = jump();
        track.scrollLeft -= amount;
        normalizeLoop();
      };

      prevBtn.addEventListener('click', slidePrev);
      nextBtn.addEventListener('click', slideNext);
      track.addEventListener('scroll', normalizeLoop);

      track.scrollLeft = setWidth();
    });

    const applySearch = () => {
      if (!searchInput) return;
      const keyword = searchInput.value.trim().toLowerCase();
      let visibleTotal = 0;

      sliderRows.forEach((rowEl) => {
        const cards = rowEl.querySelectorAll('[data-card]');
        let rowVisible = 0;

        cards.forEach((cardEl) => {
          const haystack = cardEl.getAttribute('data-search') ?? '';
          const isPrimary = cardEl.getAttribute('data-dup') === '0';
          const matched = (keyword === '' || haystack.includes(keyword)) && (keyword === '' || isPrimary);
          cardEl.classList.toggle('hidden', !matched);
          if (matched) rowVisible += 1;
        });

        rowEl.classList.toggle('hidden', rowVisible === 0);
        visibleTotal += rowVisible;
      });

      if (emptyEl) {
        emptyEl.classList.toggle('hidden', visibleTotal > 0);
      }
    };

    searchInput?.addEventListener('input', applySearch);
    applySearch();

    const renderTrendCards = (items) => {
      if (!(trendingCardListEl instanceof HTMLElement)) return;
      trendingCardListEl.innerHTML = '';
      items.forEach((item) => {
        const link = document.createElement('a');
        link.href = `https://www.google.com/search?q=${encodeURIComponent(item.title)}`;
        link.target = '_blank';
        link.rel = 'nofollow noopener noreferrer';
        link.className = 'group flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-slate-50';
        link.innerHTML = `
          <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-900 text-[11px] font-bold text-white">#${item.rank}</div>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-semibold text-slate-800 group-hover:text-sky-700">${item.title}</p>
          </div>
          <div class="shrink-0 text-[11px] text-slate-400">${item.traffic || ''}</div>
          <div class="shrink-0 text-slate-300">›</div>
        `;
        trendingCardListEl.append(link);
      });
    };

    const renderTrendUpdated = (updatedAt) => {
      if (!(trendingCardUpdatedEl instanceof HTMLElement)) return;
      const d = new Date(updatedAt || Date.now());
      if (Number.isNaN(d.getTime())) {
        trendingCardUpdatedEl.textContent = '';
        return;
      }
      trendingCardUpdatedEl.textContent = `${donateText.trendingUpdated}: ${d.toLocaleString()}`;
    };

    const loadTrends = async () => {
      if (trendingCardStatusEl instanceof HTMLElement) trendingCardStatusEl.textContent = donateText.trendingLoading;
      try {
        const hl = document.documentElement.lang?.startsWith('ja')
          ? 'ja'
          : document.documentElement.lang?.startsWith('en')
            ? 'en-US'
            : 'ko';
        const res = await fetch(`/api/trending?geo=KR&hl=${encodeURIComponent(hl)}&limit=10`, { credentials: 'same-origin' });
        if (!res.ok) throw new Error(`status ${res.status}`);
        const data = await res.json();
        if (!Array.isArray(data.items) || data.items.length === 0) throw new Error('empty');
        renderTrendCards(data.items);
        renderTrendUpdated(data.updatedAt);
        if (trendingCardStatusEl instanceof HTMLElement) trendingCardStatusEl.textContent = '';
      } catch {
        if (trendingCardStatusEl instanceof HTMLElement) trendingCardStatusEl.textContent = donateText.trendingError;
        if (trendingCardUpdatedEl instanceof HTMLElement) trendingCardUpdatedEl.textContent = '';
      }
    };

    loadTrends();

    homeDonateButton?.addEventListener('click', async () => {
      if (!apiBase) {
        if (homeDonateMessage) homeDonateMessage.textContent = donateText.donateUnavailable;
        return;
      }

      homeDonateButton.disabled = true;
      homeDonateButton.textContent = donateText.donateLoading;
      if (homeDonateMessage) homeDonateMessage.textContent = '';

      try {
        const configResponse = await fetch(`${apiBase}/config`);
        const configPayload = await configResponse.json().catch(() => null);
        if (!configResponse.ok || !configPayload?.paymentProducts?.donation) {
          throw new Error(donateText.donateUnavailable);
        }

        const currentUrl = window.location.href;
        const checkoutResponse = await fetch(`${apiBase}/checkout`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            productType: 'donation',
            amount: 100,
            currency: 'USD',
            successUrl: currentUrl,
            returnUrl: currentUrl
          })
        });
        const checkoutPayload = await checkoutResponse.json().catch(() => null);
        if (!checkoutResponse.ok || !checkoutPayload?.checkoutUrl) {
          throw new Error(checkoutPayload?.error || donateText.donateFailed);
        }

        window.location.href = checkoutPayload.checkoutUrl;
      } catch (error) {
        if (homeDonateMessage) {
          homeDonateMessage.textContent = error instanceof Error ? error.message : donateText.donateFailed;
        }
        homeDonateButton.disabled = false;
        homeDonateButton.textContent = donateButtonLabel;
      }
    });

    
  </script>

</Layout>
