---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const apiBase = import.meta.env.PUBLIC_NODE_API_BASE ?? 'http://127.0.0.1:8787';
---

<Layout
  title="AI 증명사진 디버그 뷰 | ManyTool"
  description="생성된 AI 증명사진 job의 원본, 추천 후보, 점수, pipelineReport를 확인하는 디버그 페이지입니다."
  keywords="AI 증명사진 디버그, pipeline report, manytool debug"
  noindex={true}
>
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-8">
    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <p class="inline-flex rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">Debug View</p>
      <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-900">AI 증명사진 파이프라인 디버그</h1>
      <p class="mt-2 text-sm text-slate-600">`jobId` 기준으로 원본과 추천 후보를 비교하고, 후보 점수와 파이프라인 재시도 이력을 한 화면에서 확인합니다.</p>
      <form id="debug-form" class="mt-5 flex flex-col gap-3 sm:flex-row">
        <input id="job-id-input" name="jobId" class="min-w-0 flex-1 rounded-xl border border-slate-300 px-4 py-3 text-sm" placeholder="jobId를 입력하세요" />
        <button class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-slate-800" type="submit">불러오기</button>
      </form>
      <p id="debug-status" class="mt-3 text-xs text-slate-500">URL의 `?jobId=` 또는 입력창으로 생성 기록을 조회할 수 있습니다.</p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a id="debug-back-to-ops" href="/tools/ai-photo-ops" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">운영 요약 보기</a>
        <a id="debug-open-admin" href="/tools/ai-photo-admin" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">관리 허브 보기</a>
      </div>
    </section>

    <section id="debug-ops-context" class="mt-6 hidden rounded-2xl border border-sky-200 bg-sky-50 p-5">
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Shared Ops View</p>
          <h2 class="mt-2 text-xl font-black text-slate-900">넘어온 ops 문맥</h2>
          <p class="mt-2 text-sm text-slate-600">이 debug 화면이 어떤 ops 필터 상태에서 열렸는지 바로 확인합니다.</p>
        </div>
        <a id="debug-ops-context-link" href="/tools/ai-photo-ops" class="rounded-lg border border-sky-300 bg-white px-3 py-2 text-xs font-semibold text-sky-900 transition hover:border-sky-400">
          ops view로 돌아가기
        </a>
      </div>
      <div id="debug-ops-context-grid" class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4"></div>
    </section>

    <section id="debug-overview" class="mt-6 hidden grid gap-4 md:grid-cols-4">
      <article class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Tool</p>
        <p id="overview-tool" class="mt-2 text-lg font-black text-slate-900">-</p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Provider</p>
        <p id="overview-provider" class="mt-2 text-lg font-black text-slate-900">-</p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Quality</p>
        <p id="overview-quality" class="mt-2 text-lg font-black text-slate-900">-</p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Identity</p>
        <p id="overview-identity" class="mt-2 text-lg font-black text-slate-900">-</p>
      </article>
    </section>

    <section id="debug-processing-signals" class="mt-4 hidden rounded-2xl border border-slate-200 bg-white p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Processing Signals</p>
      <div id="debug-processing-signal-chips" class="mt-3 flex flex-wrap gap-2"></div>
    </section>

    <section id="debug-compare-wrap" class="mt-6 hidden rounded-2xl border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-black text-slate-900">원본 / 추천 후보 비교</h2>
          <p class="mt-1 text-sm text-slate-600">추천 후보가 원본에서 얼마나 정리되었는지 바로 비교합니다.</p>
        </div>
        <p id="debug-job-label" class="text-xs text-slate-500"></p>
      </div>
      <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="relative h-80 overflow-hidden rounded-lg bg-slate-100">
          <img id="compare-before" alt="원본" class="h-full w-full object-cover" />
          <div id="compare-after-wrap" class="absolute inset-y-0 left-0 w-1/2 overflow-hidden border-r-2 border-white">
            <img id="compare-after" alt="추천 후보" class="h-full w-full object-cover" />
          </div>
          <div class="pointer-events-none absolute inset-x-0 bottom-2 text-center text-xs font-semibold text-white">드래그로 비교</div>
        </div>
        <input id="compare-slider" type="range" min="0" max="100" value="50" class="mt-3 w-full accent-sky-600" />
      </div>
    </section>

    <section id="debug-feedback-wrap" class="mt-6 hidden rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
      <h2 class="text-lg font-black text-emerald-950">품질 피드백</h2>
      <p id="debug-quality-summary" class="mt-2 text-sm font-semibold text-emerald-950"></p>
      <ul id="debug-quality-feedback" class="mt-3 list-disc space-y-1 pl-5 text-sm text-emerald-900"></ul>
    </section>

    <section id="debug-score-explain-wrap" class="mt-6 hidden rounded-2xl border border-slate-200 bg-white p-5">
      <div>
        <h2 class="text-xl font-black text-slate-900">Score Explanation</h2>
        <p class="mt-1 text-sm text-slate-600">quality / identity 점수 결정 근거를 빠르게 확인합니다.</p>
      </div>
      <div class="mt-4 grid gap-4 xl:grid-cols-2">
        <article class="rounded-2xl border border-sky-200 bg-sky-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Quality Drivers</p>
          <div id="debug-quality-explain" class="mt-3 grid gap-3"></div>
        </article>
        <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Identity Drivers</p>
          <div id="debug-identity-explain" class="mt-3 grid gap-3"></div>
        </article>
      </div>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-[1.4fr_1fr]">
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-black text-slate-900">후보 결과</h2>
        <div id="debug-candidates" class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          <p class="text-sm text-slate-500">불러온 결과가 여기에 표시됩니다.</p>
        </div>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-black text-slate-900">Pipeline Report</h2>
          <div class="flex flex-wrap gap-2">
            <button id="debug-copy-summary" type="button" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">요약 복사</button>
            <button id="debug-download-summary" type="button" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">요약 저장</button>
          </div>
          <div class="flex flex-wrap gap-2">
            <button id="debug-copy-json" type="button" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">JSON 복사</button>
            <button id="debug-download-json" type="button" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">JSON 저장</button>
          </div>
        </div>
        <div id="debug-report-meta" class="mt-4 grid gap-3 sm:grid-cols-2"></div>
        <div id="debug-retries" class="mt-4 hidden rounded-xl border border-amber-100 bg-amber-50 p-4">
          <h3 class="text-sm font-black text-amber-950">재시도 이력</h3>
          <div id="debug-retry-list" class="mt-3 grid gap-2"></div>
        </div>
        <pre id="debug-report" class="mt-4 max-h-[720px] overflow-auto rounded-xl border border-slate-200 bg-slate-50 p-4 text-[11px] leading-5 text-slate-700"></pre>
      </article>
    </section>
  </main>
  <Footer />
  <script is:inline src="/scripts/ai-photo-view-context.js"></script>

  <script define:vars={{ apiBase }} is:inline>
    const API_BASE = apiBase;
    const params = new URLSearchParams(window.location.search);
    const backToOpsLink = document.getElementById('debug-back-to-ops');
    const openAdminLink = document.getElementById('debug-open-admin');
    const opsContextEl = document.getElementById('debug-ops-context');
    const opsContextGridEl = document.getElementById('debug-ops-context-grid');
    const opsContextLinkEl = document.getElementById('debug-ops-context-link');
    const formEl = document.getElementById('debug-form');
    const inputEl = document.getElementById('job-id-input');
    const statusEl = document.getElementById('debug-status');
    const overviewEl = document.getElementById('debug-overview');
    const compareWrapEl = document.getElementById('debug-compare-wrap');
    const feedbackWrapEl = document.getElementById('debug-feedback-wrap');
    const scoreExplainWrapEl = document.getElementById('debug-score-explain-wrap');
    const processingSignalsEl = document.getElementById('debug-processing-signals');
    const processingSignalChipsEl = document.getElementById('debug-processing-signal-chips');
    const candidatesEl = document.getElementById('debug-candidates');
    const reportEl = document.getElementById('debug-report');
    const reportMetaEl = document.getElementById('debug-report-meta');
    const qualityExplainEl = document.getElementById('debug-quality-explain');
    const identityExplainEl = document.getElementById('debug-identity-explain');
    const retriesWrapEl = document.getElementById('debug-retries');
    const retryListEl = document.getElementById('debug-retry-list');
    const jobLabelEl = document.getElementById('debug-job-label');
    const qualitySummaryEl = document.getElementById('debug-quality-summary');
    const qualityFeedbackEl = document.getElementById('debug-quality-feedback');
    const overviewToolEl = document.getElementById('overview-tool');
    const overviewProviderEl = document.getElementById('overview-provider');
    const overviewQualityEl = document.getElementById('overview-quality');
    const overviewIdentityEl = document.getElementById('overview-identity');
    const compareBeforeEl = document.getElementById('compare-before');
    const compareAfterEl = document.getElementById('compare-after');
    const compareAfterWrapEl = document.getElementById('compare-after-wrap');
    const compareSliderEl = document.getElementById('compare-slider');
    const copySummaryBtn = document.getElementById('debug-copy-summary');
    const downloadSummaryBtn = document.getElementById('debug-download-summary');
    const copyJsonBtn = document.getElementById('debug-copy-json');
    const downloadJsonBtn = document.getElementById('debug-download-json');
    const viewContextUtils = window.AIPhotoViewContext;
    let activeOriginalUrl = null;
    let currentJob = null;

    const opsViewUrl = params.get('opsView')?.trim() ?? '';
    const adminViewUrl = params.get('adminView')?.trim() ?? '';

    if (backToOpsLink instanceof HTMLAnchorElement && opsViewUrl) {
      backToOpsLink.href = opsViewUrl;
    }
    if (openAdminLink instanceof HTMLAnchorElement && (adminViewUrl || opsViewUrl)) {
      openAdminLink.href = adminViewUrl || `/tools/ai-photo-admin?${new URLSearchParams({ opsView: opsViewUrl }).toString()}`;
    }

    const setStatus = (text) => {
      if (statusEl) statusEl.textContent = text;
    };

    const formatNumber = (value, digits = 1) => {
      if (typeof value !== 'number' || Number.isNaN(value)) return 'n/a';
      return value.toFixed(digits);
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const getOpsContextSummary = (viewUrl = opsViewUrl) => viewContextUtils?.parseOpsViewUrl(viewUrl) ?? null;

    if (opsContextEl instanceof HTMLElement && opsContextGridEl instanceof HTMLElement && opsViewUrl) {
      const opsContext = getOpsContextSummary(opsViewUrl);
      const contextItems = [
        ['status', opsContext?.status ?? 'all'],
        ['tool', opsContext?.tool ?? 'all'],
        ['provider', opsContext?.provider ?? 'all'],
        ['limit', opsContext?.limit ?? '12'],
        ['sinceHours', opsContext?.sinceHours ?? '24'],
        ['flaggedOnly', String(opsContext?.flaggedOnly ?? false)],
        ['fallbackOnly', String(opsContext?.fallbackOnly ?? false)],
        ['miniTrend', opsContext?.miniTrend ?? 'risk'],
        ['previewKey', opsContext?.previewKey ?? 'none']
      ];
      opsContextEl.classList.remove('hidden');
      if (opsContextLinkEl instanceof HTMLAnchorElement) {
        opsContextLinkEl.href = opsViewUrl;
      }
      opsContextGridEl.innerHTML = contextItems.map(([label, value]) => `
        <article class="rounded-2xl border border-sky-100 bg-white p-4">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(label)}</p>
          <p class="mt-2 text-sm font-bold text-slate-900">${escapeHtml(value)}</p>
        </article>
      `).join('');
    }

    const buildDebugExportPayload = () => {
      const exportedAt = new Date().toISOString();
      const opsContext = getOpsContextSummary(opsViewUrl);
      return viewContextUtils?.createExportEnvelope('debug', {
        job: currentJob,
        adminViewUrl: adminViewUrl || null,
        opsViewUrl: opsViewUrl || null,
        opsContext,
        viewContext: viewContextUtils?.createViewContext(opsViewUrl || null, opsContext) ?? { url: opsViewUrl || null, summary: opsContext },
        legacy: viewContextUtils?.createLegacyFields({
          adminViewUrl: adminViewUrl || null,
          opsViewUrl: opsViewUrl || null,
          opsContext
        }),
        exportMeta: viewContextUtils?.createExportMeta('debug', exportedAt) ?? { source: 'debug', exportedAt },
        exportedAt
      }, exportedAt) ?? {
        schemaVersion: 'ai-photo-view-context.v1',
        surface: 'debug',
        job: currentJob,
        adminViewUrl: adminViewUrl || null,
        opsViewUrl: opsViewUrl || null,
        opsContext,
        viewContext: viewContextUtils?.createViewContext(opsViewUrl || null, opsContext) ?? { url: opsViewUrl || null, summary: opsContext },
        legacy: viewContextUtils?.createLegacyFields({
          adminViewUrl: adminViewUrl || null,
          opsViewUrl: opsViewUrl || null,
          opsContext
        }),
        exportMeta: viewContextUtils?.createExportMeta('debug', exportedAt) ?? { source: 'debug', exportedAt },
        exportedAt
      };
    };

    const buildDebugSummary = () => {
      const exportPayload = buildDebugExportPayload();
      const report = currentJob?.pipelineReport ?? null;
      const viewSummary = exportPayload.viewContext?.summary ?? null;
      const candidates = Array.isArray(currentJob?.candidateBreakdown) ? currentJob.candidateBreakdown : [];
      const rejectedCandidates = Array.isArray(currentJob?.rejectedVariantBreakdown) ? currentJob.rejectedVariantBreakdown : [];
      const lines = [
        'AI photo debug summary',
        `exportedAt: ${exportPayload.exportedAt ?? exportPayload.exportMeta?.exportedAt ?? new Date().toISOString()}`,
        `surface: ${exportPayload.surface ?? 'debug'}`,
        `jobId: ${currentJob?.id ?? 'n/a'}`,
        `toolType: ${currentJob?.toolType ?? report?.toolType ?? 'n/a'}`,
        `provider: ${currentJob?.provider ?? report?.resolvedProvider ?? 'n/a'}`,
        `status: ${currentJob?.status ?? 'n/a'}`
      ];

      lines.push('', '[schema]');
      lines.push(`- schemaVersion: ${exportPayload.schemaVersion ?? 'ai-photo-view-context.v1'}`);
      lines.push(`- surface: ${exportPayload.surface ?? 'debug'}`);
      lines.push(`- canonicalViewContext: ${exportPayload.legacy ? 'viewContext (legacy fields preserved)' : 'viewContext'}`);
      lines.push('', '[viewContext]');
      lines.push(`- url: ${exportPayload.viewContext?.url ?? 'none'}`);
      lines.push(`- summary: ${viewContextUtils?.formatViewContextSummary(viewSummary) ?? 'status=all, tool=all, provider=all, limit=12, sinceHours=24, flaggedOnly=false, fallbackOnly=false, miniTrend=risk, previewKey=none'}`);
      lines.push('', '[adminLink]');
      lines.push(`- url: ${exportPayload.adminViewUrl ?? 'none'}`);
      lines.push('', '[exportMeta]');
      lines.push(`- source: ${exportPayload.exportMeta?.source ?? 'debug'}`);
      lines.push(`- exportedAt: ${exportPayload.exportMeta?.exportedAt ?? new Date().toISOString()}`);

      if (currentJob) {
        lines.push('', '[job]');
        lines.push(`- originalUrl: ${currentJob.originalUrl ?? 'n/a'}`);
        lines.push(`- recommendedImageUrl: ${currentJob.recommendedImageUrl ?? 'n/a'}`);
        lines.push(`- cropProfile: ${currentJob.cropProfile ?? 'n/a'}`);
        lines.push(`- poseProfile: ${currentJob.poseProfile ?? 'n/a'}`);
        lines.push(`- suitTemplate: ${currentJob.suitTemplate ?? 'n/a'}`);
        lines.push(`- qualityScore: ${formatNumber(currentJob.qualityScore)}`);
        lines.push(`- identityScore: ${formatNumber(currentJob.identityScore)}`);
      }

      if (report) {
        lines.push('', '[pipelineReport]');
        lines.push(`- requestedProvider: ${report.requestedProvider ?? 'n/a'}`);
        lines.push(`- resolvedProvider: ${report.fallbackToLocalSharp ? 'local_sharp (fallback)' : (report.resolvedProvider ?? 'n/a')}`);
        lines.push(`- backgroundProvider: ${report.backgroundProvider ?? 'n/a'}`);
        lines.push(`- qualitySummary: ${report.qualitySummary ?? 'n/a'}`);
        lines.push(`- recommendedVariant: ${report.recommendedVariant ?? 'n/a'}`);
        lines.push(`- qualityScoreBeforeRetry: ${report.qualityScoreBeforeRetry ?? 'n/a'}`);
        lines.push(`- finalQualityRetryTriggered: ${Boolean(report.finalQualityRetryTriggered)}`);
        lines.push(`- finalQualityRetryProfile: ${report.finalQualityRetryProfile ?? 'n/a'}`);
        lines.push(`- identityRejectedVariants: ${JSON.stringify(report.identityRejectedVariants ?? [])}`);
        lines.push(`- identityRegeneratedVariants: ${JSON.stringify(report.identityRegeneratedVariants ?? [])}`);
      }

      if (candidates.length || rejectedCandidates.length) {
        lines.push('', '[candidates]');
        candidates.forEach((candidate) => {
          lines.push(`- ${candidate.variant ?? 'unknown'}: quality=${formatNumber(candidate.qualityScore)}, identity=${formatNumber(candidate.identityScore)}, recommended=${Boolean(candidate.recommended)}, regenerated=${Boolean(candidate.regenerated)}`);
        });
        rejectedCandidates.forEach((candidate) => {
          lines.push(`- rejected ${candidate.variant ?? 'unknown'}: quality=${formatNumber(candidate.qualityScore)}, identity=${formatNumber(candidate.identityScore)}`);
        });
      }

      return lines.join('\n');
    };

    const scoreTone = (score) => {
      if (score >= 90) return 'emerald';
      if (score >= 80) return 'sky';
      if (score >= 70) return 'amber';
      return 'rose';
    };

    const reportMetaPairs = (report) => ([
      ['requestedProvider', report?.requestedProvider ?? 'n/a'],
      ['resolvedProvider', report?.fallbackToLocalSharp ? 'local_sharp (fallback)' : (report?.resolvedProvider ?? 'n/a')],
      ['backgroundProvider', report?.backgroundProvider ?? 'n/a'],
      ['cropProfile', report?.cropProfile ?? 'n/a'],
      ['poseProfile', report?.poseProfile ?? 'n/a'],
      ['suitTemplate', report?.suitTemplate ?? 'n/a'],
      ['suitSelectionReason', report?.suitSelectionReason ?? 'n/a'],
      ['suitSelectionSummary', report?.suitSelectionSummary ?? 'n/a'],
      ['qualityScore', report?.qualityScore ?? 0],
      ['qualityScoreBeforeRetry', report?.qualityScoreBeforeRetry ?? 'n/a'],
      ['identityScore', report?.identityScore ?? 0],
      ['identityThreshold', report?.identityThreshold ?? 0],
      ['finalQualityRetryTriggered', Boolean(report?.finalQualityRetryTriggered)],
      ['finalQualityRetryProfile', report?.finalQualityRetryProfile ?? 'n/a'],
      ['externalBackgroundCall', Boolean(report?.externalBackgroundCall)],
      ['cache.aligned', Boolean(report?.cache?.aligned)],
      ['cache.cutout', Boolean(report?.cache?.cutout)],
      ['cache.flattened', Boolean(report?.cache?.flattened)],
      ['generatedVariants', Array.isArray(report?.generatedVariants) ? report.generatedVariants.join(', ') : 'n/a'],
      ['timings.detect', `${report?.timings?.detect ?? 0}ms`],
      ['timings.align', `${report?.timings?.align ?? 0}ms`],
      ['timings.pose', `${report?.timings?.pose ?? 0}ms`],
      ['timings.cutout', `${report?.timings?.cutout ?? 0}ms`],
      ['timings.flatten', `${report?.timings?.flatten ?? 0}ms`],
      ['timings.relight', `${report?.timings?.relight ?? 0}ms`],
      ['timings.finalRetry', `${report?.timings?.finalRetry ?? 0}ms`],
      ['timings.variants', `${report?.timings?.variants ?? 0}ms`]
    ]);

    const renderProcessingSignals = (report) => {
      if (!(processingSignalsEl instanceof HTMLElement) || !(processingSignalChipsEl instanceof HTMLElement)) return;
      if (!report) {
        processingSignalsEl.classList.add('hidden');
        processingSignalChipsEl.innerHTML = '';
        return;
      }
      const resolvedProvider = report.fallbackToLocalSharp
        ? `local_sharp fallback from ${report.resolvedProvider ?? 'unknown'}`
        : (report.resolvedProvider ?? 'unknown');
      const callMode = report.externalBackgroundCall ? 'external' : 'local';
      const cacheHits = ['aligned', 'cutout', 'flattened'].filter((key) => Boolean(report?.cache?.[key]));
      const cacheLabel = cacheHits.length ? `cache:${cacheHits.join('+')}` : 'cache:miss';
      processingSignalsEl.classList.remove('hidden');
      processingSignalChipsEl.innerHTML = [
        `<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">provider ${escapeHtml(resolvedProvider)}</span>`,
        `<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">${escapeHtml(callMode)}</span>`,
        `<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">${escapeHtml(cacheLabel)}</span>`
      ].join('');
    };

    const renderMetaGrid = (report) => {
      if (!(reportMetaEl instanceof HTMLElement)) return;
      reportMetaEl.innerHTML = reportMetaPairs(report).map(([label, value]) => `
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">${label}</p>
          <p class="mt-1 text-sm font-bold text-slate-900">${String(value)}</p>
        </div>
      `).join('');
    };

    const renderReport = (report) => {
      if (!(reportEl instanceof HTMLElement)) return;
      const lines = [
        `toolType: ${report?.toolType ?? 'n/a'}`,
        `outfitType: ${report?.outfitType ?? 'n/a'}`,
        `qualitySummary: ${report?.qualitySummary ?? 'n/a'}`,
        `qualityFeedback: ${JSON.stringify(report?.qualityFeedback ?? [])}`,
        `suitSelectionReason: ${report?.suitSelectionReason ?? 'n/a'}`,
        `suitSelectionSummary: ${report?.suitSelectionSummary ?? 'n/a'}`,
        `suitSelectionInputs: ${JSON.stringify(report?.suitSelectionInputs ?? {})}`,
        `variantScores: ${JSON.stringify(report?.variantScores ?? {})}`,
        `variantIdentityScores: ${JSON.stringify(report?.variantIdentityScores ?? {})}`,
        `recommendedVariant: ${report?.recommendedVariant ?? 'n/a'}`,
        `finalQualityRetryAttempts: ${JSON.stringify(report?.finalQualityRetryAttempts ?? [])}`,
        `identityRegeneratedVariants: ${JSON.stringify(report?.identityRegeneratedVariants ?? [])}`,
        `identityRejectedVariants: ${JSON.stringify(report?.identityRejectedVariants ?? [])}`,
        `identityFallbackKept: ${report?.identityFallbackKept ?? 'n/a'}`,
        `poseAttempts: ${JSON.stringify(report?.poseAttempts ?? [])}`,
        `poseMetrics: ${JSON.stringify(report?.poseMetrics ?? {})}`,
        `relightMetrics: ${JSON.stringify(report?.relightMetrics ?? {})}`
      ];
      reportEl.textContent = lines.join('\n');
    };

    const renderRetryCards = (report) => {
      if (!(retriesWrapEl instanceof HTMLElement) || !(retryListEl instanceof HTMLElement)) return;
      const retries = Array.isArray(report?.finalQualityRetryAttempts) ? report.finalQualityRetryAttempts : [];
      const poseAttempts = Array.isArray(report?.poseAttempts) ? report.poseAttempts : [];
      const cards = [];

      retries.forEach((item) => {
        cards.push(`
          <article class="rounded-xl border border-amber-200 bg-white p-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">Final Retry</p>
            <p class="mt-1 text-sm font-black text-slate-900">${item.profile}</p>
            <p class="mt-1 text-xs text-slate-600">qualityScore ${item.qualityScore ?? 'n/a'}</p>
            <p class="mt-1 text-xs text-slate-500">${Array.isArray(item.issues) && item.issues.length ? item.issues.join(', ') : 'issues 없음'}</p>
          </article>
        `);
      });

      poseAttempts.forEach((item, index) => {
        cards.push(`
          <article class="rounded-xl border border-slate-200 bg-white p-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Pose Attempt ${index + 1}</p>
            <p class="mt-1 text-sm font-black text-slate-900">${item.profile ?? 'unknown'}</p>
            <p class="mt-1 text-xs text-slate-600">roll ${Number(item.roll ?? 0).toFixed(2)} / yawBias ${Number(item.yawBias ?? 0).toFixed(3)}</p>
          </article>
        `);
      });

      if (!cards.length) {
        retriesWrapEl.classList.add('hidden');
        retryListEl.innerHTML = '';
        return;
      }

      retriesWrapEl.classList.remove('hidden');
      retryListEl.innerHTML = cards.join('');
    };

    const renderOverview = (job) => {
      const report = job?.pipelineReport ?? {};
      if (overviewEl instanceof HTMLElement) overviewEl.classList.remove('hidden');
      if (jobLabelEl instanceof HTMLElement) {
        jobLabelEl.textContent = `jobId ${job?.id ?? '-'} · ${job?.status ?? 'unknown'}`;
      }
      if (overviewToolEl instanceof HTMLElement) overviewToolEl.textContent = report.toolType ?? job?.toolType ?? '-';
      if (overviewProviderEl instanceof HTMLElement) overviewProviderEl.textContent = report.fallbackToLocalSharp ? 'local_sharp (fallback)' : (report.resolvedProvider ?? '-');
      if (overviewQualityEl instanceof HTMLElement) overviewQualityEl.textContent = typeof report.qualityScore === 'number' ? report.qualityScore.toFixed(1) : '-';
      if (overviewIdentityEl instanceof HTMLElement) overviewIdentityEl.textContent = typeof report.identityScore === 'number' ? report.identityScore.toFixed(1) : '-';
    };

    const renderFeedback = (report) => {
      if (!(feedbackWrapEl instanceof HTMLElement)) return;
      const summary = report?.qualitySummary;
      if (!summary) {
        feedbackWrapEl.classList.add('hidden');
        return;
      }
      feedbackWrapEl.classList.remove('hidden');
      if (qualitySummaryEl instanceof HTMLElement) qualitySummaryEl.textContent = summary;
      if (qualityFeedbackEl instanceof HTMLElement) {
        const feedback = Array.isArray(report?.qualityFeedback) ? report.qualityFeedback : [];
        qualityFeedbackEl.innerHTML = feedback.map((item) => `<li>${item}</li>`).join('');
      }
    };

    const renderScoreExplain = (job) => {
      if (!(scoreExplainWrapEl instanceof HTMLElement) || !(qualityExplainEl instanceof HTMLElement) || !(identityExplainEl instanceof HTMLElement)) return;
      const report = job?.pipelineReport ?? {};
      const qualityScore = typeof report.qualityScore === 'number' ? report.qualityScore : null;
      const qualityBeforeRetry = typeof report.qualityScoreBeforeRetry === 'number' ? report.qualityScoreBeforeRetry : null;
      const retryDelta = qualityScore !== null && qualityBeforeRetry !== null ? qualityScore - qualityBeforeRetry : null;
      const qualityTone = scoreTone(Number(qualityScore ?? 0));
      const qualityFeedback = Array.isArray(report.qualityFeedback) ? report.qualityFeedback : [];
      const qualityIssueCodes = Array.isArray(report.qualityIssueCodes) ? report.qualityIssueCodes : [];
      const qualityMetrics = report.qualityMetrics ?? {};
      const identityScore = typeof report.identityScore === 'number' ? report.identityScore : null;
      const identityThreshold = typeof report.identityThreshold === 'number' ? report.identityThreshold : null;
      const identityTone = scoreTone(Number(identityScore ?? 0));
      const identitySummary = report.identitySummary ?? null;
      const variantIdentityScores = Object.entries(report.variantIdentityScores ?? {}).sort((a, b) => Number(b[1] ?? 0) - Number(a[1] ?? 0));
      const topIdentity = identitySummary?.topVariant ?? variantIdentityScores[0] ?? null;
      const lowIdentity = identitySummary?.lowestVariant ?? variantIdentityScores[variantIdentityScores.length - 1] ?? null;
      const rejectedVariants = Array.isArray(identitySummary?.rejectedVariants) ? identitySummary.rejectedVariants : (Array.isArray(report.identityRejectedVariants) ? report.identityRejectedVariants : []);
      const regeneratedVariants = Array.isArray(identitySummary?.regeneratedVariants) ? identitySummary.regeneratedVariants : (Array.isArray(report.identityRegeneratedVariants) ? report.identityRegeneratedVariants : []);
      const variantDecisionTrace = Array.isArray(report.variantDecisionTrace) ? report.variantDecisionTrace : [];

      scoreExplainWrapEl.classList.remove('hidden');
      qualityExplainEl.innerHTML = `
        <div class="rounded-xl border border-${qualityTone}-200 bg-white p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-${qualityTone}-600">score status</p>
          <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(qualityScore)}</p>
          <p class="mt-1 text-xs text-slate-500">${escapeHtml(report.qualitySummary ?? 'quality summary n/a')}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">retry effect</p>
          <p class="mt-1 text-sm font-bold text-slate-900">${retryDelta === null ? 'retry data 없음' : `before ${formatNumber(qualityBeforeRetry)} -> after ${formatNumber(qualityScore)} (${retryDelta > 0 ? '+' : ''}${formatNumber(retryDelta)})`}</p>
          <p class="mt-1 text-xs text-slate-500">${report.finalQualityRetryTriggered ? `retry profile ${escapeHtml(report.finalQualityRetryProfile ?? 'n/a')}` : 'final retry skipped'}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">main reasons</p>
          <ul class="mt-2 list-disc space-y-1 pl-4 text-sm text-slate-700">
            ${qualityFeedback.length ? qualityFeedback.map((item) => `<li>${escapeHtml(item)}</li>`).join('') : '<li>quality feedback 없음</li>'}
          </ul>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">issue codes / metrics</p>
          <p class="mt-1 text-sm font-bold text-slate-900">${qualityIssueCodes.length ? qualityIssueCodes.map((item) => escapeHtml(item)).join(', ') : 'issue codes 없음'}</p>
          <p class="mt-1 text-xs text-slate-500">centerX ${formatNumber(qualityMetrics.centerX)} / eyeLine ${formatNumber(qualityMetrics.eyeLineRatio)} / faceWidth ${formatNumber(qualityMetrics.faceWidthRatio)} / headroom ${formatNumber(qualityMetrics.topHeadMarginRatio)}</p>
        </div>
      `;

      identityExplainEl.innerHTML = `
        <div class="rounded-xl border border-${identityTone}-200 bg-white p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-${identityTone}-600">score status</p>
          <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(identityScore)}</p>
          <p class="mt-1 text-xs text-slate-500">threshold ${formatNumber(identityThreshold)} / recommended ${escapeHtml(identitySummary?.recommendedVariant ?? report.recommendedVariant ?? 'n/a')}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">variant compare</p>
          <p class="mt-1 text-sm font-bold text-slate-900">${topIdentity ? `top ${escapeHtml(topIdentity.variant ?? topIdentity[0])} ${formatNumber(Number(topIdentity.score ?? topIdentity[1]))}` : 'identity data 없음'}</p>
          <p class="mt-1 text-sm font-bold text-slate-900">${lowIdentity ? `low ${escapeHtml(lowIdentity.variant ?? lowIdentity[0])} ${formatNumber(Number(lowIdentity.score ?? lowIdentity[1]))}` : 'identity data 없음'}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">decision trace</p>
          <div class="mt-2 flex flex-wrap gap-2">
            ${rejectedVariants.length ? rejectedVariants.map((item) => `<span class="rounded-full bg-rose-100 px-2.5 py-1 text-[11px] font-semibold text-rose-900">rejected ${escapeHtml(item)}</span>`).join('') : '<span class="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-700">rejected none</span>'}
            ${regeneratedVariants.length ? regeneratedVariants.map((item) => `<span class="rounded-full bg-amber-100 px-2.5 py-1 text-[11px] font-semibold text-amber-900">regenerated ${escapeHtml(item)}</span>`).join('') : '<span class="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-700">regenerated none</span>'}
            ${report.identityFallbackKept ? `<span class="rounded-full bg-sky-100 px-2.5 py-1 text-[11px] font-semibold text-sky-900">fallback kept ${escapeHtml(report.identityFallbackKept)}</span>` : ''}
          </div>
          <div class="mt-3 grid gap-2">
            ${variantDecisionTrace.length
              ? variantDecisionTrace.map((item) => `
                  <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                    <p class="text-sm font-bold text-slate-900">${escapeHtml(item.variant)} / ${formatNumber(item.identityScore)}</p>
                    <p class="mt-1 text-xs text-slate-500">${item.accepted ? 'accepted' : 'rejected'}${item.regenerated ? ' / regenerated' : ''}</p>
                  </div>
                `).join('')
              : '<p class="text-sm text-slate-500">decision trace 없음</p>'}
          </div>
        </div>
      `;
    };

    const setCompareImages = (originalUrl, candidateUrl) => {
      if (!originalUrl || !candidateUrl) return;
      activeOriginalUrl = originalUrl;
      if (compareWrapEl instanceof HTMLElement) compareWrapEl.classList.remove('hidden');
      if (compareBeforeEl instanceof HTMLImageElement) compareBeforeEl.src = originalUrl;
      if (compareAfterEl instanceof HTMLImageElement) compareAfterEl.src = candidateUrl;
      if (compareAfterWrapEl instanceof HTMLElement) compareAfterWrapEl.style.width = '50%';
      if (compareSliderEl instanceof HTMLInputElement) compareSliderEl.value = '50';
    };

    const renderCompare = (job) => {
      const originalUrl = job?.originalUrl ? `${API_BASE}${job.originalUrl}` : null;
      const candidates = Array.isArray(job?.candidates) ? job.candidates : [];
      const recommended = candidates.find((item) => item.recommended) ?? candidates[0] ?? null;
      if (!originalUrl || !recommended || !(compareWrapEl instanceof HTMLElement)) {
        compareWrapEl?.classList.add('hidden');
        return;
      }
      setCompareImages(originalUrl, `${API_BASE}${recommended.imageUrl}`);
    };

    const renderCandidates = (job) => {
      if (!(candidatesEl instanceof HTMLElement)) return;
      const report = job?.pipelineReport ?? {};
      const qualityScore = typeof report.qualityScore === 'number' ? report.qualityScore : null;
      const candidates = Array.isArray(job?.candidates) ? job.candidates : [];
      const originalUrl = job?.originalUrl ? `${API_BASE}${job.originalUrl}` : null;
      if (!candidates.length) {
        candidatesEl.innerHTML = '<p class="text-sm text-slate-500">후보가 없습니다.</p>';
        return;
      }
      candidatesEl.innerHTML = candidates.map((item, index) => `
        <article class="overflow-hidden rounded-2xl border ${item.recommended ? 'border-amber-300 ring-2 ring-amber-200' : 'border-slate-200'} bg-white shadow-sm">
          <div class="relative">
            <img src="${API_BASE}${item.imageUrl}" alt="candidate ${index + 1}" class="h-64 w-full object-cover" />
            <div class="absolute left-3 top-3 flex items-center gap-2">
              <span class="rounded-full bg-white/95 px-2.5 py-1 text-[11px] font-black text-slate-900">${index + 1}번</span>
              ${item.recommended ? '<span class="rounded-full bg-amber-300/95 px-2.5 py-1 text-[11px] font-black text-amber-950">추천</span>' : ''}
            </div>
          </div>
          <div class="space-y-2 p-4">
            <div class="flex flex-wrap gap-2 text-[11px] font-semibold">
              <span class="rounded-full bg-slate-100 px-2 py-1 text-slate-700">추천 점수 ${typeof item.score === 'number' ? item.score.toFixed(1) : 'n/a'}</span>
              <span class="rounded-full bg-slate-100 px-2 py-1 text-slate-700">동일성 ${typeof item.identityScore === 'number' ? item.identityScore.toFixed(1) : 'n/a'}</span>
              <span class="rounded-full bg-slate-100 px-2 py-1 text-slate-700">규격 ${typeof qualityScore === 'number' ? qualityScore.toFixed(1) : 'n/a'}</span>
              ${item.regenerated ? '<span class="rounded-full bg-amber-100 px-2 py-1 text-amber-800">안전 재생성</span>' : ''}
            </div>
            <div class="space-y-2 rounded-xl border border-slate-200 bg-slate-50 p-3">
              <div>
                <div class="mb-1 flex items-center justify-between text-[11px] font-semibold text-slate-600">
                  <span>추천 점수</span>
                  <span>${typeof item.score === 'number' ? item.score.toFixed(1) : 'n/a'}</span>
                </div>
                <div class="h-2 overflow-hidden rounded-full bg-slate-200">
                  <div class="h-full rounded-full bg-amber-400" style="width:${Math.max(0, Math.min(100, Number(item.score ?? 0)))}%"></div>
                </div>
              </div>
              <div>
                <div class="mb-1 flex items-center justify-between text-[11px] font-semibold text-slate-600">
                  <span>동일성</span>
                  <span>${typeof item.identityScore === 'number' ? item.identityScore.toFixed(1) : 'n/a'}</span>
                </div>
                <div class="h-2 overflow-hidden rounded-full bg-slate-200">
                  <div class="h-full rounded-full bg-emerald-500" style="width:${Math.max(0, Math.min(100, Number(item.identityScore ?? 0)))}%"></div>
                </div>
              </div>
              <div>
                <div class="mb-1 flex items-center justify-between text-[11px] font-semibold text-slate-600">
                  <span>규격 점수</span>
                  <span>${typeof qualityScore === 'number' ? qualityScore.toFixed(1) : 'n/a'}</span>
                </div>
                <div class="h-2 overflow-hidden rounded-full bg-slate-200">
                  <div class="h-full rounded-full bg-sky-500" style="width:${Math.max(0, Math.min(100, Number(qualityScore ?? 0)))}%"></div>
                </div>
              </div>
            </div>
            ${originalUrl ? `
              <div class="grid grid-cols-2 gap-2 overflow-hidden rounded-xl border border-slate-200 bg-slate-50 p-2">
                <div>
                  <p class="mb-1 text-[10px] font-bold uppercase tracking-[0.18em] text-slate-400">Before</p>
                  <img src="${originalUrl}" alt="original preview" class="h-24 w-full rounded-lg object-cover" />
                </div>
                <div>
                  <p class="mb-1 text-[10px] font-bold uppercase tracking-[0.18em] text-slate-400">After</p>
                  <img src="${API_BASE}${item.imageUrl}" alt="candidate preview ${index + 1}" class="h-24 w-full rounded-lg object-cover" />
                </div>
              </div>
            ` : ''}
            <div class="flex flex-wrap gap-2">
              <button type="button" data-candidate-compare="${API_BASE}${item.imageUrl}" class="inline-flex rounded-lg border border-sky-200 bg-sky-50 px-3 py-2 text-xs font-semibold text-sky-700 hover:bg-sky-100">이 후보로 비교</button>
              <a href="${API_BASE}/download/${item.id}" class="inline-flex rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">다운로드 경로 확인</a>
            </div>
          </div>
        </article>
      `).join('');
    };

    const loadJob = async (jobId) => {
      if (!jobId) {
        setStatus('jobId를 입력하세요.');
        return;
      }
      setStatus('job 정보를 불러오는 중...');
      try {
        const response = await fetch(`${API_BASE}/job/${encodeURIComponent(jobId)}`);
        if (!response.ok) {
          throw new Error(response.status === 404 ? 'job not found' : `request failed (${response.status})`);
        }
        const job = await response.json();
        currentJob = job;
        if (inputEl instanceof HTMLInputElement) inputEl.value = jobId;
        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.set('jobId', jobId);
        window.history.replaceState({}, '', nextUrl);
        renderOverview(job);
        renderProcessingSignals(job.pipelineReport ?? null);
        renderCompare(job);
        renderFeedback(job.pipelineReport ?? null);
        renderScoreExplain(job);
        renderMetaGrid(job.pipelineReport ?? null);
        renderRetryCards(job.pipelineReport ?? null);
        renderReport(job.pipelineReport ?? null);
        renderCandidates(job);
        setStatus('job 정보를 불러왔습니다.');
      } catch (error) {
        setStatus(`불러오기에 실패했습니다. ${error?.message ?? ''}`.trim());
      }
    };

    if (compareSliderEl instanceof HTMLInputElement && compareAfterWrapEl instanceof HTMLElement) {
      compareSliderEl.addEventListener('input', () => {
        compareAfterWrapEl.style.width = `${compareSliderEl.value}%`;
      });
    }

    if (formEl instanceof HTMLFormElement) {
      formEl.addEventListener('submit', (event) => {
        event.preventDefault();
        const jobId = inputEl instanceof HTMLInputElement ? inputEl.value.trim() : '';
        loadJob(jobId);
      });
    }

    if (candidatesEl instanceof HTMLElement) {
      candidatesEl.addEventListener('click', (event) => {
        const target = event.target instanceof HTMLElement ? event.target.closest('[data-candidate-compare]') : null;
        if (!(target instanceof HTMLElement) || !activeOriginalUrl) return;
        const candidateUrl = target.getAttribute('data-candidate-compare');
        if (!candidateUrl) return;
        setCompareImages(activeOriginalUrl, candidateUrl);
        compareWrapEl instanceof HTMLElement && compareWrapEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    if (copyJsonBtn instanceof HTMLButtonElement) {
      copyJsonBtn.addEventListener('click', async () => {
        if (!currentJob) {
          setStatus('먼저 job을 불러오세요.');
          return;
        }
        try {
          await viewContextUtils?.copyText(JSON.stringify(buildDebugExportPayload(), null, 2));
          setStatus('job JSON을 클립보드에 복사했습니다.');
        } catch {
          setStatus('JSON 복사에 실패했습니다.');
        }
      });
    }

    if (copySummaryBtn instanceof HTMLButtonElement) {
      copySummaryBtn.addEventListener('click', async () => {
        if (!currentJob) {
          setStatus('癒쇱? job??遺덈윭?ㅼ꽭??');
          return;
        }
        try {
          await viewContextUtils?.copyText(buildDebugSummary());
          setStatus('job summary를 클립보드에 복사했습니다.');
        } catch {
          setStatus('summary 복사에 실패했습니다.');
        }
      });
    }

    if (downloadSummaryBtn instanceof HTMLButtonElement) {
      downloadSummaryBtn.addEventListener('click', () => {
        if (!currentJob) {
          setStatus('癒쇱? job??遺덈윭?ㅼ꽭??');
          return;
        }
        viewContextUtils?.downloadTextFile(`manytool-ai-photo-job-${currentJob.id ?? 'export'}-summary.txt`, buildDebugSummary());
        setStatus('job summary를 저장했습니다.');
      });
    }

    if (downloadJsonBtn instanceof HTMLButtonElement) {
      downloadJsonBtn.addEventListener('click', () => {
        if (!currentJob) {
          setStatus('먼저 job을 불러오세요.');
          return;
        }
        viewContextUtils?.downloadTextFile(`manytool-ai-photo-job-${currentJob.id ?? 'export'}.json`, JSON.stringify(buildDebugExportPayload(), null, 2), 'application/json');
        setStatus('job JSON을 저장했습니다.');
      });
    }

    const initialJobId = params.get('jobId')?.trim();
    if (initialJobId) {
      if (inputEl instanceof HTMLInputElement) inputEl.value = initialJobId;
      loadJob(initialJobId);
    }
  </script>
</Layout>
