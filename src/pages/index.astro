---
import Layout from '../layouts/Layout.astro';
import AdSense from '../components/AdSense.astro';
import SponsorBanner from '../components/SponsorBanner.astro';
import Recommend from '../components/Recommend.astro';
import Footer from '../components/Footer.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';
const localePrefix = locale === 'ko' ? '' : `/${locale}`;
const withLocale = (path: string) => `${localePrefix}${path}`.replace(/\/{2,}/g, '/');
const strippedPath = pathname.replace(/^\/(en|ja)(?=\/|$)/, '') || '/';
const langLinks = [
  { code: 'ko', label: '한국어', href: `${strippedPath}`.replace(/\/{2,}/g, '/') || '/' },
  { code: 'en', label: 'English', href: `/en${strippedPath}`.replace(/\/{2,}/g, '/') || '/en' },
  { code: 'ja', label: '日本語', href: `/ja${strippedPath}`.replace(/\/{2,}/g, '/') || '/ja' }
];

