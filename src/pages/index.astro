  </main>

  <script is:inline>
    const sliderRows = document.querySelectorAll('[data-slider]');
    const searchInput = document.getElementById('tool-search');
    const emptyEl = document.getElementById('search-empty');
    
    const dayKey = () => {
      const now = new Date();
      return `${now.getFullYear()}-${now.getMonth() + 1}-${now.getDate()}`;
    };

    const hash = (text) => {
      let h = 2166136261;
      for (let i = 0; i < text.length; i += 1) {
        h ^= text.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return h >>> 0;
    };

    const mulberry32 = (a) => () => {
      let t = (a += 0x6d2b79f5);
      t = Math.imul(t ^ (t >>> 15), t | 1);
      t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };

    const shuffle = (arr, seedText) => {
      const out = [...arr];
      const rand = mulberry32(hash(seedText));
      for (let i = out.length - 1; i > 0; i -= 1) {
        const j = Math.floor(rand() * (i + 1));
        const tmp = out[i];
        out[i] = out[j];
        out[j] = tmp;
      }
      return out;
    };

    const randomizeRows = () => {
      const key = dayKey();
      sliderRows.forEach((rowEl, rowIndex) => {
        const track = rowEl.querySelector('[data-track]');
        if (!(track instanceof HTMLElement)) return;
        const baseCards = [...track.querySelectorAll('[data-card][data-dup="0"]')];
        if (baseCards.length === 0) return;
        const shuffled = shuffle(baseCards, `${key}:row:${rowIndex}`);
        const nextNodes = [];
        for (let dup = 0; dup < 3; dup += 1) {
          shuffled.forEach((card) => {
            const clone = card.cloneNode(true);
            if (clone instanceof HTMLElement) clone.setAttribute('data-dup', String(dup));
            nextNodes.push(clone);
          });
        }
        track.replaceChildren(...nextNodes);
      });
    };

    randomizeRows();

    sliderRows.forEach((rowEl) => {
      const track = rowEl.querySelector('[data-track]');
      const prevBtn = rowEl.querySelector('[data-nav="prev"]');
      const nextBtn = rowEl.querySelector('[data-nav="next"]');

      if (!track || !prevBtn || !nextBtn) return;
      const step = () => {
        const firstCard = track.querySelector('a');
        if (!firstCard) return 240;
        const cardWidth = firstCard.getBoundingClientRect().width;
        return Math.round(cardWidth + 12);
      };
      const jump = () => Math.max(Math.round(step() * 2.8), Math.round(track.clientWidth * 0.85));

      const setWidth = () => Math.max(0, Math.floor(track.scrollWidth / 3));

      const normalizeLoop = () => {
        const loopWidth = setWidth();
        if (loopWidth <= 0) return;
        const min = 2;
        const max = loopWidth * 2 - 2;
        if (track.scrollLeft >= max) {
          track.scrollLeft -= loopWidth;
        } else if (track.scrollLeft < min) {
          track.scrollLeft += loopWidth;
        }
      };

      const slideNext = () => {
        const amount = jump();
        track.scrollLeft += amount;
        normalizeLoop();
      };

      const slidePrev = () => {
        const amount = jump();
        track.scrollLeft -= amount;
        normalizeLoop();
      };

      prevBtn.addEventListener('click', slidePrev);
      nextBtn.addEventListener('click', slideNext);
      track.addEventListener('scroll', normalizeLoop);

      track.scrollLeft = setWidth();
    });

    const applySearch = () => {
      if (!searchInput) return;
      const keyword = searchInput.value.trim().toLowerCase();
      let visibleTotal = 0;

      sliderRows.forEach((rowEl) => {
        const cards = rowEl.querySelectorAll('[data-card]');
        let rowVisible = 0;

        cards.forEach((cardEl) => {
          const haystack = cardEl.getAttribute('data-search') ?? '';
          const isPrimary = cardEl.getAttribute('data-dup') === '0';
          const matched = (keyword === '' || haystack.includes(keyword)) && (keyword === '' || isPrimary);
          cardEl.classList.toggle('hidden', !matched);
          if (matched) rowVisible += 1;
        });

        rowEl.classList.toggle('hidden', rowVisible === 0);
        visibleTotal += rowVisible;
      });

      if (emptyEl) {
        emptyEl.classList.toggle('hidden', visibleTotal > 0);
      }
    };

    searchInput?.addEventListener('input', applySearch);
    applySearch();

    
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>
