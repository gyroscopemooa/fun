---
import AiImageGenerator from '../components/home/AiImageGenerator';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';

const seoLinks = [
  { href: '/ai-image-generator/figure', label: 'AI Figure' },
  { href: '/ai-image-generator/body-profile', label: 'AI Body Profile' },
  { href: '/ai-image-generator/travel-background', label: 'AI Travel Background' },
  { href: '/ai-image-generator/europe-style', label: 'AI Europe Style' },
  { href: '/ai-image-generator/snapshot', label: 'AI Snapshot' },
  { href: '/ai-image-generator/kakao-profile', label: 'AI Social Profile' },
  { href: '/ai-image-generator/instagram-photo', label: 'AI Instagram Photo' },
  { href: '/ai-image-generator/hanbok', label: 'AI Hanbok' },
  { href: '/ai-image-generator/kimono', label: 'AI Kimono' },
  { href: '/ai-image-generator/outfit-change', label: 'AI Outfit Change' },
  { href: '/ai-image-generator/streamer-promo', label: 'AI Streamer Promo' },
  { href: '/ai-image-generator/pet-humanizer', label: 'AI Pet Humanizer' },
  { href: '/ai-image-generator/hairstyle', label: 'AI Hairstyle' },
  { href: '/ai-image-generator/interior', label: 'AI Interior' },
  { href: '/ai-image-generator/animation', label: 'AI Animation' },
  { href: '/ai-image-generator/free-style', label: 'AI Free Style' }
];
---

<Layout
  title="AI 이미지 생성기 | 피규어, 바디프로필, 여행 배경, 인스타 스타일 | ManyTool"
  description="사진 한 장으로 AI 피규어, 바디프로필, 해외여행 배경, 유럽여행 스타일, 카톡 프로필, 인스타 사진, 한복/기모노 스타일, 의상변경 이미지를 생성하세요."
  keywords="AI 이미지 생성기, AI 피규어 만들기, AI 바디프로필, AI 여행 배경, AI 유럽여행 스타일, AI 카톡 프로필, AI 인스타 사진, AI 한복 스타일, AI 기모노 스타일, AI 의상변경"
>
  <Header />
  <main>
    <section class="mx-auto max-w-6xl px-4 pt-8">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-black tracking-tight text-slate-900">AI 스타일별 전용 페이지</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">세부 키워드는 아래 전용 URL에서도 바로 확인할 수 있습니다.</p>
        <div class="mt-4 flex flex-wrap gap-3">
          {seoLinks.map((item) => (
            <a href={item.href} class="rounded-full border border-slate-300 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-900 hover:bg-white hover:text-slate-950">
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </section>
    <AiImageGenerator client:load locale="ko" />
  </main>
  <Footer />
</Layout>
