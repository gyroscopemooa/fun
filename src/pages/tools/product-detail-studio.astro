---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ProductDetailStudio from '../../components/home/ProductDetailStudio';
import Layout from '../../layouts/Layout.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const copy = {
  ko: {
    title: '쇼핑몰 상세페이지 제작 툴 | 스마트스토어 상세페이지 생성기 | ManyTool',
    description: '스마트스토어, 쿠팡, 11번가, 자사몰에 올릴 쇼핑몰 상세페이지를 빠르게 만드는 AI 상세페이지 제작 툴입니다. 상품 사진과 상품 정보만으로 판매형 상세페이지 초안, 카피, HTML, PNG, JPG, PDF 저장까지 지원합니다.',
    keywords: '상세페이지 제작, 상세페이지 생성기, 스마트스토어 상세페이지, 쇼핑몰 상세페이지, 오픈마켓 상세페이지, 쿠팡 상세페이지, 쇼핑몰 상세페이지 제작 툴, 상세페이지 만들기, 판매용 상세페이지, 상품 상세페이지 제작, AI 상세페이지',
    heading: '쇼핑몰·스마트스토어·오픈마켓용 상세페이지 제작 툴',
    body: '상품 사진과 상품 정보만 넣으면 스마트스토어, 쿠팡, 11번가, 네이버 스마트스토어, 자사몰에 맞는 판매형 상세페이지 초안을 빠르게 만들 수 있습니다. ManyTool은 무료 온라인 툴도 함께 제공하는 플랫폼이며, 이 페이지는 쇼핑몰 상세페이지 제작에 집중한 상세페이지 생성 도구입니다.',
    points: [
      {
        title: '스마트스토어형 상세페이지 흐름',
        body: '860px 기준의 긴 상세페이지 흐름으로 구성해 스마트스토어, 쿠팡, 자사몰에 올리기 쉬운 형식으로 정리합니다.'
      },
      {
        title: '쇼핑몰 판매 문구 자동 정리',
        body: '상품명, 가격, 타깃 고객, 핵심 포인트를 바탕으로 상품 소개, 장점, 사용 장면, 구매 유도 문구를 한 번에 정리합니다.'
      },
      {
        title: '저장과 재활용까지 지원',
        body: '생성된 결과는 HTML, PNG, JPG, PDF로 저장할 수 있어 쇼핑몰 상세페이지 제작 작업과 외주 검토에도 바로 활용할 수 있습니다.'
      }
    ],
    faq: [
      {
        q: '어떤 곳에 올릴 상세페이지를 만들 수 있나요?',
        a: '스마트스토어, 쿠팡, 11번가, 옥션, G마켓, 자사몰 등 한국형 쇼핑몰과 오픈마켓에서 활용할 수 있는 상세페이지 초안을 만드는 데 맞춰져 있습니다.'
      },
      {
        q: '상품 사진이 적어도 상세페이지 제작이 가능한가요?',
        a: '가능합니다. 업로드한 이미지를 바탕으로 흐름을 구성하고, 부족한 부분은 판매형 카피와 섹션 구조로 보완합니다.'
      },
      {
        q: 'ManyTool은 무료인가요?',
        a: 'ManyTool에는 무료 온라인 툴이 많고, 상세페이지 생성 툴은 결제형 흐름으로 운영됩니다. 다만 검색과 탐색 단계에서 필요한 정보는 이 페이지에서 충분히 확인할 수 있습니다.'
      }
    ]
  },
  en: {
    title: 'Product Detail Studio for Smart Store and Ecommerce | ManyTool',
    description: 'Create marketplace-ready product detail pages for Korean ecommerce channels such as Naver Smart Store, Coupang, 11st, and self-hosted stores.',
    keywords: 'product detail studio, ecommerce detail page, Smart Store detail page, marketplace product page, AI detail page builder',
    heading: 'Product Detail Studio for Korean Ecommerce',
    body: 'Build long-form product detail page drafts for Korean ecommerce channels such as Smart Store, Coupang, and 11st using product images and structured product information.',
    points: [],
    faq: []
  },
  ja: {
    title: '商品詳細ページ生成ツール | ManyTool',
    description: 'スマートストア、クーパン、自社EC向けの商品詳細ページ草案を写真と商品情報から生成します。',
    keywords: '商品詳細ページ, スマートストア, EC商品ページ, AI詳細ページ生成',
    heading: 'ショッピングモール向け商品詳細ページ生成ツール',
    body: '商品写真と商品情報をもとに、韓国EC向けの長い商品詳細ページ草案を素早く作成できます。',
    points: [],
    faq: []
  }
}[locale];
---

<Layout title={copy.title} description={copy.description} keywords={copy.keywords}>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8">
    <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">SEO Landing</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">{copy.heading}</h1>
      <p class="mt-3 max-w-4xl text-sm leading-7 text-slate-600">{copy.body}</p>

      {locale === 'ko' ? (
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {copy.points.map((item) => (
            <article class="rounded-[1.4rem] border border-slate-200 bg-slate-50 p-4">
              <h2 class="text-base font-black text-slate-900">{item.title}</h2>
              <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
            </article>
          ))}
        </div>
      ) : null}

      {locale === 'ko' ? (
        <div class="mt-6 rounded-[1.6rem] border border-slate-200 bg-slate-50 p-5">
          <h2 class="text-lg font-black text-slate-900">상세페이지 제작 키워드 안내</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            이 도구는 스마트스토어 상세페이지, 쇼핑몰 상세페이지 제작, 쿠팡 상세페이지, 오픈마켓 상세페이지, 상품 상세페이지 만들기,
            판매용 상세페이지 초안 작성 같은 검색 의도에 맞춰 설계된 AI 상세페이지 제작 툴입니다.
          </p>
        </div>
      ) : null}
    </section>

    <ProductDetailStudio client:load />

    {locale === 'ko' ? (
      <section class="mt-8 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-black tracking-tight text-slate-900">자주 찾는 검색 의도</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <article class="rounded-[1.4rem] border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-base font-black text-slate-900">스마트스토어 상세페이지 제작</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              스마트스토어에 맞는 860px 기준 상세페이지 흐름, 판매 카피, 긴 세로형 구성까지 한 번에 정리할 수 있는 상세페이지 제작 툴을 찾는 사용자에게 적합합니다.
            </p>
          </article>
          <article class="rounded-[1.4rem] border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-base font-black text-slate-900">쇼핑몰 상세페이지 만들기</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              상품 사진과 기본 정보만으로 쇼핑몰 상세페이지 초안, 판매 문구, 비교 포인트, 디테일 설명을 빠르게 정리해 자사몰이나 오픈마켓에 응용할 수 있습니다.
            </p>
          </article>
          <article class="rounded-[1.4rem] border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-base font-black text-slate-900">오픈마켓 상세페이지 툴</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              쿠팡, 11번가, 옥션, G마켓, 네이버 스마트스토어처럼 상품 페이지 전개가 중요한 오픈마켓용 상세페이지 초안 제작에 활용할 수 있습니다.
            </p>
          </article>
          <article class="rounded-[1.4rem] border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-base font-black text-slate-900">ManyTool 무료 툴과 함께 탐색</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              ManyTool은 무료 온라인 툴이 많은 플랫폼이며, 이 상세페이지 제작 도구는 쇼핑몰 운영자와 셀러를 위한 판매형 상세페이지 생성 작업에 집중합니다.
            </p>
          </article>
        </div>
      </section>
    ) : null}

    {locale === 'ko' ? (
      <section class="mt-8 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-black tracking-tight text-slate-900">FAQ</h2>
        <div class="mt-4 space-y-4">
          {copy.faq.map((item) => (
            <article class="rounded-[1.3rem] border border-slate-200 bg-slate-50 p-4">
              <h3 class="text-base font-black text-slate-900">{item.q}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{item.a}</p>
            </article>
          ))}
        </div>
      </section>
    ) : null}
  </main>
  <Footer />
</Layout>
