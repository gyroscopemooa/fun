---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const t = {
  ko: {
    title: '룰렛 | ManyTool',
    desc: '항목을 입력하고 룰렛을 돌려 결과를 확인하는 도구',
    h1: '룰렛',
    sub: '항목을 입력한 뒤 스핀 버튼을 누르세요.',
    placeholder: '예) 짜장면, 짬뽕, 돈까스',
    spin: '스핀',
    reset: '초기화',
    result: '당첨 결과',
    empty: '항목을 2개 이상 입력하세요.'
  },
  en: {
    title: 'Roulette | ManyTool',
    desc: 'Spin a roulette wheel with your own items',
    h1: 'Roulette',
    sub: 'Add items and press spin.',
    placeholder: 'e.g. Burger, Pizza, Pasta',
    spin: 'Spin',
    reset: 'Reset',
    result: 'Winner',
    empty: 'Please enter at least 2 items.'
  },
  ja: {
    title: 'ルーレット | ManyTool',
    desc: '項目を入力してルーレット抽選するツール',
    h1: 'ルーレット',
    sub: '項目を入力してスピンを押してください。',
    placeholder: '例) うどん, そば, ラーメン',
    spin: 'スピン',
    reset: 'リセット',
    result: '結果',
    empty: '2個以上入力してください。'
  }
}[locale];
---

<Layout title={t.title} description={t.desc}>
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-8">
    <h1 class="text-3xl font-black">{t.h1}</h1>
    <p class="mt-2 text-slate-700">{t.sub}</p>
    <AdSense slotName="본문 상단" />
    <section class="mt-5 grid gap-4 rounded-xl border border-slate-200 bg-white p-6 lg:grid-cols-[300px_1fr]">
      <aside>
        <textarea id="roulette-items" class="h-56 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder={t.placeholder}></textarea>
        <div class="mt-3 flex gap-2">
          <button id="roulette-spin" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">{t.spin}</button>
          <button id="roulette-reset" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold">{t.reset}</button>
        </div>
        <p class="mt-4 text-sm text-slate-700">{t.result}: <b id="roulette-result">-</b></p>
      </aside>
      <div class="flex items-center justify-center">
        <div class="relative">
          <canvas id="roulette-canvas" width="420" height="420" class="h-[320px] w-[320px] rounded-full border border-slate-200 md:h-[420px] md:w-[420px]"></canvas>
          <div class="pointer-events-none absolute left-1/2 top-[-10px] h-0 w-0 -translate-x-1/2 border-l-[10px] border-r-[10px] border-t-[18px] border-l-transparent border-r-transparent border-t-rose-500"></div>
        </div>
      </div>
    </section>
    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />
  <script is:inline define:vars={{ emptyText: t.empty }}>
    const canvas = document.getElementById('roulette-canvas');
    const itemsEl = document.getElementById('roulette-items');
    const spinBtn = document.getElementById('roulette-spin');
    const resetBtn = document.getElementById('roulette-reset');
    const resultEl = document.getElementById('roulette-result');
    const ctx = canvas instanceof HTMLCanvasElement ? canvas.getContext('2d') : null;

    const colors = ['#38bdf8', '#f472b6', '#fb923c', '#34d399', '#a78bfa', '#facc15', '#60a5fa', '#f87171'];
    let currentItems = ['A', 'B', 'C', 'D'];
    let rotation = 0;
    let spinning = false;

    const parseItems = () => {
      const raw = itemsEl instanceof HTMLTextAreaElement ? itemsEl.value : '';
      const list = raw.split(/[\n,]/g).map((v) => v.trim()).filter(Boolean);
      return list.length >= 2 ? list : null;
    };

    const draw = () => {
      if (!ctx || !(canvas instanceof HTMLCanvasElement)) return;
      const w = canvas.width;
      const h = canvas.height;
      const cx = w / 2;
      const cy = h / 2;
      const r = Math.min(w, h) / 2 - 8;
      ctx.clearRect(0, 0, w, h);
      const arc = (Math.PI * 2) / currentItems.length;

      for (let i = 0; i < currentItems.length; i += 1) {
        const start = rotation + i * arc;
        const end = start + arc;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, start, end);
        ctx.closePath();
        ctx.fillStyle = colors[i % colors.length];
        ctx.fill();
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 2;
        ctx.stroke();

        const mid = start + arc / 2;
        ctx.save();
        ctx.translate(cx + Math.cos(mid) * r * 0.62, cy + Math.sin(mid) * r * 0.62);
        ctx.rotate(mid + Math.PI / 2);
        ctx.fillStyle = '#0f172a';
        ctx.font = 'bold 15px sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(currentItems[i].slice(0, 14), 0, 0);
        ctx.restore();
      }
    };

    const pickWinner = () => {
      const arc = (Math.PI * 2) / currentItems.length;
      const pointer = -Math.PI / 2;
      const normalized = ((pointer - rotation) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
      const idx = Math.floor(normalized / arc) % currentItems.length;
      return currentItems[idx];
    };

    const spin = () => {
      if (spinning) return;
      const parsed = parseItems();
      if (!parsed) {
        if (resultEl) resultEl.textContent = emptyText;
        return;
      }
      currentItems = parsed;
      spinning = true;
      const startRot = rotation;
      const extra = Math.PI * 2 * (5 + Math.random() * 3);
      const target = startRot + extra;
      const start = performance.now();
      const duration = 3200;

      const animate = (now) => {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        rotation = startRot + (target - startRot) * eased;
        draw();
        if (t < 1) {
          requestAnimationFrame(animate);
        } else {
          rotation = target % (Math.PI * 2);
          draw();
          spinning = false;
          const winner = pickWinner();
          if (resultEl) resultEl.textContent = winner;
        }
      };
      requestAnimationFrame(animate);
    };

    spinBtn?.addEventListener('click', spin);
    resetBtn?.addEventListener('click', () => {
      if (itemsEl instanceof HTMLTextAreaElement) itemsEl.value = '';
      currentItems = ['A', 'B', 'C', 'D'];
      rotation = 0;
      if (resultEl) resultEl.textContent = '-';
      draw();
    });
    draw();
  </script>
</Layout>
