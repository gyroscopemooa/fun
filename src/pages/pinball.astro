---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Recommend from '../components/Recommend.astro';
import MarbleRoulette from '../components/MarbleRoulette.jsx';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const copy = {
  ko: {
    title: '핀볼 추첨기 | ManyTool',
    description: 'matter.js 기반 핀볼 추첨기에서 구슬이 삼각 핀에 튕기고 마지막 슬롯 위치로 결과를 정합니다.',
    guideTitle: '사용 방법',
    steps: [
      '이름이나 항목을 쉼표 또는 줄바꿈으로 입력합니다.',
      '`사과*2`처럼 입력하면 해당 결과의 가중치가 커집니다.',
      '구슬 개수를 정한 뒤 Start를 누르면 여러 공이 순차적으로 떨어집니다.',
      '아래 슬롯에 들어간 최종 위치 기준으로 결과가 집계됩니다.'
    ]
  },
  en: {
    title: 'Marble Roulette | ManyTool',
    description: 'A matter.js powered marble roulette that drops balls through triangular pins and resolves results by the final slot.',
    guideTitle: 'How It Works',
    steps: [
      'Enter names or options with commas or line breaks.',
      'Use `apple*2` style input to add weight to a result.',
      'Choose the marble count and press Start to drop multiple balls.',
      'The final slot determines each result at the bottom.'
    ]
  },
  ja: {
    title: 'マーブルルーレット | ManyTool',
    description: 'matter.js ベースのピンボール抽選機で、ビー玉が三角ピンに当たり最後のスロット位置で結果を決めます。',
    guideTitle: '使い方',
    steps: [
      '名前や項目をカンマまたは改行で入力します。',
      '`apple*2` のように書くとその結果の重みが大きくなります。',
      'ビー玉数を選んで Start を押すと複数の玉が順番に落ちます。',
      '下の最終スロット位置で結果が集計されます。'
    ]
  }
}[locale];
---

<Layout title={copy.title} description={copy.description}>
  <Header />

  <main class="bg-slate-950 pb-14">
    <section class="mx-auto max-w-7xl px-4 py-6 sm:py-8">
      <MarbleRoulette client:load locale={locale} />
    </section>

    <section class="mx-auto max-w-5xl px-4 pb-6">
      <div class="rounded-[28px] border border-cyan-400/15 bg-white/[0.03] p-6 text-white shadow-[0_20px_60px_rgba(2,6,23,0.32)]">
        <h2 class="text-2xl font-black tracking-tight">{copy.guideTitle}</h2>
        <ol class="mt-4 list-decimal space-y-2 pl-5 text-sm leading-7 text-slate-300">
          {copy.steps.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-4">
      <Recommend />
    </section>
  </main>

  <Footer />
</Layout>
