---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSense from '../../../components/AdSense.astro';
import Recommend from '../../../components/Recommend.astro';
---

<Layout title="인천 붕어빵 지도 | FunHub" description="인천 붕어빵 위치를 빠르게 찾는 지도 페이지">
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-2xl font-bold">인천 붕어빵 위치 지도</h1>
    <p class="mt-3 text-slate-700">인천에서 붕어빵 파는 곳을 찾는 사용자용 랜딩 페이지입니다.</p>
    <AdSense slotName="본문 상단" />
    <div class="mt-4 rounded-lg border bg-white p-6">Incheon Map Placeholder</div>
    <Recommend />
  </main>
  <Footer />
</Layout>
