---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="핀볼 게임 | FunHub" description="웹에서 즐기는 미니 핀볼 게임">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">핀볼 게임</h1>
    <p class="mt-3 text-slate-700">MVP 단계에서는 게임 설명과 플레이 영역 자리만 제공합니다.</p>
    <div class="mt-4 rounded-lg border bg-white p-6 text-center">Game Area Placeholder</div>
    <Recommend />
  </main>
  <Footer />
</Layout>
