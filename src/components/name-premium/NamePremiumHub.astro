---
const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();
---

<section class="relative overflow-hidden bg-[#fbf5f0] text-[#2f2a28]">
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap');
  </style>

  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -left-24 top-16 h-64 w-64 rounded-full bg-[#ff709f]/18 blur-3xl"></div>
    <div class="absolute right-0 top-20 h-72 w-72 rounded-full bg-[#fff176]/25 blur-3xl"></div>
    <div class="absolute bottom-20 left-1/3 h-56 w-56 rounded-full bg-[#7fe6db]/20 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-[1180px] px-4 pb-20 pt-10 sm:px-6 lg:px-8" style="font-family: 'Be Vietnam Pro', 'Pretendard', sans-serif;">
    <nav class="rounded-full border border-white/60 bg-white/70 px-5 py-4 shadow-[0_20px_40px_rgba(48,46,43,0.06)] backdrop-blur">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="text-lg font-bold italic text-[#a7295a]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">The Ethereal Boutique</div>
        <div class="rounded-full bg-[#a7295a] px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-white">Premium Name Analysis</div>
      </div>
    </nav>

    <section class="grid gap-10 pt-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start">
      <div>
        <p class="inline-flex rounded-full bg-[#7fe6db]/60 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.2em] text-[#005a54]">Unified Naming Service</p>
        <h1 class="mt-6 max-w-3xl text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">
          이름풀이, 개명추천, 개명풀이를
          <span class="block text-[#a7295a] italic">한 번에 보는 프리미엄 허브</span>
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[#5f5a57] sm:text-lg">
          이름, 한자, 생년월일, 성별만 입력하면 같은 기준으로 분석과 추천, 상세 풀이가 한 페이지에서 이어집니다.
        </p>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          <article class="rounded-[32px] bg-[#f6f0ea] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#ff709f]/20 text-[#a7295a]">01</div>
            <h2 class="text-xl font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">공통 계산 엔진</h2>
            <p class="mt-3 text-sm leading-7 text-[#5f5a57]">획수, 오격, 81수, 한자 메타를 같은 기준으로 읽어 결과가 흔들리지 않게 맞췄습니다.</p>
          </article>
          <article class="rounded-[32px] bg-[#fff7cb] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#fff176] text-[#655d00]">02</div>
            <h2 class="text-xl font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">한 페이지 흐름</h2>
            <p class="mt-3 text-sm leading-7 text-[#5f5a57]">이름풀이 후 바로 개명추천, 추천 후보에서 바로 상세 풀이까지 내려가며 확인할 수 있습니다.</p>
          </article>
        </div>
      </div>

      <div class="relative">
        <div class="absolute inset-x-8 top-6 h-full rounded-[40px] bg-white/45 blur-2xl"></div>
        <section id="premium-form" class="relative rounded-[36px] bg-white/82 p-5 shadow-[0_28px_80px_rgba(48,46,43,0.08)] backdrop-blur sm:p-7">
          <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.78fr)]">
            <article class="rounded-[30px] bg-[#fdf7f3] p-5">
              <div class="mb-4 flex items-center gap-2 text-sm font-bold text-[#a7295a]">
                <span>✦</span>
                <span>정보 입력하기</span>
              </div>

              <form id="name-premium-form" class="space-y-4">
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5f5a57]">이름</span>
                    <input name="displayName" placeholder="김민지" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5f5a57]">한자</span>
                    <input name="hanjaName" placeholder="金民智" maxlength="3" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5f5a57]">생년월일</span>
                    <input name="birthDate" type="date" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5f5a57]">성별</span>
                    <div class="grid grid-cols-2 gap-3">
                      <label class="cursor-pointer">
                        <input type="radio" name="gender" value="female" class="peer sr-only" checked />
                        <span class="flex items-center justify-center rounded-full bg-white px-4 py-4 text-sm font-semibold text-[#5f5a57] ring-1 ring-[#b1aca8]/20 transition peer-checked:bg-[#a7295a] peer-checked:text-white">여성</span>
                      </label>
                      <label class="cursor-pointer">
                        <input type="radio" name="gender" value="male" class="peer sr-only" />
                        <span class="flex items-center justify-center rounded-full bg-white px-4 py-4 text-sm font-semibold text-[#5f5a57] ring-1 ring-[#b1aca8]/20 transition peer-checked:bg-[#a7295a] peer-checked:text-white">남성</span>
                      </label>
                    </div>
                  </label>
                </div>

                <button type="button" class="w-full rounded-full bg-[#a7295a] px-4 py-4 text-sm font-bold text-white transition hover:scale-[0.98]" data-action="suite">
                  통합 분석 시작
                </button>
              </form>
            </article>

            <article class="rounded-[30px] bg-[#fffdfb] p-5 shadow-inner shadow-[#f1e6df]/70">
              <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">Current Analysis</p>
              <h2 class="mt-4 text-4xl font-extrabold tracking-tight" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-current-name>김 민 지</h2>
              <p class="mt-2 text-sm text-[#5f5a57]" data-current-hanja>(金民智)</p>

              <div class="mt-6 rounded-[24px] bg-[#7fe6db]/30 px-5 py-4">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-[#005a54]">Harmony Score</p>
                    <p class="mt-2 text-4xl font-extrabold text-[#005a54]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-current-score>--</p>
                  </div>
                  <div class="rounded-full bg-white px-4 py-2 text-xs font-bold text-[#005a54]" data-current-grade>입력 대기</div>
                </div>
              </div>

              <div class="mt-6 space-y-3">
                <div class="rounded-[22px] bg-[#f6f0ea] p-4">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#5f5a57]">현재 진행</p>
                  <p class="mt-2 text-sm leading-7 text-[#5f5a57]" data-current-summary>통합 분석을 시작하면 이름풀이, 개명추천, 개명풀이 결과가 아래에 순서대로 채워집니다.</p>
                </div>
                <div class="rounded-[22px] bg-[#fff7cb] p-4">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#655d00]">현재 지원</p>
                  <p class="mt-2 text-sm leading-7 text-[#5f5a57]">단성 기준, 등록된 한자 DB 범위 안에서 먼저 결과를 제공합니다.</p>
                </div>
              </div>
            </article>
          </div>
        </section>
      </div>
    </section>

    <section class="mt-14">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
        <section class="rounded-[36px] bg-[#f6f0ea] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.05)]">
          <div data-panel="analysis">
            <div class="grid gap-5 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
              <article class="rounded-[28px] bg-white p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">이름풀이</p>
                <h3 class="mt-3 text-3xl font-extrabold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-analysis-name>분석 결과 대기</h3>
                <p class="mt-3 text-sm leading-7 text-[#5f5a57]" data-analysis-explanation>통합 분석을 누르면 공통 계산 엔진 기준의 이름풀이가 여기에 표시됩니다.</p>
              </article>
              <article class="rounded-[28px] bg-[#ede7e2] p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#5f5a57]">오격 상세</p>
                <div class="mt-4 grid gap-3 sm:grid-cols-2" data-analysis-grid>
                  <div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5f5a57]">천격, 인격, 지격, 외격, 총격 결과가 여기에 채워집니다.</div>
                </div>
              </article>
            </div>
          </div>

          <div data-panel="recommendation" class="mt-6">
            <p class="mb-4 text-[11px] font-bold uppercase tracking-[0.18em] text-[#005a54]">개명추천</p>
            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-recommend-list>
              <article class="rounded-[28px] bg-white p-6 text-sm text-[#5f5a57]">통합 분석을 시작하면 개명 후보 카드가 여기에 채워집니다.</article>
            </div>
          </div>

          <div data-panel="report" class="mt-6">
            <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)]">
              <article class="rounded-[28px] bg-white p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">개명풀이</p>
                <h3 class="mt-3 text-3xl font-extrabold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-report-name>상세 풀이 대기</h3>
                <p class="mt-3 text-sm leading-7 text-[#5f5a57]" data-report-explanation>분석 또는 추천된 이름 기준의 상세 풀이가 여기에 표시됩니다.</p>
              </article>
              <article class="rounded-[28px] bg-[#fff7cb] p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#655d00]">한자 해석</p>
                <div class="mt-4 space-y-3" data-report-points>
                  <div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5f5a57]">각 글자의 뜻, 획수, 키워드가 여기서 정리됩니다.</div>
                </div>
              </article>
            </div>
          </div>
        </section>

        <aside class="space-y-6">
          <section class="overflow-hidden rounded-[32px] bg-white shadow-[0_20px_40px_rgba(48,46,43,0.05)]">
            <div class="grid min-h-[220px] gap-0 md:grid-cols-[1.2fr_0.8fr]">
              <div class="flex flex-col justify-end bg-[linear-gradient(135deg,rgba(255,112,159,0.14),rgba(255,241,118,0.2))] p-6">
                <div class="rounded-[24px] bg-[#302e2b]/78 p-5 text-white backdrop-blur">
                  <p class="text-sm font-bold">프리미엄 이름 서비스</p>
                  <p class="mt-2 text-sm leading-7 text-white/75">이름풀이에서 끝내지 않고, 개명추천과 상세 풀이까지 같은 화면 안에서 바로 이어집니다.</p>
                </div>
              </div>
              <div class="flex items-center justify-center bg-[#fff7cb] p-6">
                <div class="space-y-3 text-center">
                  <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#fff176] text-[#655d00]">名</div>
                  <p class="text-lg font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">성명학 배치 사전</p>
                  <p class="text-sm leading-7 text-[#5f5a57]">한 번 입력하면 분석과 추천, 풀이가 순서대로 이어지는 단일 서비스 구조입니다.</p>
                </div>
              </div>
            </div>
          </section>

          <section class="rounded-[32px] bg-[#a7295a] px-7 py-8 text-white shadow-[0_20px_40px_rgba(48,46,43,0.08)]">
            <h3 class="text-3xl font-extrabold tracking-tight" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">Need a deeper aura?</h3>
            <p class="mt-4 text-sm leading-7 text-white/80">사주 연동과 이름 추천 풀을 더 붙이면 부족 오행 보완형 개명추천까지 자연스럽게 확장할 수 있습니다.</p>
            <a href="/ai-manseryeok" class="mt-6 inline-flex rounded-full bg-white px-5 py-3 text-sm font-bold text-[#a7295a] transition hover:scale-[0.98]">사주 결과와 연결하기</a>
          </section>
        </aside>
      </div>
    </section>
  </div>
</section>

<script is:inline define:vars={{ rawApiBase }}>
  const API_BASE = (rawApiBase || (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost' ? 'http://127.0.0.1:8787' : '')).replace(/\/+$/, '');
  const form = document.getElementById('name-premium-form');
  const currentNameEl = document.querySelector('[data-current-name]');
  const currentHanjaEl = document.querySelector('[data-current-hanja]');
  const currentScoreEl = document.querySelector('[data-current-score]');
  const currentGradeEl = document.querySelector('[data-current-grade]');
  const currentSummaryEl = document.querySelector('[data-current-summary]');
  const analysisNameEl = document.querySelector('[data-analysis-name]');
  const analysisExplanationEl = document.querySelector('[data-analysis-explanation]');
  const analysisGridEl = document.querySelector('[data-analysis-grid]');
  const recommendListEl = document.querySelector('[data-recommend-list]');
  const reportNameEl = document.querySelector('[data-report-name]');
  const reportExplanationEl = document.querySelector('[data-report-explanation]');
  const reportPointsEl = document.querySelector('[data-report-points]');

  const panelTitleMap = {
    heaven: '천격',
    human: '인격',
    earth: '지격',
    outer: '외격',
    total: '총격'
  };

  const setCurrentSummary = (score, grade, explanation) => {
    if (currentScoreEl) currentScoreEl.textContent = score == null ? '--' : String(score);
    if (currentGradeEl) currentGradeEl.textContent = grade || '입력 대기';
    if (currentSummaryEl) currentSummaryEl.textContent = explanation || '결과가 여기에 표시됩니다.';
  };

  const getFormPayload = () => {
    const formData = new FormData(form);
    const displayName = String(formData.get('displayName') || '').trim();
    const hanjaName = String(formData.get('hanjaName') || '').trim().replace(/\s+/g, '');
    const surname = hanjaName.slice(0, 1);
    const given = hanjaName.slice(1).split('').filter(Boolean);
    const birthDate = String(formData.get('birthDate') || '').trim();
    const gender = String(formData.get('gender') || '').trim();

    if (currentNameEl) currentNameEl.textContent = displayName || '이름 입력 대기';
    if (currentHanjaEl) currentHanjaEl.textContent = hanjaName ? `(${hanjaName})` : '(한자 입력 대기)';

    return { displayName, hanjaName, surname, given, birthDate, gender };
  };

  const renderAnalysis = (payload) => {
    if (analysisNameEl) analysisNameEl.textContent = payload.input ? `${payload.input.surname}${(payload.input.given || []).join('')}` : '분석 결과';
    if (analysisExplanationEl) analysisExplanationEl.textContent = payload.explanation || '설명이 없습니다.';
    if (analysisGridEl) {
      analysisGridEl.innerHTML = (payload.details || []).map((detail) => `
        <div class="rounded-[22px] bg-white px-4 py-4">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#a7295a]">${panelTitleMap[detail.slot] || detail.slot}</p>
          <p class="mt-2 text-2xl font-extrabold text-[#302e2b]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${detail.number}</p>
          <p class="mt-1 text-sm font-semibold text-[#5f5a57]">${detail.grade}</p>
          <p class="mt-2 text-xs leading-6 text-[#5f5a57]">${detail.summary}</p>
        </div>
      `).join('');
    }
    setCurrentSummary(payload.score, payload.grade, payload.explanation);
  };

  const renderRecommendations = (payload) => {
    if (!recommendListEl) return;
    recommendListEl.innerHTML = (payload.recommendations || []).map((item, index) => `
      <article class="rounded-[28px] bg-white p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#a7295a]">Top ${index + 1}</p>
            <h3 class="mt-3 text-4xl font-extrabold text-[#a7295a]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${item.given.join(' ')}</h3>
            <p class="mt-1 text-lg text-[#5f5a57]">${item.name}</p>
          </div>
          <div class="rounded-full bg-[#f6f0ea] px-4 py-2 text-[10px] font-bold uppercase tracking-[0.15em] text-[#5f5a57]">${item.grade}</div>
        </div>
        <p class="mt-5 text-sm leading-7 text-[#5f5a57]">${item.keywords || '추천 키워드 준비 중'}</p>
        <div class="mt-5 flex items-center justify-between border-t border-[#b1aca8]/15 pt-4 text-sm font-bold text-[#a7295a]">
          <span>Score ${item.score}</span>
          <button type="button" class="rounded-full border border-[#a7295a]/15 px-3 py-1 text-xs" data-use-recommend='${JSON.stringify(item.given)}'>이 이름으로 풀이</button>
        </div>
      </article>
    `).join('');

    recommendListEl.querySelectorAll('[data-use-recommend]').forEach((button) => {
      button.addEventListener('click', async () => {
        const given = JSON.parse(button.getAttribute('data-use-recommend') || '[]');
        const hanjaInput = form?.querySelector('[name="hanjaName"]');
        const current = getFormPayload();
        if (hanjaInput) hanjaInput.value = `${current.surname}${given.join('')}`;
        await runAnalysis();
        document.querySelector('[data-panel="report"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  };

  const renderReport = (payload) => {
    if (reportNameEl) reportNameEl.textContent = payload.input ? `${payload.input.surname}${(payload.input.given || []).join('')}` : '상세 풀이';
    if (reportExplanationEl) reportExplanationEl.textContent = payload.explanation || '설명이 없습니다.';
    if (reportPointsEl) {
      reportPointsEl.innerHTML = (payload.parts || []).map((part) => `
        <div class="rounded-[22px] bg-white px-4 py-4">
          <p class="text-lg font-extrabold text-[#302e2b]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${part.hanja}</p>
          <p class="mt-2 text-sm text-[#5f5a57]">${part.meta?.reading || '-'} · ${part.meta?.meaning || '뜻 정보 없음'} · ${part.strokes || '-'}획</p>
          <p class="mt-2 text-xs leading-6 text-[#5f5a57]">${part.meta?.keywords || '키워드 정보 없음'}</p>
        </div>
      `).join('');
    }
    setCurrentSummary(payload.score, payload.grade, payload.explanation);
  };

  const runAnalysis = async () => {
    if (!API_BASE) {
      setCurrentSummary(null, 'API 없음', 'PUBLIC_NODE_API_BASE가 설정되지 않았습니다.');
      return null;
    }

    const { displayName, hanjaName, surname, given } = getFormPayload();
    if (!surname || given.length === 0) {
      setCurrentSummary(null, '입력 필요', '이름과 한자를 입력해 주세요. 한자는 성 1자 + 이름 1~2자 형식입니다.');
      return null;
    }

    if (currentNameEl && displayName) currentNameEl.textContent = displayName;
    if (currentHanjaEl) currentHanjaEl.textContent = `(${hanjaName})`;
    setCurrentSummary(null, '분석 중', '공통 계산 엔진 기준으로 이름풀이를 계산하고 있습니다.');

    const response = await fetch(`${API_BASE}/name-premium/analyze`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ surname, given })
    });
    const payload = await response.json().catch(() => null);
    if (!response.ok || !payload) {
      throw new Error(payload?.error || '분석에 실패했습니다.');
    }

    renderAnalysis(payload);
    renderReport(payload);
    return payload;
  };

  const runRecommend = async () => {
    if (!API_BASE) {
      setCurrentSummary(null, 'API 없음', 'PUBLIC_NODE_API_BASE가 설정되지 않았습니다.');
      return null;
    }

    const { displayName, surname } = getFormPayload();
    if (!surname) {
      setCurrentSummary(null, '입력 필요', '한자를 입력해 주세요.');
      return null;
    }

    if (currentNameEl && displayName) currentNameEl.textContent = displayName;
    setCurrentSummary(null, '추천 중', '현재 이름 기준으로 개명추천 후보를 정리하고 있습니다.');

    const response = await fetch(`${API_BASE}/name-premium/recommend`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ surname, givenLength: 2, topK: 6 })
    });
    const payload = await response.json().catch(() => null);
    if (!response.ok || !payload) {
      throw new Error(payload?.error || '추천에 실패했습니다.');
    }

    renderRecommendations(payload);
    if (payload.recommendations?.[0]) {
      setCurrentSummary(payload.recommendations[0].score, payload.recommendations[0].grade, '이름풀이 아래에서 개명추천과 개명풀이까지 이어서 확인할 수 있습니다.');
    }
    return payload;
  };

  const runSuite = async () => {
    try {
      await runAnalysis();
      await runRecommend();
      document.querySelector('[data-panel="analysis"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (error) {
      setCurrentSummary(null, '오류', error instanceof Error ? error.message : '처리 중 오류가 발생했습니다.');
    }
  };

  document.querySelectorAll('[data-action="suite"]').forEach((button) => {
    button.addEventListener('click', runSuite);
  });
</script>
