---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="동물상 테스트 | FunHub" description="사진 기반 동물상 테스트">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">동물상 테스트</h1>
    <p class="mt-3 text-slate-700">사진 업로드 후 AI 분석으로 동물상 결과를 확인합니다.</p>
    <AdSense slotName="본문 상단" />
    <div class="mt-4 rounded-lg border bg-white p-4">MVP: UI만 우선 제공, API 연동은 다음 단계</div>
    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />
</Layout>
