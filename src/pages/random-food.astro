---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="랜덤 음식 추천 | FunHub" description="오늘 뭐 먹지? 랜덤 음식 추천">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">랜덤 음식 추천</h1>
    <p class="mt-3 text-slate-700">랜덤 버튼으로 오늘의 메뉴를 골라보세요.</p>

    <section class="mt-6 rounded-xl border border-slate-200 bg-white p-6">
      <p id="food-result" class="text-lg font-semibold text-slate-800">오늘의 메뉴를 아직 고르지 않았습니다.</p>
      <div class="mt-4 flex flex-wrap gap-2">
        <button id="food-btn" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">랜덤 음식 뽑기</button>
        <button id="food-reset" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold">초기화</button>
      </div>
    </section>

    <script is:inline>
      const foods = [
        '김치찌개',
        '제육볶음',
        '된장찌개',
        '돈까스',
        '초밥',
        '파스타',
        '햄버거',
        '샐러드',
        '쌀국수',
        '마라탕',
        '순대국',
        '국밥'
      ];

      const foodResultEl = document.getElementById('food-result');
      const foodBtnEl = document.getElementById('food-btn');
      const foodResetEl = document.getElementById('food-reset');

      foodBtnEl?.addEventListener('click', () => {
        const idx = Math.floor(Math.random() * foods.length);
        if (foodResultEl) foodResultEl.textContent = `오늘의 추천 메뉴: ${foods[idx]}`;
      });

      foodResetEl?.addEventListener('click', () => {
        if (foodResultEl) foodResultEl.textContent = '오늘의 메뉴를 아직 고르지 않았습니다.';
      });
    </script>

    <Recommend />
  </main>
  <Footer />
</Layout>
