---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const apiBase = import.meta.env.PUBLIC_NODE_API_BASE ?? 'http://127.0.0.1:8787';
---

<Layout
  title="AI 증명사진 생성기 | ManyTool"
  description="셀카 업로드 또는 카메라 촬영으로 AI 증명사진 후보 3장을 만들고 1장을 선택해 다운로드하세요."
  keywords="AI 증명사진, 증명사진 만들기, 온라인 증명사진, 셀카 증명사진, 3x4 증명사진"
>
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-8 pb-28 md:pb-8">
    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <p class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">MVP 데모</p>
      <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-900">AI 증명사진 생성기</h1>
      <p class="mt-2 text-slate-600">사진 한 장으로 증명사진 후보 3장을 생성하고, 원하는 1장을 다운로드할 수 있습니다.</p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <p class="font-bold text-slate-900">기본 상품</p>
          <p class="mt-1 text-slate-600">$9.90 / 후보 3장 / 최종 1장 다운로드</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <p class="font-bold text-slate-900">추가 생성</p>
          <p class="mt-1 text-slate-600">+2($3.90) / +3($4.90) / +7($5.90)</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <p class="font-bold text-slate-900">의상 옵션</p>
          <p class="mt-1 text-slate-600">현재 옷 / 정장(무료)</p>
        </div>
      </div>
    </section>

    <section class="mt-6 grid gap-4 lg:grid-cols-2">
      <article id="candidate-section" class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-bold text-slate-900">1) 사진 입력</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          <label class="cursor-pointer rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">
            사진 업로드
            <input id="file-input" type="file" accept="image/*" class="hidden" />
          </label>
          <button id="camera-start" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">
            카메라 시작
          </button>
          <button id="camera-capture" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700" disabled>
            촬영
          </button>
          <button id="reset-all" class="rounded-md border border-rose-200 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-700">
            초기화
          </button>
        </div>
        <label class="mt-2 inline-flex items-center gap-2 text-xs text-slate-600">
          <input id="camera-mirror-fix" type="checkbox" class="h-4 w-4" checked />
          카메라 좌우반전 보정(헷갈리면 ON 유지)
        </label>

        <div class="relative mt-4 overflow-hidden rounded-xl border border-slate-200 bg-slate-50 p-3">
          <video id="camera" class="hidden h-64 w-full rounded-lg bg-black object-cover" autoplay playsinline></video>
          <img id="source-preview" alt="원본 미리보기" class="hidden h-64 w-full rounded-lg object-contain" />
          <p id="source-empty" class="text-sm text-slate-500">아직 사진이 선택되지 않았습니다.</p>
          <div class="pointer-events-none absolute inset-3 hidden items-center justify-center" data-guide-overlay>
            <div class="relative h-full w-full rounded-lg">
              <div class="absolute left-1/2 top-[12%] h-[62%] w-[54%] -translate-x-1/2 rounded-[32px] border-2 border-white/95 shadow-[0_0_0_9999px_rgba(15,23,42,0.26)]"></div>
              <div class="absolute left-1/2 top-[28%] h-[8%] w-[38%] -translate-x-1/2 rounded-full border border-dashed border-white/80"></div>
              <div class="absolute left-1/2 top-[12%] h-[62%] -translate-x-1/2 border-l border-dashed border-white/45"></div>
              <div class="absolute left-1/2 top-[31%] w-[54%] -translate-x-1/2 border-t border-dashed border-white/45"></div>
              <div data-live-face-box class="absolute hidden rounded-[26px] border-2 border-emerald-300/95 bg-emerald-400/10 shadow-[0_0_0_1px_rgba(255,255,255,0.18)_inset]"></div>
              <div data-live-face-centerline class="absolute hidden border-l-2 border-dashed border-emerald-200/80"></div>
              <div data-live-eye-line class="absolute hidden border-t-2 border-dashed border-emerald-200/80"></div>
              <div class="absolute inset-x-0 top-3 flex justify-center">
                <span data-live-face-status class="hidden rounded-full bg-slate-900/78 px-3 py-1 text-[10px] font-bold tracking-[0.18em] text-white shadow-sm"></span>
              </div>
              <div class="absolute inset-x-0 bottom-3 flex justify-center">
                <span class="rounded-full bg-slate-900/70 px-3 py-1 text-[10px] font-bold tracking-[0.22em] text-white">얼굴을 프레임 안에 맞춰주세요</span>
              </div>
            </div>
          </div>
        </div>
        <div id="upload-guidance" class="mt-3 hidden rounded-xl border p-3 text-xs"></div>

        <div class="mt-4">
          <label class="text-sm font-semibold text-slate-700" for="outfit">의상 옵션</label>
          <select id="outfit" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
            <option value="current">현재 옷</option>
            <option value="suit">정장</option>
          </select>
        </div>

        <div class="mt-4">
          <label class="text-sm font-semibold text-slate-700" for="provider-select">AI 처리 엔진</label>
          <select id="provider-select" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
            <option value="auto">Auto</option>
            <option value="local_sharp">Local Sharp</option>
            <option value="remove_bg">remove.bg</option>
            <option value="photoroom">PhotoRoom</option>
          </select>
          <p id="provider-help" class="mt-1 text-xs text-slate-500">기본은 Auto입니다. 외부 키가 없으면 자동으로 local_sharp로 내려갑니다.</p>
        </div>

        <button id="generate" class="mt-4 w-full rounded-xl bg-sky-600 px-4 py-3 text-sm font-bold text-white shadow-[0_10px_30px_rgba(2,132,199,0.28)] transition hover:-translate-y-0.5 hover:bg-sky-500 active:translate-y-0 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none" disabled>
          증명사진 만들기
        </button>
        <div id="blocking-cta" class="mt-3 hidden rounded-xl border border-amber-200 bg-amber-50 p-3 text-xs text-amber-900"></div>
        <div id="generate-ready" class="mt-3 hidden rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-xs text-emerald-900"></div>
        <div id="assessment-score" class="mt-3 hidden rounded-xl border border-slate-200 bg-slate-50 p-3 text-xs text-slate-800"></div>

        <section class="mt-4 rounded-2xl border border-sky-100 bg-[linear-gradient(135deg,#eff6ff_0%,#f8fafc_55%,#fefce8_100%)] p-4 text-sm text-slate-700">
          <p class="font-bold text-slate-900">개떡같이 찍어도 최대한 예쁘게 정리되는 방향으로 설계했습니다</p>
          <p class="mt-1">셀카, 전신샷, 화면 캡처처럼 완벽하지 않은 사진도 얼굴 중심으로 다시 정렬해 자연스럽고 또렷한 후보를 먼저 보여줍니다.</p>
          <ul class="mt-2 list-disc space-y-1 pl-5">
            <li>모바일/PC 업로드 + 카메라 촬영 지원</li>
            <li>3x4 비율 기준 자동 정렬</li>
            <li>후보 3장 비교 후 1장씩 다운로드</li>
          </ul>
        </section>

        <section class="mt-4 rounded-xl border border-rose-100 bg-rose-50 p-4">
          <h3 class="text-sm font-bold text-slate-900">이런 사진도 먼저 시도해보세요</h3>
          <div class="mt-2 flex flex-wrap gap-2 text-xs font-semibold">
            <span class="rounded-full bg-white px-3 py-1 text-slate-700">정면 셀카</span>
            <span class="rounded-full bg-white px-3 py-1 text-slate-700">전신 사진</span>
            <span class="rounded-full bg-white px-3 py-1 text-slate-700">저해상도 사진</span>
            <span class="rounded-full bg-white px-3 py-1 text-slate-700">스크린샷</span>
          </div>
          <p class="mt-2 text-xs text-slate-600">얼굴이 너무 가려졌거나 옆얼굴이면 품질이 떨어질 수 있습니다. 정면에 가깝고 얼굴이 또렷할수록 더 예쁘게 나옵니다.</p>
        </section>

        <section class="mt-4 rounded-lg border border-slate-200 bg-white p-4">
          <h3 class="text-base font-bold text-slate-900">셀카가 증명사진으로 바뀌는 방식</h3>
          <p class="mt-1 text-xs text-slate-600">아래 예시는 홍보용 샘플 화면입니다. 실제 결과는 원본 상태에 따라 달라질 수 있습니다.</p>
          <div class="mt-3 grid gap-3 sm:grid-cols-3">
            <article class="rounded-lg border border-slate-200 bg-slate-50 p-3">
              <p class="text-[11px] font-semibold text-slate-500">Before</p>
              <div class="mt-2 h-24 rounded-md bg-gradient-to-b from-slate-200 to-slate-300"></div>
              <p class="mt-2 text-[11px] text-slate-600">일반 셀카</p>
            </article>
            <article class="rounded-lg border border-slate-200 bg-sky-50 p-3">
              <p class="text-[11px] font-semibold text-sky-700">Step</p>
              <div class="mt-2 h-24 rounded-md bg-gradient-to-b from-sky-100 to-slate-100"></div>
              <p class="mt-2 text-[11px] text-slate-600">배경 정리 + 얼굴 정렬</p>
            </article>
            <article class="rounded-lg border border-slate-200 bg-emerald-50 p-3">
              <p class="text-[11px] font-semibold text-emerald-700">After</p>
              <div class="mt-2 h-24 rounded-md bg-gradient-to-b from-white to-emerald-100"></div>
              <p class="mt-2 text-[11px] text-slate-600">증명사진 규격 결과</p>
            </article>
          </div>
          <ol class="mt-3 list-decimal space-y-1 pl-5 text-xs text-slate-700">
            <li>정면 얼굴 자동 감지</li>
            <li>흰 배경/규격 비율 자동 적용</li>
            <li>밝기/톤 미세 보정 후보 3장 생성</li>
          </ol>
        </section>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-bold text-slate-900">2) 후보 선택</h2>
        <p class="mt-2 text-sm text-slate-600">후보 중 1장을 선택하면 다운로드가 활성화됩니다. 생성 직후에는 가장 자연스러운 1번 후보를 먼저 골라드립니다.</p>
        <p class="mt-1 text-xs text-slate-500">결제 전 미리보기에는 워터마크가 표시됩니다.</p>
        <div id="candidate-grid" class="mt-4 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          <p class="text-sm text-slate-500">생성 결과가 여기에 표시됩니다.</p>
        </div>
        <button id="download-selected" class="mt-4 w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white shadow-[0_10px_30px_rgba(5,150,105,0.28)] transition hover:-translate-y-0.5 hover:bg-emerald-500 active:translate-y-0 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none" disabled>
          선택한 1장 다운로드
        </button>
        <div class="mt-3 grid gap-2 sm:grid-cols-3">
          <button data-add-count="2" class="rounded-xl border border-slate-300 px-3 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-400 hover:bg-slate-50 active:translate-y-0">+2장 추가 생성 ($3.90)</button>
          <button data-add-count="3" class="rounded-xl border border-slate-300 px-3 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-400 hover:bg-slate-50 active:translate-y-0">+3장 추가 생성 ($4.90)</button>
          <button data-add-count="7" class="rounded-xl border border-slate-300 px-3 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-400 hover:bg-slate-50 active:translate-y-0">+7장 추가 생성 ($5.90)</button>
        </div>
        <div class="mt-3 grid gap-2 sm:grid-cols-2">
          <a href="/online-passport-photo" class="rounded-md border border-sky-100 bg-sky-50 px-3 py-2 text-center text-sm font-semibold text-sky-700">같은 사진으로 여권사진 만들기</a>
          <a href="/ai-headshot" class="rounded-md border border-sky-100 bg-sky-50 px-3 py-2 text-center text-sm font-semibold text-sky-700">같은 사진으로 프로필 버전 만들기</a>
        </div>
        <p id="api-status" class="mt-2 text-xs text-slate-500">API 상태 확인 중...</p>
        <p id="provider-result-badge" class="mt-2 hidden inline-flex rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold text-slate-700"></p>
        <p id="status" class="mt-2 text-xs text-slate-500">Node API 연결 시 서버 기반 생성, 실패 시 로컬 생성으로 자동 전환됩니다.</p>
        <div id="quality-feedback" class="mt-3 hidden rounded-xl border border-emerald-100 bg-emerald-50 p-3 text-xs text-emerald-900"></div>
        <pre id="pipeline-report" class="mt-3 hidden whitespace-pre-wrap rounded-xl border border-slate-200 bg-slate-50 p-3 text-[11px] leading-5 text-slate-600"></pre>
        <div class="mt-3 flex flex-wrap gap-2">
          <a id="job-debug-link" href="/tools/ai-photo-debug" target="_blank" rel="noreferrer" class="hidden inline-flex rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">이번 생성 디버그 보기</a>
          <a id="job-ops-link" href="/tools/ai-photo-ops" target="_blank" rel="noreferrer" class="hidden inline-flex rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">운영 요약 보기</a>
        </div>
        <p class="mt-1 text-xs text-slate-400">결제/후보 상태는 같은 브라우저에서 최대 3일 동안 자동 복원됩니다.</p>
      </article>
    </section>

    <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-5">
      <h2 class="text-2xl font-black tracking-tight text-slate-900">Before / After 비교</h2>
      <p class="mt-2 text-sm text-slate-600">슬라이더로 원본과 생성 결과 차이를 확인하세요.</p>
      <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="relative h-72 overflow-hidden rounded-lg bg-slate-100">
          <img id="compare-before" alt="원본" class="h-full w-full object-cover" />
          <div id="compare-after-wrap" class="absolute inset-y-0 left-0 w-1/2 overflow-hidden border-r-2 border-white">
            <img id="compare-after" alt="결과" class="h-full w-full object-cover" />
            <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-[repeating-linear-gradient(-32deg,rgba(15,23,42,0.18)_0,rgba(15,23,42,0.18)_18px,transparent_18px,transparent_48px)]">
              <span class="rotate-[-24deg] rounded-full border border-white/50 bg-slate-900/55 px-6 py-2 text-lg font-black tracking-[0.35em] text-white/95">MANYTOOL PREVIEW</span>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-x-0 bottom-2 text-center text-xs font-semibold text-white">드래그로 비교</div>
        </div>
        <input id="compare-slider" type="range" min="0" max="100" value="50" class="mt-3 w-full accent-sky-600" disabled />
        <p id="compare-help" class="mt-2 text-xs text-slate-500">사진 업로드 후 후보 생성 시 비교가 활성화됩니다.</p>
      </div>
    </section>

    <section class="mt-6 grid gap-4 lg:grid-cols-2">
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-bold text-slate-900">처리 단계</h2>
        <ol class="mt-3 list-decimal space-y-1 pl-5 text-sm text-slate-700">
          <li>사진 업로드 또는 카메라 촬영</li>
          <li>얼굴 위치/각도 분석</li>
          <li>배경 정리 + 3x4 규격 정렬</li>
          <li>자연 보정 후보 3장 생성</li>
          <li>1장 선택 후 다운로드</li>
        </ol>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-bold text-slate-900">촬영 가이드</h2>
        <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-700">
          <li>정면 얼굴, 수평 맞춤</li>
          <li>얼굴 중앙 배치</li>
          <li>밝은 조명 환경 권장</li>
          <li>모자/마스크/선글라스 제거</li>
          <li>얼굴선을 가리는 머리카락 최소화</li>
        </ul>
      </article>
    </section>

    <section class="mt-6 grid gap-4 lg:grid-cols-2">
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-bold text-slate-900">가격 안내</h2>
        <div class="mt-3 space-y-2 text-sm text-slate-700">
          <p><span class="font-bold text-slate-900">기본:</span> $9.90 (후보 3장 / 최종 1장)</p>
          <p><span class="font-bold text-slate-900">추가:</span> +2장 $3.90 / +3장 $4.90 / +7장 $5.90</p>
          <p><span class="font-bold text-slate-900">다운로드:</span> 추가 1장마다 기본 결제가 한 번 더 필요합니다.</p>
          <p><span class="font-bold text-slate-900">의상:</span> 현재 옷 / 정장(무료)</p>
        </div>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-xl font-bold text-slate-900">FAQ</h2>
        <div class="mt-3 space-y-2 text-sm text-slate-700">
          <p><span class="font-semibold text-slate-900">Q.</span> 모바일에서도 가능한가요? <span class="font-semibold text-slate-900">A.</span> 네, 업로드/촬영 모두 지원합니다.</p>
          <p><span class="font-semibold text-slate-900">Q.</span> 여권사진도 만들 수 있나요? <span class="font-semibold text-slate-900">A.</span> 아래 페이지에서 바로 이동할 수 있습니다.</p>
        </div>
        <div class="mt-3 grid gap-2 text-sm font-semibold sm:grid-cols-2">
          <a href="/web-id-photo" class="rounded-md border border-sky-100 bg-sky-50 px-3 py-2 text-sky-700">웹 증명사진</a>
          <a href="/free-id-photo" class="rounded-md border border-sky-100 bg-sky-50 px-3 py-2 text-sky-700">무료 증명사진</a>
          <a href="/online-passport-photo" class="rounded-md border border-sky-100 bg-sky-50 px-3 py-2 text-sky-700">온라인 여권사진</a>
          <a href="/free-passport-photo" class="rounded-md border border-sky-100 bg-sky-50 px-3 py-2 text-sky-700">무료 여권사진</a>
          <a href="/ai-headshot" class="rounded-md border border-sky-100 bg-sky-50 px-3 py-2 text-sky-700">AI 프로필사진</a>
        </div>
      </article>
    </section>
  </main>
  <div id="mobile-download-bar" class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-slate-200 bg-white/95 p-4 shadow-[0_-12px_28px_rgba(15,23,42,0.16)] backdrop-blur md:hidden">
    <div class="mx-auto flex max-w-5xl items-center gap-3">
      <div class="min-w-0 flex-1">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-400">Quick Select</p>
        <p id="mobile-selection-status" class="truncate text-sm font-bold text-slate-900">후보 1개를 선택해주세요.</p>
      </div>
      <button id="mobile-download-selected" class="rounded-xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white shadow-[0_10px_24px_rgba(5,150,105,0.28)] transition disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none" disabled>
        1장 다운로드
      </button>
    </div>
  </div>
  <Footer />

  <script define:vars={{ apiBase }} is:inline>
    const fileInput = document.getElementById('file-input');
    const cameraStartBtn = document.getElementById('camera-start');
    const cameraCaptureBtn = document.getElementById('camera-capture');
    const cameraMirrorFixEl = document.getElementById('camera-mirror-fix');
    const cameraEl = document.getElementById('camera');
    const resetBtn = document.getElementById('reset-all');
    const sourcePreview = document.getElementById('source-preview');
    const sourceEmpty = document.getElementById('source-empty');
    const uploadGuidanceEl = document.getElementById('upload-guidance');
    const guideOverlayEl = document.querySelector('[data-guide-overlay]');
    const liveFaceBoxEl = document.querySelector('[data-live-face-box]');
    const liveFaceStatusEl = document.querySelector('[data-live-face-status]');
    const liveFaceCenterlineEl = document.querySelector('[data-live-face-centerline]');
    const liveEyeLineEl = document.querySelector('[data-live-eye-line]');
    const liveFaceCoachingEl = document.querySelector('[data-live-face-coaching]');
    const generateBtn = document.getElementById('generate');
    const blockingCtaEl = document.getElementById('blocking-cta');
    const readyToGenerateEl = document.getElementById('generate-ready');
    const assessmentScoreEl = document.getElementById('assessment-score');
    const outfitEl = document.getElementById('outfit');
    const providerSelectEl = document.getElementById('provider-select');
    const providerHelpEl = document.getElementById('provider-help');
    const gridEl = document.getElementById('candidate-grid');
    const downloadBtn = document.getElementById('download-selected');
    const addButtons = Array.from(document.querySelectorAll('[data-add-count]'));
    const apiStatusEl = document.getElementById('api-status');
    const providerResultBadgeEl = document.getElementById('provider-result-badge');
    const statusEl = document.getElementById('status');
    const qualityFeedbackEl = document.getElementById('quality-feedback');
    const pipelineReportEl = document.getElementById('pipeline-report');
    const jobDebugLinkEl = document.getElementById('job-debug-link');
    const jobOpsLinkEl = document.getElementById('job-ops-link');
    const compareBeforeEl = document.getElementById('compare-before');
    const compareAfterEl = document.getElementById('compare-after');
    const compareAfterWrapEl = document.getElementById('compare-after-wrap');
    const compareSliderEl = document.getElementById('compare-slider');
    const compareHelpEl = document.getElementById('compare-help');
    const candidateSectionEl = document.getElementById('candidate-section');
    const mobileDownloadBarEl = document.getElementById('mobile-download-bar');
    const mobileSelectionStatusEl = document.getElementById('mobile-selection-status');
    const mobileDownloadBtn = document.getElementById('mobile-download-selected');

    const API_BASE = apiBase;
    const PAGE_STATE_KEY = 'manytool:ai-id-photo:v1';

    let stream = null;
    let sourceDataUrl = null;
    let sourceFile = null;
    let sourceFaceHint = null;
    let cachedPhotoId = null;
    let candidates = [];
    let isGenerating = false;
    let basePaid = false;
    let baseOrderId = null;
    let creditedBaseOrders = [];
    let apiOnline = false;
    let paymentMode = 'mock';
    let paymentProducts = { base: false, add2: false, add3: false, add7: false };
    let addonOrders = { add2: null, add3: null, add7: null };
    let latestJobId = null;
    let sourceUploadAssessment = { messages: [], blocking: false, faceHint: null };
    let providerAvailability = { auto: true, local_sharp: true, remove_bg: false, photoroom: false };
    let providerDiagnostics = {};

    const getSelectedProvider = () => {
      if (!(providerSelectEl instanceof HTMLSelectElement)) return 'auto';
      return providerSelectEl.value || 'auto';
    };

    const formatProviderLabel = (provider) => {
      if (provider === 'local_sharp') return 'local_sharp';
      if (provider === 'remove_bg') return 'remove.bg';
      if (provider === 'photoroom') return 'PhotoRoom';
      return 'auto';
    };

    const syncProviderOptions = () => {
      if (!(providerSelectEl instanceof HTMLSelectElement)) return;
      Array.from(providerSelectEl.options).forEach((option) => {
        if (option.value === 'auto' || option.value === 'local_sharp') {
          option.disabled = false;
          return;
        }
        option.disabled = !providerAvailability?.[option.value];
      });
      if (providerSelectEl.selectedOptions[0]?.disabled) {
        providerSelectEl.value = 'auto';
      }
    };

    const updateProviderHelp = () => {
      if (!(providerHelpEl instanceof HTMLElement)) return;
      const selectedProvider = getSelectedProvider();
      if (selectedProvider === 'auto') {
        providerHelpEl.textContent = '기본은 Auto입니다. 외부 키가 없으면 자동으로 local_sharp로 내려갑니다.';
        return;
      }
      const available = Boolean(providerAvailability?.[selectedProvider]);
      const missingEnv = Array.isArray(providerDiagnostics?.[selectedProvider]?.missingEnv)
        ? providerDiagnostics[selectedProvider].missingEnv
        : [];
      providerHelpEl.textContent = available
        ? `${formatProviderLabel(selectedProvider)}로 생성 요청합니다. 실패하면 local_sharp fallback이 동작할 수 있습니다.`
        : `${formatProviderLabel(selectedProvider)}가 현재 준비되지 않아 local_sharp로 fallback될 수 있습니다.${missingEnv.length ? ` 필요한 env: ${missingEnv.join(', ')}` : ''}`;
    };

    const setStatus = (text) => {
      if (statusEl) statusEl.textContent = text;
    };

    const setApiStatus = (text) => {
      if (apiStatusEl) apiStatusEl.textContent = text;
    };

    const renderProviderResultBadge = (report = null) => {
      if (!(providerResultBadgeEl instanceof HTMLElement)) return;
      if (!report) {
        providerResultBadgeEl.textContent = '';
        providerResultBadgeEl.className = 'mt-2 hidden inline-flex rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold text-slate-700';
        return;
      }
      const requestedProvider = report.requestedProvider ?? 'auto';
      const resolvedProvider = report.fallbackToLocalSharp
        ? `local_sharp fallback from ${report.resolvedProvider ?? 'unknown'}`
        : (report.resolvedProvider ?? 'unknown');
      const signalParts = [];
      signalParts.push(report.externalBackgroundCall ? 'external' : 'local');
      const cacheHits = ['aligned', 'cutout', 'flattened'].filter((key) => Boolean(report.cache?.[key]));
      signalParts.push(cacheHits.length ? `cache:${cacheHits.join('+')}` : 'cache:miss');
      providerResultBadgeEl.textContent = `provider ${requestedProvider} -> ${resolvedProvider} | ${signalParts.join(' | ')}`;
      providerResultBadgeEl.className = report.fallbackToLocalSharp
        ? 'mt-2 inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-[11px] font-semibold text-amber-800'
        : 'mt-2 inline-flex rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[11px] font-semibold text-emerald-800';
    };

    const renderPipelineReport = (report) => {
      if (!(pipelineReportEl instanceof HTMLElement)) return;
      if (!report) {
        pipelineReportEl.textContent = '';
        pipelineReportEl.classList.add('hidden');
        return;
      }
      const lines = [
        `toolType: ${report.toolType ?? 'n/a'}`,
        `requestedProvider: ${report.requestedProvider ?? 'n/a'}`,
        `resolvedProvider: ${report.fallbackToLocalSharp ? 'local_sharp (fallback)' : (report.resolvedProvider ?? 'n/a')}`,
        `fallbackToLocalSharp: ${Boolean(report.fallbackToLocalSharp)}`,
        `backgroundProvider: ${report.backgroundProvider ?? 'n/a'}`,
        `cropProfile: ${report.cropProfile ?? 'n/a'}`,
        `poseProfile: ${report.poseProfile ?? 'n/a'}`,
        `suitTemplate: ${report.suitTemplate ?? 'n/a'}`,
        `suitSelectionReason: ${report.suitSelectionReason ?? 'n/a'}`,
        `suitSelectionSummary: ${report.suitSelectionSummary ?? 'n/a'}`,
        `qualityScore: ${report.qualityScore ?? 0}`,
        `qualityScoreBeforeRetry: ${report.qualityScoreBeforeRetry ?? 'n/a'}`,
        `identityScore: ${report.identityScore ?? 0}`,
        `identityThreshold: ${report.identityThreshold ?? 0}`,
        `finalQualityRetryTriggered: ${Boolean(report.finalQualityRetryTriggered)}`,
        `finalQualityRetryProfile: ${report.finalQualityRetryProfile ?? 'n/a'}`,
        `cache.aligned: ${Boolean(report.cache?.aligned)}`,
        `cache.cutout: ${Boolean(report.cache?.cutout)}`,
        `cache.flattened: ${Boolean(report.cache?.flattened)}`,
        `externalBackgroundCall: ${Boolean(report.externalBackgroundCall)}`,
        `generatedVariants: ${Array.isArray(report.generatedVariants) ? report.generatedVariants.join(', ') : 'n/a'}`,
        `timings.detect: ${report.timings?.detect ?? 0}ms`,
        `timings.align: ${report.timings?.align ?? 0}ms`,
        `timings.pose: ${report.timings?.pose ?? 0}ms`,
        `timings.cutout: ${report.timings?.cutout ?? 0}ms`,
        `timings.flatten: ${report.timings?.flatten ?? 0}ms`,
        `timings.relight: ${report.timings?.relight ?? 0}ms`,
        `timings.finalRetry: ${report.timings?.finalRetry ?? 0}ms`,
        `timings.variants: ${report.timings?.variants ?? 0}ms`,
        `variantIdentityScores: ${report.variantIdentityScores ? JSON.stringify(report.variantIdentityScores) : '{}'}`,
        `finalQualityRetryAttempts: ${Array.isArray(report.finalQualityRetryAttempts) ? JSON.stringify(report.finalQualityRetryAttempts) : '[]'}`,
        `identityRegeneratedVariants: ${Array.isArray(report.identityRegeneratedVariants) ? report.identityRegeneratedVariants.join(', ') : 'n/a'}`,
        `identityRejectedVariants: ${Array.isArray(report.identityRejectedVariants) ? report.identityRejectedVariants.join(', ') : 'n/a'}`,
        `identityFallbackKept: ${report.identityFallbackKept ?? 'n/a'}`,
        `poseAttempts: ${Array.isArray(report.poseAttempts) ? JSON.stringify(report.poseAttempts) : '[]'}`
      ];
      pipelineReportEl.textContent = lines.join('\n');
      pipelineReportEl.classList.remove('hidden');
    };

    const renderJobDebugLink = (jobId, report = null) => {
      latestJobId = typeof jobId === 'string' && jobId.trim() ? jobId.trim() : null;
      if (!(jobDebugLinkEl instanceof HTMLAnchorElement)) return;
      if (!latestJobId) {
        jobDebugLinkEl.href = '/tools/ai-photo-debug';
        jobDebugLinkEl.classList.add('hidden');
        if (jobOpsLinkEl instanceof HTMLAnchorElement) {
          jobOpsLinkEl.href = '/tools/ai-photo-ops';
          jobOpsLinkEl.classList.add('hidden');
        }
        return;
      }
      jobDebugLinkEl.href = `/tools/ai-photo-debug?jobId=${encodeURIComponent(latestJobId)}`;
      jobDebugLinkEl.classList.remove('hidden');
      if (jobOpsLinkEl instanceof HTMLAnchorElement) {
        const params = new URLSearchParams({ flagged: 'false', tool: report?.toolType ?? 'id_photo' });
        const provider = report?.fallbackToLocalSharp ? 'local_sharp' : (report?.resolvedProvider ?? '');
        if (provider) params.set('provider', provider);
        jobOpsLinkEl.href = `/tools/ai-photo-ops?${params.toString()}`;
        jobOpsLinkEl.classList.remove('hidden');
      }
    };

    const renderQualityFeedback = (report) => {
      if (!(qualityFeedbackEl instanceof HTMLElement)) return;
      if (!report?.qualitySummary) {
        qualityFeedbackEl.innerHTML = '';
        qualityFeedbackEl.classList.add('hidden');
        return;
      }
      const feedbackLines = Array.isArray(report.qualityFeedback) ? report.qualityFeedback : [];
      qualityFeedbackEl.innerHTML = `
        <p class="font-bold">${report.qualitySummary}</p>
        <ul class="mt-2 list-disc space-y-1 pl-5">
          ${feedbackLines.map((line) => `<li>${line}</li>`).join('')}
        </ul>
      `;
      qualityFeedbackEl.classList.remove('hidden');
    };

    const scrollToCandidates = () => {
      if (!(candidateSectionEl instanceof HTMLElement)) return;
      candidateSectionEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    const syncMobileActionBar = () => {
      if (!(mobileDownloadBarEl instanceof HTMLElement)) return;
      const selectedCount = candidates.filter((item) => item.selected).length;
      const hasCandidates = candidates.length > 0;
      mobileDownloadBarEl.classList.toggle('hidden', !hasCandidates);
      if (mobileSelectionStatusEl instanceof HTMLElement) {
        mobileSelectionStatusEl.textContent = selectedCount === 1
          ? '후보 1개 선택됨. 지금 바로 다운로드할 수 있습니다.'
          : '후보 1개를 선택해주세요.';
      }
      if (mobileDownloadBtn instanceof HTMLButtonElement) {
        mobileDownloadBtn.disabled = !hasCandidates || !(downloadBtn instanceof HTMLButtonElement) || downloadBtn.disabled;
      }
    };

    const renderUploadGuidance = (assessment) => {
      if (!(uploadGuidanceEl instanceof HTMLElement)) return;
      const messages = Array.isArray(assessment?.messages) ? assessment.messages.filter(Boolean) : [];
      if (!messages.length) {
        uploadGuidanceEl.innerHTML = '';
        uploadGuidanceEl.className = 'mt-3 hidden rounded-xl border p-3 text-xs';
        renderReadyToGenerate(assessment);
        renderAssessmentScore(assessment);
        return;
      }
      const blocking = Boolean(assessment?.blocking);
      const tips = [];
      if (messages.some((message) => message.includes('얼굴이 너무 작') || message.includes('얼굴이 작게'))) {
        tips.push('얼굴을 화면에서 더 크게 채워주세요');
      }
      if (messages.some((message) => message.includes('가까워') || message.includes('턱선이 잘릴'))) {
        tips.push('카메라와 거리를 조금만 벌려주세요');
      }
      if (messages.some((message) => message.includes('중앙'))) {
        tips.push('코가 화면 가운데에 오도록 맞춰주세요');
      }
      if (messages.some((message) => message.includes('기울기') || message.includes('수평'))) {
        tips.push('눈높이가 수평이 되게 고개를 바로 세워주세요');
      }
      if (messages.some((message) => message.includes('해상도'))) {
        tips.push('캡처 대신 원본 사진이나 카메라 촬영을 권장합니다');
      }
      uploadGuidanceEl.className = blocking
        ? 'mt-3 rounded-xl border border-rose-200 bg-rose-50 p-3 text-xs text-rose-900'
        : 'mt-3 rounded-xl border border-amber-200 bg-amber-50 p-3 text-xs text-amber-900';
      uploadGuidanceEl.innerHTML = `
        <p class="font-bold">${blocking ? '다시 촬영하는 편이 좋습니다.' : '이 사진은 결과가 흔들릴 수 있습니다.'}</p>
        <ul class="mt-2 list-disc space-y-1 pl-4">${messages.map((message) => `<li>${message}</li>`).join('')}</ul>
        ${tips.length ? `<div class="mt-3 flex flex-wrap gap-2">${tips.map((tip) => `<span class="rounded-full bg-white/80 px-3 py-1 font-semibold">${tip}</span>`).join('')}</div>` : ''}
        ${blocking ? '<p class="mt-3 rounded-lg bg-white/80 px-3 py-2 text-[11px] font-bold">이 상태로 생성해도 점수가 낮을 가능성이 큽니다. 아래 버튼으로 다시 맞추는 편이 좋습니다.</p>' : ''}
        <div class="mt-3 flex flex-wrap gap-2">
          <button type="button" data-guidance-action="start-camera" class="rounded-lg border border-current/20 bg-white/80 px-3 py-2 text-[11px] font-bold">카메라 다시 열기</button>
          <button type="button" data-guidance-action="upload-file" class="rounded-lg border border-current/20 bg-white/80 px-3 py-2 text-[11px] font-bold">다른 사진 업로드</button>
        </div>
      `;
      renderBlockingCta({ blocking });
      renderReadyToGenerate(null);
      renderAssessmentScore(assessment);
    };

    const clampScore = (value) => Math.max(0, Math.min(100, Math.round(value)));

    const buildAssessmentScore = (assessment) => {
      const faceHint = assessment?.faceHint;
      if (!faceHint?.bbox) return null;
      const centerX = Number(faceHint.bbox.x ?? 0) + Number(faceHint.bbox.width ?? 0) / 2;
      const faceRatio = Number(faceHint.bbox.width ?? 0);
      const centerPenalty = Math.abs(centerX - 0.5) * 180;
      const sizePenalty = Math.abs(faceRatio - 0.26) * 220;
      const eyeTilt = faceHint.leftEye && faceHint.rightEye
        ? Math.abs(Number(faceHint.leftEye.y ?? 0) - Number(faceHint.rightEye.y ?? 0))
        : 0;
      const tiltPenalty = eyeTilt * 900;
      const warningPenalty = (Array.isArray(assessment?.messages) ? assessment.messages.length : 0) * 6;
      const hardPenalty = assessment?.blocking ? 18 : 0;
      const alignment = clampScore(100 - centerPenalty - tiltPenalty);
      const cropFit = clampScore(100 - centerPenalty * 0.55 - sizePenalty - tiltPenalty * 0.4 - hardPenalty);
      const retakeNeed = clampScore(18 + warningPenalty + hardPenalty + centerPenalty * 0.35 + sizePenalty * 0.3 + tiltPenalty * 0.2);
      return {
        alignment,
        cropFit,
        retakeNeed,
        summary: assessment?.blocking
          ? '재촬영 권장'
          : (cropFit >= 85 ? '바로 생성 가능' : '생성 가능하지만 구도 보정 여지 있음')
      };
    };

    const renderAssessmentScore = (assessment) => {
      if (!(assessmentScoreEl instanceof HTMLElement)) return;
      const score = buildAssessmentScore(assessment);
      if (!score) {
        assessmentScoreEl.classList.add('hidden');
        assessmentScoreEl.innerHTML = '';
        return;
      }
      assessmentScoreEl.classList.remove('hidden');
      assessmentScoreEl.innerHTML = `
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="font-bold text-slate-900">업로드 예상 품질: ${score.summary}</p>
            <p class="mt-1 text-[11px] text-slate-500">생성 전 프론트 검사 기준입니다. 실제 후보 점수와는 약간 다를 수 있습니다.</p>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-[11px] font-bold text-slate-700 shadow-sm">규격예상 ${score.cropFit}</span>
        </div>
        <div class="mt-3 grid grid-cols-3 gap-2 text-[11px] font-semibold">
          <div class="rounded-lg bg-white px-3 py-2">
            <p class="text-slate-400">정렬</p>
            <p class="mt-1 text-base font-black text-slate-900">${score.alignment}</p>
          </div>
          <div class="rounded-lg bg-white px-3 py-2">
            <p class="text-slate-400">규격예상</p>
            <p class="mt-1 text-base font-black text-slate-900">${score.cropFit}</p>
          </div>
          <div class="rounded-lg bg-white px-3 py-2">
            <p class="text-slate-400">재촬영필요도</p>
            <p class="mt-1 text-base font-black ${score.retakeNeed >= 70 ? 'text-rose-600' : 'text-slate-900'}">${score.retakeNeed}</p>
          </div>
        </div>
      `;
    };

    const renderReadyToGenerate = (assessment) => {
      if (!(readyToGenerateEl instanceof HTMLElement)) return;
      const hasStableFace = Boolean(assessment?.faceHint?.bbox);
      const hasMessages = Array.isArray(assessment?.messages) && assessment.messages.length > 0;
      const blocking = Boolean(assessment?.blocking);
      if (!hasStableFace || hasMessages || blocking) {
        readyToGenerateEl.classList.add('hidden');
        readyToGenerateEl.innerHTML = '';
        return;
      }
      readyToGenerateEl.classList.remove('hidden');
      readyToGenerateEl.innerHTML = `
        <p class="font-bold">지금 바로 생성해도 좋은 상태입니다.</p>
        <p class="mt-2">얼굴 위치와 수평이 안정적입니다. 현재 구도로 생성하면 추천 후보가 나올 가능성이 높습니다.</p>
      `;
    };

    const updateGuideOverlay = () => {
      if (!(guideOverlayEl instanceof HTMLElement)) return;
      const shouldShow = Boolean(sourceDataUrl || stream);
      guideOverlayEl.classList.toggle('hidden', !shouldShow);
      guideOverlayEl.classList.toggle('flex', shouldShow);
      renderLiveFaceOverlay();
    };

    const buildLiveFaceStatus = (assessment) => {
      if (assessment?.blocking) {
        return { tone: 'rose', label: '다시 맞춰주세요' };
      }
      if (Array.isArray(assessment?.messages) && assessment.messages.length) {
        return { tone: 'amber', label: '조금만 더 맞춰주세요' };
      }
      if (assessment?.faceHint?.bbox) {
        return { tone: 'emerald', label: '정렬이 안정적입니다' };
      }
      return { tone: 'sky', label: '얼굴을 찾는 중' };
    };

    const buildLiveFaceCoaching = (faceHint) => {
      if (!faceHint?.bbox) return '얼굴이 보이게 카메라를 맞춰주세요';
      const centerX = Number(faceHint.bbox.x ?? 0) + Number(faceHint.bbox.width ?? 0) / 2;
      const centerY = Number(faceHint.bbox.y ?? 0) + Number(faceHint.bbox.height ?? 0) / 2;
      const tips = [];
      if (centerX < 0.45) tips.push('얼굴을 조금 오른쪽으로');
      else if (centerX > 0.55) tips.push('얼굴을 조금 왼쪽으로');
      if (centerY < 0.43) tips.push('카메라를 조금 아래로');
      else if (centerY > 0.58) tips.push('카메라를 조금 위로');
      if (faceHint.leftEye && faceHint.rightEye) {
        const eyeTilt = Number(faceHint.leftEye.y ?? 0) - Number(faceHint.rightEye.y ?? 0);
        if (Math.abs(eyeTilt) > 0.018) tips.push(eyeTilt > 0 ? '고개를 오른쪽으로 살짝' : '고개를 왼쪽으로 살짝');
      }
      return tips.length ? tips[0] : '지금 구도가 가장 안정적입니다';
    };

    const renderLiveFaceOverlay = () => {
      if (!(liveFaceBoxEl instanceof HTMLElement) || !(liveFaceStatusEl instanceof HTMLElement)) return;
      const activeFaceHint = stream ? livePreviewFaceHint : (sourceFaceHint ?? sourceUploadAssessment?.faceHint ?? null);
      const activeStatus = stream
        ? (livePreviewFaceStatus ?? { tone: 'sky', label: '얼굴을 찾는 중' })
        : buildLiveFaceStatus(sourceUploadAssessment);

      if (activeFaceHint?.bbox) {
        const { x, y, width, height } = activeFaceHint.bbox;
        const mirroredLeft = stream ? (1 - x - width) : x;
        const left = Math.max(0, Math.min(1, mirroredLeft));
        const top = Math.max(0, Math.min(1, y));
        const safeWidth = Math.max(0.08, Math.min(1, width));
        const safeHeight = Math.max(0.12, Math.min(1, height));
        const centerX = left + safeWidth / 2;
        const eyeLineY = activeFaceHint.leftEye && activeFaceHint.rightEye
          ? ((Number(activeFaceHint.leftEye.y) + Number(activeFaceHint.rightEye.y)) / 2)
          : top + safeHeight * 0.34;
        liveFaceBoxEl.style.left = `${left * 100}%`;
        liveFaceBoxEl.style.top = `${top * 100}%`;
        liveFaceBoxEl.style.width = `${safeWidth * 100}%`;
        liveFaceBoxEl.style.height = `${safeHeight * 100}%`;
        liveFaceBoxEl.classList.remove('hidden');
        if (liveFaceCenterlineEl instanceof HTMLElement) {
          liveFaceCenterlineEl.style.left = `${centerX * 100}%`;
          liveFaceCenterlineEl.style.top = `${top * 100}%`;
          liveFaceCenterlineEl.style.height = `${safeHeight * 100}%`;
          liveFaceCenterlineEl.classList.remove('hidden');
        }
        if (liveEyeLineEl instanceof HTMLElement) {
          liveEyeLineEl.style.left = `${left * 100}%`;
          liveEyeLineEl.style.top = `${Math.max(0, Math.min(1, eyeLineY)) * 100}%`;
          liveEyeLineEl.style.width = `${safeWidth * 100}%`;
          liveEyeLineEl.classList.remove('hidden');
        }
      } else {
        liveFaceBoxEl.classList.add('hidden');
        liveFaceCenterlineEl instanceof HTMLElement && liveFaceCenterlineEl.classList.add('hidden');
        liveEyeLineEl instanceof HTMLElement && liveEyeLineEl.classList.add('hidden');
      }

      if (activeStatus?.label) {
        const toneClasses = {
          emerald: 'bg-emerald-500/88 text-white',
          amber: 'bg-amber-400/92 text-slate-950',
          rose: 'bg-rose-500/90 text-white',
          sky: 'bg-sky-500/88 text-white',
        };
        liveFaceStatusEl.className = `rounded-full px-3 py-1 text-[10px] font-bold tracking-[0.18em] shadow-sm ${toneClasses[activeStatus.tone] ?? toneClasses.sky}`;
        liveFaceStatusEl.textContent = activeStatus.label;
        liveFaceStatusEl.classList.remove('hidden');
      } else {
        liveFaceStatusEl.classList.add('hidden');
      }

      if (liveFaceCoachingEl instanceof HTMLElement) {
        const coaching = buildLiveFaceCoaching(activeFaceHint);
        liveFaceCoachingEl.textContent = coaching;
        liveFaceCoachingEl.classList.toggle('hidden', !activeFaceHint);
      }
    };

    const updateGenerateAvailability = () => {
      if (generateBtn instanceof HTMLButtonElement) {
        generateBtn.disabled = isGenerating || !sourceDataUrl || Boolean(sourceUploadAssessment?.blocking);
        generateBtn.classList.toggle('opacity-60', Boolean(sourceUploadAssessment?.blocking));
      }
    };

    const renderBlockingCta = (assessment) => {
      if (!(blockingCtaEl instanceof HTMLElement)) return;
      if (!assessment?.blocking) {
        blockingCtaEl.classList.add('hidden');
        blockingCtaEl.innerHTML = '';
        return;
      }
      blockingCtaEl.classList.remove('hidden');
      blockingCtaEl.innerHTML = `
        <p class="font-bold">지금은 다시 맞춰 찍는 편이 더 빠릅니다.</p>
        <p class="mt-1 text-[11px] text-amber-800">얼굴 위치를 먼저 바로잡은 뒤 생성하면 추천 점수와 규격 점수가 더 안정적으로 올라갑니다.</p>
        <div class="mt-3 flex flex-wrap gap-2">
          <button type="button" data-guidance-action="start-camera" class="rounded-lg border border-amber-300 bg-white px-3 py-2 text-[11px] font-bold text-amber-900">카메라 다시 열기</button>
          <button type="button" data-guidance-action="upload-file" class="rounded-lg border border-amber-300 bg-white px-3 py-2 text-[11px] font-bold text-amber-900">다른 사진 업로드</button>
        </div>
      `;
    };

    const handleGuidanceAction = (event) => {
      const target = event.target instanceof HTMLElement ? event.target.closest('[data-guidance-action]') : null;
      if (!(target instanceof HTMLElement)) return;
      const action = target.getAttribute('data-guidance-action');
      if (action === 'start-camera' && cameraStartBtn instanceof HTMLButtonElement) {
        cameraStartBtn.click();
      }
      if (action === 'upload-file' && fileInput instanceof HTMLInputElement) {
        fileInput.click();
      }
    };

    const setBusy = (busy) => {
      isGenerating = busy;
      updateGenerateAvailability();
      addButtons.forEach((buttonEl) => {
        buttonEl.disabled = busy;
      });
      syncMobileActionBar();
    };

    const isPolarProductReady = (productType) => {
      if (paymentMode !== 'polar') return true;
      return Boolean(paymentProducts?.[productType]);
    };

    const savePageState = () => {
      try {
        const serializableCandidates = candidates
          .filter((item) => typeof item.url === 'string' && !item.url.startsWith('data:'))
          .map((item) => ({
            id: item.id,
            url: item.url,
            selected: Boolean(item.selected),
            downloadUrl: item.downloadUrl || null,
            recommended: Boolean(item.recommended),
            score: item.score ?? null,
            identityScore: item.identityScore ?? null,
            qualityScore: item.qualityScore ?? null,
            regenerated: Boolean(item.regenerated)
          }));
        const payload = {
          candidates: serializableCandidates,
          basePaid,
          baseOrderId,
          creditedBaseOrders,
          addonOrders,
          latestJobId,
          savedAt: Date.now(),
          outfit: outfitEl instanceof HTMLSelectElement ? outfitEl.value : 'current',
          provider: getSelectedProvider()
        };
        localStorage.setItem(PAGE_STATE_KEY, JSON.stringify(payload));
      } catch {}
    };

    const MAX_UPLOAD_BYTES = 12 * 1024 * 1024;
    const MIN_WIDTH = 480;
    const MIN_HEIGHT = 640;
    const MEDIAPIPE_TASKS_VERSION = '0.10.14';
    const MEDIAPIPE_WASM_BASE = `https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@${MEDIAPIPE_TASKS_VERSION}/wasm`;
    const MEDIAPIPE_FACE_MODEL = 'https://storage.googleapis.com/mediapipe-models/face_detector/blaze_face_short_range/float16/1/blaze_face_short_range.tflite';

    let mediaPipeDetector = null;
    let mediaPipeDetectorLoading = null;
    let mediaPipeUnavailable = false;
    let livePreviewFaceHint = null;
    let livePreviewFaceStatus = null;
    let livePreviewAnalysisTimer = null;

    const validateSelectedFile = (file, inputEl) => {
      if (!String(file.type).startsWith('image/')) {
        setStatus('이미지 파일만 업로드할 수 있습니다.');
        if (inputEl) inputEl.value = '';
        return false;
      }
      if (file.size > MAX_UPLOAD_BYTES) {
        setStatus('이미지 용량은 12MB 이하만 가능합니다.');
        if (inputEl) inputEl.value = '';
        return false;
      }
      return true;
    };

    const loadImageFromUrl = (url) => new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => resolve(img);
      img.onerror = () => reject(new Error('image load failed'));
      img.src = url;
    });

    const getQualityHint = (width, height) => {
      if (width < 360 || height < 480) {
        return {
          level: 'blocking',
          message: `해상도(${width}x${height})가 너무 낮아 결과가 심하게 흐려질 수 있습니다. 다시 촬영해 주세요.`
        };
      }
      if (width < MIN_WIDTH || height < MIN_HEIGHT) {
        return {
          level: 'warning',
          message: `해상도(${width}x${height})가 낮아 품질이 떨어질 수 있습니다.`
        };
      }
      return null;
    };

    const getMediaPipeDetector = async () => {
      if (mediaPipeDetector) return mediaPipeDetector;
      if (mediaPipeUnavailable) return null;
      if (mediaPipeDetectorLoading) return mediaPipeDetectorLoading;

      mediaPipeDetectorLoading = (async () => {
        try {
          const vision = await import(`https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@${MEDIAPIPE_TASKS_VERSION}`);
          const filesetResolver = await vision.FilesetResolver.forVisionTasks(MEDIAPIPE_WASM_BASE);
          mediaPipeDetector = await vision.FaceDetector.createFromOptions(filesetResolver, {
            baseOptions: { modelAssetPath: MEDIAPIPE_FACE_MODEL },
            runningMode: 'IMAGE',
            minDetectionConfidence: 0.5
          });
          return mediaPipeDetector;
        } catch {
          mediaPipeUnavailable = true;
          return null;
        } finally {
          mediaPipeDetectorLoading = null;
        }
      })();

      return mediaPipeDetectorLoading;
    };

    const buildFaceAssessmentFromDetections = (detections, width, height) => {
      if (detections.length === 0) return { messages: ['얼굴을 인식하지 못했습니다. 정면 사진으로 다시 촬영해 주세요.'], blocking: true, faceHint: null };
      if (detections.length > 1) return { messages: ['여러 얼굴이 감지되었습니다. 1인 사진으로 다시 촬영해 주세요.'], blocking: true, faceHint: null };

      const detection = detections[0];
      const box = detection?.boundingBox;
      if (!box) return { messages: [], blocking: false, faceHint: null };
      const keypoints = Array.isArray(detection?.keypoints) ? detection.keypoints : [];

      const faceHint = {
        bbox: {
          x: Number(box.originX || 0) / Math.max(1, width),
          y: Number(box.originY || 0) / Math.max(1, height),
          width: Number(box.width || 0) / Math.max(1, width),
          height: Number(box.height || 0) / Math.max(1, height)
        },
        leftEye: keypoints[1] ? {
          x: Number(keypoints[1].x || 0) / Math.max(1, width),
          y: Number(keypoints[1].y || 0) / Math.max(1, height)
        } : null,
        rightEye: keypoints[0] ? {
          x: Number(keypoints[0].x || 0) / Math.max(1, width),
          y: Number(keypoints[0].y || 0) / Math.max(1, height)
        } : null
      };
      const messages = [];
      let blocking = false;

      const faceRatio = Number(box.width || 0) / Math.max(1, width);
      if (faceRatio < 0.14) {
        blocking = true;
        messages.push('얼굴이 너무 작습니다. 얼굴이 더 크게 나온 사진으로 다시 촬영해 주세요.');
      } else if (faceRatio < 0.18) {
        messages.push('얼굴이 작게 보여 품질이 떨어질 수 있습니다. 얼굴이 더 크게 나온 사진을 권장합니다.');
      }
      if (faceRatio > 0.82) {
        blocking = true;
        messages.push('얼굴이 너무 가까워 상단 여백과 턱선이 잘릴 수 있습니다. 약간 떨어져 촬영해 주세요.');
      } else if (faceRatio > 0.78) {
        messages.push('얼굴이 가까워 규격 정렬이 어려울 수 있습니다. 약간 떨어져 촬영해 주세요.');
      }

      const centerX = (Number(box.originX || 0) + Number(box.width || 0) / 2) / Math.max(1, width);
      if (centerX < 0.14 || centerX > 0.86) {
        blocking = true;
        messages.push('얼굴이 화면 중앙에서 너무 많이 벗어났습니다. 정면으로 중앙에 맞춰 다시 촬영해 주세요.');
      } else if (centerX < 0.2 || centerX > 0.8) {
        messages.push('얼굴이 화면 중앙에서 벗어나 있습니다. 중앙 정렬 사진을 권장합니다.');
      }

      if (faceHint.leftEye && faceHint.rightEye) {
        const eyeTilt = Math.abs(faceHint.leftEye.y - faceHint.rightEye.y);
        if (eyeTilt > 0.06) {
          blocking = true;
          messages.push('고개 기울기가 큽니다. 얼굴을 수평에 가깝게 맞춰 다시 촬영해 주세요.');
        } else if (eyeTilt > 0.03) {
          messages.push('고개가 약간 기울어져 있습니다. 얼굴을 조금만 더 수평으로 맞추면 더 좋습니다.');
        }
      }
      return { messages, blocking, faceHint };
    };

    const getFaceQualityHint = async (img, width, height) => {
      const detector = await getMediaPipeDetector();
      if (!detector) return { messages: [], blocking: false, faceHint: null };

      try {
        const result = detector.detect(img);
        const detections = Array.isArray(result?.detections) ? result.detections : [];
        return buildFaceAssessmentFromDetections(detections, width, height);
      } catch {
        return { messages: [], blocking: false, faceHint: null };
      }
    };

    const inspectImageFile = async (file) => {
      const objectUrl = URL.createObjectURL(file);
      try {
        const img = await loadImageFromUrl(objectUrl);
        const width = img.naturalWidth || 0;
        const height = img.naturalHeight || 0;
        const messages = [];
        let blocking = false;
        const qualityHint = getQualityHint(width, height);
        if (qualityHint?.message) {
          messages.push(qualityHint.message);
          blocking = qualityHint.level === 'blocking';
        }
        const faceAssessment = await getFaceQualityHint(img, width, height);
        if (Array.isArray(faceAssessment.messages) && faceAssessment.messages.length) {
          messages.push(...faceAssessment.messages);
        }
        return {
          messages,
          blocking: blocking || Boolean(faceAssessment.blocking),
          faceHint: faceAssessment.faceHint ?? null
        };
      } finally {
        URL.revokeObjectURL(objectUrl);
      }
    };

    const detectFaceHintForFile = async (file) => (await inspectImageFile(file)).faceHint ?? null;

    const stopLivePreviewAnalysis = () => {
      if (livePreviewAnalysisTimer) window.clearInterval(livePreviewAnalysisTimer);
      livePreviewAnalysisTimer = null;
      livePreviewFaceHint = null;
      livePreviewFaceStatus = null;
      renderLiveFaceOverlay();
    };

    const analyzeLivePreviewFrame = async () => {
      if (!stream || !(cameraEl instanceof HTMLVideoElement)) return;
      if (cameraEl.readyState < 2) return;
      const detector = await getMediaPipeDetector();
      if (!detector) return;
      try {
        const result = detector.detect(cameraEl);
        const detections = Array.isArray(result?.detections) ? result.detections : [];
        const assessment = buildFaceAssessmentFromDetections(
          detections,
          cameraEl.videoWidth || cameraEl.clientWidth || 1,
          cameraEl.videoHeight || cameraEl.clientHeight || 1
        );
        livePreviewFaceHint = assessment.faceHint ?? null;
        livePreviewFaceStatus = buildLiveFaceStatus(assessment);
        renderLiveFaceOverlay();
      } catch {}
    };

    const startLivePreviewAnalysis = () => {
      stopLivePreviewAnalysis();
      livePreviewFaceStatus = { tone: 'sky', label: '얼굴을 찾는 중' };
      renderLiveFaceOverlay();
      livePreviewAnalysisTimer = window.setInterval(() => {
        void analyzeLivePreviewFrame();
      }, 450);
      void analyzeLivePreviewFrame();
    };

    const setSource = (dataUrl, file = null) => {
      sourceDataUrl = dataUrl;
      sourceFile = file;
      sourceFaceHint = null;
      sourceUploadAssessment = { messages: [], blocking: false, faceHint: null };
      livePreviewFaceHint = null;
      livePreviewFaceStatus = null;
      cachedPhotoId = null;
      basePaid = false;
      baseOrderId = null;
      creditedBaseOrders = [];
      candidates = [];
      renderPipelineReport(null);
      renderJobDebugLink(null);
      renderQualityFeedback(null);
      renderProviderResultBadge(null);
      renderUploadGuidance(null);
      renderBlockingCta(null);
      renderReadyToGenerate(null);
      renderAssessmentScore(null);
      renderCandidates();
      updateGuideOverlay();
      if (sourcePreview instanceof HTMLImageElement) {
        sourcePreview.src = dataUrl;
        sourcePreview.classList.remove('hidden');
      }
      if (sourceEmpty instanceof HTMLElement) sourceEmpty.classList.add('hidden');
      updateGenerateAvailability();
      if (compareBeforeEl instanceof HTMLImageElement) compareBeforeEl.src = dataUrl;
      if (compareAfterEl instanceof HTMLImageElement) compareAfterEl.src = '';
      if (compareHelpEl instanceof HTMLElement) compareHelpEl.textContent = '후보 생성 후 결과 비교가 활성화됩니다.';
      if (compareSliderEl instanceof HTMLInputElement) {
        compareSliderEl.value = '50';
        compareSliderEl.disabled = true;
      }
      if (compareAfterWrapEl instanceof HTMLElement) compareAfterWrapEl.style.width = '50%';
      savePageState();
    };

    const resetAllState = (message = '초기화되었습니다.') => {
      stopCamera();
      sourceDataUrl = null;
      sourceFile = null;
      sourceFaceHint = null;
      sourceUploadAssessment = { messages: [], blocking: false, faceHint: null };
      cachedPhotoId = null;
      basePaid = false;
      baseOrderId = null;
      creditedBaseOrders = [];
      addonOrders = { add2: null, add3: null, add7: null };
      candidates = [];
      renderPipelineReport(null);
      renderJobDebugLink(null);
      renderQualityFeedback(null);
      renderProviderResultBadge(null);
      renderUploadGuidance(null);
      renderBlockingCta(null);
      renderReadyToGenerate(null);
      renderAssessmentScore(null);
      renderCandidates();
      updateGuideOverlay();
      if (sourcePreview instanceof HTMLImageElement) {
        sourcePreview.src = '';
        sourcePreview.classList.add('hidden');
      }
      if (sourceEmpty instanceof HTMLElement) sourceEmpty.classList.remove('hidden');
      if (fileInput instanceof HTMLInputElement) fileInput.value = '';
      updateGenerateAvailability();
      if (downloadBtn instanceof HTMLButtonElement) downloadBtn.disabled = true;
      if (compareBeforeEl instanceof HTMLImageElement) compareBeforeEl.src = '';
      if (compareAfterEl instanceof HTMLImageElement) compareAfterEl.src = '';
      if (compareAfterWrapEl instanceof HTMLElement) compareAfterWrapEl.style.width = '50%';
      if (compareSliderEl instanceof HTMLInputElement) {
        compareSliderEl.value = '50';
        compareSliderEl.disabled = true;
      }
      if (compareHelpEl instanceof HTMLElement) {
        compareHelpEl.textContent = '사진 업로드 후 후보 생성 시 비교가 활성화됩니다.';
      }
      try {
        localStorage.removeItem(PAGE_STATE_KEY);
      } catch {}
      setStatus(message);
    };

    const stopCamera = () => {
      stopLivePreviewAnalysis();
      if (stream) stream.getTracks().forEach((track) => track.stop());
      stream = null;
      if (cameraEl instanceof HTMLVideoElement) {
        cameraEl.classList.add('hidden');
        cameraEl.style.transform = '';
      }
      if (cameraCaptureBtn instanceof HTMLButtonElement) cameraCaptureBtn.disabled = true;
      updateGuideOverlay();
    };

    const ensureRecommendedSelection = () => {
      if (!Array.isArray(candidates) || candidates.length === 0) return;
      if (candidates.some((item) => item.selected)) return;
      const recommendedIndex = candidates.findIndex((item) => item.recommended);
      candidates = candidates.map((item, idx) => ({
        ...item,
        selected: idx === (recommendedIndex >= 0 ? recommendedIndex : 0)
      }));
    };

    const renderCandidates = () => {
      if (!(gridEl instanceof HTMLElement)) return;
      gridEl.innerHTML = '';
      candidates.forEach((item, idx) => {
        const card = document.createElement('button');
        card.type = 'button';
        card.className = `overflow-hidden rounded-2xl border bg-white p-2 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-md ${item.selected ? 'border-emerald-500 ring-2 ring-emerald-300' : 'border-slate-200'}`;
        card.innerHTML = `
          <div class="relative">
            <img src="${item.url}" alt="후보 ${idx + 1}" class="h-56 w-full rounded-xl object-cover sm:h-48" />
            <div class="absolute left-3 top-3 flex items-center gap-2">
              <span class="rounded-full bg-white/95 px-2.5 py-1 text-[11px] font-black text-slate-900 shadow-sm">${idx + 1}번 후보</span>
              ${item.recommended ? '<span class="rounded-full bg-amber-300/95 px-2.5 py-1 text-[11px] font-black text-amber-950 shadow-sm">추천</span>' : ''}
            </div>
            <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-[repeating-linear-gradient(-32deg,rgba(15,23,42,0.18)_0,rgba(15,23,42,0.18)_16px,transparent_16px,transparent_42px)]">
              <span class="rotate-[-24deg] rounded-full border border-white/45 bg-slate-900/60 px-4 py-1.5 text-[10px] font-black tracking-[0.28em] text-white/95">MANYTOOL PREVIEW</span>
            </div>
          </div>
          <div class="mt-2 flex items-center justify-between px-1">
            <p class="text-sm font-bold text-slate-800">${item.recommended ? '점수 기준 추천 후보' : '분위기 다른 후보'}</p>
            <span class="text-xs font-semibold ${item.selected ? 'text-emerald-600' : 'text-slate-400'}">${item.selected ? '선택됨' : '탭해서 선택'}</span>
          </div>
          <div class="mt-2 rounded-xl bg-slate-50 px-3 py-2 text-[11px] leading-5 text-slate-600">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
              <span><strong class="text-slate-900">추천 점수</strong> ${typeof item.score === 'number' ? item.score.toFixed(1) : 'n/a'}</span>
              <span><strong class="text-slate-900">동일성</strong> ${typeof item.identityScore === 'number' ? item.identityScore.toFixed(1) : 'n/a'}</span>
              <span><strong class="text-slate-900">규격</strong> ${typeof item.qualityScore === 'number' ? item.qualityScore.toFixed(1) : 'n/a'}</span>
              ${item.regenerated ? '<span class="rounded-full bg-amber-100 px-2 py-0.5 font-semibold text-amber-800">안전 재생성</span>' : ''}
            </div>
          </div>
        `;
        card.addEventListener('click', () => {
          const selectedCount = candidates.filter((c) => c.selected).length;
          if (!item.selected && selectedCount >= 1) {
            window.alert('후보 이미지는 1개만 선택할 수 있습니다.');
            setStatus('최대 1장까지 선택할 수 있습니다.');
            return;
          }
          item.selected = !item.selected;
          renderCandidates();
        });
        gridEl.append(card);
      });
      if (downloadBtn instanceof HTMLButtonElement) {
        downloadBtn.disabled = candidates.filter((c) => c.selected).length !== 1;
      }
      syncMobileActionBar();
      savePageState();
    };

    const restorePageState = () => {
      try {
        const raw = localStorage.getItem(PAGE_STATE_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        if (parsed.savedAt && Date.now() - Number(parsed.savedAt) > 1000 * 60 * 60 * 24 * 3) {
          localStorage.removeItem(PAGE_STATE_KEY);
          return;
        }
        if (outfitEl instanceof HTMLSelectElement && typeof parsed.outfit === 'string') {
          outfitEl.value = parsed.outfit;
        }
        if (providerSelectEl instanceof HTMLSelectElement && typeof parsed.provider === 'string') {
          providerSelectEl.value = parsed.provider;
          updateProviderHelp();
        }
        if (Array.isArray(parsed.candidates) && parsed.candidates.length > 0) {
          candidates = parsed.candidates
            .filter((item) => typeof item.url === 'string')
            .map((item) => ({
              id: item.id || `restored_${Date.now()}`,
              url: item.url,
              selected: Boolean(item.selected),
              downloadUrl: item.downloadUrl || null,
              recommended: Boolean(item.recommended),
              score: item.score ?? null,
              identityScore: item.identityScore ?? null,
              qualityScore: item.qualityScore ?? null,
              regenerated: Boolean(item.regenerated)
            }));
          ensureRecommendedSelection();
          renderCandidates();
          if (compareAfterEl instanceof HTMLImageElement) compareAfterEl.src = candidates[0].url;
          if (compareHelpEl instanceof HTMLElement) compareHelpEl.textContent = '이전 생성 결과를 복원했습니다.';
          setStatus('이전 후보 결과를 복원했습니다. 필요하면 다시 생성할 수 있습니다.');
        }
        basePaid = Boolean(parsed.basePaid);
        baseOrderId = typeof parsed.baseOrderId === 'string' ? parsed.baseOrderId : null;
        creditedBaseOrders = Array.isArray(parsed.creditedBaseOrders) ? parsed.creditedBaseOrders.filter((item) => typeof item === 'string') : [];
        if (basePaid && baseOrderId && !creditedBaseOrders.includes(baseOrderId)) {
          creditedBaseOrders.push(baseOrderId);
        }
        addonOrders = {
          add2: typeof parsed?.addonOrders?.add2 === 'string' ? parsed.addonOrders.add2 : null,
          add3: typeof parsed?.addonOrders?.add3 === 'string' ? parsed.addonOrders.add3 : null,
          add7: typeof parsed?.addonOrders?.add7 === 'string' ? parsed.addonOrders.add7 : null
        };
        renderJobDebugLink(typeof parsed.latestJobId === 'string' ? parsed.latestJobId : null);
      } catch {}
    };

    const verifyBaseOrder = async () => {
      if (!baseOrderId) return;
      try {
        const res = await fetch(`${API_BASE}/order/${baseOrderId}`);
        if (!res.ok) return;
        const order = await res.json();
        if (String(order.status) === 'paid' && baseOrderId && !creditedBaseOrders.includes(baseOrderId)) {
          creditedBaseOrders.push(baseOrderId);
          basePaid = true;
        }
        savePageState();
      } catch {}
    };

    const fetchOrder = async (orderId) => {
      if (!orderId) return null;
      const res = await fetch(`${API_BASE}/order/${orderId}`);
      if (!res.ok) return null;
      return res.json();
    };

    const requestRefund = async (orderId, reason = 'service_disruption') => {
      if (!orderId || !apiOnline || paymentMode !== 'polar') return false;
      const res = await fetch(`${API_BASE}/refund`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId, reason })
      });
      return res.ok;
    };

    const centerCropTo34 = (img, shiftX = 0, shiftY = 0, filter = 'none') => {
      const ratio = 3 / 4;
      const srcW = img.naturalWidth || img.width;
      const srcH = img.naturalHeight || img.height;
      let cropW = srcW;
      let cropH = Math.round(cropW / ratio);
      if (cropH > srcH) {
        cropH = srcH;
        cropW = Math.round(cropH * ratio);
      }
      const baseX = Math.floor((srcW - cropW) / 2);
      const baseY = Math.floor((srcH - cropH) / 2);
      const x = Math.max(0, Math.min(srcW - cropW, baseX + shiftX));
      const y = Math.max(0, Math.min(srcH - cropH, baseY + shiftY));
      const canvas = document.createElement('canvas');
      canvas.width = 600;
      canvas.height = 800;
      const ctx = canvas.getContext('2d');
      if (!ctx) return '';
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.filter = filter;
      ctx.drawImage(img, x, y, cropW, cropH, 0, 0, canvas.width, canvas.height);
      return canvas.toDataURL('image/jpeg', 0.92);
    };

    const generateCandidatesLocalFallback = async (count = 3) => {
      const img = new Image();
      img.src = sourceDataUrl;
      await img.decode();
      const outfit = outfitEl instanceof HTMLSelectElement ? outfitEl.value : 'current';
      const suitFilter = outfit === 'suit' ? 'contrast(1.03) saturate(0.97)' : 'none';
      const variants = [];
      for (let i = 0; i < count; i += 1) {
        const shiftX = (i % 3) * 6;
        const shiftY = (i % 2) * -6;
        const filter = i % 2 === 0 ? suitFilter : `${suitFilter} brightness(1.08)`;
        variants.push({
          id: `candidate_${Date.now()}_${i + 1}`,
          url: centerCropTo34(img, shiftX, shiftY, filter),
          selected: false,
          downloadUrl: null,
          recommended: i === 0,
          score: null,
          identityScore: null,
          qualityScore: null,
          regenerated: false
        });
      }
      candidates = [...candidates, ...variants];
    };

    const uploadSourceIfNeeded = async () => {
      if (cachedPhotoId) return cachedPhotoId;
      if (!sourceFile) throw new Error('source file is missing');
      if (!sourceFaceHint) {
        sourceFaceHint = await detectFaceHintForFile(sourceFile);
      }
      const form = new FormData();
      form.append('image', sourceFile);
      form.append('sourceType', 'upload');
      if (sourceFaceHint) {
        form.append('faceHint', JSON.stringify(sourceFaceHint));
      }
      const uploadRes = await fetch(`${API_BASE}/upload`, { method: 'POST', body: form });
      if (!uploadRes.ok) throw new Error(`upload failed: ${uploadRes.status}`);
      const uploadData = await uploadRes.json();
      if (!uploadData.photoId) throw new Error('photoId missing');
      cachedPhotoId = uploadData.photoId;
      return cachedPhotoId;
    };

    const requestServerCandidates = async (count = 3) => {
      const photoId = await uploadSourceIfNeeded();
      const outfit = outfitEl instanceof HTMLSelectElement ? outfitEl.value : 'current';
      const rounds = Math.ceil(count / 3);
      const generated = [];
      let latestPipelineReport = null;
      let latestResponseJobId = null;

      for (let i = 0; i < rounds; i += 1) {
        const genRes = await fetch(`${API_BASE}/generate`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            photoId,
            toolType: 'id_photo',
            outfitType: outfit,
            provider: getSelectedProvider()
          })
        });
        if (!genRes.ok) throw new Error(`generate failed: ${genRes.status}`);
        const genData = await genRes.json();
        if (!Array.isArray(genData.candidates)) throw new Error('invalid candidates');
        latestPipelineReport = genData.pipelineReport ?? latestPipelineReport;
        latestResponseJobId = typeof genData.jobId === 'string' ? genData.jobId : latestResponseJobId;
        generated.push(...genData.candidates);
      }

      return {
        jobId: latestResponseJobId,
        candidates: generated.slice(0, count).map((item) => ({
          id: item.id,
          url: `${API_BASE}${item.imageUrl}`,
          selected: false,
          downloadUrl: `${API_BASE}/download/${item.id}`,
          recommended: Boolean(item.recommended),
          score: item.score ?? null,
          identityScore: item.identityScore ?? null,
          qualityScore: latestPipelineReport?.qualityScore ?? null,
          regenerated: Boolean(item.regenerated)
        })),
        pipelineReport: latestPipelineReport
      };
    };

    const generateCandidates = async (count = 3, append = false) => {
      if (!sourceDataUrl || isGenerating) return;
      setBusy(true);
      setStatus('후보를 생성하고 있습니다...');
      try {
        const generation = await requestServerCandidates(count);
        candidates = append ? [...candidates, ...generation.candidates] : generation.candidates;
        renderPipelineReport(generation.pipelineReport ?? null);
        renderJobDebugLink(generation.jobId ?? null, generation.pipelineReport ?? null);
        renderQualityFeedback(generation.pipelineReport ?? null);
        if (!append) ensureRecommendedSelection();
        const resolvedProvider = generation.pipelineReport?.fallbackToLocalSharp
          ? `local_sharp fallback from ${generation.pipelineReport?.resolvedProvider ?? 'unknown'}`
          : (generation.pipelineReport?.resolvedProvider ?? 'unknown');
        renderProviderResultBadge(generation.pipelineReport ?? null);
        setStatus(`Node API 생성 완료. provider=${resolvedProvider}. 현재 ${candidates.length}장 후보가 준비되었습니다. ${generation.pipelineReport?.qualitySummary ?? ''}`.trim());
      } catch {
        if (!append) candidates = [];
        try {
          await generateCandidatesLocalFallback(count);
          renderPipelineReport(null);
          renderJobDebugLink(null);
          renderQualityFeedback(null);
          renderProviderResultBadge({
            requestedProvider: getSelectedProvider(),
            resolvedProvider: 'local_sharp',
            fallbackToLocalSharp: false,
            externalBackgroundCall: false,
            cache: {}
          });
          if (!append) ensureRecommendedSelection();
          setStatus(`Node API 연결 실패. 로컬 생성 모드로 전환되었습니다. 현재 ${candidates.length}장 후보가 준비되었습니다.`);
        } catch (fallbackError) {
          throw fallbackError;
        }
      }
      finally {
        if (compareAfterEl instanceof HTMLImageElement) compareAfterEl.src = candidates[0]?.url ?? '';
        if (compareHelpEl instanceof HTMLElement) compareHelpEl.textContent = '슬라이더를 움직여 전/후 변화를 비교하세요.';
        if (compareSliderEl instanceof HTMLInputElement) compareSliderEl.disabled = false;
        renderCandidates();
        setBusy(false);
        if (candidates.length > 0) {
          window.setTimeout(scrollToCandidates, 120);
        }
      }
    };

    const requestAddonCheckout = async (count) => {
      const priceMap = { 2: 390, 3: 490, 7: 590 };
      const amount = priceMap[count];
      if (!amount) throw new Error('invalid addon count');
      if (!isPolarProductReady(`add${count}`)) {
        throw new Error(`Polar product is not configured for add${count}`);
      }

      const res = await fetch(`${API_BASE}/checkout`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          productType: `add${count}`,
          amount,
          currency: 'USD'
        })
      });
      if (!res.ok) throw new Error(`checkout failed: ${res.status}`);
      return res.json();
    };

    const requestBaseCheckout = async () => {
      if (!isPolarProductReady('base')) {
        throw new Error('Polar base product is not configured');
      }
      const res = await fetch(`${API_BASE}/checkout`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          productType: 'base',
          amount: 990,
          currency: 'USD'
        })
      });
      if (!res.ok) throw new Error(`checkout failed: ${res.status}`);
      return res.json();
    };

    const moveToCheckoutIfPending = (checkout, pendingMessage, persistBaseOrder = false) => {
      if (!checkout || !checkout.checkoutUrl || checkout.paid) return false;
      if (persistBaseOrder) {
        baseOrderId = checkout.orderId ?? baseOrderId;
        savePageState();
