    if (compareSliderEl instanceof HTMLInputElement && compareAfterWrapEl instanceof HTMLElement) {
      compareSliderEl.addEventListener('input', () => {
        compareAfterWrapEl.style.width = `${compareSliderEl.value}%`;
      });
    }

    const loadApiStatus = async () => {
      try {
        const [healthRes, configRes] = await Promise.all([
          fetch(`${API_BASE}/health`),
          fetch(`${API_BASE}/config`)
        ]);
        if (!healthRes.ok || !configRes.ok) throw new Error('status check failed');
        const config = await configRes.json();
        apiOnline = true;
        paymentMode = config?.paymentMode ?? 'mock';
        paymentProducts = {
          base: Boolean(config?.paymentProducts?.base),
          add2: Boolean(config?.paymentProducts?.add2),
          add3: Boolean(config?.paymentProducts?.add3),
          add7: Boolean(config?.paymentProducts?.add7)
        };
        const configuredProvider = config.configuredImageProvider ?? 'unknown';
        const resolvedProvider = config.imageProvider ?? 'unknown';
        const removeBgReady = Boolean(config?.readiness?.removeBgReady);
        const photoroomReady = Boolean(config?.readiness?.photoroomReady);
        providerAvailability = {
          auto: true,
          local_sharp: true,
          remove_bg: Boolean(config?.providerAvailability?.remove_bg),
          photoroom: Boolean(config?.providerAvailability?.photoroom)
        };
        providerDiagnostics = config?.providerDiagnostics ?? {};
        syncProviderOptions();
        const externalAi = config.externalAiEnabled ? 'ON' : 'OFF';
        const providerBilling = resolvedProvider === 'local_sharp' ? 'free' : 'paid';
        const missingBits = [
          ...(removeBgReady ? [] : ['remove.bg:REMOVE_BG_API_KEY']),
          ...(photoroomReady ? [] : ['photoroom:PHOTOROOM_API_KEY+PHOTOROOM_REMOVE_BG_URL'])
        ];
        setApiStatus(`API 연결됨 · provider=${resolvedProvider}/${providerBilling} (configured=${configuredProvider}) · externalAI=${externalAi} · payment=${config.paymentMode} · remove.bg=${removeBgReady ? 'OK' : 'MISSING'} · photoroom=${photoroomReady ? 'OK' : 'MISSING'}${missingBits.length ? ` · need=${missingBits.join(' | ')}` : ''}`);
        updateProviderHelp();
        if (paymentMode === 'polar' && !paymentProducts.base) {
          setStatus('Polar 기본 상품 ID가 설정되지 않아 실결제를 시작할 수 없습니다.');
        }
        addButtons.forEach((buttonEl) => {
          const count = Number(buttonEl.getAttribute('data-add-count') || '0');
          if (paymentMode === 'polar' && count && !paymentProducts[`add${count}`]) {
            buttonEl.disabled = true;
            buttonEl.title = `Polar add${count} 상품 ID가 필요합니다.`;
          }
        });
      } catch {
        apiOnline = false;
        setApiStatus('API 미연결 · 로컬 fallback 모드');
      }
    };

    if (providerSelectEl instanceof HTMLSelectElement) {
      providerSelectEl.addEventListener('change', () => {
        updateProviderHelp();
        savePageState();
      });
    }

    loadApiStatus();
    restorePageState();
    verifyBaseOrder();

    if (fileInput instanceof HTMLInputElement) {
      fileInput.addEventListener('change', async (e) => {
        const input = e.target;
        const file = input.files && input.files[0];
        if (!file) return;
        if (!validateSelectedFile(file, input)) return;
        stopCamera();
        const reader = new FileReader();
        reader.onload = async () => {
          if (typeof reader.result === 'string') {
            setSource(reader.result, file);
            const assessment = await inspectImageFile(file);
            sourceUploadAssessment = assessment;
            sourceFaceHint = assessment.faceHint ?? null;
            renderUploadGuidance(assessment);
            renderBlockingCta(assessment);
            updateGenerateAvailability();
            setStatus(
              assessment.blocking
                ? '사진 품질이 낮아 다시 촬영을 권장합니다.'
                : (assessment.messages[0] ? `${assessment.messages[0]} 계속 진행합니다.` : '사진 업로드 완료.')
            );
          }
        };
        reader.readAsDataURL(file);
      });
    }

    if (resetBtn instanceof HTMLButtonElement) {
      resetBtn.addEventListener('click', () => resetAllState());
    }

    if (uploadGuidanceEl instanceof HTMLElement) uploadGuidanceEl.addEventListener('click', handleGuidanceAction);
    if (blockingCtaEl instanceof HTMLElement) blockingCtaEl.addEventListener('click', handleGuidanceAction);

    if (cameraStartBtn instanceof HTMLButtonElement) {
      cameraStartBtn.addEventListener('click', async () => {
        try {
          stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
          if (cameraEl instanceof HTMLVideoElement) {
            cameraEl.srcObject = stream;
            cameraEl.classList.remove('hidden');
            cameraEl.style.transform = 'scaleX(-1)';
          }
          if (cameraCaptureBtn instanceof HTMLButtonElement) cameraCaptureBtn.disabled = false;
          updateGuideOverlay();
          startLivePreviewAnalysis();
          setStatus('카메라가 켜졌습니다. 촬영 버튼을 눌러주세요.');
        } catch {
          setStatus('카메라 접근 실패. 업로드를 사용해주세요.');
        }
      });
    }

    if (cameraCaptureBtn instanceof HTMLButtonElement) {
      cameraCaptureBtn.addEventListener('click', async () => {
        if (!(cameraEl instanceof HTMLVideoElement)) return;
        const canvas = document.createElement('canvas');
        canvas.width = cameraEl.videoWidth || 720;
        canvas.height = cameraEl.videoHeight || 960;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;
        const applyMirrorFix = cameraMirrorFixEl instanceof HTMLInputElement ? cameraMirrorFixEl.checked : true;
        if (applyMirrorFix) {
          ctx.translate(canvas.width, 0);
          ctx.scale(-1, 1);
        }
        ctx.drawImage(cameraEl, 0, 0, canvas.width, canvas.height);
        if (applyMirrorFix) {
          ctx.setTransform(1, 0, 0, 1, 0, 0);
        }
        const dataUrl = canvas.toDataURL('image/jpeg', 0.92);
        const blob = dataURLToBlob(dataUrl);
        const file = new File([blob], `camera-${Date.now()}.jpg`, { type: 'image/jpeg' });
        setSource(dataUrl, file);
        stopCamera();
        const assessment = await inspectImageFile(file);
        sourceUploadAssessment = assessment;
        sourceFaceHint = assessment.faceHint ?? null;
        renderUploadGuidance(assessment);
        renderBlockingCta(assessment);
        updateGenerateAvailability();
        setStatus(
          assessment.blocking
            ? '사진 품질이 낮아 다시 촬영을 권장합니다.'
            : (assessment.messages[0] ? `${assessment.messages[0]} 계속 진행합니다.` : '촬영 완료.')
        );
        window.setTimeout(() => {
          generateBtn instanceof HTMLButtonElement && generateBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 120);
      });
    }

    if (generateBtn instanceof HTMLButtonElement) {
      generateBtn.addEventListener('click', () => generateCandidates(3, false));
    }

    addButtons.forEach((buttonEl) => {
      buttonEl.addEventListener('click', async () => {
        const count = Number(buttonEl.getAttribute('data-add-count') || '0');
        const productType = `add${count}`;
        if (!sourceDataUrl || !count) {
          setStatus('먼저 사진을 업로드하고 기본 후보를 생성해주세요.');
          return;
        }
        if (isGenerating) return;
        if (!apiOnline) {
          setStatus(`API 미연결 상태입니다. 결제 확인 없이 +${count}장 로컬 추가 생성을 진행합니다.`);
          await generateCandidates(count, true);
          return;
        }
        try {
          const existingOrderId = addonOrders[productType];
          if (existingOrderId) {
            const existingOrder = await fetchOrder(existingOrderId);
            if (existingOrder?.status === 'paid') {
              setStatus(`결제 완료(+${count}장). 추가 후보를 생성합니다...`);
              try {
                await generateCandidates(count, true);
                addonOrders[productType] = null;
                savePageState();
                return;
              } catch {
                await requestRefund(existingOrderId, 'service_disruption');
                addonOrders[productType] = null;
                savePageState();
                setStatus(`추가 생성 처리에 실패해 +${count}장 결제를 환불 요청했습니다.`);
                return;
              }
            }
            if (existingOrder?.status === 'pending' && existingOrder?.checkoutUrl) {
              window.location.href = existingOrder.checkoutUrl;
              return;
            }
            if (existingOrder?.status === 'refunded' || existingOrder?.status === 'failed' || existingOrder?.status === 'expired') {
              addonOrders[productType] = null;
              savePageState();
            }
          }
          setStatus('추가 생성 결제를 확인하고 있습니다...');
          const checkout = await requestAddonCheckout(count);
          if (!checkout.paid) {
            addonOrders[productType] = checkout.orderId ?? null;
            savePageState();
            if (moveToCheckoutIfPending(checkout, '결제 페이지로 이동합니다. 결제 후 돌아와 +추가 생성을 다시 눌러주세요.')) return;
            setStatus('결제가 완료되지 않아 추가 생성을 진행할 수 없습니다.');
            return;
          }
          setStatus(`결제 완료(+${count}장). 추가 후보를 생성합니다...`);
          try {
            await generateCandidates(count, true);
          } catch {
            await requestRefund(checkout.orderId, 'service_disruption');
            setStatus(`추가 생성 처리에 실패해 +${count}장 결제를 환불 요청했습니다.`);
            return;
          }
        } catch (error) {
          if (error instanceof Error && error.message.includes('not configured')) {
            setStatus('추가 생성용 Polar 상품 ID가 아직 설정되지 않았습니다.');
            return;
          }
          setStatus('추가 생성 결제 확인에 실패했습니다. 잠시 후 다시 시도해주세요.');
        }
      });
    });

    if (downloadBtn instanceof HTMLButtonElement) {
      downloadBtn.addEventListener('click', async () => {
        const selected = candidates.filter((item) => item.selected);
        if (selected.length !== 1) {
          window.alert('후보 이미지를 1개 선택해주세요.');
          setStatus('후보 이미지를 1개 선택해주세요.');
          return;
        }
        if (isGenerating) return;
        if (!apiOnline) {
          try {
            setStatus('API 미연결 상태입니다. 결제 확인 없이 다운로드를 시작합니다.');
            await downloadCandidate(selected[0], 1, 'manytool-id-photo');
            setStatus('다운로드를 시작했습니다.');
          } catch {
            setStatus('다운로드에 실패했습니다. 다시 시도해주세요.');
          }
          return;
        }
        if (!basePaid) {
          try {
            setStatus(paymentMode === 'mock' ? '기본 결제(mock) 상태를 확인하고 있습니다...' : '기본 결제를 확인하고 있습니다...');
            const checkout = await requestBaseCheckout();
            if (!checkout.paid) {
              if (moveToCheckoutIfPending(checkout, '결제 페이지로 이동합니다. 결제 후 돌아오면 다운로드가 가능합니다.', true)) return;
              setStatus('결제가 완료되지 않아 다운로드할 수 없습니다.');
              return;
            }
            basePaid = true;
            baseOrderId = checkout.orderId ?? null;
            if (baseOrderId && !creditedBaseOrders.includes(baseOrderId)) {
              creditedBaseOrders.push(baseOrderId);
            }
            savePageState();
            setStatus('기본 결제 완료. 다운로드를 시작합니다.');
          } catch (error) {
            if (error instanceof Error && error.message.includes('not configured')) {
              setStatus('기본 결제용 Polar 상품 ID가 아직 설정되지 않았습니다.');
              return;
            }
            setStatus('결제 확인에 실패했습니다. 잠시 후 다시 시도해주세요.');
            return;
          }
        }
        try {
          setStatus('다운로드 파일을 준비 중입니다...');
          await downloadCandidate(selected[0], 1, 'manytool-id-photo');
          basePaid = false;
          candidates.forEach((item) => {
            item.selected = false;
          });
          renderCandidates();
          savePageState();
          setStatus('다운로드를 시작했습니다.');
        } catch {
          await requestRefund(baseOrderId, 'service_disruption');
          basePaid = false;
          savePageState();
          setStatus('다운로드에 실패했습니다. 다시 시도해주세요.');
        }
      });
    }

    if (mobileDownloadBtn instanceof HTMLButtonElement && downloadBtn instanceof HTMLButtonElement) {
      mobileDownloadBtn.addEventListener('click', () => {
        downloadBtn.click();
      });
    }

    async function downloadCandidate(item, order, namePrefix) {
      const fileUrl = item.downloadUrl || item.url;
      const res = await fetch(fileUrl);
      if (!res.ok) throw new Error(`download failed: ${res.status}`);
      const blob = await res.blob();
      const objectUrl = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = objectUrl;
      link.download = `${namePrefix}-${order}.jpg`;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(objectUrl);
    }

    function dataURLToBlob(dataUrl) {
      const parts = dataUrl.split(',');
      const mime = parts[0].match(/:(.*?);/)?.[1] || 'image/jpeg';
      const binary = atob(parts[1]);
      const len = binary.length;
      const bytes = new Uint8Array(len);
      for (let i = 0; i < len; i += 1) bytes[i] = binary.charCodeAt(i);
      return new Blob([bytes], { type: mime });
    }
  </script>
</Layout>


