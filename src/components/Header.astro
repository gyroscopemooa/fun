---
const navItems = [
  { href: '/', label: '홈' },
  { href: '/animal-test', label: '동물상 테스트' },
  { href: '/personal-color', label: '퍼스널컬러' },
  { href: '/maps/fishbread', label: '붕어빵 지도' },
  { href: '/contact', label: '광고 문의' }
];
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="text-xl font-bold tracking-tight">FunHub</a>
    <nav class="flex flex-wrap gap-3 text-sm">
      {navItems.map((item) => (
        <a class="rounded-md px-2 py-1 hover:bg-slate-100" href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
