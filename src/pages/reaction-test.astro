---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="반응속도 테스트 | ManyTool" description="클릭 반응속도를 측정하는 웹 기반 미니게임 도구입니다.">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">반응속도 테스트</h1>
    <p class="mt-3 text-slate-700">시작 버튼을 누른 뒤 박스가 초록색으로 바뀌는 순간 클릭하세요.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-4 rounded-xl border border-slate-200 bg-white p-6">
      <p id="reaction-status" class="text-slate-700">시작 버튼을 누르세요.</p>
      <div class="mt-2 grid grid-cols-2 gap-2 text-sm md:grid-cols-4">
        <p class="rounded-md bg-slate-100 px-2 py-1">현재: <span id="reaction-current" class="font-bold">-</span></p>
        <p class="rounded-md bg-slate-100 px-2 py-1">최고: <span id="reaction-best" class="font-bold">-</span></p>
        <p class="rounded-md bg-slate-100 px-2 py-1">평균: <span id="reaction-avg" class="font-bold">-</span></p>
        <p class="rounded-md bg-slate-100 px-2 py-1">시도: <span id="reaction-count" class="font-bold">0</span></p>
      </div>
      <button id="reaction-start" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">시작</button>
      <button id="reaction-box" class="mt-4 block h-40 w-full rounded-lg bg-rose-500 text-lg font-bold text-white">
        대기 중
      </button>
      <p id="reaction-clock" class="mt-2 text-xs text-slate-500">측정 시각: -</p>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-semibold text-slate-900">반응속도 테스트란?</h2>
      <p class="mt-1">색상 전환 타이밍에 클릭하여 반응 시간을 측정하는 도구입니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">예시</h2>
      <p class="mt-1">친구 대결, 방송 컨텐츠, 집중력 체크 용도로 활용할 수 있습니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">FAQ</h2>
      <p class="mt-1">Q. 기록 저장되나요? A. 현재 탭에서만 임시 유지됩니다.</p>
    </section>

    <script is:inline>
      const statusEl = document.getElementById('reaction-status');
      const startEl = document.getElementById('reaction-start');
      const boxEl = document.getElementById('reaction-box');
      const currentEl = document.getElementById('reaction-current');
      const bestEl = document.getElementById('reaction-best');
      const avgEl = document.getElementById('reaction-avg');
      const countEl = document.getElementById('reaction-count');
      const clockEl = document.getElementById('reaction-clock');

      let startTime = 0;
      let timeoutId;
      let ready = false;
      const records = [];

      const nowText = () => {
        const d = new Date();
        return `${d.getHours().toString().padStart(2, '0')}:${d.getMinutes().toString().padStart(2, '0')}:${d.getSeconds().toString().padStart(2, '0')}`;
      };

      const renderStats = (current = null) => {
        if (countEl) countEl.textContent = String(records.length);
        if (currentEl) currentEl.textContent = current == null ? '-' : `${current}ms`;
        if (records.length === 0) {
          if (bestEl) bestEl.textContent = '-';
          if (avgEl) avgEl.textContent = '-';
          return;
        }
        const best = Math.min(...records);
        const avg = Math.round(records.reduce((a, b) => a + b, 0) / records.length);
        if (bestEl) bestEl.textContent = `${best}ms`;
        if (avgEl) avgEl.textContent = `${avg}ms`;
      };

      const setWaiting = () => {
        if (!boxEl) return;
        boxEl.textContent = '대기 중';
        boxEl.classList.remove('bg-emerald-500');
        boxEl.classList.add('bg-rose-500');
      };

      startEl?.addEventListener('click', () => {
        ready = false;
        setWaiting();
        if (statusEl) statusEl.textContent = '준비... 색이 바뀌면 바로 클릭하세요.';
        if (clockEl) clockEl.textContent = `측정 시각: ${nowText()}`;

        const delay = 1200 + Math.floor(Math.random() * 2200);
        clearTimeout(timeoutId);
        timeoutId = setTimeout(() => {
          if (!boxEl) return;
          ready = true;
          startTime = performance.now();
          boxEl.textContent = '지금 클릭!';
          boxEl.classList.remove('bg-rose-500');
          boxEl.classList.add('bg-emerald-500');
        }, delay);
      });

      boxEl?.addEventListener('click', () => {
        if (!ready) {
          if (statusEl) statusEl.textContent = '너무 빨라요. 다시 시작하세요.';
          clearTimeout(timeoutId);
          setWaiting();
          return;
        }

        const elapsed = Math.round(performance.now() - startTime);
        if (statusEl) statusEl.textContent = `반응속도: ${elapsed}ms`;
        records.push(elapsed);
        renderStats(elapsed);
        ready = false;
        setWaiting();
      });

      renderStats();
    </script>

    <Recommend />
  </main>
  <Footer />
</Layout>
