---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="퍼스널컬러 테스트 | FunHub" description="사진 기반 퍼스널컬러 테스트">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">퍼스널컬러 테스트</h1>
    <p class="mt-3 text-slate-700">얼굴 사진으로 퍼스널컬러를 1회성 분석합니다.</p>
    <AdSense slotName="본문 상단" />
    <div class="mt-4 rounded-lg border bg-white p-4">MVP: UI만 우선 제공, API 연동은 다음 단계</div>
    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />
</Layout>
