---
interface Props {
  mode: 'analyze' | 'recommend' | 'report';
}

const { mode } = Astro.props;
const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();

const config = mode === 'recommend'
  ? {
      sectionTitle: '개명 추천 엔진',
      sectionDesc: '성을 넣으면 현재 DB 기준으로 오격 점수가 높은 후보를 바로 추천합니다.',
      submitLabel: '추천 받기',
      endpoint: '/name-premium/recommend'
    }
  : mode === 'report'
    ? {
        sectionTitle: '개명 풀이 리포트',
        sectionDesc: '후보 이름을 직접 넣으면 오격, 점수, 해석 문장을 상세 리포트 형태로 보여줍니다.',
        submitLabel: '리포트 보기',
        endpoint: '/name-premium/analyze'
      }
    : {
        sectionTitle: 'AI 이름풀이 분석',
        sectionDesc: '성과 이름 한자를 입력하면 오격과 간단한 해석을 바로 확인할 수 있습니다.',
        submitLabel: '분석하기',
        endpoint: '/name-premium/analyze'
      };
---

<section class="mt-8 rounded-[32px] border border-slate-200 bg-white p-6 shadow-[0_24px_80px_rgba(15,23,42,0.08)]">
  <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-[11px] font-black uppercase tracking-[0.2em] text-amber-600">Live API</p>
      <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950">{config.sectionTitle}</h2>
      <p class="mt-2 max-w-3xl text-sm leading-7 text-slate-600">{config.sectionDesc}</p>
    </div>
    <p class="text-xs text-slate-500">현재 기준: 단성 지원, 추천 풀/성씨 DB 확장 진행 중</p>
  </div>

  <form class="name-premium-form mt-6 grid gap-4 lg:grid-cols-4" data-mode={mode}>
    <label class="flex flex-col gap-2">
      <span class="text-sm font-semibold text-slate-700">성씨 한자</span>
      <input name="surname" maxlength="2" placeholder="金" class="rounded-2xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-slate-950" />
    </label>

    {mode === 'recommend' ? (
      <>
        <label class="flex flex-col gap-2">
          <span class="text-sm font-semibold text-slate-700">이름 글자 수</span>
          <select name="givenLength" class="rounded-2xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-slate-950">
            <option value="2">2자 이름</option>
            <option value="1">1자 이름</option>
          </select>
        </label>
        <label class="flex flex-col gap-2">
          <span class="text-sm font-semibold text-slate-700">추천 개수</span>
          <select name="topK" class="rounded-2xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-slate-950">
            <option value="5">5개</option>
            <option value="10">10개</option>
          </select>
        </label>
      </>
    ) : (
      <>
        <label class="flex flex-col gap-2">
          <span class="text-sm font-semibold text-slate-700">이름 첫 글자</span>
          <input name="given1" maxlength="1" placeholder="民" class="rounded-2xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-slate-950" />
        </label>
        <label class="flex flex-col gap-2">
          <span class="text-sm font-semibold text-slate-700">이름 둘째 글자</span>
          <input name="given2" maxlength="1" placeholder="秀" class="rounded-2xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-slate-950" />
        </label>
      </>
    )}

    <div class="flex items-end">
      <button type="submit" class="w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white transition hover:bg-slate-800">
        {config.submitLabel}
      </button>
    </div>
  </form>

  <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600" data-status>
    입력 후 {config.submitLabel} 버튼을 누르세요.
  </div>

  <div class="mt-6 hidden rounded-[28px] border border-slate-200 bg-slate-50 p-5" data-result></div>
</section>

<script is:inline define:vars={{ mode, rawApiBase, endpoint: config.endpoint }}>
  const forms = document.querySelectorAll('.name-premium-form');

  forms.forEach((form) => {
    const section = form.closest('section');
    const statusEl = section?.querySelector('[data-status]');
    const resultEl = section?.querySelector('[data-result]');
    const API_BASE = (rawApiBase || (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost' ? 'http://127.0.0.1:8787' : '')).replace(/\/+$/, '');

    const setStatus = (message, tone = 'normal') => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.className = `mt-4 rounded-2xl border px-4 py-3 text-sm ${
        tone === 'error'
          ? 'border-rose-200 bg-rose-50 text-rose-700'
          : tone === 'success'
            ? 'border-emerald-200 bg-emerald-50 text-emerald-700'
            : 'border-slate-200 bg-slate-50 text-slate-600'
      }`;
    };

    const renderAnalyze = (payload) => {
      if (!resultEl) return;
      const parts = (payload.parts || [])
        .map((part) => {
          const meta = part.meta || {};
          return `
            <div class="rounded-2xl border border-slate-200 bg-white p-4">
              <p class="text-lg font-black text-slate-950">${part.hanja}</p>
              <p class="mt-2 text-sm text-slate-600">${meta.reading || '-'} · ${meta.meaning || '메타 없음'} · ${part.strokes || '-'}획</p>
              <p class="mt-2 text-xs text-slate-500">${meta.keywords || '키워드 없음'}</p>
            </div>
          `;
        })
        .join('');

      const details = (payload.details || [])
        .map((detail) => `<li class="rounded-xl border border-slate-200 bg-white px-4 py-3">${detail.slot} ${detail.number} · ${detail.grade} · ${detail.summary}</li>`)
        .join('');

      resultEl.innerHTML = `
        <div class="grid gap-6 lg:grid-cols-[minmax(0,0.88fr)_minmax(0,1.12fr)]">
          <div class="space-y-4">
            <div class="rounded-[24px] bg-slate-950 p-5 text-white">
              <p class="text-[11px] uppercase tracking-[0.18em] text-slate-400">종합 점수</p>
              <p class="mt-3 text-4xl font-black">${payload.score}</p>
              <p class="mt-2 text-sm text-white/70">${payload.grade}</p>
            </div>
            <div class="grid gap-3 sm:grid-cols-3">${parts}</div>
          </div>
          <div class="space-y-4">
            <div class="rounded-[24px] border border-slate-200 bg-white p-5">
              <p class="text-sm font-black text-slate-950">오격 해석</p>
              <ul class="mt-4 space-y-3 text-sm text-slate-700">${details}</ul>
            </div>
            <div class="rounded-[24px] border border-slate-200 bg-white p-5">
              <p class="text-sm font-black text-slate-950">AI 설명</p>
              <p class="mt-3 text-sm leading-7 text-slate-700">${payload.explanation || '설명 없음'}</p>
            </div>
          </div>
        </div>
      `;
      resultEl.classList.remove('hidden');
    };

    const renderRecommend = (payload) => {
      if (!resultEl) return;
      const cards = (payload.recommendations || [])
        .map((item, index) => `
          <article class="rounded-[24px] border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">TOP ${index + 1}</p>
            <h3 class="mt-2 text-2xl font-black text-slate-950">${item.name}</h3>
            <p class="mt-2 text-sm text-slate-600">${item.grade} · ${item.score}점</p>
            <p class="mt-3 text-sm leading-7 text-slate-700">${item.keywords || '키워드 준비중'}</p>
            <p class="mt-3 text-xs text-slate-500">천 ${item.grids.heaven} · 인 ${item.grids.human} · 지 ${item.grids.earth} · 외 ${item.grids.outer} · 총 ${item.grids.total}</p>
          </article>
        `)
        .join('');

      resultEl.innerHTML = `<div class="grid gap-4 lg:grid-cols-3">${cards}</div>`;
      resultEl.classList.remove('hidden');
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!API_BASE) {
        setStatus('PUBLIC_NODE_API_BASE가 설정되지 않았습니다.', 'error');
        return;
      }

      const formData = new FormData(form);
      const surname = String(formData.get('surname') || '').trim();

      const body = mode === 'recommend'
        ? {
            surname,
            givenLength: Number(formData.get('givenLength') || 2),
            topK: Number(formData.get('topK') || 5)
          }
        : {
            surname,
            given: [String(formData.get('given1') || '').trim(), String(formData.get('given2') || '').trim()].filter(Boolean)
          };

      setStatus('분석 중입니다...', 'normal');

      try {
        const response = await fetch(`${API_BASE}${endpoint}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(body)
        });

        const payload = await response.json().catch(() => null);
        if (!response.ok || !payload) {
          throw new Error(payload?.error || '요청 실패');
        }

        setStatus(mode === 'recommend' ? '추천 결과를 불러왔습니다.' : '분석 결과를 불러왔습니다.', 'success');
        if (mode === 'recommend') renderRecommend(payload);
        else renderAnalyze(payload);
      } catch (error) {
        setStatus(error instanceof Error ? error.message : '오류가 발생했습니다.', 'error');
      }
    });
  });
</script>
