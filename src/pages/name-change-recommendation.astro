---
import Layout from '../layouts/Layout.astro';
import NamePremiumLanding from '../components/name-premium/NamePremiumLanding.astro';
import NamePremiumStudio from '../components/name-premium/NamePremiumStudio.astro';
---

<Layout
  title="개명추천 프리미엄 | ManyTool"
  description="사주팔자와 이름 데이터를 함께 참고하는 개명추천 프리미엄 페이지입니다. 무료 이름풀이에서 업그레이드된 유료 추천 흐름을 제공합니다."
>
  <NamePremiumLanding
    eyebrow="Rename Upgrade"
    title="개명추천 프리미엄"
    description="개명은 가볍게 다루기 어려워 무료 페이지와 분리했습니다. 사주에서 필요한 보완 흐름, 이름 데이터 조건, 발음/사용감 필터를 함께 반영하는 참고형 개명추천 페이지로 확장합니다."
    heroSummary="사주 보완 포인트와 이름 후보 DB를 함께 보는 유료 추천 화면"
    heroDetail="후보 이름을 한 번에 여러 개 제시하고, 왜 추천되는지와 어떤 점이 주의 포인트인지까지 비교형으로 설명하는 구조를 기준으로 세팅했습니다. CSV DB가 들어오면 추천 로직과 후보군 노출을 바로 붙일 수 있습니다."
    featureTitle="추천 설계 방향"
    featurePoints={[
      '사주 부족 오행 기반 보완형 추천',
      '이름 길이, 발음감, 첫인상 키워드 필터',
      '후보별 추천 이유와 주의 포인트 비교',
      '무료 이름풀이 및 AI 만세력에서 자연스럽게 유입'
    ]}
    relatedLinks={[
      {
        href: '/name-insight',
        title: 'AI 이름풀이 보기',
        desc: '현재 이름의 구조와 해석 포인트를 먼저 보는 프리미엄 리포트입니다.'
      },
      {
        href: '/seongmyeonghak',
        title: '개명풀이 보기',
        desc: '추천된 후보 이름 하나하나를 자세히 해석하는 상세 리포트입니다.'
      },
      {
        href: '/name-meaning',
        title: '무료 이름풀이로 이동',
        desc: '먼저 무료 버전으로 재미형 결과를 확인한 뒤 프리미엄으로 업그레이드할 수 있습니다.'
      }
    ]}
  />
  <div class="mx-auto max-w-6xl px-4 pb-12">
    <NamePremiumStudio mode="recommend" />
  </div>
</Layout>
