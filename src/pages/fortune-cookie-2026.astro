---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="올해 포츈쿠키 | FunHub" description="2026년 키워드 포츈쿠키를 뽑아보세요.">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">올해 포츈쿠키</h1>
    <p class="mt-3 text-slate-700">버튼을 눌러 올해의 키워드를 랜덤으로 받아보세요.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-6">
      <p id="cookie-result" class="text-lg font-semibold text-slate-800">아직 포츈쿠키를 열지 않았습니다.</p>
      <button id="cookie-btn" class="mt-4 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">포츈쿠키 열기</button>
    </section>

    <script is:inline>
      const fortunes = [
        '2026 키워드: 확장 - 작은 시작이 큰 결과로 이어집니다.',
        '2026 키워드: 연결 - 사람과 협업에서 기회가 열립니다.',
        '2026 키워드: 집중 - 핵심 1개에 몰입하면 성과가 큽니다.',
        '2026 키워드: 회복 - 무리보다 페이스 조절이 중요합니다.',
        '2026 키워드: 실험 - 새로운 방식이 의외의 답이 됩니다.',
        '2026 키워드: 정리 - 우선순위를 비우면 운이 트입니다.',
        '2026 키워드: 꾸준함 - 느려도 멈추지 않으면 이깁니다.'
      ];
      const resultEl = document.getElementById('cookie-result');
      const btnEl = document.getElementById('cookie-btn');

      btnEl?.addEventListener('click', () => {
        const idx = Math.floor(Math.random() * fortunes.length);
        if (resultEl) resultEl.textContent = fortunes[idx];
      });
    </script>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />
</Layout>
