---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const t = {
  ko: {
    title: '이름풀이 | ManyTool',
    desc: '이름 입력으로 성향 키워드를 보여주는 재미형 이름풀이 도구입니다.',
    h1: '이름풀이',
    sub: '이름 기반 키워드 결과를 간단히 확인해보세요.',
    placeholder: '이름 입력',
    run: '결과 보기',
    empty: '이름을 입력해 주세요.',
    resultPrefix: '의 키워드:',
    faqQ: 'Q. 결과가 저장되나요?',
    faqA: 'A. 저장하지 않고 현재 브라우저에서만 계산합니다.'
  },
  en: {
    title: 'Name Meaning | ManyTool',
    desc: 'Fun name keyword analyzer based on input text.',
    h1: 'Name Meaning',
    sub: 'Get simple personality keywords from a name.',
    placeholder: 'Enter a name',
    run: 'Show result',
    empty: 'Please enter a name.',
    resultPrefix: 'keywords:',
    faqQ: 'Q. Is this saved?',
    faqA: 'A. No. It is calculated locally in your browser.'
  },
  ja: {
    title: '名前診断 | ManyTool',
    desc: '名前を入力してキーワードを表示するお楽しみ診断です。',
    h1: '名前診断',
    sub: '名前ベースのキーワード結果を確認できます。',
    placeholder: '名前を入力',
    run: '結果を見る',
    empty: '名前を入力してください。',
    resultPrefix: 'のキーワード:',
    faqQ: 'Q. 結果は保存されますか？',
    faqA: 'A. いいえ。ブラウザ内でのみ計算します。'
  }
}[locale];
---

<Layout title={t.title} description={t.desc}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">{t.h1}</h1>
    <p class="mt-3 text-slate-700">{t.sub}</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5">
      <input id="name-input" class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder={t.placeholder} type="text" />
      <button id="name-run" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">{t.run}</button>
      <p id="name-result" class="mt-3 rounded-md bg-slate-100 px-3 py-3 text-sm text-slate-700">{t.empty}</p>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-bold">FAQ</h2>
      <p class="mt-2">{t.faqQ}</p>
      <p>{t.faqA}</p>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline define:vars={{ t }}>
    const inputEl = document.getElementById('name-input');
    const runEl = document.getElementById('name-run');
    const resultEl = document.getElementById('name-result');

    const traits = [
      'focused', 'empathetic', 'curious', 'steady', 'creative', 'practical',
      'bold', 'calm', 'analytical', 'friendly', 'adaptive', 'persistent'
    ];

    runEl?.addEventListener('click', () => {
      const name = inputEl instanceof HTMLInputElement ? inputEl.value.trim() : '';
      if (!name) {
        if (resultEl) resultEl.textContent = t.empty;
        return;
      }
      let sum = 0;
      for (const ch of name) sum += ch.charCodeAt(0);
      const a = traits[sum % traits.length];
      const b = traits[(sum + 5) % traits.length];
      if (resultEl) resultEl.textContent = `${name} ${t.resultPrefix} ${a}, ${b}`;
    });
  </script>
</Layout>
