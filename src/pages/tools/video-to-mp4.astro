---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';

const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();
const apiBase = rawApiBase.replace(/\/+$/, '');
---

<Layout
  title="동영상 MP4 변환기 | 온라인 영상 변환 | 최대 1.5GB | ManyTool"
  description="온라인 동영상 MP4 변환기입니다. MKV, MOV, AVI, M4V 파일을 최대 1.5GB까지 업로드해 MP4로 변환할 수 있습니다."
  keywords="동영상 변환기, 온라인 동영상 변환, 영상 변환, video to mp4, mkv to mp4, mov to mp4, avi to mp4, m4v to mp4, 대용량 동영상 변환기"
  canonical="https://manytool.net/tools/video-to-mp4"
>
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-8">
    <section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-600">Online Video Converter</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">동영상 MP4 변환기</h1>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600 sm:text-base">
        온라인에서 대용량 동영상을 MP4로 변환합니다. 최대 1.5GB 업로드를 지원하며
        MKV, MOV, AVI, M4V 파일을 MP4로 바꿀 수 있습니다.
      </p>
    </section>

    <section class="mt-6 grid gap-6 lg:grid-cols-[360px_minmax(0,1fr)]">
      <aside class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Progress</p>
          <div class="mt-3 h-3 overflow-hidden rounded-full bg-slate-200">
            <div id="video-progress-bar" class="h-full w-[8%] rounded-full bg-sky-500 transition-all duration-300"></div>
          </div>
          <div class="mt-4 flex items-center justify-between gap-3">
            <p id="video-progress-label" class="text-sm font-semibold text-slate-900">파일 선택 대기</p>
            <p id="video-progress-percent" class="text-sm font-black text-sky-700">0%</p>
          </div>
          <div class="mt-4 space-y-2 text-sm text-slate-600">
            <div id="video-step-file" class="font-semibold text-sky-700">1. 파일 선택</div>
            <div id="video-step-payment">2. 결제 확인</div>
            <div id="video-step-convert">3. 변환 진행</div>
            <div id="video-step-download">4. 다운로드</div>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm leading-6 text-slate-600">
          <p class="font-semibold text-slate-900">지원 범위</p>
          <ul class="mt-2 list-disc space-y-1 pl-5">
            <li>최대 업로드: 1.5GB</li>
            <li>입력 형식: MKV, MOV, AVI, M4V</li>
            <li>출력 형식: MP4</li>
            <li>결제 1회당 1개 파일 변환</li>
          </ul>
        </div>

        <p id="video-checkout-status" class="mt-4 text-sm leading-6 text-slate-500">
          파일을 올린 뒤 변환 시작을 누르면 결제 또는 변환이 진행됩니다.
        </p>
      </aside>

      <section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-lg font-bold text-slate-950">업로드 및 변환</h2>
            <p class="mt-1 text-sm text-slate-600">드래그앤드롭 또는 클릭으로 영상을 올린 뒤 바로 변환을 시작할 수 있습니다.</p>
          </div>
          <div class="rounded-3xl bg-sky-50 px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Status</p>
            <p id="video-job-status" class="mt-2 text-xl font-black text-sky-900">파일 선택 대기</p>
          </div>
        </div>

        <label
          id="video-dropzone"
          class="mt-5 flex min-h-[240px] cursor-pointer flex-col items-center justify-center rounded-[28px] border border-dashed border-slate-300 bg-slate-50 px-6 py-8 text-center transition hover:border-slate-950 hover:bg-white"
        >
          <input id="video-file-input" type="file" accept=".mkv,.mov,.avi,.m4v,video/*" class="hidden" />
          <div class="space-y-3">
            <p class="text-base font-semibold text-slate-900">동영상 파일 선택</p>
            <p id="video-file-label" class="text-sm leading-6 text-slate-500">
              MKV, MOV, AVI, M4V 파일을 드래그하거나 클릭해 업로드하세요.
            </p>
          </div>
        </label>

        <button id="video-convert-button" class="mt-4 w-full rounded-2xl bg-sky-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-sky-500 disabled:cursor-not-allowed disabled:bg-slate-300" disabled>
          변환 시작
        </button>

        <div class="mt-5 rounded-[24px] border border-slate-200 bg-slate-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Result</p>
          <p id="video-result-message" class="mt-2 text-sm leading-6 text-slate-700">아직 변환 결과가 없습니다.</p>
          <a id="video-download-link" href="#" class="mt-4 hidden inline-flex rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white" download>
            MP4 다운로드
          </a>
        </div>
      </section>
    </section>

    <script is:inline define:vars={{ apiBase }}>
      const API_BASE = apiBase || (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost'
        ? 'http://127.0.0.1:8787'
        : '');
      const CHECKOUT_AMOUNT = 100;
      const CHECKOUT_CURRENCY = 'USD';
      const ORDER_STORAGE_KEY = 'manytool.videoMkvMp4.orderId';
      const MAX_VIDEO_BYTES = Math.floor(1.5 * 1024 * 1024 * 1024);

      const checkoutStatus = document.getElementById('video-checkout-status');
      const dropzone = document.getElementById('video-dropzone');
      const fileInput = document.getElementById('video-file-input');
      const fileLabel = document.getElementById('video-file-label');
      const convertButton = document.getElementById('video-convert-button');
      const jobStatus = document.getElementById('video-job-status');
      const resultMessage = document.getElementById('video-result-message');
      const downloadLink = document.getElementById('video-download-link');
      const progressBar = document.getElementById('video-progress-bar');
      const progressLabel = document.getElementById('video-progress-label');
      const progressPercent = document.getElementById('video-progress-percent');
      const stepFile = document.getElementById('video-step-file');
      const stepPayment = document.getElementById('video-step-payment');
      const stepConvert = document.getElementById('video-step-convert');
      const stepDownload = document.getElementById('video-step-download');

      let paymentMode = 'mock';
      let converterReady = true;
      let currentOrderId = null;

      const stepEls = [stepFile, stepPayment, stepConvert, stepDownload];

      const updateProgress = (percent, label, stage) => {
        if (progressBar instanceof HTMLElement) {
          progressBar.style.width = `${Math.max(8, Math.min(100, percent))}%`;
        }
        if (progressLabel) progressLabel.textContent = label;
        if (progressPercent) progressPercent.textContent = `${Math.max(0, Math.min(100, Math.round(percent)))}%`;
        stepEls.forEach((element, index) => {
          if (!(element instanceof HTMLElement)) return;
          const active = index + 1 === stage;
          const done = index + 1 < stage;
          element.classList.toggle('font-semibold', active || done);
          element.classList.toggle('text-sky-700', active || done);
          element.classList.toggle('text-slate-600', !active && !done);
        });
      };

      const setCheckoutStatus = (message) => {
        if (checkoutStatus) checkoutStatus.textContent = message;
      };

      const setJobStatus = (message) => {
        if (jobStatus) jobStatus.textContent = message;
      };

      const setResultMessage = (message) => {
        if (resultMessage) resultMessage.textContent = message;
      };

      const toApiUrl = (value) => {
        if (!value) return '#';
        if (value.startsWith('http://') || value.startsWith('https://')) return value;
        return API_BASE ? `${API_BASE}${value}` : value;
      };

      const resetDownloadLink = () => {
        if (downloadLink instanceof HTMLAnchorElement) {
          downloadLink.href = '#';
          downloadLink.classList.add('hidden');
        }
      };

      const setSelectedFile = (file) => {
        if (!(fileInput instanceof HTMLInputElement)) return;
        const transfer = new DataTransfer();
        transfer.items.add(file);
        fileInput.files = transfer.files;
      };

      const updateSelectedFile = (file) => {
        if (!(file instanceof File)) return;
        setSelectedFile(file);
        if (fileLabel) {
          fileLabel.textContent = `${file.name} / ${(file.size / (1024 * 1024)).toFixed(1)}MB`;
        }
        setJobStatus('변환 준비 완료');
        updateProgress(20, '파일 선택 완료', 1);
        if (file.size > MAX_VIDEO_BYTES) {
          setResultMessage('파일 용량이 1.5GB를 초과했습니다.');
        } else {
          setResultMessage('변환 시작을 누르면 결제 또는 변환이 진행됩니다.');
        }
        syncButtons();
      };

      const syncButtons = () => {
        const hasFile = Boolean(fileInput instanceof HTMLInputElement && fileInput.files && fileInput.files.length > 0);
        if (convertButton instanceof HTMLButtonElement) {
          convertButton.disabled = !(converterReady && hasFile);
        }
      };

      const setPaidState = (orderId) => {
        currentOrderId = orderId;
        if (orderId) window.localStorage.setItem(ORDER_STORAGE_KEY, orderId);
        setCheckoutStatus('결제가 확인되었습니다. 변환을 계속 진행합니다.');
        updateProgress(45, '결제 확인 완료', 2);
      };

      const verifyExistingOrder = async (orderId) => {
        if (!orderId || !API_BASE) return false;
        try {
          const response = await fetch(`${API_BASE}/order/${encodeURIComponent(orderId)}`);
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload) return false;
          if (payload.status === 'paid') {
            setPaidState(orderId);
            return true;
          }
          return false;
        } catch {
          return false;
        }
      };

      const requestCheckout = async () => {
        const currentUrl = window.location.href.split('?')[0];
        const response = await fetch(`${API_BASE}/checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            productType: 'video_mkv_mp4',
            amount: CHECKOUT_AMOUNT,
            currency: CHECKOUT_CURRENCY,
            successUrl: currentUrl,
            returnUrl: currentUrl
          })
        });
        const payload = await response.json().catch(() => null);
        if (!response.ok || !payload) {
          throw new Error(payload?.error || 'checkout failed');
        }
        return payload;
      };

      const pollJob = async (jobId) => {
        while (true) {
          const response = await fetch(`${API_BASE}/video/mkv-mp4/job/${encodeURIComponent(jobId)}`);
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.job) {
            throw new Error(payload?.error || '작업 상태를 불러오지 못했습니다.');
          }

          const { job } = payload;
          if (job.status === 'queued') {
            setJobStatus('변환 대기 중');
            updateProgress(60, '변환 대기 중', 3);
          }
          if (job.status === 'processing') {
            setJobStatus('동영상 변환 중');
            updateProgress(80, '동영상 변환 중', 3);
          }
          if (job.status === 'done') {
            setJobStatus('변환 완료');
            updateProgress(100, '다운로드 준비 완료', 4);
            setResultMessage(`${job.outputName} 다운로드가 준비되었습니다.`);
            if (downloadLink instanceof HTMLAnchorElement) {
              downloadLink.href = toApiUrl(job.outputUrl);
              downloadLink.classList.remove('hidden');
            }
            return;
          }
          if (job.status === 'failed') {
            throw new Error(job.error || '변환에 실패했습니다.');
          }

          await new Promise((resolve) => window.setTimeout(resolve, 2500));
        }
      };

      if (fileInput instanceof HTMLInputElement) {
        fileInput.addEventListener('change', () => {
          const file = fileInput.files?.[0] ?? null;
          if (!file) return;
          updateSelectedFile(file);
        });
      }

      if (dropzone) {
        const setDropzoneActive = (active) => {
          dropzone.classList.toggle('border-sky-500', active);
          dropzone.classList.toggle('bg-sky-50', active);
        };

        ['dragenter', 'dragover'].forEach((eventName) => {
          dropzone.addEventListener(eventName, (event) => {
            event.preventDefault();
            setDropzoneActive(true);
          });
        });

        ['dragleave', 'dragend', 'drop'].forEach((eventName) => {
          dropzone.addEventListener(eventName, (event) => {
            event.preventDefault();
            setDropzoneActive(false);
          });
        });

        dropzone.addEventListener('drop', (event) => {
          const file = event.dataTransfer?.files?.[0] ?? null;
          if (!file) return;
          updateSelectedFile(file);
        });
      }

      convertButton?.addEventListener('click', async () => {
        if (!(fileInput instanceof HTMLInputElement) || !fileInput.files?.[0]) return;

        const selectedFile = fileInput.files[0];
        if (selectedFile.size > MAX_VIDEO_BYTES) {
          setJobStatus('실패');
          setResultMessage('파일 용량이 1.5GB를 초과했습니다.');
          return;
        }

        if (!currentOrderId && paymentMode === 'polar') {
          try {
            setCheckoutStatus('결제 정보를 생성하는 중입니다...');
            updateProgress(30, '결제 준비 중', 2);
            const checkout = await requestCheckout();
            if (checkout.orderId) {
              currentOrderId = checkout.orderId;
              window.localStorage.setItem(ORDER_STORAGE_KEY, checkout.orderId);
            }
            if (checkout.paid) {
              setPaidState(checkout.orderId);
            } else if (checkout.checkoutUrl) {
              window.location.href = checkout.checkoutUrl;
              return;
            } else {
              throw new Error('checkout url is missing');
            }
          } catch (error) {
            setJobStatus('결제 실패');
            setResultMessage(error instanceof Error ? error.message : '결제를 시작하지 못했습니다.');
            return;
          }
        }

        try {
          const formData = new FormData();
          if (currentOrderId) {
            formData.append('orderId', currentOrderId);
          }
          formData.append('video', selectedFile);

          setJobStatus('업로드 중');
          updateProgress(55, '파일 업로드 중', 3);
          setResultMessage('파일 업로드와 변환 작업 생성이 진행 중입니다.');
          resetDownloadLink();

          const response = await fetch(`${API_BASE}/video/mkv-mp4/convert`, {
            method: 'POST',
            body: formData
          });
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.jobId) {
            throw new Error(payload?.error || '변환 작업을 시작하지 못했습니다.');
          }

          await pollJob(payload.jobId);
        } catch (error) {
          setJobStatus('실패');
          setResultMessage(error instanceof Error ? error.message : '변환에 실패했습니다.');
        }
      });

      (async () => {
        updateProgress(0, '파일 선택 대기', 1);
        if (!API_BASE) {
          converterReady = false;
          setCheckoutStatus('API 서버 주소가 설정되지 않았습니다.');
          setJobStatus('설정 필요');
          syncButtons();
          return;
        }

        try {
          const configResponse = await fetch(`${API_BASE}/config`);
          const config = await configResponse.json().catch(() => null);
          paymentMode = config?.paymentMode === 'polar' ? 'polar' : 'mock';

          if (!config?.readiness?.videoConverterReady) {
            converterReady = false;
            setCheckoutStatus('서버의 동영상 변환 기능이 아직 준비되지 않았습니다.');
            setJobStatus('서버 준비 필요');
            syncButtons();
            return;
          }
          if (paymentMode === 'polar' && !config?.paymentProducts?.video_mkv_mp4) {
            converterReady = false;
            setCheckoutStatus('비디오 변환 결제 상품이 아직 설정되지 않았습니다.');
            setJobStatus('상품 설정 필요');
            syncButtons();
            return;
          }

          const savedOrderId = window.localStorage.getItem(ORDER_STORAGE_KEY);
          const restored = await verifyExistingOrder(savedOrderId);
          if (!restored) {
            setCheckoutStatus(paymentMode === 'mock'
              ? 'mock 모드에서는 바로 변환됩니다.'
              : '파일을 선택한 뒤 변환 시작을 누르면 결제가 열립니다.');
          }
          syncButtons();
        } catch {
          converterReady = false;
          setCheckoutStatus('초기 설정을 불러오지 못했습니다.');
          setJobStatus('설정 확인 필요');
          syncButtons();
        }
      })();
    </script>
  </main>
  <Footer />
</Layout>
