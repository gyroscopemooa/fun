---
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import ProductDetailStudio from '../../../components/home/ProductDetailStudio';
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="商品詳細ページ生成スタジオ | ManyTool"
  description="商品画像と基本情報から、Smart Store、Coupang、11st、自社EC向けの縦長商品詳細ページ草案を生成します。"
  keywords="商品詳細ページ, EC商品ページ, Smart Store 詳細ページ, AI商品ページ生成, 商品紹介ページ"
>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8">
    <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">SEO Landing</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">韓国EC向け 商品詳細ページスタジオ</h1>
      <p class="mt-3 max-w-4xl text-sm leading-7 text-slate-600">
        商品画像と商品情報から、販売用の商品詳細ページ草案、コピー、HTML、PNG、JPG、PDFまでまとめて作成できます。
      </p>
    </section>

    <ProductDetailStudio client:load locale="ja" />
  </main>
  <Footer />
</Layout>
