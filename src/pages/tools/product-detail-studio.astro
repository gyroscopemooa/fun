---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductDetailStudio from '../../components/home/ProductDetailStudio';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const copy = {
  ko: {
    title: '쇼핑몰 상세페이지 생성기 | ManyTool',
    description: '상품 사진과 LLM 프롬프트를 넣으면 쇼핑몰 상세페이지 초안을 만들어주는 도구입니다.',
    heading: '쇼핑몰 상세페이지 생성기',
    body: '메인 카드에서는 진입만 하고, 실제 제작은 이 페이지에서 진행하도록 분리했습니다.'
  },
  en: {
    title: 'Product Detail Studio | ManyTool',
    description: 'Create a product detail page draft from product photos and an LLM prompt.',
    heading: 'Product Detail Studio',
    body: 'The homepage now links here as a card, while the full creation flow lives on this dedicated page.'
  },
  ja: {
    title: '商品詳細ページ生成 | ManyTool',
    description: '商品写真とLLMプロンプトから、商品詳細ページの下書きを生成するツールです。',
    heading: '商品詳細ページ生成',
    body: 'ホームではカード導線だけを置き、実際の制作フローはこの専用ページに分離しました。'
  }
}[locale];
---

<Layout title={copy.title} description={copy.description}>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8">
    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h1 class="text-3xl font-black tracking-tight text-slate-900">{copy.heading}</h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600">{copy.body}</p>
    </section>

    <ProductDetailStudio client:load />
  </main>
  <Footer />
</Layout>
