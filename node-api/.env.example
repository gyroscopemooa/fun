PORT=8787
PAYMENT_MODE=mock
PUBLIC_WEB_BASE_URL=http://localhost:4321

# auto | remove_bg | photoroom | local_sharp
IMAGE_PROVIDER=auto

# remove.bg
REMOVE_BG_API_KEY=
REMOVE_BG_URL=https://api.remove.bg/v1.0/removebg

# Photoroom
PHOTOROOM_API_KEY=
# Set the exact endpoint from your Photoroom plan/docs
PHOTOROOM_REMOVE_BG_URL=
PHOTOROOM_IMAGE_FIELD=image_file

# Polar (used when PAYMENT_MODE=polar)
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=http://localhost:4321/ai-id-photo
POLAR_RETURN_URL=http://localhost:4321/ai-id-photo
POLAR_PRODUCT_BASE=
POLAR_PRODUCT_ADD2=
POLAR_PRODUCT_ADD3=
POLAR_PRODUCT_ADD7=
POLAR_PRODUCT_PASSPORT_ADDON=
POLAR_PRODUCT_HEADSHOT_ADDON=
# Local webhook token guard (temporary, not a signature verifier)
POLAR_WEBHOOK_INSECURE_TOKEN=
