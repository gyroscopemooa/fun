---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const apiBase = import.meta.env.PUBLIC_NODE_API_BASE ?? 'http://127.0.0.1:8787';
---

<Layout
  title="AI 증명사진 운영 요약 | ManyTool"
  description="최근 생성 작업, 저점수 경고, provider fallback, 디버그 진입 링크를 한 화면에서 확인하는 운영 페이지입니다."
  keywords="AI 증명사진 운영, job summary, manytool ops"
  noindex={true}
>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8">
    <section class="rounded-2xl border border-slate-200 bg-white p-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">Ops View</p>
          <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-900">AI 증명사진 운영 요약</h1>
          <p class="mt-2 text-sm text-slate-600">최근 생성 작업, 저점수 후보, provider fallback, 품질 재시도 여부를 빠르게 확인합니다.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="ops-refresh" type="button" class="rounded-xl bg-slate-900 px-4 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-slate-800">새로고침</button>
          <button id="ops-copy-summary" type="button" class="rounded-xl border border-slate-300 px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-slate-50">요약 복사</button>
          <button id="ops-download-summary" type="button" class="rounded-xl border border-slate-300 px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-slate-50">요약 저장</button>
          <button id="ops-download-json" type="button" class="rounded-xl border border-slate-300 px-4 py-3 text-sm font-bold text-slate-700 transition hover:bg-slate-50">JSON 저장</button>
        </div>
      </div>
      <form id="ops-filter-form" class="mt-5 grid gap-3 md:grid-cols-4">
        <label class="text-sm font-semibold text-slate-700">
          상태
          <select id="ops-status" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-3 text-sm">
            <option value="">전체</option>
            <option value="done">done</option>
            <option value="failed">failed</option>
            <option value="processing">processing</option>
          </select>
        </label>
        <label class="text-sm font-semibold text-slate-700">
          툴
          <select id="ops-tool" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-3 text-sm">
            <option value="">전체</option>
            <option value="id_photo">id_photo</option>
            <option value="passport_photo">passport_photo</option>
            <option value="headshot">headshot</option>
          </select>
        </label>
        <label class="text-sm font-semibold text-slate-700">
          개수
          <select id="ops-limit" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-3 text-sm">
            <option value="12">12</option>
            <option value="20" selected>20</option>
            <option value="40">40</option>
            <option value="80">80</option>
          </select>
        </label>
        <label class="text-sm font-semibold text-slate-700">
          기간
          <select id="ops-period" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-3 text-sm">
            <option value="1">최근 1시간</option>
            <option value="24" selected>최근 24시간</option>
            <option value="168">최근 7일</option>
            <option value="0">전체</option>
          </select>
        </label>
        <label class="flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700">
          <input id="ops-flagged" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-sky-600" />
          문제 있는 생성만 보기
        </label>
      </form>
      <p id="ops-status-text" class="mt-4 text-xs text-slate-500">최근 생성 작업을 불러올 준비가 되었습니다.</p>
    </section>

    <section id="ops-stats" class="mt-6 hidden grid gap-4 md:grid-cols-5"></section>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-black text-slate-900">현재 필터 기준 추세</h2>
          <p class="mt-1 text-sm text-slate-600">지금 보고 있는 목록 안에서 툴별 상태 분포를 봅니다.</p>
        </div>
      </div>
      <div id="ops-trends" class="mt-4 grid gap-3 md:grid-cols-3">
        <p class="text-sm text-slate-500">추세를 계산하는 중입니다.</p>
      </div>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-[1.1fr_1fr]">
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-xl font-black text-slate-900">경고 요약</h2>
            <p class="mt-1 text-sm text-slate-600">실패, 저품질, 저동일성 발생이 많은 툴을 우선 확인합니다.</p>
          </div>
        </div>
        <div id="ops-alert-tools" class="mt-4 grid gap-3 md:grid-cols-3">
          <p class="text-sm text-slate-500">경고 요약을 불러오는 중입니다.</p>
        </div>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-xl font-black text-slate-900">Provider 경향</h2>
            <p class="mt-1 text-sm text-slate-600">fallback과 저품질 경향을 provider 기준으로 봅니다.</p>
          </div>
        </div>
        <div id="ops-alert-providers" class="mt-4 grid gap-3">
          <p class="text-sm text-slate-500">Provider 경향을 불러오는 중입니다.</p>
        </div>
      </article>
    </section>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-black text-slate-900">최신 경고 작업</h2>
          <p class="mt-1 text-sm text-slate-600">문제 있는 작업만 빠르게 골라 디버그로 들어갈 수 있습니다.</p>
        </div>
      </div>
      <div id="ops-latest-flagged" class="mt-4 grid gap-3">
        <p class="text-sm text-slate-500">경고 작업을 불러오는 중입니다.</p>
      </div>
    </section>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-black text-slate-900">최근 생성 작업</h2>
          <p class="mt-1 text-sm text-slate-600">추천 점수, 동일성, 규격 점수와 경고 플래그를 한 번에 확인합니다.</p>
        </div>
        <a href="/tools/ai-photo-debug" class="text-sm font-semibold text-sky-700 hover:text-sky-800">단일 job 디버그 보기</a>
      </div>
      <div id="ops-list" class="mt-4 grid gap-4 xl:grid-cols-2">
        <p class="text-sm text-slate-500">아직 불러온 작업이 없습니다.</p>
      </div>
    </section>
  </main>
  <Footer />

  <script define:vars={{ apiBase }} is:inline>
    const API_BASE = apiBase;
    const statusTextEl = document.getElementById('ops-status-text');
    const statsEl = document.getElementById('ops-stats');
    const listEl = document.getElementById('ops-list');
    const alertToolsEl = document.getElementById('ops-alert-tools');
    const alertProvidersEl = document.getElementById('ops-alert-providers');
    const latestFlaggedEl = document.getElementById('ops-latest-flagged');
    const trendsEl = document.getElementById('ops-trends');
    const refreshBtn = document.getElementById('ops-refresh');
    const copySummaryBtn = document.getElementById('ops-copy-summary');
    const downloadSummaryBtn = document.getElementById('ops-download-summary');
    const downloadBtn = document.getElementById('ops-download-json');
    const filterForm = document.getElementById('ops-filter-form');
    const statusSelect = document.getElementById('ops-status');
    const toolSelect = document.getElementById('ops-tool');
    const limitSelect = document.getElementById('ops-limit');
    const periodSelect = document.getElementById('ops-period');
    const flaggedCheckbox = document.getElementById('ops-flagged');
    let currentPayload = null;

    const setStatus = (text) => {
      if (statusTextEl) statusTextEl.textContent = text;
    };

    const formatNumber = (value) => typeof value === 'number' && Number.isFinite(value) ? value.toFixed(1) : 'n/a';
    const formatDate = (value) => {
      if (!value) return '-';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '-';
      return date.toLocaleString('ko-KR');
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');

    const renderStats = (stats) => {
      if (!(statsEl instanceof HTMLElement)) return;
      const entries = [
        ['총 작업', stats?.total ?? 0],
        ['실패', stats?.failed ?? 0],
        ['저품질', stats?.lowQuality ?? 0],
        ['저동일성', stats?.lowIdentity ?? 0],
        ['Fallback', stats?.providerFallback ?? 0]
      ];
      statsEl.classList.remove('hidden');
      statsEl.innerHTML = entries.map(([label, value]) => `
        <article class="rounded-2xl border border-slate-200 bg-white p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${label}</p>
          <p class="mt-2 text-2xl font-black text-slate-900">${value}</p>
        </article>
      `).join('');
    };

    const renderList = (items) => {
      if (!(listEl instanceof HTMLElement)) return;
      if (!Array.isArray(items) || !items.length) {
        listEl.innerHTML = '<p class="text-sm text-slate-500">조건에 맞는 작업이 없습니다.</p>';
        return;
      }

      listEl.innerHTML = items.map((item) => {
        const flags = Array.isArray(item.flags) ? item.flags : [];
        const flagBadges = flags.length
          ? flags.map((flag) => `<span class="rounded-full bg-rose-100 px-2 py-1 text-[11px] font-semibold text-rose-700">${escapeHtml(flag)}</span>`).join('')
          : '<span class="rounded-full bg-emerald-100 px-2 py-1 text-[11px] font-semibold text-emerald-700">정상</span>';

        return `
          <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(item.toolType ?? 'unknown')}</p>
                <h3 class="mt-1 text-lg font-black text-slate-900">${escapeHtml(item.id)}</h3>
                <p class="mt-1 text-xs text-slate-500">${formatDate(item.createdAt)}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <span class="rounded-full bg-slate-900 px-2 py-1 text-[11px] font-semibold text-white">${escapeHtml(item.status)}</span>
                ${flagBadges}
              </div>
            </div>
            <div class="mt-4 grid gap-4 sm:grid-cols-[180px_1fr]">
              <div class="grid gap-2">
                <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
                  ${item.originalUrl ? `<img src="${item.originalUrl}" alt="original" class="aspect-[3/4] w-full object-cover" />` : '<div class="aspect-[3/4] w-full bg-slate-100"></div>'}
                </div>
                <div class="overflow-hidden rounded-xl border border-sky-200 bg-white ring-1 ring-sky-100">
                  ${item.recommendedImageUrl ? `<img src="${item.recommendedImageUrl}" alt="recommended" class="aspect-[3/4] w-full object-cover" />` : '<div class="aspect-[3/4] w-full bg-slate-100"></div>'}
                </div>
                <div class="grid grid-cols-2 gap-2 text-[11px] font-semibold text-slate-500">
                  <span class="rounded-lg bg-slate-100 px-2 py-1 text-center">원본</span>
                  <span class="rounded-lg bg-sky-100 px-2 py-1 text-center text-sky-700">추천</span>
                </div>
              </div>
              <div class="space-y-3">
                <div class="grid gap-2 sm:grid-cols-3">
                  <div class="rounded-xl border border-slate-200 bg-white p-3">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">추천 점수</p>
                    <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(item.score)}</p>
                  </div>
                  <div class="rounded-xl border border-slate-200 bg-white p-3">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">동일성</p>
                    <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(item.identityScore)}</p>
                  </div>
                  <div class="rounded-xl border border-slate-200 bg-white p-3">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">규격 점수</p>
                    <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(item.qualityScore)}</p>
                  </div>
                </div>
                <div class="grid gap-2 text-sm text-slate-700 sm:grid-cols-2">
                  <p><span class="font-semibold text-slate-900">Provider:</span> ${escapeHtml(item.resolvedProvider ?? 'n/a')}</p>
                  <p><span class="font-semibold text-slate-900">Crop:</span> ${escapeHtml(item.cropProfile ?? 'n/a')}</p>
                  <p><span class="font-semibold text-slate-900">Pose:</span> ${escapeHtml(item.poseProfile ?? 'n/a')}</p>
                  <p><span class="font-semibold text-slate-900">Suit:</span> ${escapeHtml(item.suitTemplate ?? 'n/a')}</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-3 text-sm text-slate-700">
                  <p class="font-semibold text-slate-900">요약</p>
                  <p class="mt-1">${escapeHtml(item.qualitySummary ?? '요약 없음')}</p>
                  ${item.suitSelectionSummary ? `<p class="mt-2 text-xs text-slate-500">정장 선택: ${escapeHtml(item.suitSelectionSummary)}</p>` : ''}
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-3 text-sm text-slate-700">
                  <div class="flex items-center justify-between gap-3">
                    <p class="font-semibold text-slate-900">후보 추적</p>
                    <span class="text-xs text-slate-500">추천 / 생성 / 제외</span>
                  </div>
                  <div class="mt-2 flex flex-wrap gap-2">
                    ${Array.isArray(item.candidateBreakdown) && item.candidateBreakdown.length
                      ? item.candidateBreakdown.map((candidate) => `
                          <span class="rounded-full px-2 py-1 text-[11px] font-semibold ${
                            candidate.recommended
                              ? 'bg-sky-100 text-sky-700'
                              : candidate.regenerated
                                ? 'bg-amber-100 text-amber-800'
                                : 'bg-slate-100 text-slate-700'
                          }">
                            ${candidate.recommended ? '추천' : candidate.regenerated ? '재생성' : '후보'} ${escapeHtml(candidate.variant)}
                            ${typeof candidate.score === 'number' ? ` ${escapeHtml(formatNumber(candidate.score))}` : ''}
                          </span>
                        `).join('')
                      : '<span class="text-xs text-slate-500">생성된 후보 정보가 없습니다.</span>'}
                    ${Array.isArray(item.rejectedVariants) && item.rejectedVariants.length
                      ? item.rejectedVariants.map((variant) => `
                          <span class="rounded-full bg-rose-100 px-2 py-1 text-[11px] font-semibold text-rose-700">
                            제외 ${escapeHtml(variant)}
                          </span>
                        `).join('')
                      : ''}
                  </div>
                  ${(() => {
                    const compareItems = [
                      ...(Array.isArray(item.candidateBreakdown) ? item.candidateBreakdown.map((candidate) => ({
                        label: `${candidate.recommended ? '추천' : candidate.regenerated ? '재생성' : '후보'} ${candidate.variant}`,
                        score: candidate.score,
                        tone: candidate.recommended ? 'sky' : 'slate'
                      })) : []),
                      ...(Array.isArray(item.rejectedVariantBreakdown) ? item.rejectedVariantBreakdown.map((candidate) => ({
                        label: `제외 ${candidate.variant}`,
                        score: candidate.score,
                        tone: 'rose'
                      })) : [])
                    ].filter((candidate) => typeof candidate.score === 'number');
                    const maxScore = compareItems.reduce((max, candidate) => Math.max(max, Number(candidate.score ?? 0)), 0) || 1;
                    return compareItems.length ? `
                      <div class="mt-3 space-y-2">
                        ${compareItems.map((candidate) => `
                          <div>
                            <div class="mb-1 flex items-center justify-between gap-3 text-[11px] font-semibold">
                              <span class="${candidate.tone === 'sky' ? 'text-sky-700' : candidate.tone === 'rose' ? 'text-rose-700' : 'text-slate-700'}">${escapeHtml(candidate.label)}</span>
                              <span class="text-slate-500">${escapeHtml(formatNumber(candidate.score))}</span>
                            </div>
                            <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                              <div class="h-full rounded-full ${candidate.tone === 'sky' ? 'bg-sky-500' : candidate.tone === 'rose' ? 'bg-rose-400' : 'bg-slate-400'}" style="width:${Math.max(8, Math.round((Number(candidate.score ?? 0) / maxScore) * 100))}%"></div>
                            </div>
                          </div>
                        `).join('')}
                      </div>
                    ` : '';
                  })()}
                </div>
                <div class="flex flex-wrap gap-2">
                  <a href="/tools/ai-photo-debug?jobId=${encodeURIComponent(item.id)}" class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800">디버그 열기</a>
                  ${item.originalUrl ? `<a href="${item.originalUrl}" target="_blank" rel="noreferrer" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-white">원본 보기</a>` : ''}
                  ${item.recommendedImageUrl ? `<a href="${item.recommendedImageUrl}" target="_blank" rel="noreferrer" class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-white">추천 후보 보기</a>` : ''}
                </div>
              </div>
            </div>
          </article>
        `;
      }).join('');
    };

    const renderTrends = (items) => {
      if (!(trendsEl instanceof HTMLElement)) return;
      const toolMap = new Map();
      (Array.isArray(items) ? items : []).forEach((item) => {
        const key = item.toolType ?? 'unknown';
        const current = toolMap.get(key) ?? { total: 0, failed: 0, flagged: 0, avgQuality: 0, avgIdentity: 0 };
        current.total += 1;
        if (item.status === 'failed') current.failed += 1;
        if (Array.isArray(item.flags) && item.flags.length) current.flagged += 1;
        current.avgQuality += Number(item.qualityScore ?? 0);
        current.avgIdentity += Number(item.identityScore ?? 0);
        toolMap.set(key, current);
      });
      const cards = Array.from(toolMap.entries()).map(([tool, item]) => {
        const avgQuality = item.total ? (item.avgQuality / item.total) : 0;
        const avgIdentity = item.total ? (item.avgIdentity / item.total) : 0;
        return `
          <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(tool)}</p>
            <p class="mt-2 text-2xl font-black text-slate-900">${item.total}</p>
            <div class="mt-3 space-y-1 text-sm text-slate-600">
              <p>실패 ${item.failed}</p>
              <p>경고 ${item.flagged}</p>
              <p>평균 규격 ${formatNumber(avgQuality)}</p>
              <p>평균 동일성 ${formatNumber(avgIdentity)}</p>
            </div>
          </article>
        `;
      });
      trendsEl.innerHTML = cards.length ? cards.join('') : '<p class="text-sm text-slate-500">현재 필터 기준 데이터가 없습니다.</p>';
    };

    const renderAlerts = (payload) => {
      if (alertToolsEl instanceof HTMLElement) {
        const tools = Object.entries(payload?.toolBreakdown ?? {});
        alertToolsEl.innerHTML = tools.length
          ? tools.map(([tool, item]) => `
              <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(tool)}</p>
                <p class="mt-2 text-2xl font-black text-slate-900">${item.total}</p>
                <div class="mt-3 space-y-1 text-sm text-slate-600">
                  <p>실패 ${item.failed}</p>
                  <p>저품질 ${item.lowQuality}</p>
                  <p>저동일성 ${item.lowIdentity}</p>
                </div>
              </article>
            `).join('')
          : '<p class="text-sm text-slate-500">현재 경고 작업이 없습니다.</p>';
      }

      if (alertProvidersEl instanceof HTMLElement) {
        const providers = Object.entries(payload?.providerBreakdown ?? {});
        alertProvidersEl.innerHTML = providers.length
          ? providers.map(([provider, item]) => `
              <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                <div class="flex items-center justify-between gap-3">
                  <p class="text-sm font-black text-slate-900">${escapeHtml(provider)}</p>
                  <span class="rounded-full bg-slate-900 px-2 py-1 text-[11px] font-semibold text-white">${item.total}</span>
                </div>
                <div class="mt-3 flex flex-wrap gap-2 text-[11px] font-semibold">
                  <span class="rounded-full bg-amber-100 px-2 py-1 text-amber-800">fallback ${item.fallback}</span>
                  <span class="rounded-full bg-rose-100 px-2 py-1 text-rose-700">저품질 ${item.lowQuality}</span>
                </div>
              </article>
            `).join('')
          : '<p class="text-sm text-slate-500">현재 provider 경고가 없습니다.</p>';
      }

      if (latestFlaggedEl instanceof HTMLElement) {
        const items = Array.isArray(payload?.latestFlagged) ? payload.latestFlagged : [];
        latestFlaggedEl.innerHTML = items.length
          ? items.map((item) => `
              <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-black text-slate-900">${escapeHtml(item.id)}</p>
                    <p class="mt-1 text-xs text-slate-500">${formatDate(item.createdAt)} · ${escapeHtml(item.toolType ?? 'unknown')}</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    ${(item.flags ?? []).map((flag) => `<span class="rounded-full bg-rose-100 px-2 py-1 text-[11px] font-semibold text-rose-700">${escapeHtml(flag)}</span>`).join('')}
                  </div>
                </div>
                <div class="mt-3 grid gap-2 text-sm text-slate-700 sm:grid-cols-3">
                  <p>추천 ${formatNumber(item.score)}</p>
                  <p>동일성 ${formatNumber(item.identityScore)}</p>
                  <p>규격 ${formatNumber(item.qualityScore)}</p>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                  <a href="/tools/ai-photo-debug?jobId=${encodeURIComponent(item.id)}" class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800">디버그 열기</a>
                </div>
              </article>
            `).join('')
          : '<p class="text-sm text-slate-500">현재 경고 작업이 없습니다.</p>';
      }
    };

    const buildOpsSummary = () => {
      if (!currentPayload) return null;
      const recent = currentPayload.recent ?? {};
      const alerts = currentPayload.alerts ?? {};
      const items = Array.isArray(recent.items) ? recent.items : [];
      const toolTrend = Object.entries((items || []).reduce((acc, item) => {
        const key = item.toolType ?? 'unknown';
        const current = acc[key] ?? { total: 0, flagged: 0, failed: 0, qualityTotal: 0, identityTotal: 0 };
        current.total += 1;
        if (item.status === 'failed') current.failed += 1;
        if (Array.isArray(item.flags) && item.flags.length) current.flagged += 1;
        current.qualityTotal += Number(item.qualityScore ?? 0);
        current.identityTotal += Number(item.identityScore ?? 0);
        acc[key] = current;
        return acc;
      }, {})).map(([tool, value]) => ({
        tool,
        total: value.total,
        failed: value.failed,
        flagged: value.flagged,
        avgQuality: value.total ? Number((value.qualityTotal / value.total).toFixed(1)) : null,
        avgIdentity: value.total ? Number((value.identityTotal / value.total).toFixed(1)) : null
      }));

      return {
        generatedAt: new Date().toISOString(),
        filters: recent.filters ?? {},
        counts: {
          recentJobs: items.length,
          flaggedJobs: alerts.totalFlagged ?? 0
        },
        stats: recent.stats ?? {},
        toolBreakdown: alerts.toolBreakdown ?? {},
        providerBreakdown: alerts.providerBreakdown ?? {},
        toolTrend
      };
    };

    const downloadJson = (payload, filename) => {
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = filename;
      link.click();
      URL.revokeObjectURL(url);
    };

    const buildQuery = () => {
      const params = new URLSearchParams();
      const status = statusSelect instanceof HTMLSelectElement ? statusSelect.value : '';
      const toolType = toolSelect instanceof HTMLSelectElement ? toolSelect.value : '';
      const limit = limitSelect instanceof HTMLSelectElement ? limitSelect.value : '20';
      const sinceHours = periodSelect instanceof HTMLSelectElement ? periodSelect.value : '24';
      const flagged = flaggedCheckbox instanceof HTMLInputElement ? flaggedCheckbox.checked : false;
      if (status) params.set('status', status);
      if (toolType) params.set('toolType', toolType);
      if (limit) params.set('limit', limit);
      if (sinceHours && sinceHours !== '0') params.set('sinceHours', sinceHours);
      if (flagged) params.set('flagged', 'true');
      return params;
    };

    const loadOps = async () => {
      try {
        setStatus('최근 생성 작업을 불러오는 중입니다...');
        const params = buildQuery();
        const sinceHours = periodSelect instanceof HTMLSelectElement ? periodSelect.value : '24';
        const [recentResponse, alertResponse] = await Promise.all([
          fetch(`${API_BASE}/jobs/recent?${params.toString()}`),
          fetch(`${API_BASE}/jobs/alerts${sinceHours && sinceHours !== '0' ? `?sinceHours=${encodeURIComponent(sinceHours)}` : ''}`)
        ]);
        const payload = await recentResponse.json();
        const alerts = await alertResponse.json();
        if (!recentResponse.ok) throw new Error(payload?.error ?? 'ops load failed');
        if (!alertResponse.ok) throw new Error(alerts?.error ?? 'alert load failed');
        currentPayload = { recent: payload, alerts };
        renderStats(payload.stats ?? {});
        renderList(payload.items ?? []);
        renderTrends(payload.items ?? []);
        renderAlerts(alerts);
        const periodLabel = periodSelect instanceof HTMLSelectElement ? periodSelect.options[periodSelect.selectedIndex]?.text ?? '' : '';
        setStatus(`${periodLabel || '선택 기간'} 기준 최근 작업 ${Array.isArray(payload.items) ? payload.items.length : 0}건, 경고 ${alerts?.totalFlagged ?? 0}건`);
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'ops load failed');
      }
    };

    if (filterForm instanceof HTMLFormElement) {
      filterForm.addEventListener('submit', (event) => {
        event.preventDefault();
        loadOps();
      });
      filterForm.addEventListener('change', () => {
        loadOps();
      });
    }

    if (refreshBtn instanceof HTMLButtonElement) {
      refreshBtn.addEventListener('click', () => {
        loadOps();
      });
    }

    if (downloadBtn instanceof HTMLButtonElement) {
      downloadBtn.addEventListener('click', () => {
        if (!currentPayload) return;
        downloadJson(currentPayload, `manytool-ai-photo-ops-${Date.now()}.json`);
      });
    }

    if (copySummaryBtn instanceof HTMLButtonElement) {
      copySummaryBtn.addEventListener('click', async () => {
        const summary = buildOpsSummary();
        if (!summary) return;
        try {
          await navigator.clipboard.writeText(JSON.stringify(summary, null, 2));
          setStatus('운영 요약을 클립보드에 복사했습니다.');
        } catch {
          setStatus('요약 복사에 실패했습니다.');
        }
      });
    }

    if (downloadSummaryBtn instanceof HTMLButtonElement) {
      downloadSummaryBtn.addEventListener('click', () => {
        const summary = buildOpsSummary();
        if (!summary) return;
        downloadJson(summary, `manytool-ai-photo-ops-summary-${Date.now()}.json`);
      });
    }

    loadOps();
  </script>
</Layout>
