---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="마법책 | ManyTool" description="랜덤 문구를 뽑는 웹 기반 마법책 도구입니다.">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">마법책</h1>
    <p class="mt-3 text-slate-700">랜덤 문구를 뽑아보는 가벼운 재미 콘텐츠입니다.</p>

    <section class="mt-6 rounded-xl border border-slate-200 bg-white p-6">
      <p id="magic-result" class="text-lg font-semibold text-slate-800">버튼을 눌러 오늘의 문구를 확인하세요.</p>
      <button id="magic-btn" class="mt-4 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">
        마법책 펼치기
      </button>
    </section>

    <script is:inline>
      const starts = ['오늘은', '지금은', '이번 주는', '다음 선택은', '새로운 흐름은', '당신의 리듬은'];
      const middles = ['작은 집중이', '차분한 실행이', '꾸준한 반복이', '명확한 우선순위가', '짧은 결단이', '가벼운 시도가'];
      const ends = ['큰 변화를 만듭니다.', '좋은 결과를 부릅니다.', '생각보다 빨리 보답됩니다.', '불필요한 고민을 줄입니다.', '새 기회를 당겨옵니다.', '오늘의 흐름을 정리해줍니다.'];
      const tones = ['침착하게', '가볍게', '단단하게', '유연하게', '빠르게', '천천히', '정직하게', '담대하게', '차분하게', '꾸준하게', '확실하게', '명료하게', '실용적으로', '선명하게', '집요하게', '영리하게', '용기 있게', '간결하게', '정교하게', '밝게', '유쾌하게', '현명하게', '강하게', '안정적으로'];
      const directQuotes = [
        '그냥 해라.',
        '지금이 기회다.',
        '네 말이 맞다.',
        '네 생각과 다를 수 있다.',
        '한 번 더 확인해라.',
        '속도를 줄여라.',
        '밀어붙여도 된다.',
        '잠깐 멈추고 봐라.',
        '결론부터 말해라.',
        '지금은 기다릴 때다.',
        '오늘은 공격적으로 가라.',
        '오늘은 방어적으로 가라.',
        '정답은 가까이에 있다.',
        '초심으로 돌아가라.',
        '작게 시작해라.',
        '크게 보고 움직여라.',
        '네 선택을 믿어라.',
        '지금 방향이 맞다.',
        '방법을 바꿔라.',
        '판을 뒤집을 타이밍이다.'
      ];
      const comboQuotes = [];
      starts.forEach((a) => {
        middles.forEach((b) => {
          ends.forEach((c) => {
            tones.forEach((d) => {
              comboQuotes.push(`${a} ${d} ${b} ${c}`);
            });
          });
        });
      });
      const quotes = [...directQuotes, ...comboQuotes];
      const resultEl = document.getElementById('magic-result');
      const buttonEl = document.getElementById('magic-btn');
      buttonEl?.addEventListener('click', () => {
        const idx = Math.floor(Math.random() * quotes.length);
        if (resultEl) resultEl.textContent = quotes[idx];
      });
    </script>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-semibold text-slate-900">마법책이란?</h2>
      <p class="mt-1">버튼 클릭으로 랜덤 메시지를 보여주는 가벼운 운세형 도구입니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">예시</h2>
      <p class="mt-1">하루 시작 전 오늘의 한 문장, 방송 중 랜덤 미션 뽑기에 사용할 수 있습니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">FAQ</h2>
      <p class="mt-1">Q. 결과 저장되나요? A. 저장하지 않습니다.</p>
    </section>

    <Recommend />
  </main>
  <Footer />
</Layout>
