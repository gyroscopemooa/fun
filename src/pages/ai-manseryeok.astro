    <script is:inline define:vars={{ apiBase }}>
      const API_BASE = apiBase || (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost' ? 'http://127.0.0.1:8787' : '');
      const CHECKOUT_AMOUNT = 2988;
      const CHECKOUT_CURRENCY = 'USD';
      const ORDER_STORAGE_KEY = 'manytool.aiManseryeok.orderId';
      const FORM_STORAGE_KEY = 'manytool.aiManseryeok.form';
      const elements = { name: document.getElementById('saju-name'), birthDate: document.getElementById('saju-birth-date'), birthTime: document.getElementById('saju-birth-time'), timeBranch: document.getElementById('saju-time-branch'), birthPlace: document.getElementById('saju-birth-place'), timeUnknown: document.getElementById('saju-time-unknown'), leapMonth: document.getElementById('saju-leap-month'), leapWrap: document.getElementById('saju-leap-wrap'), submit: document.getElementById('saju-submit'), statusBox: document.getElementById('saju-status-box'), stage: document.getElementById('saju-stage'), empty: document.getElementById('saju-empty'), result: document.getElementById('saju-result') };
      let paymentMode = 'mock';
      let currentOrderId = null;
      let currentRenderedJob = null;
      let currentViewMode = 'analysis';
      const qs = (name) => document.getElementById(name);
      const setText = (id, value) => { const node = qs(id); if (node) node.textContent = value ?? ''; };
      const setHtml = (id, value) => { const node = qs(id); if (node) node.innerHTML = value ?? ''; };
      const setStatus = (message, stage = '진행 중') => { if (elements.statusBox) elements.statusBox.textContent = message; if (elements.stage) elements.stage.textContent = stage; };
      const getCalendarType = () => { const checked = document.querySelector('input[name="calendar-type"]:checked'); return checked instanceof HTMLInputElement ? checked.value : 'solar'; };
      const getGender = () => { const checked = document.querySelector('input[name="saju-gender"]:checked'); return checked instanceof HTMLInputElement ? checked.value : 'unknown'; };
      const syncCalendarUi = () => { const isLunar = getCalendarType() === 'lunar'; elements.leapWrap?.classList.toggle('hidden', !isLunar); };
      const syncTimeUi = () => {
        if (!(elements.birthTime instanceof HTMLInputElement) || !(elements.timeUnknown instanceof HTMLInputElement)) return;
        const disabled = elements.timeUnknown.checked;
        elements.birthTime.disabled = disabled;
        if (elements.timeBranch instanceof HTMLSelectElement) elements.timeBranch.disabled = disabled;
      };
      const syncBranchFromTime = () => {
        if (!(elements.birthTime instanceof HTMLInputElement) || !(elements.timeBranch instanceof HTMLSelectElement)) return;
        const value = elements.birthTime.value;
        if (!value) return;
        const options = Array.from(elements.timeBranch.options).map((option) => option.value);
        if (options.includes(value)) elements.timeBranch.value = value;
      };
      const syncTimeFromBranch = () => {
        if (!(elements.birthTime instanceof HTMLInputElement) || !(elements.timeBranch instanceof HTMLSelectElement)) return;
        if (elements.timeBranch.value) elements.birthTime.value = elements.timeBranch.value;
      };
      const buildPayload = () => {
        const payload = {
          name: elements.name instanceof HTMLInputElement ? elements.name.value.trim() : '',
          birthDate: elements.birthDate instanceof HTMLInputElement ? elements.birthDate.value : '',
          birthTime: elements.birthTime instanceof HTMLInputElement ? elements.birthTime.value : '',
          birthPlace: elements.birthPlace instanceof HTMLInputElement ? elements.birthPlace.value.trim() : '',
          gender: getGender(),
          calendarType: getCalendarType(),
          isLeapMonth: elements.leapMonth instanceof HTMLInputElement ? elements.leapMonth.checked : false,
          timeUnknown: elements.timeUnknown instanceof HTMLInputElement ? elements.timeUnknown.checked : false
        };
        if (!payload.birthTime && elements.timeBranch instanceof HTMLSelectElement && elements.timeBranch.value) {
          payload.birthTime = elements.timeBranch.value;
        }
        if (!payload.birthDate) throw new Error('생년월일을 입력해 주세요.');
        if (!payload.timeUnknown && !payload.birthTime) throw new Error('출생 시간을 입력하거나 시간 모름을 체크해 주세요.');
        return payload;
      };
      const savePayload = (payload) => window.sessionStorage.setItem(FORM_STORAGE_KEY, JSON.stringify(payload));
      const restorePayload = () => { try { const raw = window.sessionStorage.getItem(FORM_STORAGE_KEY); return raw ? JSON.parse(raw) : null; } catch { return null; } };
      const applyPayload = (payload) => {
        if (!payload) return;
        if (elements.name instanceof HTMLInputElement) elements.name.value = payload.name || '';
        if (elements.birthDate instanceof HTMLInputElement) elements.birthDate.value = payload.birthDate || '';
        if (elements.birthTime instanceof HTMLInputElement) elements.birthTime.value = payload.birthTime || '';
        if (elements.timeBranch instanceof HTMLSelectElement) elements.timeBranch.value = payload.birthTime || '';
        if (elements.birthPlace instanceof HTMLInputElement) elements.birthPlace.value = payload.birthPlace || '';
        if (elements.timeUnknown instanceof HTMLInputElement) elements.timeUnknown.checked = Boolean(payload.timeUnknown);
        if (elements.leapMonth instanceof HTMLInputElement) elements.leapMonth.checked = Boolean(payload.isLeapMonth);
        const radio = document.querySelector(`input[name="calendar-type"][value="${payload.calendarType === 'lunar' ? 'lunar' : 'solar'}"]`);
        if (radio instanceof HTMLInputElement) radio.checked = true;
        const genderRadio = document.querySelector(`input[name="saju-gender"][value="${payload.gender || 'unknown'}"]`);
        if (genderRadio instanceof HTMLInputElement) genderRadio.checked = true;
        syncCalendarUi();
        syncTimeUi();
      };
      const createBadgeList = (items, className = 'bg-white/6 text-white/72') => (items || []).filter(Boolean).map((item) => `<span class="${className} px-3 py-2 text-xs font-semibold">${item}</span>`).join('');
      const renderList = (id, items) => setHtml(id, (items || []).map((item) => `<li>${item}</li>`).join(''));
      const renderBars = (items) => (items || []).map((item) => `<div><div class="mb-2 flex items-center justify-between text-sm"><span class="font-semibold text-white/72">${item.label}</span><span class="text-white/38">${item.count} / 8</span></div><div class="ledger-bar"><span style="width:${Math.max(10, item.ratio)}%"></span></div></div>`).join('');
      const renderScoreText = (id, score) => setText(id, typeof score === 'number' ? `${score}점` : '');
      const renderScorePair = (scoreId, summaryId, block, basisId = null) => {
        renderScoreText(scoreId, block?.score);
        setText(summaryId, block?.summary ?? '');
        if (basisId) setText(basisId, block?.basis ?? '');
      };
      const renderTrendBar = (id, score, mirrorId) => { const node = qs(id); if (node) node.style.width = `${Math.max(8, Math.min(100, Number(score || 0)))}%`; renderScoreText(mirrorId, Number(score || 0)); };
      const applyViewMode = (mode) => {
        currentViewMode = mode === 'dosa' ? 'dosa' : 'analysis';
        document.querySelectorAll('[data-saju-mode]').forEach((node) => {
          const targetMode = node.getAttribute('data-saju-mode');
          node.classList.toggle('hidden', Boolean(targetMode) && targetMode !== currentViewMode);
        });
        qs('analysis-mode-btn')?.classList.toggle('ledger-toggle-active', currentViewMode === 'analysis');
        qs('dosa-mode-btn')?.classList.toggle('ledger-toggle-active', currentViewMode === 'dosa');
      };
      const buildShareText = () => {
        const headline = qs('saju-headline')?.textContent?.trim() || 'AI 만세력 사주풀이 올인원 통합형';
        const summary = qs('saju-summary')?.textContent?.trim() || '';
        return `${headline}\n${summary}\n${window.location.href}`;
      };
      const shareResult = async () => {
        if (!currentRenderedJob) return;
        const title = qs('saju-headline')?.textContent?.trim() || 'AI 만세력 사주풀이';
        const text = buildShareText();
        try {
          if (navigator.share) {
            await navigator.share({ title, text, url: window.location.href });
            setStatus('공유 시트를 열었습니다.', '공유');
            return;
          }
          await navigator.clipboard.writeText(text);
          setStatus('결과 링크와 요약을 클립보드에 복사했습니다.', '공유');
        } catch (error) {
          setStatus(error instanceof Error ? error.message : '공유를 완료하지 못했습니다.', '오류');
        }
      };
      const exportPdf = async () => {
        if (!currentRenderedJob || !elements.result) return;
        try {
          setStatus('PDF 파일을 준비하는 중입니다.', '저장 중');
          const { jsPDF } = await import('jspdf');
          const pdf = new jsPDF({ orientation: 'portrait', unit: 'pt', format: 'a4' });
          const pageWidth = pdf.internal.pageSize.getWidth();
          const pageHeight = pdf.internal.pageSize.getHeight();
          const margin = 40;
          const lineHeight = 18;
          const activeBlocks = Array.from(elements.result.querySelectorAll(':scope > section, :scope > article')).filter((node) => !node.classList.contains('hidden'));
          const textContent = activeBlocks.map((node) => node.textContent?.replace(/\s+/g, ' ').trim()).filter(Boolean).join('\n\n');
          const lines = pdf.splitTextToSize(textContent || 'AI 만세력 사주풀이 결과', pageWidth - (margin * 2));
          let y = margin;
          pdf.setFont('helvetica', 'bold');
          pdf.setFontSize(18);
          pdf.text('AI Manseryeok Saju Report', margin, y);
          y += 28;
          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(10);
          pdf.text(`Mode: ${currentViewMode === 'analysis' ? 'Analysis' : 'AI Dosa'}`, margin, y);
          y += 20;
          pdf.setFontSize(11);
          lines.forEach((line) => {
            if (y > pageHeight - margin) {
              pdf.addPage();
              y = margin;
            }
            pdf.text(line, margin, y);
            y += lineHeight;
          });
          pdf.save(`manytool-saju-report-${Date.now()}.pdf`);
          setStatus('PDF 저장이 완료되었습니다.', '저장 완료');
        } catch (error) {
          setStatus(error instanceof Error ? error.message : 'PDF 저장을 완료하지 못했습니다.', '오류');
        }
      };
      const renderResult = (job) => {
        const analysis = job?.analysis;
        const profile = analysis?.profile;
        const report = analysis?.report;
        if (!profile || !report) return;
        currentRenderedJob = job;
        if (job?.id) {
          const nextUrl = `${window.location.pathname}?jobId=${encodeURIComponent(job.id)}`;
          window.history.replaceState({}, '', nextUrl);
        }
        window.localStorage.removeItem(ORDER_STORAGE_KEY);
        elements.empty?.classList.add('hidden');
        elements.result?.classList.remove('hidden');
        setHtml('saju-badges', createBadgeList([
          profile.calendarType === 'lunar' ? '음력 기준 입력' : '양력 기준 입력',
          profile.timeKnown ? `출생 시간 ${profile.birthTime}` : '출생 시간 모름',
          `오행 균형 ${profile.elementSummary.balanceScore}점`,
          '참고용 라이프 인사이트'
        ]));
        setText('saju-headline', report.headline);
        setText('saju-summary', report.summary);
        setText('saju-personality', report.personality);
        setText('easy-dosa-line', report.easyReading?.dosaLine);
        setText('easy-elemental-story', report.easyReading?.elementalStory);
        setText('easy-timing-note', report.easyReading?.timingNote);
        const nameBadge = qs('saju-name-badge');
        if (nameBadge) { const hasName = Boolean(profile.name); nameBadge.classList.toggle('hidden', !hasName); nameBadge.textContent = hasName ? profile.name : ''; }
        renderScoreText('saju-consistency-score', profile.metaScores.consistencyScore);
        setText('saju-consistency-comment', report.consistencyComment);
        renderScoreText('saju-reliability-score', profile.metaScores.reliabilityScore);
        setText('saju-reliability-comment', report.reliabilityComment);
        renderScoreText('saju-accuracy-score', profile.metaScores.accuracyScore);
        setText('saju-accuracy-comment', report.accuracyComment);
        setText('saju-birth-meta', `${profile.solarDate.year}.${String(profile.solarDate.month).padStart(2, '0')}.${String(profile.solarDate.day).padStart(2, '0')} / ${profile.lunarDate.year}.${String(profile.lunarDate.month).padStart(2, '0')}.${String(profile.lunarDate.day).padStart(2, '0')}${profile.lunarDate.isLeapMonth ? ' 윤달' : ''}`);
        setText('pillar-year', profile.pillars.korean.year); setText('pillar-month', profile.pillars.korean.month); setText('pillar-day', profile.pillars.korean.day); setText('pillar-hour', profile.pillars.korean.hour);
        setText('pillar-year-hanja', profile.pillars.hanja.year.hanja); setText('pillar-month-hanja', profile.pillars.hanja.month.hanja); setText('pillar-day-hanja', profile.pillars.hanja.day.hanja); setText('pillar-hour-hanja', profile.pillars.hanja.hour.hanja);
        setText('saju-day-master', `일간 ${profile.dayMaster}`);
        setHtml('element-bars', renderBars(profile.elementSummary.items));
        setText('element-dominant', profile.elementSummary.dominant.join(', '));
        setText('element-lacking', profile.elementSummary.lacking.join(', '));
        setText('element-balance', `${profile.elementSummary.balanceScore}점`);
        renderScorePair('love-score', 'love-summary', report.baseCategories.love, 'love-basis');
        renderScorePair('marriage-score', 'marriage-summary', report.baseCategories.marriage, 'marriage-basis');
        renderScorePair('money-score', 'money-summary', report.baseCategories.money, 'money-basis');
        renderScorePair('business-score', 'business-summary', report.baseCategories.business, 'business-basis');
        renderScoreText('career-score', report.baseCategories.career.score); setText('career-summary', report.baseCategories.career.summary); setText('career-basis', report.baseCategories.career.basis);
        setHtml('work-roles', createBadgeList(report.baseCategories.career.suitableRoles, 'bg-[#59de9b]/10 text-[#59de9b]'));
        renderScorePair('study-score', 'study-summary', report.baseCategories.study, 'study-basis');
        renderScorePair('health-score', 'health-summary', report.baseCategories.health, 'health-basis');
        renderScorePair('social-score', 'social-summary', report.baseCategories.social, 'social-basis');
        renderScorePair('benefactor-score', 'benefactor-summary', report.baseCategories.benefactor, 'benefactor-basis');
        renderScorePair('yearly-score', 'yearly-summary', report.yearlyFlow);
        renderScorePair('fortune-today-score', 'fortune-today-summary', report.fortunes.today);
        renderScorePair('fortune-week-score', 'fortune-week-summary', report.fortunes.thisWeek);
        renderScorePair('fortune-month-score', 'fortune-month-summary', report.fortunes.thisMonth);
        renderScorePair('fortune-firsthalf-score', 'fortune-firsthalf-summary', report.fortunes.firstHalf);
        renderScorePair('fortune-secondhalf-score', 'fortune-secondhalf-summary', report.fortunes.secondHalf);
        renderScorePair('fortune-year-score', 'fortune-year-summary', report.fortunes.thisYear);
        setText('life-primary-eyebrow', profile.lifeStageLabels?.primary?.eyebrow);
        setText('life-primary-title', profile.lifeStageLabels?.primary?.title);
        setText('life-primary-description', profile.lifeStageLabels?.primary?.description);
        setText('life-secondary-eyebrow', profile.lifeStageLabels?.secondary?.eyebrow);
        setText('life-secondary-title', profile.lifeStageLabels?.secondary?.title);
        setText('life-secondary-description', profile.lifeStageLabels?.secondary?.description);
        renderScorePair('life-midlife-score', 'life-midlife-summary', report.lifeStages.midlife);
        renderScorePair('life-later-score', 'life-later-summary', report.lifeStages.laterYears);
        renderTrendBar('fortune-today-bar', report.fortunes.today?.score, 'fortune-today-score-side');
        renderTrendBar('fortune-week-bar', report.fortunes.thisWeek?.score, 'fortune-week-score-side');
        renderTrendBar('fortune-month-bar', report.fortunes.thisMonth?.score, 'fortune-month-score-side');
        renderTrendBar('fortune-firsthalf-bar', report.fortunes.firstHalf?.score, 'fortune-firsthalf-score-side');
        renderTrendBar('fortune-secondhalf-bar', report.fortunes.secondHalf?.score, 'fortune-secondhalf-score-side');
        renderTrendBar('fortune-year-bar', report.fortunes.thisYear?.score, 'fortune-year-score-side');
        renderList('dosa-top-actions', report.dosaAdvisory.topActions);
        renderList('dosa-avoid-choices', report.dosaAdvisory.avoidChoices);
        setText('dosa-yearly-strategy', report.dosaAdvisory.yearlyStrategy);
        setText('dosa-life-direction', report.dosaAdvisory.lifeDirection);
        setText('dosa-risky-period', report.dosaAdvisory.riskyPeriod);
        setText('dosa-conflict-period', report.dosaAdvisory.conflictPeriod);
        setText('dosa-money-loss-risk', report.dosaAdvisory.moneyLossRisk);
        setText('dosa-health-caution', report.dosaAdvisory.healthCautionPeriod);
        setText('dosa-love-timing', report.dosaAdvisory.loveStartTiming);
        setText('dosa-marriage-timing', report.dosaAdvisory.marriageTiming);
        setText('dosa-job-timing', report.dosaAdvisory.jobChangeTiming);
        setText('dosa-investment-timing', report.dosaAdvisory.investmentTiming);
        setText('dosa-business-timing', report.dosaAdvisory.businessTiming);
        setText('dosa-moving-timing', report.dosaAdvisory.movingTiming);
        setHtml('dosa-career-top3', createBadgeList(report.dosaAdvisory.careerTop3, 'bg-[#e9c349]/10 text-[#e9c349]'));
        setText('dosa-money-style', report.dosaAdvisory.moneyStyle);
        setText('dosa-good-partner', report.dosaAdvisory.goodPartnerType);
        setText('dosa-avoid-partner', report.dosaAdvisory.avoidPartnerType);
        setText('dosa-good-direction', report.dosaAdvisory.goodDirection);
        setText('dosa-good-region', report.dosaAdvisory.goodRegionStyle);
        setText('dosa-good-name', report.dosaAdvisory.goodNameStyle);
        setHtml('dosa-good-colors', createBadgeList(report.dosaAdvisory.goodColors, 'bg-[#59de9b]/10 text-[#59de9b]'));
        setHtml('dosa-good-numbers', createBadgeList(report.dosaAdvisory.goodNumbers, 'bg-[#e9c349]/10 text-[#e9c349]'));
        renderList('dosa-lucky-actions', report.dosaAdvisory.luckyActions);
        renderList('dosa-avoid-habits', report.dosaAdvisory.avoidHabits);
        setText('dosa-timing-howto', report.dosaAdvisory.timingHowto);
        setHtml('keyword-list', createBadgeList(report.keywords, 'bg-[#e9c349]/10 text-[#e9c349]'));
        renderList('strength-list', report.strengths);
        renderList('blindspot-list', report.blindSpots);
        renderList('advice-list', report.advice);
        renderList('rule-hints', profile.ruleHints);
        applyViewMode(currentViewMode);
        setStatus('분석이 완료되었습니다. 결과를 아래에서 확인하세요.', '분석 완료');
      };
      const verifyOrder = async (orderId) => {
        if (!orderId || !API_BASE) return false;
        try {
          const response = await fetch(`${API_BASE}/order/${encodeURIComponent(orderId)}`);
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload) return false;
          if (payload.status === 'paid') {
            currentOrderId = orderId;
            window.localStorage.setItem(ORDER_STORAGE_KEY, orderId);
            setStatus('결제가 확인되었습니다. 입력값으로 정밀분석을 이어갑니다.', '결제 확인');
            return true;
          }
          return false;
        } catch {
          return false;
        }
      };
      const requestCheckout = async () => { const currentUrl = window.location.href.split('?')[0]; const response = await fetch(`${API_BASE}/checkout`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productType: 'ai_manseryeok', amount: CHECKOUT_AMOUNT, currency: CHECKOUT_CURRENCY, successUrl: currentUrl, returnUrl: currentUrl }) }); const payload = await response.json().catch(() => null); if (!response.ok || !payload) throw new Error(payload?.error || 'checkout failed'); return payload; };
      const runAnalysis = async (payload) => { setStatus('만세력 계산과 AI 해석을 생성하는 중입니다.', '분석 중'); const response = await fetch(`${API_BASE}/ai-manseryeok/analyze`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ...payload, orderId: currentOrderId }) }); const result = await response.json().catch(() => null); if (!response.ok || !result?.job) throw new Error(result?.error || 'analysis failed'); renderResult(result.job); };
      const loadJobFromQuery = async () => {
        const params = new URLSearchParams(window.location.search);
        const jobId = params.get('jobId');
        if (!jobId || !API_BASE) return false;
        try {
          const response = await fetch(`${API_BASE}/ai-manseryeok/job/${encodeURIComponent(jobId)}`);
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.job) return false;
          renderResult(payload.job);
          return true;
        } catch {
          return false;
        }
      };
      document.querySelectorAll('input[name="calendar-type"]').forEach((node) => node.addEventListener('change', syncCalendarUi));
      elements.timeUnknown?.addEventListener('change', syncTimeUi);
      elements.birthTime?.addEventListener('change', syncBranchFromTime);
      elements.timeBranch?.addEventListener('change', syncTimeFromBranch);
      qs('analysis-mode-btn')?.addEventListener('click', () => applyViewMode('analysis'));
      qs('dosa-mode-btn')?.addEventListener('click', () => applyViewMode('dosa'));
      qs('saju-share-btn')?.addEventListener('click', shareResult);
      qs('saju-pdf-btn')?.addEventListener('click', exportPdf);
      elements.submit?.addEventListener('click', async () => {
        if (!(elements.submit instanceof HTMLButtonElement)) return;
        try {
          const payload = buildPayload();
          savePayload(payload);
          if (!currentOrderId && paymentMode === 'polar') {
            setStatus('결제 정보를 생성하는 중입니다.', '결제 준비');
            const checkout = await requestCheckout();
            if (checkout.orderId) { currentOrderId = checkout.orderId; window.localStorage.setItem(ORDER_STORAGE_KEY, checkout.orderId); }
            if (checkout.paid) {
              setStatus('결제가 바로 확인되었습니다. 분석을 이어갑니다.', '결제 확인');
            } else if (checkout.checkoutUrl) {
              window.location.href = checkout.checkoutUrl;
              return;
            } else {
              throw new Error('checkout url is missing');
            }
          }
          elements.submit.disabled = true;
          await runAnalysis(payload);
        } catch (error) {
          setStatus(error instanceof Error ? error.message : '분석을 시작하지 못했습니다.', '오류');
        } finally {
          if (elements.submit instanceof HTMLButtonElement) elements.submit.disabled = false;
        }
      });
      (async () => {
        applyViewMode('analysis');
        syncCalendarUi();
        syncTimeUi();
        if (!API_BASE) {
          setStatus('API 서버 주소가 설정되지 않았습니다.', '설정 필요');
          if (elements.submit instanceof HTMLButtonElement) elements.submit.disabled = true;
          return;
        }
        try {
          const renderedFromJob = await loadJobFromQuery();
          if (renderedFromJob) return;
          const configResponse = await fetch(`${API_BASE}/config`);
          if (!configResponse.ok) throw new Error('config request failed');
          const config = await configResponse.json().catch(() => null);
          paymentMode = config?.paymentMode === 'polar' ? 'polar' : 'mock';
          if (!config?.readiness?.aiManseryeokReady) {
            setStatus('사주 분석 API가 아직 준비되지 않았습니다.', '설정 필요');
            if (elements.submit instanceof HTMLButtonElement) elements.submit.disabled = true;
            return;
          }
          if (paymentMode === 'polar' && !config?.paymentProducts?.ai_manseryeok) {
            paymentMode = 'mock';
            setStatus('결제 상품이 아직 연결되지 않아 현재는 테스트 모드로 바로 풀이합니다.', '테스트 모드');
          }
          const savedPayload = restorePayload();
          if (savedPayload) applyPayload(savedPayload);
          const params = new URLSearchParams(window.location.search);
          const savedOrderId = params.get('orderId') || window.localStorage.getItem(ORDER_STORAGE_KEY);
          const restored = savedOrderId ? await verifyOrder(savedOrderId) : false;
          if (restored && savedPayload) {
            if (elements.submit instanceof HTMLButtonElement) elements.submit.disabled = true;
            try { await runAnalysis(savedPayload); } finally { if (elements.submit instanceof HTMLButtonElement) elements.submit.disabled = false; }
          } else if (paymentMode !== 'mock') {
            setStatus(paymentMode === 'mock' ? 'mock 모드에서는 바로 분석됩니다.' : '입력값을 저장한 뒤 결제 페이지로 이동합니다.', '입력 대기');
          } else {
            setStatus('테스트 모드에서는 결제 없이 바로 풀이를 확인할 수 있습니다.', '테스트 모드');
          }
        } catch {
          paymentMode = 'mock';
          setStatus('초기 설정을 불러오지 못해 테스트 모드로 전환했습니다. 바로 풀이를 시작할 수 있습니다.', '테스트 모드');
        }
      })();
    </script>
  </main>
</Layout>
