---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="MBTI 테스트 | FunHub" description="간단 문답으로 보는 MBTI 성향 테스트">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">MBTI 테스트</h1>
    <p class="mt-3 text-slate-700">짧은 질문으로 현재 성향을 빠르게 확인해보세요.</p>
    <AdSense slotName="본문 상단" />
    <div class="mt-4 rounded-lg border bg-white p-6">MBTI Question Placeholder</div>
    <Recommend />
  </main>
  <Footer />
</Layout>
