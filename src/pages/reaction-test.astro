---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="반응속도 테스트 | FunHub" description="클릭 반응속도를 측정하는 미니게임">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">반응속도 테스트</h1>
    <p class="mt-3 text-slate-700">시작 버튼을 누른 뒤 박스가 초록색으로 바뀌는 순간 클릭하세요.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-4 rounded-xl border border-slate-200 bg-white p-6">
      <p id="reaction-status" class="text-slate-700">시작 버튼을 누르세요.</p>
      <button id="reaction-start" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">시작</button>
      <button id="reaction-box" class="mt-4 block h-40 w-full rounded-lg bg-rose-500 text-lg font-bold text-white" disabled>
        대기 중
      </button>
    </section>

    <script is:inline>
      const statusEl = document.getElementById('reaction-status');
      const startEl = document.getElementById('reaction-start');
      const boxEl = document.getElementById('reaction-box');

      let startTime = 0;
      let timeoutId;
      let ready = false;

      const setWaiting = () => {
        if (!boxEl) return;
        boxEl.textContent = '대기 중';
        boxEl.classList.remove('bg-emerald-500');
        boxEl.classList.add('bg-rose-500');
      };

      startEl?.addEventListener('click', () => {
        ready = false;
        setWaiting();
        if (statusEl) statusEl.textContent = '준비... 색이 바뀌면 바로 클릭하세요.';

        const delay = 1200 + Math.floor(Math.random() * 2200);
        clearTimeout(timeoutId);
        timeoutId = setTimeout(() => {
          if (!boxEl) return;
          ready = true;
          startTime = performance.now();
          boxEl.textContent = '지금 클릭!';
          boxEl.classList.remove('bg-rose-500');
          boxEl.classList.add('bg-emerald-500');
        }, delay);
      });

      boxEl?.addEventListener('click', () => {
        if (!ready) {
          if (statusEl) statusEl.textContent = '너무 빨라요. 다시 시작하세요.';
          clearTimeout(timeoutId);
          setWaiting();
          return;
        }

        const elapsed = Math.round(performance.now() - startTime);
        if (statusEl) statusEl.textContent = `반응속도: ${elapsed}ms`;
        ready = false;
        setWaiting();
      });
    </script>

    <Recommend />
  </main>
  <Footer />
</Layout>
