---
import { createTranslator, detectLocale, withLocalePath } from '../lib/i18n';

const pathname = Astro.url.pathname;
const locale = detectLocale(pathname);
const t = await createTranslator(locale);
---

<footer class="mt-12 border-t border-slate-200 bg-white">
  <div class="mx-auto grid max-w-5xl gap-4 px-4 py-6 text-sm text-slate-600 md:grid-cols-2">
    <div class="space-y-1">
      <p>&copy; {new Date().getFullYear()} ManyTool. {t('footer.rights')}</p>
      <p class="text-xs text-slate-500">운영 문의: <a href="mailto:mooameensoo@gmail.com" class="underline underline-offset-4">mooameensoo@gmail.com</a></p>
    </div>
    <div class="flex flex-wrap gap-3 md:justify-end">
      <a href={withLocalePath(locale, '/about')} class="hover:underline">{t('footer.about')}</a>
      <a href={withLocalePath(locale, '/privacy')} class="hover:underline">{t('footer.privacy')}</a>
      <a href={withLocalePath(locale, '/terms')} class="hover:underline">{t('footer.terms')}</a>
      <a href={withLocalePath(locale, '/refund-policy')} class="hover:underline">{t('footer.refund')}</a>
      <a href={withLocalePath(locale, '/contact')} class="hover:underline">{t('footer.contact')}</a>
      <a href={withLocalePath(locale, '/editorial-policy')} class="hover:underline">{t('footer.editorial')}</a>
      <a href={withLocalePath(locale, '/content-disclaimer')} class="hover:underline">{t('footer.disclaimer')}</a>
    </div>
  </div>
</footer>
