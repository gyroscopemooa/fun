---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const t = {
  ko: {
    title: '하루 영어 한문장 | ManyTool',
    desc: '영어/스페인어/일본어/한국어 중 선택해 오늘의 문장을 확인하세요.',
    h1: '하루 영어 한문장',
    sub: '언어를 선택하면 오늘 날짜 기준 고정 문장이 표시됩니다.',
    langLabel: '언어 선택',
    copy: '문장 복사',
    copied: '복사됨'
  },
  en: {
    title: 'Daily English Sentence | ManyTool',
    desc: 'Choose English, Spanish, Japanese, or Korean and get a fixed sentence of the day.',
    h1: 'Daily English Sentence',
    sub: 'Pick a language to see today\'s fixed sentence.',
    langLabel: 'Language',
    copy: 'Copy sentence',
    copied: 'Copied'
  },
  ja: {
    title: '毎日の英語一文 | ManyTool',
    desc: '英語/スペイン語/日本語/韓国語から選んで今日の一文を確認できます。',
    h1: '毎日の英語一文',
    sub: '言語を選ぶと今日の日付で固定された文章が表示されます。',
    langLabel: '言語選択',
    copy: 'コピー',
    copied: 'コピー完了'
  }
}[locale];
---

<Layout title={t.title} description={t.desc}>
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-3xl font-black">{t.h1}</h1>
    <p class="mt-2 text-slate-700">{t.sub}</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-6">
      <label for="lang" class="text-sm font-semibold text-slate-700">{t.langLabel}</label>
      <select id="lang" class="ml-2 rounded-md border border-slate-300 bg-white px-2 py-1 text-sm">
        <option value="en">English</option>
        <option value="es">Espanol</option>
        <option value="ja">Japanese</option>
        <option value="ko">Korean</option>
      </select>

      <blockquote id="line" class="mt-4 text-2xl font-bold leading-snug text-slate-900">-</blockquote>
      <button id="copy-line" class="mt-4 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold">{t.copy}</button>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline define:vars={{ copiedText: t.copied }}>
    const bank = {
      en: [
        'Small progress beats perfect timing.',
        'Clear priorities reduce daily stress.',
        'Consistency creates visible results.',
        'Simple routines build strong habits.',
        'Focus on one task and finish it.',
        'Calm execution wins over rushed effort.',
        'Start now and adjust on the way.',
        'Good systems make hard work lighter.',
        'One clear decision can change your day.',
        'Momentum grows when you keep moving.'
      ],
      es: [
        'El progreso pequeno supera el momento perfecto.',
        'Las prioridades claras reducen el estres diario.',
        'La constancia crea resultados visibles.',
        'Las rutinas simples construyen habitos fuertes.',
        'Enfocate en una tarea y terminala.',
        'La ejecucion tranquila gana al apuro.',
        'Empieza ahora y ajusta en el camino.',
        'Los buenos sistemas hacen el esfuerzo mas ligero.',
        'Una decision clara puede cambiar tu dia.',
        'El impulso crece cuando sigues avanzando.'
      ],
      ja: [
        '小さな前進は完璧なタイミングより強い。',
        '優先順位を明確にすると毎日が楽になる。',
        '継続は見える結果を作る。',
        'シンプルな習慣が強い土台になる。',
        '一つの作業に集中して終わらせよう。',
        '焦るより落ち着いた実行が勝つ。',
        '今始めて、進みながら調整しよう。',
        '良い仕組みは努力を軽くする。',
        '明確な一つの決断が一日を変える。',
        '動き続けるほど勢いは増える。'
      ],
      ko: [
        '작은 전진이 완벽한 타이밍보다 강하다.',
        '우선순위를 명확히 하면 하루가 가벼워진다.',
        '꾸준함은 눈에 보이는 결과를 만든다.',
        '단순한 루틴이 강한 습관을 만든다.',
        '한 가지 일에 집중하고 끝내라.',
        '급한 실행보다 차분한 실행이 이긴다.',
        '지금 시작하고 가면서 조정하면 된다.',
        '좋은 시스템은 노력을 가볍게 만든다.',
        '명확한 한 번의 결정이 하루를 바꾼다.',
        '계속 움직일수록 추진력은 커진다.'
      ]
    };

    const langEl = document.getElementById('lang');
    const lineEl = document.getElementById('line');
    const copyBtn = document.getElementById('copy-line');

    const now = new Date();
    const kst = new Date(now.getTime() + 9 * 60 * 60 * 1000);
    const dateKey = `${kst.getUTCFullYear()}-${kst.getUTCMonth() + 1}-${kst.getUTCDate()}`;

    const hash = (text) => {
      let h = 5381;
      for (let i = 0; i < text.length; i += 1) h = (h * 33 + text.charCodeAt(i)) >>> 0;
      return h;
    };

    const render = () => {
      const lang = langEl instanceof HTMLSelectElement ? langEl.value : 'en';
      const list = bank[lang] ?? bank.en;
      const idx = hash(`${dateKey}:${lang}`) % list.length;
      const line = list[idx];
      if (lineEl) lineEl.textContent = line;
      return line;
    };

    const initial = render();
    langEl?.addEventListener('change', render);
    copyBtn?.addEventListener('click', async () => {
      const line = render() ?? initial ?? '';
      await navigator.clipboard.writeText(line);
      if (copyBtn instanceof HTMLButtonElement) copyBtn.textContent = copiedText;
    });
  </script>
</Layout>
