---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout
  title="이름 궁합 테스트 | ManyTool"
  description="두 이름을 입력해 간단한 궁합 점수를 보는 무료 이름 궁합 테스트입니다."
  keywords="이름 궁합, 이름궁합 테스트, 무료 이름 궁합, 이름 점수, 이름 조합"
>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">이름 궁합 테스트</h1>
    <p class="mt-3 text-slate-700">두 이름 조합으로 간단한 궁합 점수를 계산합니다.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="text-lg font-semibold">사용 방법</h2>
      <p class="mt-1 text-sm text-slate-600">두 사람 이름을 입력하고 결과 확인 버튼을 눌러주세요.</p>
      <div class="mt-3 grid gap-3 md:grid-cols-2">
        <input id="name-a" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="첫 번째 이름" type="text" />
        <input id="name-b" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="두 번째 이름" type="text" />
      </div>
      <button id="compat-run" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">결과 확인</button>
      <p id="compat-result" class="mt-3 rounded-md bg-slate-100 px-3 py-3 text-sm text-slate-700">이름 두 개를 입력해 주세요.</p>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="text-lg font-semibold">FAQ</h2>
      <p class="mt-2 text-sm text-slate-700">Q. 결과가 저장되나요? A. 저장되지 않습니다.</p>
      <p class="mt-1 text-sm text-slate-700">Q. 가입이 필요한가요? A. 필요 없습니다.</p>
    </section>

    <section class="mt-5 overflow-hidden rounded-[28px] border border-slate-900/10 bg-[radial-gradient(circle_at_top,_rgba(233,195,73,0.18),_transparent_32%),linear-gradient(135deg,_#111827_0%,_#1f2937_100%)] p-6 text-white">
      <p class="inline-flex rounded-full border border-[#e9c349]/40 bg-[#e9c349]/10 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-[#f2d677]">
        Premium
      </p>
      <h2 class="mt-4 text-2xl font-black tracking-tight">프리미엄 이름분석으로 이동</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/72">
        이름궁합을 넘어서 성명학 기반 이름풀이, 개명추천, 개명풀이와 추천 이유까지 한 번에 보려면 프리미엄 이름분석으로 이동하세요.
      </p>
      <div class="mt-5">
        <a href="/name-premium" class="inline-flex rounded-full bg-[#e9c349] px-5 py-3 text-sm font-black text-[#3c2f00] transition hover:brightness-110">
          프리미엄 이름분석 바로가기
        </a>
      </div>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline>
    const aEl = document.getElementById('name-a');
    const bEl = document.getElementById('name-b');
    const runEl = document.getElementById('compat-run');
    const resultEl = document.getElementById('compat-result');

    runEl?.addEventListener('click', () => {
      const a = aEl instanceof HTMLInputElement ? aEl.value.trim() : '';
      const b = bEl instanceof HTMLInputElement ? bEl.value.trim() : '';
      if (!a || !b) {
        if (resultEl) resultEl.textContent = '이름 두 개를 입력해 주세요.';
        return;
      }

      let sum = 0;
      for (const ch of `${a}${b}`) sum += ch.charCodeAt(0);
      const score = 55 + (sum % 46);
      const grade = score >= 85 ? '찰떡 궁합' : score >= 70 ? '좋은 궁합' : score >= 60 ? '무난한 궁합' : '노력형 궁합';

      if (resultEl) resultEl.textContent = `${a} + ${b}: ${score}점 (${grade})`;
    });
  </script>
</Layout>
