---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Recommend from '../components/Recommend.astro';
import Footer from '../components/Footer.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';
const t = {
  ko: {
    title: '핀볼 아레나 | ManyTool',
    desc: '참가자 이름과 공 개수를 넣고 자동으로 튕기는 핀볼/플링코 스타일 게임',
    subtitle: 'ManyTool Pinball Arena',
    main: '실시간 내기 핀볼',
    participants: '참가 공',
    inputTitle: '참가자 입력',
    inputHint: '중복 이름 허용, 공 개수 자유 입력',
    namePh: '이름 (예: 철수)',
    ballsPh: '공 개수 (예: 5)',
    addBtn: '참가자 추가',
    queue: '대기열',
    clear: '전체 삭제',
    start: '시작',
    stop: '중지',
    reset: '리셋',
    result: '실시간 결과'
  },
  en: {
    title: 'Pinball Arena | ManyTool',
    desc: 'Add player names and ball counts for an auto-bouncing pinball/plinko game',
    subtitle: 'ManyTool Pinball Arena',
    main: 'Live Pinball Match',
    participants: 'Balls',
    inputTitle: 'Participants',
    inputHint: 'Duplicate names allowed',
    namePh: 'Name (e.g. Alex)',
    ballsPh: 'Ball count (e.g. 5)',
    addBtn: 'Add Player',
    queue: 'Queue',
    clear: 'Clear',
    start: 'Start',
    stop: 'Stop',
    reset: 'Reset',
    result: 'Live Result'
  },
  ja: {
    title: 'ピンボールアリーナ | ManyTool',
    desc: '参加者名とボール数を入力して自動で進行するピンボールゲーム',
    subtitle: 'ManyTool Pinball Arena',
    main: 'リアルタイムピンボール',
    participants: 'ボール数',
    inputTitle: '参加者入力',
    inputHint: '同名可・ボール数自由',
    namePh: '名前 (例: タロウ)',
    ballsPh: 'ボール数 (例: 5)',
    addBtn: '参加者追加',
    queue: '待機列',
    clear: '全削除',
    start: '開始',
    stop: '停止',
    reset: 'リセット',
    result: 'リアルタイム結果'
  }
}[locale];
---

<Layout title={t.title} description={t.desc}>
  <Header />

  <main class="bg-slate-100 pb-10">
    <section class="mx-auto max-w-[1400px] px-4 py-5">
      <div class="mb-4 rounded-2xl border border-sky-200 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 px-5 py-4 text-white shadow-lg">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-sky-300">{t.subtitle}</p>
            <h1 class="text-2xl font-black tracking-tight">{t.main}</h1>
          </div>
          <div class="rounded-full border border-sky-300/40 bg-sky-400/10 px-4 py-2 text-sm text-sky-200">
            {t.participants} <span id="ball-count" class="font-bold text-white">0</span>
          </div>
        </div>
      </div>

      <div class="grid gap-4 lg:grid-cols-[280px_minmax(0,1fr)_250px]">
        <aside class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">{t.inputTitle}</h2>
          <p class="mt-1 text-xs text-slate-500">{t.inputHint}</p>

          <div class="mt-4 space-y-2">
            <input id="player-name" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" placeholder={t.namePh} type="text" />
            <input id="player-balls" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" placeholder={t.ballsPh} type="number" min="1" max="30" value="3" />
            <button id="add-player" class="w-full rounded-xl bg-sky-500 py-2.5 text-sm font-bold text-white">{t.addBtn}</button>
          </div>

          <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
            <div class="mb-2 flex items-center justify-between">
              <h3 class="text-sm font-bold">{t.queue}</h3>
              <button id="clear-players" class="text-xs font-semibold text-rose-500">{t.clear}</button>
            </div>
            <ul id="players-list" class="space-y-2 text-sm"></ul>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-2">
            <button id="start-game" class="rounded-xl bg-emerald-500 py-2.5 text-sm font-bold text-white">{t.start}</button>
            <button id="stop-game" class="rounded-xl bg-slate-800 py-2.5 text-sm font-bold text-white">{t.stop}</button>
            <button id="reset-game" class="col-span-2 rounded-xl border border-slate-300 bg-white py-2.5 text-sm font-bold">{t.reset}</button>
          </div>
        </aside>

        <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
          <div class="mb-2 flex items-center justify-between px-1">
            <p class="text-sm font-semibold text-slate-600">DROP ZONE</p>
            <p id="status-text" class="text-xs font-bold uppercase tracking-wide text-sky-600">ready</p>
          </div>
          <canvas id="pinball-board" width="1200" height="920" class="w-full rounded-xl border border-slate-200 bg-slate-950"></canvas>
          <div class="mt-2 text-xs text-slate-500">공은 자동으로 투하되고, 하단 슬롯 도착 순서로 결과가 집계됩니다.</div>
        </section>

        <aside class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900">{t.result}</h2>
          <div class="mt-3 rounded-xl bg-slate-50 p-3">
            <p class="text-xs text-slate-500">현재 1등</p>
            <p id="leader-text" class="mt-1 text-xl font-black text-emerald-600">-</p>
            <p id="leader-meta" class="text-xs text-slate-500">진행 전</p>
          </div>

          <div class="mt-4">
            <h3 class="text-sm font-bold">도착 순위</h3>
            <ol id="finish-list" class="mt-2 space-y-2 text-sm"></ol>
          </div>

          <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
            <h3 class="text-sm font-bold">슬롯 배수</h3>
            <div id="slot-info" class="mt-2 grid grid-cols-3 gap-2 text-xs"></div>
          </div>
        </aside>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-4">
      <Recommend />
    </section>
  </main>

  <script is:inline>
    const canvas = document.getElementById('pinball-board');
    const playersListEl = document.getElementById('players-list');
    const addPlayerBtn = document.getElementById('add-player');
    const clearPlayersBtn = document.getElementById('clear-players');
    const startBtn = document.getElementById('start-game');
    const stopBtn = document.getElementById('stop-game');
    const resetBtn = document.getElementById('reset-game');
    const playerNameEl = document.getElementById('player-name');
    const playerBallsEl = document.getElementById('player-balls');
    const finishListEl = document.getElementById('finish-list');
    const leaderTextEl = document.getElementById('leader-text');
    const leaderMetaEl = document.getElementById('leader-meta');
    const ballCountEl = document.getElementById('ball-count');
    const statusTextEl = document.getElementById('status-text');
    const slotInfoEl = document.getElementById('slot-info');

    if (!(canvas instanceof HTMLCanvasElement)) throw new Error('pinball board missing');
    const ctx = canvas.getContext('2d');
    if (!ctx) throw new Error('2d context missing');

    const W = canvas.width;
    const H = canvas.height;
    const WALL = 16;
    const DROP_Y = 88;
    const SLOT_H = 74;
    const PEG_R_BASE = 4;
    const BALL_R = 8;
    const GRAVITY = 0.19;
    const AIR = 0.999;
    const BOUNCE = 0.78;

    const SLOT_MULT = [1.2, 1.8, 2.5, 5, 10, 5, 2.5, 1.8, 1.2];
    const slotWidth = (W - WALL * 2) / SLOT_MULT.length;

    const colorPool = ['#22d3ee', '#a3e635', '#f97316', '#f43f5e', '#60a5fa', '#c084fc', '#34d399', '#facc15'];

    const pegs = [];
    for (let row = 0; row < 16; row += 1) {
      const count = 7 + (row % 5);
      const y = 136 + row * 42;
      const usable = W - 2 * (WALL + 54);
      const step = usable / (count - 1);
      for (let i = 0; i < count; i += 1) {
        const offset = row % 2 ? step / 2 : 0;
        const jitter = Math.sin((row + 1) * (i + 2)) * 8.5;
        const x = WALL + 54 + i * step + offset + jitter;
        const r = PEG_R_BASE + ((row + i) % 3);
        const avoidDropLane = row < 3 && Math.abs(x - W / 2) < 82;
        if (x > WALL + 34 && x < W - WALL - 34 && !avoidDropLane) pegs.push({ x, y, r });
      }
    }

    const bumpers = [
      { x: W * 0.22, y: H * 0.34, r: 18, bounce: 0.96 },
      { x: W * 0.76, y: H * 0.38, r: 16, bounce: 0.94 },
      { x: W * 0.36, y: H * 0.55, r: 20, bounce: 0.98 },
      { x: W * 0.67, y: H * 0.61, r: 14, bounce: 0.92 }
    ];

    const rails = [
      { x1: W * 0.18, y1: H * 0.23, x2: W * 0.34, y2: H * 0.38, thickness: 4, bounce: 0.88 },
      { x1: W * 0.82, y1: H * 0.3, x2: W * 0.65, y2: H * 0.46, thickness: 4, bounce: 0.88 },
      { x1: W * 0.27, y1: H * 0.62, x2: W * 0.12, y2: H * 0.76, thickness: 4, bounce: 0.9 },
      { x1: W * 0.73, y1: H * 0.67, x2: W * 0.88, y2: H * 0.8, thickness: 4, bounce: 0.9 }
    ];

    let participants = [
      { id: 'p1', name: 'Jake', balls: 3, color: colorPool[0] },
      { id: 'p2', name: 'Sarah', balls: 2, color: colorPool[5] },
      { id: 'p3', name: 'Tom', balls: 4, color: colorPool[1] }
    ];

    let balls = [];
    let finishOrder = [];
    let dropQueue = [];
    let running = false;
    let rafId = 0;
    let lastDrop = 0;

    const fmt = (n) => Number(n).toFixed(n >= 10 ? 0 : 1).replace('.0', '');

    const totalBallCount = () => participants.reduce((sum, p) => sum + p.balls, 0);

    const renderSlotInfo = () => {
      if (!slotInfoEl) return;
      slotInfoEl.innerHTML = SLOT_MULT.map((m) => `<div class="rounded-md border border-slate-200 bg-white px-2 py-1 text-center font-semibold">${fmt(m)}x</div>`).join('');
    };

    const renderParticipants = () => {
      if (!playersListEl) return;
      if (participants.length === 0) {
        playersListEl.innerHTML = '<li class="rounded-lg bg-white px-2 py-2 text-xs text-slate-500">참가자를 추가하세요.</li>';
      } else {
        playersListEl.innerHTML = participants.map((p) => `
          <li class="flex items-center justify-between rounded-lg bg-white px-2 py-2">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full" style="background:${p.color}"></span>
              <span class="font-semibold">${p.name}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-slate-500">x${p.balls}</span>
              <button data-remove="${p.id}" class="text-xs text-rose-500">삭제</button>
            </div>
          </li>
        `).join('');
      }
      if (ballCountEl) ballCountEl.textContent = String(totalBallCount());
    };

    const renderFinish = () => {
      if (!finishListEl) return;
      if (finishOrder.length === 0) {
        finishListEl.innerHTML = '<li class="rounded-lg bg-slate-50 px-2 py-2 text-xs text-slate-500">아직 도착한 공 없음</li>';
      } else {
        finishListEl.innerHTML = finishOrder.slice(0, 12).map((f, i) => `
          <li class="flex items-center justify-between rounded-lg border border-slate-200 bg-white px-2 py-2">
            <span><b>${i + 1}.</b> ${f.name}</span>
            <span class="text-xs font-semibold text-sky-600">${fmt(f.mult)}x</span>
          </li>
        `).join('');
      }

      if (leaderTextEl && leaderMetaEl) {
        if (finishOrder[0]) {
          leaderTextEl.textContent = finishOrder[0].name;
          leaderMetaEl.textContent = `첫 골인 · ${fmt(finishOrder[0].mult)}x 슬롯`;
        } else {
          leaderTextEl.textContent = '-';
          leaderMetaEl.textContent = '진행 전';
        }
      }
    };

    const setStatus = (v) => {
      if (statusTextEl) statusTextEl.textContent = v;
    };

    const buildQueue = () => {
      const queue = [];
      participants.forEach((p) => {
        for (let i = 0; i < p.balls; i += 1) {
          queue.push({ ownerId: p.id, owner: p.name, color: p.color, serial: i + 1 });
        }
      });
      for (let i = queue.length - 1; i > 0; i -= 1) {
        const j = Math.floor(Math.random() * (i + 1));
        const tmp = queue[i];
        queue[i] = queue[j];
        queue[j] = tmp;
      }
      return queue;
    };

    const spawnBall = (item) => {
      balls.push({
        id: `${item.ownerId}-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        ownerId: item.ownerId,
        name: item.owner,
        color: item.color,
        x: W / 2 + (Math.random() * 20 - 10),
        y: DROP_Y,
        vx: Math.random() * 1.3 - 0.65,
        vy: 0,
        r: BALL_R,
        done: false
      });
    };

    const addParticipant = () => {
      const name = playerNameEl instanceof HTMLInputElement ? playerNameEl.value.trim() : '';
      const ballsInput = playerBallsEl instanceof HTMLInputElement ? Number(playerBallsEl.value) : 1;
      const ballsCount = Number.isFinite(ballsInput) ? Math.max(1, Math.min(30, Math.floor(ballsInput))) : 1;
      if (!name) return;

      participants.push({
        id: `p-${Date.now()}-${Math.random().toString(16).slice(2, 8)}`,
        name,
        balls: ballsCount,
        color: colorPool[participants.length % colorPool.length]
      });

      if (playerNameEl instanceof HTMLInputElement) playerNameEl.value = '';
      renderParticipants();
    };

    const resetGame = () => {
      running = false;
      balls = [];
      finishOrder = [];
      dropQueue = [];
      renderFinish();
      setStatus('ready');
    };

    const startGame = () => {
      if (participants.length === 0 || totalBallCount() === 0) return;
      balls = [];
      finishOrder = [];
      dropQueue = buildQueue();
      running = true;
      lastDrop = 0;
      renderFinish();
      setStatus('running');
    };

    const stopGame = () => {
      running = false;
      setStatus('paused');
    };

    const resolvePegCollision = (ball, peg) => {
      const dx = ball.x - peg.x;
      const dy = ball.y - peg.y;
      const minDist = ball.r + peg.r;
      const dist2 = dx * dx + dy * dy;
      if (dist2 > minDist * minDist || dist2 === 0) return;

      const dist = Math.sqrt(dist2);
      const nx = dx / dist;
      const ny = dy / dist;
      const overlap = minDist - dist;
      ball.x += nx * overlap;
      ball.y += ny * overlap;

      const dot = ball.vx * nx + ball.vy * ny;
      ball.vx -= (1 + BOUNCE) * dot * nx;
      ball.vy -= (1 + BOUNCE) * dot * ny;
      ball.vx *= 0.985;
      ball.vy *= 0.985;
    };

    const resolveRailCollision = (ball, rail) => {
      const vx = rail.x2 - rail.x1;
      const vy = rail.y2 - rail.y1;
      const segLen2 = vx * vx + vy * vy;
      if (segLen2 === 0) return;
      const t = Math.max(0, Math.min(1, ((ball.x - rail.x1) * vx + (ball.y - rail.y1) * vy) / segLen2));
      const cx = rail.x1 + t * vx;
      const cy = rail.y1 + t * vy;
      const dx = ball.x - cx;
      const dy = ball.y - cy;
      const minDist = ball.r + rail.thickness;
      const dist2 = dx * dx + dy * dy;
      if (dist2 > minDist * minDist || dist2 === 0) return;

      const dist = Math.sqrt(dist2);
      const nx = dx / dist;
      const ny = dy / dist;
      const overlap = minDist - dist;
      ball.x += nx * overlap;
      ball.y += ny * overlap;

      const dot = ball.vx * nx + ball.vy * ny;
      ball.vx -= (1 + rail.bounce) * dot * nx;
      ball.vy -= (1 + rail.bounce) * dot * ny;
    };

    const settleBall = (ball) => {
      const idx = Math.max(0, Math.min(SLOT_MULT.length - 1, Math.floor((ball.x - WALL) / slotWidth)));
      const mult = SLOT_MULT[idx];
      finishOrder.push({ name: ball.name, mult, slot: idx + 1 });
      ball.done = true;
      renderFinish();
    };

    const update = (ts) => {
      if (running && dropQueue.length > 0 && ts - lastDrop > 360) {
        const item = dropQueue.shift();
        if (item) spawnBall(item);
        lastDrop = ts;
      }

      balls.forEach((ball) => {
        if (ball.done) return;

        ball.vy += GRAVITY;
        ball.vx *= AIR;
        ball.vy *= AIR;
        ball.x += ball.vx;
        ball.y += ball.vy;

        if (ball.x < WALL + ball.r) {
          ball.x = WALL + ball.r;
          ball.vx *= -0.88;
        }
        if (ball.x > W - WALL - ball.r) {
          ball.x = W - WALL - ball.r;
          ball.vx *= -0.88;
        }

        pegs.forEach((peg) => resolvePegCollision(ball, peg));
        bumpers.forEach((b) => resolvePegCollision(ball, b));
        rails.forEach((rail) => resolveRailCollision(ball, rail));

        if (ball.y >= H - SLOT_H - ball.r) {
          settleBall(ball);
        }
      });

      balls = balls.filter((b) => !b.done);

      if (running && balls.length === 0 && dropQueue.length === 0) {
        running = false;
        setStatus('finished');
      }
    };

    const drawBoard = () => {
      const grad = ctx.createLinearGradient(0, 0, 0, H);
      grad.addColorStop(0, '#020617');
      grad.addColorStop(1, '#0b1120');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);

      ctx.strokeStyle = '#1e293b';
      ctx.lineWidth = 1;
      for (let y = 0; y < H - SLOT_H; y += 44) {
        ctx.beginPath();
        ctx.moveTo(WALL, y + 0.5);
        ctx.lineTo(W - WALL, y + 0.5);
        ctx.stroke();
      }

      for (let x = WALL; x < W - WALL; x += 56) {
        ctx.beginPath();
        ctx.moveTo(x + 0.5, WALL);
        ctx.lineTo(x + 0.5, H - SLOT_H);
        ctx.stroke();
      }

      ctx.fillStyle = '#06b6d4';
      ctx.fillRect(W / 2 - 68, 22, 136, 26);
      ctx.fillStyle = '#ecfeff';
      ctx.font = 'bold 13px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('START ZONE', W / 2, 40);

      pegs.forEach((peg) => {
        ctx.beginPath();
        ctx.arc(peg.x, peg.y, peg.r, 0, Math.PI * 2);
        ctx.fillStyle = '#dbeafe';
        ctx.shadowColor = '#60a5fa';
        ctx.shadowBlur = 8;
        ctx.fill();
      });

      bumpers.forEach((b) => {
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(236,72,153,0.22)';
        ctx.shadowColor = '#f472b6';
        ctx.shadowBlur = 20;
        ctx.fill();
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r - 4, 0, Math.PI * 2);
        ctx.strokeStyle = '#f472b6';
        ctx.lineWidth = 2;
        ctx.stroke();
      });

      rails.forEach((rail) => {
        ctx.strokeStyle = '#22d3ee';
        ctx.lineWidth = 4;
        ctx.shadowColor = '#06b6d4';
        ctx.shadowBlur = 12;
        ctx.beginPath();
        ctx.moveTo(rail.x1, rail.y1);
        ctx.lineTo(rail.x2, rail.y2);
        ctx.stroke();
      });
      ctx.shadowBlur = 0;

      ctx.fillStyle = '#0f172a';
      ctx.fillRect(WALL, H - SLOT_H, W - WALL * 2, SLOT_H);

      for (let i = 0; i <= SLOT_MULT.length; i += 1) {
        const x = WALL + i * slotWidth;
        ctx.strokeStyle = '#1e3a8a';
        ctx.lineWidth = 1.3;
        ctx.beginPath();
        ctx.moveTo(x, H - SLOT_H);
        ctx.lineTo(x, H);
        ctx.stroke();
      }

      SLOT_MULT.forEach((m, i) => {
        const x = WALL + i * slotWidth + slotWidth / 2;
        ctx.fillStyle = m >= 10 ? '#fde047' : m >= 5 ? '#7dd3fc' : '#93c5fd';
        ctx.font = `bold ${m >= 10 ? 28 : 16}px sans-serif`;
        ctx.textAlign = 'center';
        ctx.fillText(`${fmt(m)}x`, x, H - 18);
      });

      balls.forEach((ball) => {
        ctx.beginPath();
        ctx.arc(ball.x, ball.y, ball.r, 0, Math.PI * 2);
        ctx.fillStyle = ball.color;
        ctx.shadowColor = ball.color;
        ctx.shadowBlur = 16;
        ctx.fill();
        ctx.shadowBlur = 0;
      });

      ctx.strokeStyle = '#0ea5e9';
      ctx.lineWidth = 3;
      ctx.strokeRect(WALL, WALL, W - WALL * 2, H - WALL * 2);
    };

    const tick = (ts) => {
      update(ts);
      drawBoard();
      rafId = window.requestAnimationFrame(tick);
    };

    addPlayerBtn?.addEventListener('click', addParticipant);
    clearPlayersBtn?.addEventListener('click', () => {
      participants = [];
      renderParticipants();
      resetGame();
    });

    playersListEl?.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      const id = target.dataset.remove;
      if (!id) return;
      participants = participants.filter((p) => p.id !== id);
      renderParticipants();
      resetGame();
    });

    startBtn?.addEventListener('click', startGame);
    stopBtn?.addEventListener('click', stopGame);
    resetBtn?.addEventListener('click', resetGame);

    renderSlotInfo();
    renderParticipants();
    renderFinish();
    drawBoard();
    rafId = window.requestAnimationFrame(tick);

    window.addEventListener('beforeunload', () => {
      if (rafId) window.cancelAnimationFrame(rafId);
    });
  </script>
  <Footer />
</Layout>
