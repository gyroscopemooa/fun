---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="채팅 랜덤 뽑기 | ManyTool" description="채팅 참여자 목록에서 랜덤 당첨자를 뽑는 도구">
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-3xl font-black">채팅 랜덤 뽑기</h1>
    <p class="mt-2 text-slate-700">채팅 닉네임 목록을 붙여넣고 당첨자를 추첨하세요.</p>
    <AdSense slotName="본문 상단" />
    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-6">
      <textarea id="chat-input" class="h-44 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="한 줄에 한 명씩 입력&#10;예) user01&#10;user02&#10;user03"></textarea>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <label class="text-sm">당첨 인원
          <input id="chat-count" class="ml-2 w-20 rounded-md border border-slate-300 px-2 py-1 text-sm" type="number" min="1" value="1" />
        </label>
        <label class="text-sm"><input id="chat-unique" type="checkbox" checked class="mr-1" />중복 닉네임 제거</label>
      </div>
      <div class="mt-4 flex gap-2">
        <button id="chat-pick" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">추첨하기</button>
        <button id="chat-reset" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold">초기화</button>
      </div>
      <div class="mt-4 rounded-lg bg-slate-100 p-4">
        <p class="text-sm text-slate-600">당첨자</p>
        <ol id="chat-result" class="mt-2 list-decimal space-y-1 pl-5 text-slate-900"></ol>
      </div>
    </section>
    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />
  <script is:inline>
    const inputEl = document.getElementById('chat-input');
    const countEl = document.getElementById('chat-count');
    const uniqueEl = document.getElementById('chat-unique');
    const resultEl = document.getElementById('chat-result');
    const pickBtn = document.getElementById('chat-pick');
    const resetBtn = document.getElementById('chat-reset');

    const parse = () => {
      const raw = inputEl instanceof HTMLTextAreaElement ? inputEl.value : '';
      let users = raw.split('\n').map((v) => v.trim()).filter(Boolean);
      const unique = uniqueEl instanceof HTMLInputElement ? uniqueEl.checked : true;
      if (unique) users = [...new Set(users)];
      return users;
    };

    pickBtn?.addEventListener('click', () => {
      const users = parse();
      const n = countEl instanceof HTMLInputElement ? Math.max(1, Number(countEl.value) || 1) : 1;
      if (!resultEl) return;
      if (users.length === 0) {
        resultEl.innerHTML = '<li>참여자가 없습니다.</li>';
        return;
      }
      const pool = [...users];
      const winners = [];
      const max = Math.min(n, pool.length);
      for (let i = 0; i < max; i += 1) {
        const idx = Math.floor(Math.random() * pool.length);
        winners.push(pool[idx]);
        pool.splice(idx, 1);
      }
      resultEl.innerHTML = winners.map((w) => `<li>${w}</li>`).join('');
    });

    resetBtn?.addEventListener('click', () => {
      if (inputEl instanceof HTMLTextAreaElement) inputEl.value = '';
      if (countEl instanceof HTMLInputElement) countEl.value = '1';
      if (uniqueEl instanceof HTMLInputElement) uniqueEl.checked = true;
      if (resultEl) resultEl.innerHTML = '';
    });
  </script>
</Layout>
