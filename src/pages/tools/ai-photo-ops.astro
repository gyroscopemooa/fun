---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const apiBase = import.meta.env.PUBLIC_NODE_API_BASE ?? 'http://127.0.0.1:8787';
---

<Layout
  title="AI 사진 운영 요약 | ManyTool"
  description="AI 증명사진 최근 작업, 경고, 추세, fallback, 품질 재시도 결과를 한 화면에서 확인하는 운영 페이지"
  noindex={true}
>
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-8">
    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">Ops Summary</p>
          <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-900">AI 사진 운영 요약</h1>
          <p class="mt-2 text-sm text-slate-600">
            최근 생성 결과, 저품질 경고, provider fallback, 품질 재시도 전후 점수를 한 화면에서 확인합니다.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="ops-refresh" type="button" class="rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-slate-800">새로고침</button>
          <button id="ops-copy-summary" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">요약 복사</button>
          <button id="ops-download-summary" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">요약 저장</button>
          <button id="ops-download-json" type="button" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">JSON 저장</button>
        </div>
      </div>

      <div class="mt-5 grid gap-3 md:grid-cols-2 xl:grid-cols-7">
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">상태</p>
          <select id="ops-status" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="all">전체</option>
            <option value="completed">completed</option>
            <option value="failed">failed</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">툴</p>
          <select id="ops-tool" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="all">전체</option>
            <option value="id_photo">id_photo</option>
            <option value="passport_photo">passport_photo</option>
            <option value="headshot">headshot</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">개수</p>
          <select id="ops-limit" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="8">8</option>
            <option value="12" selected>12</option>
            <option value="20">20</option>
            <option value="40">40</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">기간</p>
          <select id="ops-period" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="1">최근 1시간</option>
            <option value="24" selected>최근 24시간</option>
            <option value="168">최근 7일</option>
            <option value="0">전체</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">경고만</p>
          <select id="ops-flagged" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="false" selected>전체 포함</option>
            <option value="true">경고만 보기</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">fallback만</p>
          <select id="ops-fallback-only" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="false" selected>전체 포함</option>
            <option value="true">fallback만 보기</option>
          </select>
        </label>
        <label class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">provider</p>
          <select id="ops-provider" class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm">
            <option value="all" selected>전체</option>
            <option value="local_sharp">local_sharp</option>
            <option value="remove_bg">remove_bg</option>
            <option value="photoroom">photoroom</option>
          </select>
        </label>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <button data-preset="all" type="button" class="ops-preset rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">전체 보기</button>
        <button data-preset="flagged" type="button" class="ops-preset rounded-full border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100">경고만</button>
        <button data-preset="fallback" type="button" class="ops-preset rounded-full border border-sky-200 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:bg-sky-100">fallback만</button>
        <button data-preset="failed" type="button" class="ops-preset rounded-full border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-900 transition hover:bg-rose-100">실패만</button>
      </div>

      <p id="ops-status-text" class="mt-4 text-sm text-slate-500">최근 운영 데이터를 불러오는 중입니다.</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <a id="ops-open-debug" href="/tools/ai-photo-debug" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">현재 필터 디버그</a>
      </div>
    </section>

    <section id="ops-stats" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4"></section>

    <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-xl font-black text-slate-900">운영 인사이트</h2>
      <p class="mt-1 text-sm text-slate-600">가장 자주 터지는 문제와 품질 재시도 효과를 빠르게 요약합니다.</p>
      <div id="ops-insights" class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4"></div>
    </section>

    <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-xl font-black text-slate-900">시간대별 mini trend</h2>
      <p class="mt-1 text-sm text-slate-600">최근 작업 기준으로 실패, 경고, fallback이 몰린 시간대를 빠르게 봅니다.</p>
      <div id="ops-mini-trend" class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4"></div>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">툴별 추세</h2>
        <p class="mt-1 text-sm text-slate-600">현재 필터 기준으로 어떤 툴이 계속 문제인지 빠르게 봅니다.</p>
        <div id="ops-trends" class="mt-4 grid gap-3"></div>
      </article>

      <div class="grid gap-6">
        <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-xl font-black text-slate-900">경고 툴 집계</h2>
          <div id="ops-alert-tools" class="mt-4 grid gap-3"></div>
        </article>
        <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-xl font-black text-slate-900">경고 provider 집계</h2>
          <div id="ops-alert-providers" class="mt-4 grid gap-3"></div>
        </article>
      </div>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-2">
      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">툴별 원인 drill-down</h2>
        <p class="mt-1 text-sm text-slate-600">어떤 툴에서 어떤 플래그가 반복되는지 바로 봅니다.</p>
        <div id="ops-tool-drilldown" class="mt-4 grid gap-3"></div>
        <div id="ops-tool-debug-links" class="mt-4 flex flex-wrap gap-2"></div>
      </article>
      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">provider별 원인 drill-down</h2>
        <p class="mt-1 text-sm text-slate-600">fallback, 저품질, 저동일성 같은 원인을 provider 기준으로 묶어 봅니다.</p>
        <div id="ops-provider-drilldown" class="mt-4 grid gap-3"></div>
        <div id="ops-provider-debug-links" class="mt-4 flex flex-wrap gap-2"></div>
      </article>
    </section>

    <section class="mt-6 grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
      <article class="rounded-3xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
        <h2 class="text-xl font-black text-amber-950">최근 경고 작업</h2>
        <p class="mt-1 text-sm text-amber-900">저품질, 저동일성, fallback, 실패 작업만 모아서 봅니다.</p>
        <div id="ops-latest-flagged" class="mt-4 grid gap-3"></div>
      </article>

      <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black text-slate-900">관리 링크</h2>
        <p class="mt-1 text-sm text-slate-600">운영과 디버그 화면으로 바로 이동합니다.</p>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          <a href="/tools/ai-photo-admin" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-slate-300 hover:bg-white">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Admin</p>
            <p class="mt-2 text-base font-black text-slate-900">관리자 허브</p>
          </a>
          <a href="/tools/ai-photo-debug" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-slate-300 hover:bg-white">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Debug</p>
            <p class="mt-2 text-base font-black text-slate-900">단일 job 디버그</p>
          </a>
        </div>
      </article>
    </section>

    <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-xl font-black text-slate-900">최근 작업</h2>
      <p class="mt-1 text-sm text-slate-600">원본/추천 결과, 품질 재시도 전후, 후보 결정 흐름을 함께 봅니다.</p>
      <div id="ops-list" class="mt-4 grid gap-4"></div>
    </section>
  </main>
  <Footer />
  <script define:vars={{ apiBase }} is:inline>
    const API_BASE = apiBase;
    const statusTextEl = document.getElementById('ops-status-text');
    const statsEl = document.getElementById('ops-stats');
    const trendsEl = document.getElementById('ops-trends');
    const alertToolsEl = document.getElementById('ops-alert-tools');
    const alertProvidersEl = document.getElementById('ops-alert-providers');
    const latestFlaggedEl = document.getElementById('ops-latest-flagged');
    const listEl = document.getElementById('ops-list');
    const insightsEl = document.getElementById('ops-insights');
    const miniTrendEl = document.getElementById('ops-mini-trend');
    const toolDrilldownEl = document.getElementById('ops-tool-drilldown');
    const providerDrilldownEl = document.getElementById('ops-provider-drilldown');
    const toolDebugLinksEl = document.getElementById('ops-tool-debug-links');
    const providerDebugLinksEl = document.getElementById('ops-provider-debug-links');
    const refreshBtn = document.getElementById('ops-refresh');
    const openDebugLink = document.getElementById('ops-open-debug');
    const copySummaryBtn = document.getElementById('ops-copy-summary');
    const downloadSummaryBtn = document.getElementById('ops-download-summary');
    const downloadJsonBtn = document.getElementById('ops-download-json');
    const presetButtons = Array.from(document.querySelectorAll('.ops-preset'));

    const filters = {
      status: document.getElementById('ops-status'),
      tool: document.getElementById('ops-tool'),
      limit: document.getElementById('ops-limit'),
      period: document.getElementById('ops-period'),
      flagged: document.getElementById('ops-flagged'),
      fallbackOnly: document.getElementById('ops-fallback-only'),
      provider: document.getElementById('ops-provider')
    };

    let latestRecentPayload = null;
    let latestAlertsPayload = null;

    const setStatus = (text) => {
      if (statusTextEl instanceof HTMLElement) statusTextEl.textContent = text;
    };

    const formatNumber = (value, digits = 1) => {
      if (typeof value !== 'number' || Number.isNaN(value)) return '-';
      return value.toFixed(digits);
    };

    const formatPercent = (value) => `${formatNumber(value, 1)}%`;

    const formatDate = (value) => {
      if (!value) return '-';
      const parsed = new Date(value);
      if (Number.isNaN(parsed.getTime())) return String(value);
      return parsed.toLocaleString('ko-KR');
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const createMetricCard = (label, value, tone = 'slate') => `
      <article class="rounded-2xl border border-${tone}-200 bg-${tone}-50 p-4">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-${tone}-500">${label}</p>
        <p class="mt-2 text-2xl font-black text-${tone}-950">${escapeHtml(value)}</p>
      </article>
    `;

    const createTrendCard = (item) => `
      <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(item.toolType)}</p>
            <p class="mt-1 text-lg font-black text-slate-900">${escapeHtml(item.total)}건</p>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600">실패 ${escapeHtml(item.failed)}</span>
        </div>
        <div class="mt-3 grid gap-2 sm:grid-cols-2">
          <div class="rounded-xl bg-white px-3 py-2">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">평균 규격 점수</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${formatNumber(item.avgQualityScore)}</p>
          </div>
          <div class="rounded-xl bg-white px-3 py-2">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">평균 동일성 점수</p>
            <p class="mt-1 text-sm font-bold text-slate-900">${formatNumber(item.avgIdentityScore)}</p>
          </div>
        </div>
      </article>
    `;

    const createAlertRow = (label, count, total, tone = 'amber') => {
      const percent = total > 0 ? (count / total) * 100 : 0;
      return `
        <article class="rounded-2xl border border-${tone}-200 bg-${tone}-50 p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="text-sm font-bold text-${tone}-950">${escapeHtml(label)}</p>
            <span class="text-sm font-black text-${tone}-950">${escapeHtml(count)}건</span>
          </div>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-white/80">
            <div class="h-full rounded-full bg-${tone}-500" style="width:${Math.max(6, percent)}%"></div>
          </div>
          <p class="mt-2 text-xs text-${tone}-900">전체 경고 중 ${formatPercent(percent)}</p>
        </article>
      `;
    };

    const groupFlags = (items, keySelector) => {
      const grouped = new Map();
      for (const item of items) {
        const key = keySelector(item) ?? 'unknown';
        const bucket = grouped.get(key) ?? { total: 0, flags: new Map() };
        bucket.total += 1;
        for (const flag of item.flags ?? []) {
          bucket.flags.set(flag, (bucket.flags.get(flag) ?? 0) + 1);
        }
        grouped.set(key, bucket);
      }
      return [...grouped.entries()]
        .map(([key, bucket]) => ({
          key,
          total: bucket.total,
          flags: [...bucket.flags.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5)
        }))
        .sort((a, b) => b.total - a.total);
    };

    const applyDirectFilter = ({ toolType = 'all', provider = 'all', fallbackOnly = false, flaggedOnly = true, status = 'all' }) => {
      if (filters.tool instanceof HTMLSelectElement) filters.tool.value = toolType;
      if (filters.provider instanceof HTMLSelectElement) filters.provider.value = provider;
      if (filters.fallbackOnly instanceof HTMLSelectElement) filters.fallbackOnly.value = fallbackOnly ? 'true' : 'false';
      if (filters.flagged instanceof HTMLSelectElement) filters.flagged.value = flaggedOnly ? 'true' : 'false';
      if (filters.status instanceof HTMLSelectElement) filters.status.value = status;
      loadOps();
    };

    const scoreTone = (score) => {
      if (score >= 90) return 'emerald';
      if (score >= 80) return 'sky';
      if (score >= 70) return 'amber';
      return 'rose';
    };

    const summarizeInsights = (recentPayload, alertsPayload) => {
      const items = Array.isArray(recentPayload?.items) ? recentPayload.items : [];
      const alertItems = Array.isArray(alertsPayload?.items) ? alertsPayload.items : [];
      const toolTrends = Array.isArray(recentPayload?.toolTrends) ? recentPayload.toolTrends : [];

      const retryItems = items.filter((item) => typeof item.qualityScoreBeforeRetry === 'number' && typeof item.qualityScore === 'number');
      const avgRetryGain = retryItems.length
        ? retryItems.reduce((sum, item) => sum + (item.qualityScore - item.qualityScoreBeforeRetry), 0) / retryItems.length
        : null;

      const flagCounts = new Map();
      for (const item of alertItems) {
        for (const flag of item.flags ?? []) {
          flagCounts.set(flag, (flagCounts.get(flag) ?? 0) + 1);
        }
      }
      const topFlagEntry = [...flagCounts.entries()].sort((a, b) => b[1] - a[1])[0] ?? null;
      const worstTool = [...toolTrends].sort((a, b) => b.failed - a.failed)[0] ?? null;
      const fallbackCount = items.filter((item) => (item.flags ?? []).includes('provider_fallback')).length;

      return [
        {
          label: '가장 많은 경고',
          value: topFlagEntry ? `${topFlagEntry[0]} (${topFlagEntry[1]}건)` : '없음',
          tone: topFlagEntry ? 'amber' : 'slate'
        },
        {
          label: '실패가 가장 많은 툴',
          value: worstTool ? `${worstTool.toolType} (${worstTool.failed}건)` : '없음',
          tone: worstTool && worstTool.failed > 0 ? 'rose' : 'slate'
        },
        {
          label: '평균 재시도 개선폭',
          value: avgRetryGain === null ? '데이터 없음' : `+${formatNumber(avgRetryGain)}`,
          tone: avgRetryGain !== null && avgRetryGain > 0 ? 'emerald' : 'slate'
        },
        {
          label: 'fallback 비율',
          value: items.length ? formatPercent((fallbackCount / items.length) * 100) : '0.0%',
          tone: fallbackCount > 0 ? 'sky' : 'slate'
        }
      ];
    };

    const renderStats = (payload, alertsPayload) => {
      if (!(statsEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.items) ? payload.items : [];
      const alertItems = Array.isArray(alertsPayload?.items) ? alertsPayload.items : [];
      const failed = items.filter((item) => item.status === 'failed').length;
      const fallback = items.filter((item) => Array.isArray(item.flags) && item.flags.includes('provider_fallback')).length;
      const avgQuality = items.length ? items.reduce((sum, item) => sum + (typeof item.qualityScore === 'number' ? item.qualityScore : 0), 0) / items.length : 0;
      const avgIdentity = items.length ? items.reduce((sum, item) => sum + (typeof item.identityScore === 'number' ? item.identityScore : 0), 0) / items.length : 0;

      statsEl.innerHTML = [
        createMetricCard('총 작업', items.length, 'slate'),
        createMetricCard('실패 작업', failed, failed ? 'rose' : 'slate'),
        createMetricCard('경고 작업', alertItems.length, alertItems.length ? 'amber' : 'slate'),
        createMetricCard('fallback 작업', fallback, fallback ? 'sky' : 'slate'),
        createMetricCard('평균 규격 점수', formatNumber(avgQuality), scoreTone(avgQuality)),
        createMetricCard('평균 동일성 점수', formatNumber(avgIdentity), scoreTone(avgIdentity)),
        createMetricCard('필터 기간', payload?.filters?.sinceHours ? `${payload.filters.sinceHours}시간` : '전체', 'slate'),
        createMetricCard('경고/전체 비율', items.length ? formatPercent((alertItems.length / items.length) * 100) : '0.0%', 'amber')
      ].join('');
    };

    const renderTrends = (payload) => {
      if (!(trendsEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.toolTrends) ? payload.toolTrends : [];
      trendsEl.innerHTML = items.length
        ? items.map(createTrendCard).join('')
        : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-5 text-sm text-slate-500">표시할 추세 데이터가 없습니다.</p>';
    };

    const renderAlerts = (payload) => {
      const items = Array.isArray(payload?.items) ? payload.items : [];
      const toolCounts = payload?.byTool ?? {};
      const providerCounts = payload?.byProvider ?? {};

      if (alertToolsEl instanceof HTMLElement) {
        const entries = Object.entries(toolCounts);
        alertToolsEl.innerHTML = entries.length
          ? entries.map(([label, count]) => createAlertRow(label, count, items.length, 'amber')).join('')
          : '<p class="rounded-2xl border border-dashed border-amber-200 bg-white p-4 text-sm text-amber-900">경고 작업이 없습니다.</p>';
      }

      if (alertProvidersEl instanceof HTMLElement) {
        const entries = Object.entries(providerCounts);
        alertProvidersEl.innerHTML = entries.length
          ? entries.map(([label, count]) => createAlertRow(label, count, items.length, 'rose')).join('')
          : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-500">provider 경고 데이터가 없습니다.</p>';
      }

      if (latestFlaggedEl instanceof HTMLElement) {
        latestFlaggedEl.innerHTML = items.length
          ? items.slice(0, 6).map((item) => `
              <article class="rounded-2xl border border-amber-200 bg-white p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">${escapeHtml(item.toolType)}</p>
                    <p class="mt-1 text-sm font-black text-slate-900">${escapeHtml(item.id)}</p>
                  </div>
                  <a href="/tools/ai-photo-debug?jobId=${encodeURIComponent(item.id)}" class="rounded-lg bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-200">디버그</a>
                </div>
                <p class="mt-2 text-xs text-slate-500">${formatDate(item.createdAt)}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  ${(item.flags ?? []).map((flag) => `<span class="rounded-full bg-amber-50 px-2.5 py-1 text-[11px] font-semibold text-amber-900">${escapeHtml(flag)}</span>`).join('')}
                </div>
              </article>
            `).join('')
          : '<p class="rounded-2xl border border-dashed border-amber-200 bg-white p-4 text-sm text-amber-900">최근 경고 작업이 없습니다.</p>';
      }
    };

    const renderInsights = (recentPayload, alertsPayload) => {
      if (!(insightsEl instanceof HTMLElement)) return;
      insightsEl.innerHTML = summarizeInsights(recentPayload, alertsPayload)
        .map((item) => createMetricCard(item.label, item.value, item.tone))
        .join('');
    };

    const summarizeMiniTrend = (items) => {
      const buckets = new Map();
      items.forEach((item) => {
        const parsed = item?.createdAt ? new Date(item.createdAt) : null;
        if (!parsed || Number.isNaN(parsed.getTime())) return;
        const hourKey = `${parsed.getMonth() + 1}/${parsed.getDate()} ${String(parsed.getHours()).padStart(2, '0')}:00`;
        const bucket = buckets.get(hourKey) ?? { label: hourKey, total: 0, failed: 0, flagged: 0, fallback: 0 };
        bucket.total += 1;
        if (item.status === 'failed') bucket.failed += 1;
        if (Array.isArray(item.flags) && item.flags.length) bucket.flagged += 1;
        if (Array.isArray(item.flags) && item.flags.includes('provider_fallback')) bucket.fallback += 1;
        buckets.set(hourKey, bucket);
      });
      return [...buckets.values()]
        .sort((a, b) => {
          const riskA = a.failed * 4 + a.flagged * 2 + a.fallback;
          const riskB = b.failed * 4 + b.flagged * 2 + b.fallback;
          return riskB - riskA || b.total - a.total;
        })
        .slice(0, 4);
    };

    const renderMiniTrend = (payload) => {
      if (!(miniTrendEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.items) ? payload.items : [];
      const trendItems = summarizeMiniTrend(items);
      miniTrendEl.innerHTML = trendItems.length
        ? trendItems.map((item) => {
            const severity = item.failed > 0 ? 'rose' : item.flagged > 1 ? 'amber' : item.fallback > 0 ? 'sky' : 'slate';
            return `
              <article class="rounded-2xl border border-${severity}-200 bg-${severity}-50 p-4">
                <div class="flex items-center justify-between gap-3">
                  <p class="text-sm font-black text-${severity}-950">${escapeHtml(item.label)}</p>
                  <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-${severity}-900">총 ${item.total}</span>
                </div>
                <div class="mt-3 grid gap-2 sm:grid-cols-3">
                  <div class="rounded-xl bg-white px-3 py-2">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">실패</p>
                    <p class="mt-1 text-sm font-bold text-slate-900">${item.failed}</p>
                  </div>
                  <div class="rounded-xl bg-white px-3 py-2">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">경고</p>
                    <p class="mt-1 text-sm font-bold text-slate-900">${item.flagged}</p>
                  </div>
                  <div class="rounded-xl bg-white px-3 py-2">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">fallback</p>
                    <p class="mt-1 text-sm font-bold text-slate-900">${item.fallback}</p>
                  </div>
                </div>
              </article>
            `;
          }).join('')
        : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-500">표시할 시간대 데이터가 없습니다.</p>';
    };

    const getRepresentativeJobId = (type, key) => {
      const recentItems = Array.isArray(latestRecentPayload?.items) ? latestRecentPayload.items : [];
      const alertItems = Array.isArray(latestAlertsPayload?.items) ? latestAlertsPayload.items : [];
      const combined = [...recentItems, ...alertItems];
      const match = combined.find((item) => {
        if (type === 'tool') return item.toolType === key;
        return (item.provider ?? item.resolvedProvider) === key;
      });
      return match?.id ?? null;
    };

    const renderDrilldown = (alertsPayload) => {
      const items = Array.isArray(alertsPayload?.items) ? alertsPayload.items : [];
      const toolGroups = groupFlags(items, (item) => item.toolType);
      const providerGroups = groupFlags(items, (item) => item.provider);

      const renderGroup = (groups, target, emptyText) => {
        if (!(target instanceof HTMLElement)) return;
        target.innerHTML = groups.length
          ? groups.map((group) => `
              <button
                type="button"
                class="ops-drilldown w-full rounded-2xl border border-slate-200 bg-slate-50 p-4 text-left transition hover:border-slate-300 hover:bg-white"
                data-group-key="${escapeHtml(group.key)}"
                data-group-type="${target === toolDrilldownEl ? 'tool' : 'provider'}"
              >
                <div class="flex items-center justify-between gap-3">
                  <p class="text-sm font-black text-slate-900">${escapeHtml(group.key)}</p>
                  <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700">${group.total}건</span>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                  ${group.flags.length
                    ? group.flags.map(([flag, count]) => `<span class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold text-slate-700 shadow-sm">${escapeHtml(flag)} · ${count}</span>`).join('')
                    : '<span class="text-xs text-slate-500">플래그 없음</span>'}
                </div>
              </button>
            `).join('')
          : `<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm text-slate-500">${emptyText}</p>`;
      };

      renderGroup(toolGroups, toolDrilldownEl, '표시할 툴별 경고 원인이 없습니다.');
      renderGroup(providerGroups, providerDrilldownEl, '표시할 provider별 경고 원인이 없습니다.');
      if (toolDebugLinksEl instanceof HTMLElement) {
        toolDebugLinksEl.innerHTML = toolGroups.length
          ? toolGroups.map((group) => {
              const jobId = getRepresentativeJobId('tool', group.key);
              return jobId
                ? `<a href="/tools/ai-photo-debug?jobId=${encodeURIComponent(jobId)}" class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:bg-sky-100">${escapeHtml(group.key)} 대표 job 디버그</a>`
                : '';
            }).join('')
          : '';
      }

      if (providerDebugLinksEl instanceof HTMLElement) {
        providerDebugLinksEl.innerHTML = providerGroups.length
          ? providerGroups.map((group) => {
              const jobId = getRepresentativeJobId('provider', group.key);
              return jobId
                ? `<a href="/tools/ai-photo-debug?jobId=${encodeURIComponent(jobId)}" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">${escapeHtml(group.key)} 대표 job 디버그</a>`
                : '';
            }).join('')
          : '';
      }
    };

    const variantChip = (item, type) => {
      const tone = type === 'rejected' ? 'rose' : type === 'recommended' ? 'emerald' : type === 'regenerated' ? 'amber' : 'sky';
      const label = type === 'rejected' ? '제외' : type === 'recommended' ? '추천' : item.regenerated ? '재생성' : '후보';
      return `
        <span class="rounded-full bg-${tone}-50 px-2.5 py-1 text-[11px] font-semibold text-${tone}-900">
          ${escapeHtml(label)} ${escapeHtml(item.variantId ?? item.id ?? '-')} · ${formatNumber(item.score ?? item.estimatedScore ?? 0)}
        </span>
      `;
    };

    const scoreBar = (item, type) => {
      const score = Math.max(0, Math.min(100, Number(item.score ?? item.estimatedScore ?? 0)));
      const tone = type === 'rejected' ? 'rose' : type === 'recommended' ? 'emerald' : item.regenerated ? 'amber' : 'sky';
      const label = type === 'rejected' ? '제외' : type === 'recommended' ? '추천' : item.regenerated ? '재생성' : '후보';
      return `
        <div class="rounded-xl border border-slate-200 bg-white p-3">
          <div class="flex items-center justify-between gap-3">
            <p class="text-xs font-semibold text-slate-600">${escapeHtml(label)} · ${escapeHtml(item.variantId ?? item.id ?? '-')}</p>
            <p class="text-sm font-black text-slate-900">${formatNumber(score)}</p>
          </div>
          <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-${tone}-500" style="width:${Math.max(4, score)}%"></div>
          </div>
          <div class="mt-2 flex flex-wrap gap-2 text-[11px] text-slate-500">
            <span>동일성 ${formatNumber(item.identityScore ?? 0)}</span>
            <span>규격 ${formatNumber(item.qualityScore ?? 0)}</span>
          </div>
        </div>
      `;
    };

    const renderList = (payload) => {
      if (!(listEl instanceof HTMLElement)) return;
      const items = Array.isArray(payload?.items) ? payload.items : [];
      listEl.innerHTML = items.length
        ? items.map((item) => {
            const recommended = Array.isArray(item.candidateBreakdown)
              ? item.candidateBreakdown.find((candidate) => candidate.recommended)
              : null;
            const candidateBars = [
              ...(item.candidateBreakdown ?? []).map((candidate) => scoreBar(candidate, candidate.recommended ? 'recommended' : candidate.regenerated ? 'regenerated' : 'candidate')),
              ...(item.rejectedVariantBreakdown ?? []).map((candidate) => scoreBar(candidate, 'rejected'))
            ].join('');

            return `
              <article class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">${escapeHtml(item.toolType)} · ${escapeHtml(item.provider)}</p>
                    <h3 class="mt-1 text-lg font-black text-slate-900">${escapeHtml(item.id)}</h3>
                    <p class="mt-1 text-sm text-slate-500">${formatDate(item.createdAt)}</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <a href="/tools/ai-photo-debug?jobId=${encodeURIComponent(item.id)}" class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white transition hover:bg-slate-800">디버그</a>
                    ${(item.flags ?? []).map((flag) => `<span class="rounded-full bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm">${escapeHtml(flag)}</span>`).join('')}
                  </div>
                </div>

                <div class="mt-4 grid gap-4 xl:grid-cols-[0.95fr_1.05fr]">
                  <div class="grid gap-4">
                    <div class="grid gap-4 sm:grid-cols-2">
                      <div class="rounded-2xl border border-slate-200 bg-white p-3">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">원본</p>
                        <div class="mt-2 overflow-hidden rounded-xl bg-slate-100">
                          ${item.originalUrl ? `<img src="${escapeHtml(item.originalUrl)}" alt="원본" class="h-64 w-full object-cover" loading="lazy" />` : '<div class="flex h-64 items-center justify-center text-sm text-slate-400">원본 없음</div>'}
                        </div>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-3">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">추천 후보</p>
                        <div class="mt-2 overflow-hidden rounded-xl bg-slate-100">
                          ${item.recommendedImageUrl ? `<img src="${escapeHtml(item.recommendedImageUrl)}" alt="추천 후보" class="h-64 w-full object-cover" loading="lazy" />` : '<div class="flex h-64 items-center justify-center text-sm text-slate-400">추천 후보 없음</div>'}
                        </div>
                      </div>
                    </div>

                    <div class="grid gap-3 md:grid-cols-4">
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">규격 점수</p>
                        <p class="mt-2 text-xl font-black text-slate-900">${formatNumber(item.qualityScore)}</p>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">동일성 점수</p>
                        <p class="mt-2 text-xl font-black text-slate-900">${formatNumber(item.identityScore)}</p>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">crop profile</p>
                        <p class="mt-2 text-sm font-bold text-slate-900">${escapeHtml(item.cropProfile ?? '-')}</p>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">pose / suit</p>
                        <p class="mt-2 text-sm font-bold text-slate-900">${escapeHtml(item.poseProfile ?? '-')} / ${escapeHtml(item.suitTemplate ?? '-')}</p>
                      </div>
                    </div>

                    ${(item.finalQualityRetryTriggered || typeof item.qualityScoreBeforeRetry === 'number') ? `
                      <div class="rounded-2xl border border-amber-200 bg-amber-50 p-4">
                        <div class="flex items-center justify-between gap-3">
                          <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">품질 재시도</p>
                            <p class="mt-1 text-sm font-bold text-amber-950">${item.finalQualityRetryTriggered ? '최종 재프레이밍이 실행되었습니다.' : '재시도는 실행되지 않았습니다.'}</p>
                          </div>
                          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-amber-900">${escapeHtml(item.finalQualityRetryProfile ?? 'n/a')}</span>
                        </div>
                        <div class="mt-4 grid gap-3 sm:grid-cols-2">
                          <div class="rounded-xl bg-white p-3">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">재시도 전</p>
                            <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(item.qualityScoreBeforeRetry)}</p>
                          </div>
                          <div class="rounded-xl bg-white p-3">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">현재 점수</p>
                            <p class="mt-1 text-lg font-black text-slate-900">${formatNumber(item.qualityScore)}</p>
                          </div>
                        </div>
                      </div>
                    ` : ''}
                  </div>

                  <div class="grid gap-4">
                    <div class="rounded-2xl border border-slate-200 bg-white p-4">
                      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">품질 요약</p>
                      <p class="mt-2 text-sm font-bold text-slate-900">${escapeHtml(item.qualitySummary ?? '요약 없음')}</p>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4">
                      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">후보 추적</p>
                      <div class="mt-3 flex flex-wrap gap-2">
                        ${recommended ? variantChip(recommended, 'recommended') : ''}
                        ${(item.candidateBreakdown ?? []).filter((candidate) => !candidate.recommended).map((candidate) => variantChip(candidate, candidate.regenerated ? 'regenerated' : 'candidate')).join('')}
                        ${(item.rejectedVariantBreakdown ?? []).map((candidate) => variantChip(candidate, 'rejected')).join('')}
                      </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4">
                      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">점수 비교</p>
                      <div class="mt-3 grid gap-3">
                        ${candidateBars || '<p class="text-sm text-slate-500">후보 점수 데이터가 없습니다.</p>'}
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            `;
          }).join('')
        : '<p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-500">표시할 작업이 없습니다.</p>';
    };

    const buildOpsSummary = () => {
      const recent = latestRecentPayload;
      const alerts = latestAlertsPayload;
      const items = Array.isArray(recent?.items) ? recent.items : [];
      const alertItems = Array.isArray(alerts?.items) ? alerts.items : [];
      const lines = [
        'AI 사진 운영 요약',
        `생성 시각: ${new Date().toLocaleString('ko-KR')}`,
        `필터: status=${recent?.filters?.status ?? 'all'}, tool=${recent?.filters?.toolType ?? 'all'}, limit=${recent?.filters?.limit ?? '-'}, period=${recent?.filters?.sinceHours ?? 'all'}h, flagged=${recent?.filters?.flaggedOnly ?? false}, fallbackOnly=${recent?.filters?.fallbackOnly ?? false}`,
        `총 작업: ${items.length}`,
        `경고 작업: ${alertItems.length}`
      ];

      (recent?.toolTrends ?? []).forEach((item) => {
        lines.push(`- ${item.toolType}: total=${item.total}, failed=${item.failed}, avgQuality=${formatNumber(item.avgQualityScore)}, avgIdentity=${formatNumber(item.avgIdentityScore)}`);
      });

      alertItems.slice(0, 10).forEach((item) => {
        lines.push(`- alert ${item.id}: ${item.toolType} / ${item.provider} / flags=${(item.flags ?? []).join(', ')}`);
      });

      return lines.join('\n');
    };

    const downloadText = (name, text) => {
      const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = name;
      anchor.click();
      URL.revokeObjectURL(url);
    };

    const downloadJson = () => {
      const text = JSON.stringify({ recent: latestRecentPayload, alerts: latestAlertsPayload }, null, 2);
      downloadText(`ai-photo-ops-${Date.now()}.json`, text);
    };

    const buildQuery = () => {
      const params = new URLSearchParams();
      const status = filters.status instanceof HTMLSelectElement ? filters.status.value : 'all';
      const toolType = filters.tool instanceof HTMLSelectElement ? filters.tool.value : 'all';
      const provider = filters.provider instanceof HTMLSelectElement ? filters.provider.value : 'all';
      const limit = filters.limit instanceof HTMLSelectElement ? filters.limit.value : '12';
      const period = filters.period instanceof HTMLSelectElement ? filters.period.value : '24';
      const flaggedOnly = filters.flagged instanceof HTMLSelectElement ? filters.flagged.value === 'true' : false;
      const fallbackOnly = filters.fallbackOnly instanceof HTMLSelectElement ? filters.fallbackOnly.value === 'true' : false;

      params.set('limit', limit);
      if (status !== 'all') params.set('status', status);
      if (toolType !== 'all') params.set('toolType', toolType);
      if (provider !== 'all') params.set('provider', provider);
      if (period !== '0') params.set('sinceHours', period);
      if (flaggedOnly) params.set('flaggedOnly', 'true');
      if (fallbackOnly) params.set('fallbackOnly', 'true');
      return params;
    };

    const getPrimaryDebugUrl = () => {
      const recentItems = Array.isArray(latestRecentPayload?.items) ? latestRecentPayload.items : [];
      const alertItems = Array.isArray(latestAlertsPayload?.items) ? latestAlertsPayload.items : [];
      const target = recentItems[0] ?? alertItems[0] ?? null;
      return target?.id ? `/tools/ai-photo-debug?jobId=${encodeURIComponent(target.id)}` : '/tools/ai-photo-debug';
    };

    const syncDebugLink = () => {
      if (!(openDebugLink instanceof HTMLAnchorElement)) return;
      const href = getPrimaryDebugUrl();
      const hasTarget = href !== '/tools/ai-photo-debug';
      openDebugLink.href = href;
      openDebugLink.classList.toggle('opacity-50', !hasTarget);
      openDebugLink.classList.toggle('pointer-events-none', !hasTarget);
      openDebugLink.setAttribute('aria-disabled', hasTarget ? 'false' : 'true');
    };

    const applyPreset = (preset) => {
      if (filters.status instanceof HTMLSelectElement) filters.status.value = 'all';
      if (filters.flagged instanceof HTMLSelectElement) filters.flagged.value = 'false';
      if (filters.fallbackOnly instanceof HTMLSelectElement) filters.fallbackOnly.value = 'false';
      if (filters.provider instanceof HTMLSelectElement) filters.provider.value = 'all';

      if (preset === 'flagged' && filters.flagged instanceof HTMLSelectElement) {
        filters.flagged.value = 'true';
      }
      if (preset === 'fallback' && filters.fallbackOnly instanceof HTMLSelectElement) {
        filters.fallbackOnly.value = 'true';
      }
      if (preset === 'failed' && filters.status instanceof HTMLSelectElement) {
        filters.status.value = 'failed';
      }
      loadOps();
    };

    const loadOps = async () => {
      setStatus('운영 데이터를 불러오는 중입니다.');
      const query = buildQuery();
      try {
        const [recentRes, alertsRes] = await Promise.all([
          fetch(`${API_BASE}/jobs/recent?${query.toString()}`),
          fetch(`${API_BASE}/jobs/alerts?${query.toString()}`)
        ]);
        if (!recentRes.ok || !alertsRes.ok) throw new Error('운영 데이터를 불러오지 못했습니다.');
        const recentPayload = await recentRes.json();
        const alertsPayload = await alertsRes.json();
        latestRecentPayload = recentPayload;
        latestAlertsPayload = alertsPayload;
        renderStats(recentPayload, alertsPayload);
        renderInsights(recentPayload, alertsPayload);
        renderMiniTrend(recentPayload);
        renderTrends(recentPayload);
        renderAlerts(alertsPayload);
        renderDrilldown(alertsPayload);
        renderList(recentPayload);
        syncDebugLink();
        setStatus(`최근 ${Array.isArray(recentPayload.items) ? recentPayload.items.length : 0}건, 경고 ${Array.isArray(alertsPayload.items) ? alertsPayload.items.length : 0}건을 불러왔습니다.`);
      } catch (error) {
        latestRecentPayload = null;
        latestAlertsPayload = null;
        syncDebugLink();
        setStatus(error instanceof Error ? error.message : '운영 데이터를 불러오지 못했습니다.');
      }
    };

    refreshBtn?.addEventListener('click', () => loadOps());
    Object.values(filters).forEach((element) => element?.addEventListener('change', () => loadOps()));
    presetButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const preset = button.getAttribute('data-preset') ?? 'all';
        applyPreset(preset);
      });
    });
    document.addEventListener('click', (event) => {
      const target = event.target instanceof HTMLElement ? event.target.closest('.ops-drilldown') : null;
      if (!(target instanceof HTMLElement)) return;
      const key = target.getAttribute('data-group-key') ?? 'all';
      const type = target.getAttribute('data-group-type') ?? 'tool';
      if (type === 'tool') {
        applyDirectFilter({ toolType: key, provider: 'all', fallbackOnly: false, flaggedOnly: true, status: 'all' });
        return;
      }
      applyDirectFilter({
        toolType: 'all',
        provider: key,
        fallbackOnly: key === 'local_sharp',
        flaggedOnly: true,
        status: 'all'
      });
    });

    copySummaryBtn?.addEventListener('click', async () => {
      const summary = buildOpsSummary();
      try {
        await navigator.clipboard.writeText(summary);
        setStatus('운영 요약을 클립보드에 복사했습니다.');
      } catch {
        setStatus('클립보드 복사에 실패했습니다.');
      }
    });

    downloadSummaryBtn?.addEventListener('click', () => {
      downloadText(`ai-photo-ops-summary-${Date.now()}.txt`, buildOpsSummary());
      setStatus('운영 요약을 텍스트 파일로 저장했습니다.');
    });

    downloadJsonBtn?.addEventListener('click', () => {
      downloadJson();
      setStatus('운영 JSON을 저장했습니다.');
    });

    loadOps();
  </script>
</Layout>
