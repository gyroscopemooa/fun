---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="동물상 테스트 | ManyTool" description="사진 업로드 기반 동물상 테스트. 브라우저 로컬 분석으로 빠르게 결과를 확인합니다.">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">동물상 테스트</h1>
    <p class="mt-3 text-slate-700">사진을 올리면 브라우저에서 밝기/색감 기반으로 동물상 타입을 추정합니다.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-4 rounded-xl border border-slate-200 bg-white p-5">
      <input id="animal-file" accept="image/*" class="block w-full text-sm" type="file" />
      <img id="animal-preview" class="mt-3 hidden max-h-72 w-full rounded-lg object-contain" alt="미리보기" loading="lazy" decoding="async" />
      <button id="animal-run" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">분석하기</button>
      <p id="animal-result" class="mt-3 rounded-md bg-slate-100 px-3 py-3 text-sm text-slate-700">이미지를 올리고 분석 버튼을 눌러주세요.</p>
      <canvas id="animal-canvas" class="hidden"></canvas>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-semibold text-slate-900">동물상 테스트란?</h2>
      <p class="mt-1">사진의 색감/밝기 패턴을 기준으로 재미형 동물상 결과를 보여주는 웹 도구입니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">사용 방법</h2>
      <p class="mt-1">사진 업로드 후 분석하기를 누르면 즉시 결과가 표시됩니다.</p>
      <h2 class="mt-4 text-lg font-semibold text-slate-900">FAQ</h2>
      <p class="mt-1">Q. 사진 저장하나요? A. 저장하지 않고 현재 브라우저에서만 처리합니다.</p>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline>
    const fileEl = document.getElementById('animal-file');
    const previewEl = document.getElementById('animal-preview');
    const runEl = document.getElementById('animal-run');
    const resultEl = document.getElementById('animal-result');
    const canvasEl = document.getElementById('animal-canvas');

    let imageLoaded = false;

    fileEl?.addEventListener('change', () => {
      const file = fileEl.files?.[0];
      if (!file || !(previewEl instanceof HTMLImageElement)) return;
      const url = URL.createObjectURL(file);
      previewEl.src = url;
      previewEl.classList.remove('hidden');
      imageLoaded = true;
    });

    runEl?.addEventListener('click', () => {
      if (!imageLoaded || !(previewEl instanceof HTMLImageElement) || !(canvasEl instanceof HTMLCanvasElement)) {
        if (resultEl) resultEl.textContent = '먼저 이미지를 업로드해 주세요.';
        return;
      }

      const ctx = canvasEl.getContext('2d');
      if (!ctx) return;

      canvasEl.width = 64;
      canvasEl.height = 64;
      ctx.drawImage(previewEl, 0, 0, 64, 64);
      const data = ctx.getImageData(0, 0, 64, 64).data;

      let sumR = 0;
      let sumG = 0;
      let sumB = 0;
      for (let i = 0; i < data.length; i += 4) {
        sumR += data[i];
        sumG += data[i + 1];
        sumB += data[i + 2];
      }

      const px = data.length / 4;
      const r = sumR / px;
      const g = sumG / px;
      const b = sumB / px;
      const brightness = (r + g + b) / 3;

      let type = '고양이상';
      if (brightness > 170 && r > g + 8) type = '강아지상';
      else if (g > r + 8 && g > b + 5) type = '사슴상';
      else if (b > r + 10) type = '여우상';
      else if (brightness < 110) type = '늑대상';

      if (resultEl) resultEl.textContent = `분석 결과: ${type} (무API 로컬 추정)`;
    });
  </script>
</Layout>
