---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import SponsorBanner from '../components/SponsorBanner.astro';
import Recommend from '../components/Recommend.astro';

const categories = [
  {
    title: '테스트',
    desc: 'AI 분석과 심리형 테스트 콘텐츠',
    links: [
      { href: '/animal-test', label: '동물상 테스트' },
      { href: '/personal-color', label: '퍼스널컬러 테스트' },
      { href: '/mbti-test', label: 'MBTI 테스트' },
      { href: '/love-compatibility', label: '연애 궁합 테스트' }
    ]
  },
  {
    title: '게임',
    desc: '짧게 즐기는 미니게임',
    links: [
      { href: '/pinball', label: '핀볼 게임' },
      { href: '/reaction-test', label: '반응속도 테스트' },
      { href: '/magic-book', label: '마법책' }
    ]
  },
  {
    title: '지도',
    desc: '지역/테마 기반 위치 탐색',
    links: [
      { href: '/maps/fishbread', label: '붕어빵 지도' },
      { href: '/maps/hidden-cafe', label: '숨은 카페 지도' },
      { href: '/maps/local-eats', label: '지역 맛집 지도' }
    ]
  },
  {
    title: '랜덤 도구',
    desc: '빠르게 고르는 랜덤 추천',
    links: [{ href: '/random-food', label: '랜덤 음식 추천' }]
  }
];

const hotNow = [
  { href: '/maps/fishbread/seoul', label: '서울 붕어빵 지도' },
  { href: '/animal-test', label: '동물상 테스트' },
  { href: '/personal-color', label: '퍼스널컬러 테스트' },
  { href: '/reaction-test', label: '반응속도 테스트' }
];
---

<Layout title="FunHub | 테스트, 게임, 지도, 랜덤 도구 포털" description="FunHub 메인 포털 페이지">
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-8">
    <section class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm font-semibold text-indigo-600">FunHub Portal</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight">테스트, 게임, 지도, 랜덤 도구를 한 번에</h1>
      <p class="mt-3 text-slate-600">
        검색으로 들어와도 다음 콘텐츠로 바로 이동할 수 있게 설계된 허브형 페이지입니다.
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <a href="/animal-test" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">지금 시작</a>
        <a href="/maps/fishbread" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold">인기 지도 보기</a>
      </div>
    </section>

    <AdSense slotName="Header 아래" />

    <section class="mt-8">
      <h2 class="text-xl font-bold">지금 인기 콘텐츠</h2>
      <div class="mt-3 grid gap-3 md:grid-cols-2">
        {hotNow.map((item) => (
          <a href={item.href} class="rounded-lg border border-slate-200 bg-white p-4 hover:border-slate-400">
            {item.label}
          </a>
        ))}
      </div>
    </section>

    <AdSense slotName="본문 상단" />

    <section class="mt-8 grid gap-4 md:grid-cols-2">
      {categories.map((category) => (
        <article class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="text-lg font-bold">{category.title}</h3>
          <p class="mt-1 text-sm text-slate-600">{category.desc}</p>
          <div class="mt-4 grid gap-2">
            {category.links.map((item) => (
              <a href={item.href} class="rounded-md bg-slate-100 px-3 py-2 text-sm hover:bg-slate-200">{item.label}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <AdSense slotName="본문 중간" />
    <SponsorBanner position="본문 중간" />

    <section class="mt-8 rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="text-xl font-bold">탐색 동선</h2>
      <p class="mt-2 text-slate-700">붕어빵 지도 -> 동물상 테스트 -> 퍼스널컬러 테스트처럼 연속 탐색을 유도합니다.</p>
      <div class="mt-4 grid gap-2 md:grid-cols-3">
        <a href="/maps/fishbread" class="rounded-md border border-slate-300 px-3 py-2 text-sm">1) 지도 진입</a>
        <a href="/animal-test" class="rounded-md border border-slate-300 px-3 py-2 text-sm">2) 테스트 이동</a>
        <a href="/personal-color" class="rounded-md border border-slate-300 px-3 py-2 text-sm">3) 추가 테스트</a>
      </div>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
    <AdSense slotName="추천 콘텐츠 위" />
  </main>
  <Footer />
</Layout>
