---
interface Props {
  slotName?: string;
}

const { slotName = '본문 상단' } = Astro.props;
const showPlaceholder = import.meta.env.DEV || import.meta.env.PUBLIC_SHOW_AD_PLACEHOLDERS === 'true';
---

{
  showPlaceholder && (
    <div class="my-6 rounded-lg border border-dashed border-slate-300 bg-slate-100 px-4 py-6 text-center text-sm text-slate-600">
      Adsense Placeholder: {slotName}
    </div>
  )
}
