      const reading=partsReading(item.parts)||item.given.join('');
      const fallbackStory=partsMeaning(item.parts)?`${partsMeaning(item.parts)}의 뜻이 연결된 이름입니다.`:'한자 의미 데이터가 연결되면 스토리형 해석이 더 확장됩니다.';
      return`<article class="rounded-[28px] bg-white p-6"><div class="flex items-start justify-between gap-4"><div><p class="text-xs font-bold uppercase tracking-[0.18em] text-[#a7295a]">Top ${index+1}</p><h3 class="mt-3 text-3xl font-extrabold text-[#a7295a]">${reading}</h3><p class="mt-1 text-sm font-semibold text-[#5f5a57]">${item.given.join('')}</p></div><div class="rounded-full bg-[#f6f0ea] px-4 py-2 text-[10px] font-bold tracking-[0.15em] text-[#5f5a57]">${item.grade}</div></div><div class="mt-5 space-y-3 text-sm leading-7 text-[#5f5a57]"><p><span class="font-bold text-[#2f2a28]">추천 이유</span><br />${item.recommendationReason||'오격과 이름 이미지 기준으로 추천한 후보입니다.'}</p><p><span class="font-bold text-[#2f2a28]">이름풀이</span><br />${item.story||fallbackStory}</p><p><span class="font-bold text-[#2f2a28]">한자 / 뜻</span><br />${(item.parts||[]).map((p)=>`${p.meta?.reading||'-'} (${p.hanja}) · ${p.meta?.meaning||'의미 정보 없음'}`).join('<br />')}</p></div><div class="mt-5 border-t border-[#b1aca8]/15 pt-4 text-sm font-bold text-[#a7295a]">후보 점수 ${item.score}</div></article>`;
    }).join(''));
  };
  const runAnalysis=async()=>{const f=getFormPayload();if(!f.displayName){setText('[data-current-summary]','이름은 필수 입력입니다.');throw new Error('이름은 필수 입력입니다.');}if(!f.surname||f.given.length===0){renderNameOnly(f);return null;}const r=await fetch(`${API_BASE}/name-premium/analyze`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({orderId:currentOrderId,input:f,surname:f.surname,given:f.given})});const p=await r.json().catch(()=>null);if(!r.ok||!p){if(r.status===409){clearPaymentState('결제한 이름 정보가 변경되어 다시 결제가 필요합니다.');updatePaymentUi();}throw new Error(p?.error||'이름 분석에 실패했습니다.');}if(p.orderLock){currentOrderLock=normalizeLockPayload(p.orderLock);paymentReady=true;paymentResetReason='';}renderAnalysis(p,f);return p;};
  const runRecommend=async()=>{const f=getFormPayload();if(!f.surname)return null;const r=await fetch(`${API_BASE}/name-premium/recommend`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({orderId:currentOrderId,input:f,surname:f.surname,givenLength:2,topK:6,currentName:f.hanjaName||f.displayName})});const p=await r.json().catch(()=>null);if(!r.ok||!p){if(r.status===409){clearPaymentState('결제한 이름 정보가 변경되어 다시 결제가 필요합니다.');updatePaymentUi();}throw new Error(p?.error||'개명추천 생성에 실패했습니다.');}if(p.orderLock){currentOrderLock=normalizeLockPayload(p.orderLock);paymentReady=true;paymentResetReason='';}renderRecommendations(p);return p;};
  const runSuite=async(resumeAfterPayment=false)=>{try{const f=getFormPayload();if(!f.displayName)throw new Error('이름은 필수 입력입니다.');saveFormPayload(f);if(!paymentReady){sessionStorage.setItem(PENDING_RUN_KEY,'1');setLoading(true,'결제 준비 중','프리미엄 이름풀이 리포트를 열기 위해 결제를 준비합니다.');const proceeded=await requestCheckout();if(!proceeded)return;}if(!resumeAfterPayment)sessionStorage.removeItem(PENDING_RUN_KEY);setLoading(true,'이름풀이 분석 중','현재 이름의 성명학 구조와 분위기를 정리하고 있습니다.');await runAnalysis();setLoading(true,'개명추천 생성 중','추천 이름 6개와 각 추천 이유를 정리하고 있습니다.');await runRecommend();}catch(error){sessionStorage.removeItem(PENDING_RUN_KEY);setText('[data-current-summary]',error instanceof Error?error.message:'처리 중 오류가 발생했습니다.');}finally{setLoading(false,'분석 준비 중','이름풀이와 개명추천 결과를 순서대로 정리하고 있습니다.');}};
  const formElement=document.getElementById('name-premium-form');if(formElement){const handleFormSync=()=>syncPaymentStateWithForm(getFormPayload());formElement.addEventListener('input',handleFormSync);formElement.addEventListener('change',handleFormSync);}document.querySelectorAll('[data-action="suite"]').forEach((b)=>b.addEventListener('click',runSuite));hydratePaymentState();
</script>
