---
interface Props {
  initialView?: 'analysis' | 'recommendation' | 'report';
}

const { initialView = 'analysis' } = Astro.props;
const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();

const viewMap = {
  analysis: {
    key: 'analysis',
    label: '이름풀이',
    eyebrow: 'Name Analysis'
  },
  recommendation: {
    key: 'recommendation',
    label: '개명추천',
    eyebrow: 'Rename Recommendation'
  },
  report: {
    key: 'report',
    label: '개명풀이',
    eyebrow: 'Analysis Result'
  }
};

const views = [viewMap.analysis, viewMap.recommendation, viewMap.report];
---

<section class="relative overflow-hidden bg-[#fbf5f0] text-[#302e2b]">
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap');
  </style>

  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -left-24 top-14 h-64 w-64 rounded-full bg-[#ff709f]/18 blur-3xl"></div>
    <div class="absolute right-0 top-24 h-72 w-72 rounded-full bg-[#fff176]/28 blur-3xl"></div>
    <div class="absolute bottom-16 left-1/3 h-56 w-56 rounded-full bg-[#7fe6db]/22 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-[1180px] px-4 pb-20 pt-10 sm:px-6 lg:px-8" style="font-family: 'Be Vietnam Pro', 'Pretendard', sans-serif;">
    <nav class="rounded-full border border-white/60 bg-white/65 px-5 py-4 shadow-[0_20px_40px_rgba(48,46,43,0.06)] backdrop-blur">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="text-lg font-bold italic text-[#a7295a]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">The Ethereal Boutique</div>
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-[#5e5b57]">
          {views.map((view) => (
            <button
              type="button"
              data-switch-view={view.key}
              class:list={[
                'rounded-full px-4 py-2 transition',
                initialView === view.key ? 'bg-[#a7295a] text-white shadow-md' : 'hover:bg-white hover:text-[#a7295a]'
              ]}
            >
              {view.label}
            </button>
          ))}
        </div>
      </div>
    </nav>

    <section class="grid gap-10 pt-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start">
      <div>
        <p class="inline-flex rounded-full bg-[#7fe6db]/60 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.2em] text-[#005a54]">
          AI 기반 프리미엄 이름 리포트
        </p>
        <h1 class="mt-6 max-w-3xl text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">
          이름 속에 담긴
          <span class="block text-[#a7295a] italic">나의 운명과 개명 방향</span>
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[#5e5b57] sm:text-lg">
          이름풀이, 개명추천, 개명풀이를 한 화면에서 이어서 보는 프리미엄 허브입니다.
          기본 이름과 한자를 먼저 입력하고, 생년월일과 성별을 함께 넣어 더 깊은 해석 흐름으로 이어집니다.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <button type="button" class="rounded-full bg-[#a7295a] px-6 py-3 text-sm font-bold text-white shadow-lg shadow-[#a7295a]/20 transition hover:scale-[0.98]" data-scroll-target="premium-form">
            Start Name Analysis
          </button>
          <button type="button" class="rounded-full bg-[#7fe6db] px-6 py-3 text-sm font-bold text-[#003e39] transition hover:scale-[0.98]" data-switch-view="recommendation">
            Get Recommendations
          </button>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-2">
          <article class="rounded-[32px] bg-[#f6f0ea] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#ff709f]/20 text-[#a7295a]">✦</div>
            <h2 class="text-xl font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">이름 구조 해석</h2>
            <p class="mt-3 text-sm leading-7 text-[#5e5b57]">획수, 오격, 81수, 한자 의미를 같은 기준으로 읽어 이름풀이와 개명풀이의 일관성을 유지합니다.</p>
          </article>
          <article class="rounded-[32px] bg-[#fff7cb] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#fff176] text-[#655d00]">◎</div>
            <h2 class="text-xl font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">개명 추천 흐름</h2>
            <p class="mt-3 text-sm leading-7 text-[#5e5b57]">후보 이름 추천과 선택 이름의 상세 리포트를 한 번에 이어서 보여주는 런칭형 프리미엄 구조입니다.</p>
          </article>
        </div>
      </div>

      <div class="relative">
        <div class="absolute inset-x-8 top-6 h-full rounded-[40px] bg-white/45 blur-2xl"></div>
        <section id="premium-form" class="relative rounded-[36px] bg-white/80 p-5 shadow-[0_28px_80px_rgba(48,46,43,0.08)] backdrop-blur sm:p-7">
          <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.78fr)]">
            <article class="rounded-[30px] bg-[#fdf7f3] p-5">
              <div class="mb-4 flex items-center gap-2 text-sm font-bold text-[#a7295a]">
                <span>✦</span>
                <span>정보 입력하기</span>
              </div>

              <form id="name-premium-form" class="space-y-4">
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5e5b57]">기본 이름</span>
                    <input name="displayName" placeholder="김민지" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5e5b57]">성씨 한자</span>
                    <input name="surname" placeholder="金" maxlength="2" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5e5b57]">이름 한자 1</span>
                    <input name="given1" placeholder="民" maxlength="1" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5e5b57]">이름 한자 2</span>
                    <input name="given2" placeholder="秀" maxlength="1" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5e5b57]">생년월일</span>
                    <input name="birthDate" type="date" class="w-full rounded-full border-0 bg-white px-5 py-4 text-sm shadow-inner shadow-[#e8d9d3]/60 outline-none ring-1 ring-[#b1aca8]/20 focus:ring-2 focus:ring-[#a7295a]/35" />
                  </label>
                  <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.14em] text-[#5e5b57]">성별</span>
                    <div class="grid grid-cols-2 gap-3">
                      <label class="cursor-pointer">
                        <input type="radio" name="gender" value="female" class="peer sr-only" checked />
                        <span class="flex items-center justify-center gap-2 rounded-full bg-white px-4 py-4 text-sm font-semibold text-[#5e5b57] ring-1 ring-[#b1aca8]/20 transition peer-checked:bg-[#a7295a] peer-checked:text-white">여성</span>
                      </label>
                      <label class="cursor-pointer">
                        <input type="radio" name="gender" value="male" class="peer sr-only" />
                        <span class="flex items-center justify-center gap-2 rounded-full bg-white px-4 py-4 text-sm font-semibold text-[#5e5b57] ring-1 ring-[#b1aca8]/20 transition peer-checked:bg-[#a7295a] peer-checked:text-white">남성</span>
                      </label>
                    </div>
                  </label>
                </div>

                <div class="grid gap-3 sm:grid-cols-3">
                  <button type="button" class="rounded-full bg-[#a7295a] px-4 py-4 text-sm font-bold text-white transition hover:scale-[0.98]" data-action="analysis">이름풀이</button>
                  <button type="button" class="rounded-full bg-[#7fe6db] px-4 py-4 text-sm font-bold text-[#003e39] transition hover:scale-[0.98]" data-action="recommendation">개명추천</button>
                  <button type="button" class="rounded-full bg-[#fff176] px-4 py-4 text-sm font-bold text-[#655d00] transition hover:scale-[0.98]" data-action="report">개명풀이</button>
                </div>
              </form>
            </article>

            <article class="rounded-[30px] bg-[#fffdfb] p-5 shadow-inner shadow-[#f1e6df]/70">
              <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">Current Analysis</p>
              <h2 class="mt-4 text-4xl font-extrabold tracking-tight" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-current-name>
                김 민 지
              </h2>
              <p class="mt-2 text-sm text-[#5e5b57]" data-current-hanja>(金 民 秀)</p>

              <div class="mt-6 rounded-[24px] bg-[#7fe6db]/30 px-5 py-4">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-[#005a54]">Harmony Score</p>
                    <p class="mt-2 text-4xl font-extrabold text-[#005a54]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-current-score>--</p>
                  </div>
                  <div class="rounded-full bg-white px-4 py-2 text-xs font-bold text-[#005a54]" data-current-grade>입력 대기</div>
                </div>
              </div>

              <div class="mt-6 space-y-3">
                <div class="rounded-[22px] bg-[#f6f0ea] p-4">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#5e5b57]">오늘의 진행</p>
                  <p class="mt-2 text-sm leading-7 text-[#5e5b57]" data-current-summary>이름과 한자를 입력하면 오격 기반 요약이 여기에 표시됩니다.</p>
                </div>
                <div class="rounded-[22px] bg-[#fff7cb] p-4">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#655d00]">런칭 상태</p>
                  <p class="mt-2 text-sm leading-7 text-[#5e5b57]">단성 기준, 현재 등록된 한자 DB 범위 내에서만 결과를 제공합니다.</p>
                </div>
              </div>
            </article>
          </div>
        </section>
      </div>
    </section>

    <section class="mt-14">
      <div class="flex flex-wrap items-center gap-3">
        {views.map((view) => (
          <button
            type="button"
            class:list={[
              'rounded-full px-5 py-3 text-sm font-bold transition',
              initialView === view.key ? 'bg-[#a7295a] text-white' : 'bg-white text-[#5e5b57] hover:text-[#a7295a]'
            ]}
            data-result-tab={view.key}
          >
            {view.label}
          </button>
        ))}
      </div>

      <div class="mt-8 grid gap-8 xl:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
        <section class="rounded-[36px] bg-[#f6f0ea] p-6 shadow-[0_20px_40px_rgba(48,46,43,0.05)]">
          <div data-panel="analysis" class={initialView !== 'analysis' ? 'hidden' : ''}>
            <div class="grid gap-5 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
              <article class="rounded-[28px] bg-white p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">이름풀이</p>
                <h3 class="mt-3 text-3xl font-extrabold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-analysis-name>분석 결과 대기</h3>
                <p class="mt-3 text-sm leading-7 text-[#5e5b57]" data-analysis-explanation>이름풀이 버튼을 누르면 공통 엔진 기준 설명이 표시됩니다.</p>
              </article>
              <article class="rounded-[28px] bg-[#ede7e2] p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#5e5b57]">오격 상세</p>
                <div class="mt-4 grid gap-3 sm:grid-cols-2" data-analysis-grid>
                  <div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5e5b57]">천격/인격/지격 결과가 여기에 표시됩니다.</div>
                </div>
              </article>
            </div>
          </div>

          <div data-panel="recommendation" class={initialView !== 'recommendation' ? 'hidden' : ''}>
            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-recommend-list>
              <article class="rounded-[28px] bg-white p-6 text-sm text-[#5e5b57]">개명추천 버튼을 누르면 후보 카드가 여기에 채워집니다.</article>
            </div>
          </div>

          <div data-panel="report" class={initialView !== 'report' ? 'hidden' : ''}>
            <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)]">
              <article class="rounded-[28px] bg-white p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#a7295a]">개명풀이 리포트</p>
                <h3 class="mt-3 text-3xl font-extrabold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;" data-report-name>후보 이름 리포트 대기</h3>
                <p class="mt-3 text-sm leading-7 text-[#5e5b57]" data-report-explanation>선택한 한자 조합의 상세 해석이 여기에 표시됩니다.</p>
              </article>
              <article class="rounded-[28px] bg-[#fff7cb] p-6">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#655d00]">핵심 포인트</p>
                <div class="mt-4 space-y-3" data-report-points>
                  <div class="rounded-[22px] bg-white px-4 py-4 text-sm text-[#5e5b57]">이름 구조, 키워드, 점수 요약이 여기에 표시됩니다.</div>
                </div>
              </article>
            </div>
          </div>
        </section>

        <aside class="space-y-6">
          <section class="overflow-hidden rounded-[32px] bg-white shadow-[0_20px_40px_rgba(48,46,43,0.05)]">
            <div class="grid min-h-[220px] gap-0 md:grid-cols-[1.2fr_0.8fr]">
              <div class="flex flex-col justify-end bg-[linear-gradient(135deg,rgba(255,112,159,0.14),rgba(255,241,118,0.2))] p-6">
                <p class="text-sm font-semibold text-white/0">.</p>
                <h3 class="text-2xl font-bold text-white/0">.</h3>
                <div class="rounded-[24px] bg-[#302e2b]/78 p-5 text-white backdrop-blur">
                  <p class="text-sm font-bold">프리미엄 개명 추천 서비스</p>
                  <p class="mt-2 text-sm leading-7 text-white/75">부족한 기준을 채우는 방향의 한자 조합을 한 페이지 안에서 분석과 추천, 풀이까지 이어서 봅니다.</p>
                </div>
              </div>
              <div class="flex items-center justify-center bg-[#fff7cb] p-6">
                <div class="space-y-3 text-center">
                  <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#fff176] text-[#655d00]">◐</div>
                  <p class="text-lg font-bold" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">성명학 배치사전</p>
                  <p class="text-sm leading-7 text-[#5e5b57]">빠른 런칭형 구조지만 공통 계산 기준은 고정해서 일관성을 유지합니다.</p>
                </div>
              </div>
            </div>
          </section>

          <section class="rounded-[32px] bg-[#a7295a] px-7 py-8 text-white shadow-[0_20px_40px_rgba(48,46,43,0.08)]">
            <h3 class="text-3xl font-extrabold tracking-tight" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">Need a deeper aura?</h3>
            <p class="mt-4 text-sm leading-7 text-white/80">사주 연동과 이름 추천 풀을 계속 확장해, 이후에는 부족 오행 보완형 개명추천까지 자연스럽게 연결합니다.</p>
            <a href="/ai-manseryeok" class="mt-6 inline-flex rounded-full bg-white px-5 py-3 text-sm font-bold text-[#a7295a] transition hover:scale-[0.98]">사주 결과와 연결하기</a>
          </section>
        </aside>
      </div>
    </section>
  </div>
</section>

<script is:inline define:vars={{ initialView, rawApiBase }}>
  const API_BASE = (rawApiBase || (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost' ? 'http://127.0.0.1:8787' : '')).replace(/\/+$/, '');
  const form = document.getElementById('name-premium-form');
  const tabButtons = Array.from(document.querySelectorAll('[data-result-tab]'));
  const panels = Array.from(document.querySelectorAll('[data-panel]'));
  const currentNameEl = document.querySelector('[data-current-name]');
  const currentHanjaEl = document.querySelector('[data-current-hanja]');
  const currentScoreEl = document.querySelector('[data-current-score]');
  const currentGradeEl = document.querySelector('[data-current-grade]');
  const currentSummaryEl = document.querySelector('[data-current-summary]');
  const analysisNameEl = document.querySelector('[data-analysis-name]');
  const analysisExplanationEl = document.querySelector('[data-analysis-explanation]');
  const analysisGridEl = document.querySelector('[data-analysis-grid]');
  const recommendListEl = document.querySelector('[data-recommend-list]');
  const reportNameEl = document.querySelector('[data-report-name]');
  const reportExplanationEl = document.querySelector('[data-report-explanation]');
  const reportPointsEl = document.querySelector('[data-report-points]');

  let activeView = initialView;

  const panelTitleMap = {
    heaven: '천격',
    human: '인격',
    earth: '지격',
    outer: '외격',
    total: '총격'
  };

  const setView = (view) => {
    activeView = view;
    panels.forEach((panel) => {
      panel.classList.toggle('hidden', panel.getAttribute('data-panel') !== view);
    });
    tabButtons.forEach((button) => {
      const selected = button.getAttribute('data-result-tab') === view;
      button.className = selected
        ? 'rounded-full bg-[#a7295a] px-5 py-3 text-sm font-bold text-white transition'
        : 'rounded-full bg-white px-5 py-3 text-sm font-bold text-[#5e5b57] transition hover:text-[#a7295a]';
    });
  };

  const getFormPayload = () => {
    const formData = new FormData(form);
    const displayName = String(formData.get('displayName') || '').trim();
    const surname = String(formData.get('surname') || '').trim();
    const given = [String(formData.get('given1') || '').trim(), String(formData.get('given2') || '').trim()].filter(Boolean);
    const birthDate = String(formData.get('birthDate') || '').trim();
    const gender = String(formData.get('gender') || '').trim();

    if (currentNameEl) currentNameEl.textContent = displayName || '이름 입력 대기';
    if (currentHanjaEl) currentHanjaEl.textContent = surname || given.length ? `(${[surname, ...given].filter(Boolean).join(' ')})` : '(한자 입력 대기)';

    return {
      displayName,
      surname,
      given,
      birthDate,
      gender
    };
  };

  const setCurrentSummary = (score, grade, explanation) => {
    if (currentScoreEl) currentScoreEl.textContent = score == null ? '--' : String(score);
    if (currentGradeEl) currentGradeEl.textContent = grade || '입력 대기';
    if (currentSummaryEl) currentSummaryEl.textContent = explanation || '결과 설명이 여기에 표시됩니다.';
  };

  const renderAnalysis = (payload) => {
    if (analysisNameEl) analysisNameEl.textContent = payload.input ? `${payload.input.surname}${(payload.input.given || []).join('')}` : '분석 결과';
    if (analysisExplanationEl) analysisExplanationEl.textContent = payload.explanation || '설명 없음';
    if (analysisGridEl) {
      analysisGridEl.innerHTML = (payload.details || []).map((detail) => `
        <div class="rounded-[22px] bg-white px-4 py-4">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#a7295a]">${panelTitleMap[detail.slot] || detail.slot}</p>
          <p class="mt-2 text-2xl font-extrabold text-[#302e2b]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${detail.number}</p>
          <p class="mt-1 text-sm font-semibold text-[#5e5b57]">${detail.grade}</p>
          <p class="mt-2 text-xs leading-6 text-[#5e5b57]">${detail.summary}</p>
        </div>
      `).join('');
    }
    setCurrentSummary(payload.score, payload.grade, payload.explanation);
  };

  const renderRecommendations = (payload) => {
    if (!recommendListEl) return;
    recommendListEl.innerHTML = (payload.recommendations || []).map((item, index) => `
      <article class="rounded-[28px] bg-white p-6 shadow-[0_20px_40px_rgba(48,46,43,0.04)]">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#a7295a]">Top ${index + 1}</p>
            <h3 class="mt-3 text-4xl font-extrabold text-[#a7295a]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${item.given.join(' ')}</h3>
            <p class="mt-1 text-lg text-[#5e5b57]">${item.name}</p>
          </div>
          <div class="rounded-full bg-[#f6f0ea] px-4 py-2 text-[10px] font-bold uppercase tracking-[0.15em] text-[#5e5b57]">${item.grade}</div>
        </div>
        <p class="mt-5 text-sm leading-7 text-[#5e5b57]">${item.keywords || '추천 키워드 준비중'}</p>
        <div class="mt-5 flex items-center justify-between border-t border-[#b1aca8]/15 pt-4 text-sm font-bold text-[#a7295a]">
          <span>Score ${item.score}</span>
          <button type="button" class="rounded-full border border-[#a7295a]/15 px-3 py-1 text-xs" data-use-recommend='${JSON.stringify(item.given)}'>선택</button>
        </div>
      </article>
    `).join('');

    recommendListEl.querySelectorAll('[data-use-recommend]').forEach((button) => {
      button.addEventListener('click', () => {
        const given = JSON.parse(button.getAttribute('data-use-recommend') || '[]');
        const given1 = form?.querySelector('[name=\"given1\"]');
        const given2 = form?.querySelector('[name=\"given2\"]');
        if (given1) given1.value = given[0] || '';
        if (given2) given2.value = given[1] || '';
        setView('report');
        runAnalysis('report');
      });
    });
  };

  const renderReport = (payload) => {
    if (reportNameEl) reportNameEl.textContent = payload.input ? `${payload.input.surname}${(payload.input.given || []).join('')}` : '개명풀이 결과';
    if (reportExplanationEl) reportExplanationEl.textContent = payload.explanation || '설명 없음';
    if (reportPointsEl) {
      reportPointsEl.innerHTML = (payload.parts || []).map((part) => `
        <div class="rounded-[22px] bg-white px-4 py-4">
          <p class="text-lg font-extrabold text-[#302e2b]" style="font-family: 'Plus Jakarta Sans', 'Pretendard', sans-serif;">${part.hanja}</p>
          <p class="mt-2 text-sm text-[#5e5b57]">${part.meta?.reading || '-'} · ${part.meta?.meaning || '메타 없음'} · ${part.strokes || '-'}획</p>
          <p class="mt-2 text-xs leading-6 text-[#5e5b57]">${part.meta?.keywords || '키워드 없음'}</p>
        </div>
      `).join('');
    }
    setCurrentSummary(payload.score, payload.grade, payload.explanation);
  };

  const runAnalysis = async (targetView = 'analysis') => {
    if (!API_BASE) {
      setCurrentSummary(null, 'API 없음', 'PUBLIC_NODE_API_BASE가 설정되지 않았습니다.');
      return;
    }

    const { surname, given, displayName } = getFormPayload();
    if (!surname || given.length === 0) {
      setCurrentSummary(null, '입력 필요', '성씨 한자와 이름 한자를 입력해 주세요.');
      return;
    }

    if (currentNameEl && displayName) currentNameEl.textContent = displayName;
    if (currentHanjaEl) currentHanjaEl.textContent = `(${[surname, ...given].join(' ')})`;
    setCurrentSummary(null, '분석 중', '공통 엔진 기준으로 결과를 계산하고 있습니다.');

    try {
      const response = await fetch(`${API_BASE}/name-premium/analyze`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ surname, given })
      });
      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload) throw new Error(payload?.error || '분석 실패');

      renderAnalysis(payload);
      renderReport(payload);
      setView(targetView);
    } catch (error) {
      setCurrentSummary(null, '오류', error instanceof Error ? error.message : '분석 오류');
    }
  };

  const runRecommend = async () => {
    if (!API_BASE) {
      setCurrentSummary(null, 'API 없음', 'PUBLIC_NODE_API_BASE가 설정되지 않았습니다.');
      return;
    }

    const { surname, displayName } = getFormPayload();
    if (!surname) {
      setCurrentSummary(null, '입력 필요', '성씨 한자를 입력해 주세요.');
      return;
    }

    if (currentNameEl && displayName) currentNameEl.textContent = displayName;
    setCurrentSummary(null, '추천 중', '현재 이름 풀 기준으로 후보를 정리하고 있습니다.');

    try {
      const response = await fetch(`${API_BASE}/name-premium/recommend`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ surname, givenLength: 2, topK: 6 })
      });
      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload) throw new Error(payload?.error || '추천 실패');
      renderRecommendations(payload);
      setCurrentSummary(payload.recommendations?.[0]?.score ?? null, payload.recommendations?.[0]?.grade ?? '추천 완료', '후보 이름을 눌러 바로 개명풀이 리포트로 이어서 볼 수 있습니다.');
      setView('recommendation');
    } catch (error) {
      setCurrentSummary(null, '오류', error instanceof Error ? error.message : '추천 오류');
    }
  };

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => setView(button.getAttribute('data-result-tab')));
  });

  document.querySelectorAll('[data-action]').forEach((button) => {
    button.addEventListener('click', () => {
      const action = button.getAttribute('data-action');
      if (action === 'recommendation') runRecommend();
      else runAnalysis(action === 'report' ? 'report' : 'analysis');
    });
  });

  document.querySelectorAll('[data-switch-view]').forEach((button) => {
    button.addEventListener('click', () => setView(button.getAttribute('data-switch-view')));
  });

  document.querySelectorAll('[data-scroll-target]').forEach((button) => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-scroll-target');
      const target = targetId ? document.getElementById(targetId) : null;
      target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  setView(initialView);
</script>
