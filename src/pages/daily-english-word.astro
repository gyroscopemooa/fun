---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const t = {
  ko: {
    title: '오늘의 영단어 | ManyTool',
    desc: '매일 1개의 영단어를 뜻, 발음, 예문과 함께 확인하는 학습 도구입니다.',
    h1: '오늘의 영단어',
    sub: '매일 1개 단어를 빠르게 익히세요.',
    explain: '단어는 날짜 기준으로 자동 갱신됩니다.',
    copy: '복사',
    copied: '복사됨',
    faqQ: 'Q. 로그인이나 저장이 필요한가요?',
    faqA: 'A. 필요 없습니다. 페이지 접속만으로 사용 가능합니다.'
  },
  en: {
    title: 'Daily English Word | ManyTool',
    desc: 'Learn one English word a day with meaning, pronunciation, and example sentence.',
    h1: 'Daily English Word',
    sub: 'Learn one useful word every day.',
    explain: 'The word rotates automatically by date.',
    copy: 'Copy',
    copied: 'Copied',
    faqQ: 'Q. Do I need sign in?',
    faqA: 'A. No. It works instantly in your browser.'
  },
  ja: {
    title: '今日の英単語 | ManyTool',
    desc: '毎日1つの英単語を意味、発音、例文と一緒に学べるツールです。',
    h1: '今日の英単語',
    sub: '毎日1つ、実用単語を覚えましょう。',
    explain: '単語は日付ベースで自動更新されます。',
    copy: 'コピー',
    copied: 'コピー完了',
    faqQ: 'Q. ログインは必要ですか？',
    faqA: 'A. 不要です。ブラウザですぐ使えます。'
  }
}[locale];

const entries = [
  { word: 'resilient', pron: '/rɪˈzɪliənt/', meaning: '회복력이 강한', ex: 'She is resilient after failures.' },
  { word: 'efficient', pron: '/ɪˈfɪʃənt/', meaning: '효율적인', ex: 'This workflow is efficient.' },
  { word: 'insight', pron: '/ˈɪnsaɪt/', meaning: '통찰', ex: 'Your insight helped the team.' },
  { word: 'curious', pron: '/ˈkjʊriəs/', meaning: '호기심 많은', ex: 'Stay curious and keep learning.' },
  { word: 'momentum', pron: '/moʊˈmentəm/', meaning: '추진력', ex: 'We gained momentum this week.' },
  { word: 'clarity', pron: '/ˈklærəti/', meaning: '명확성', ex: 'Clear goals bring clarity.' },
  { word: 'adapt', pron: '/əˈdæpt/', meaning: '적응하다', ex: 'We adapt to new challenges quickly.' },
  { word: 'rewarding', pron: '/rɪˈwɔːrdɪŋ/', meaning: '보람 있는', ex: 'Teaching can be rewarding.' }
];
---

<Layout title={t.title} description={t.desc}>
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-3xl font-black">{t.h1}</h1>
    <p class="mt-2 text-slate-700">{t.sub}</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-sm text-slate-500">{t.explain}</p>
      <h2 id="word" class="mt-2 text-3xl font-black text-slate-900">-</h2>
      <p id="pron" class="mt-1 text-slate-500">-</p>
      <p id="meaning" class="mt-3 text-lg font-semibold text-slate-800">-</p>
      <p id="example" class="mt-2 rounded-lg bg-slate-100 px-3 py-2 text-slate-700">-</p>
      <button id="copy-btn" class="mt-3 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold">{t.copy}</button>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-bold">FAQ</h2>
      <p class="mt-2">{t.faqQ}</p>
      <p>{t.faqA}</p>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline define:vars={{ entries, copiedText: t.copied }}>
    const date = new Date();
    const key = `${date.getFullYear()}-${date.getMonth() + 1}-${date.getDate()}`;
    let hash = 0;
    for (let i = 0; i < key.length; i += 1) hash = (hash * 31 + key.charCodeAt(i)) >>> 0;
    const pick = entries[hash % entries.length];

    const wordEl = document.getElementById('word');
    const pronEl = document.getElementById('pron');
    const meaningEl = document.getElementById('meaning');
    const exampleEl = document.getElementById('example');
    const copyBtn = document.getElementById('copy-btn');

    if (wordEl) wordEl.textContent = pick.word;
    if (pronEl) pronEl.textContent = pick.pron;
    if (meaningEl) meaningEl.textContent = pick.meaning;
    if (exampleEl) exampleEl.textContent = pick.ex;

    copyBtn?.addEventListener('click', async () => {
      const text = `${pick.word} ${pick.pron} - ${pick.meaning} / ${pick.ex}`;
      await navigator.clipboard.writeText(text);
      if (copyBtn instanceof HTMLButtonElement) copyBtn.textContent = copiedText;
    });
  </script>
</Layout>
