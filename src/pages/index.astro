const cards = cardSeed.map((card) => {
  const i18n = cardTitleI18n[card.href];
  const title = locale === 'ko' || !i18n ? card.title : i18n[locale];
  const desc = locale === 'ko'
    ? card.desc
    : locale === 'en'
      ? `${title} tool`
      : `${title}ツール`;
  return { ...card, title, desc, href: withLocale(card.href) };
});

const rowSize = Math.min(10, cards.length);
const makeRow = (start: number) => Array.from({ length: rowSize }, (_, idx) => cards[(start + idx) % cards.length]);
const rows = [makeRow(0), makeRow(Math.floor(cards.length / 3)), makeRow(Math.floor((cards.length * 2) / 3))];
const faqJsonLd = {
