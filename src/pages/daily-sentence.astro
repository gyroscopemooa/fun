---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';

const pathname = Astro.url.pathname;
const locale = pathname.startsWith('/en/') || pathname === '/en'
  ? 'en'
  : pathname.startsWith('/ja/') || pathname === '/ja'
    ? 'ja'
    : 'ko';

const t = {
  ko: {
    title: '하루 한문장 | ManyTool',
    desc: '매일 1개의 실전 문장을 확인하고 바로 복습할 수 있는 페이지입니다.',
    h1: '하루 한문장',
    sub: '짧지만 자주 쓰는 표현을 매일 1개씩.',
    explain: '문장은 날짜 기준으로 자동 갱신됩니다.',
    copy: '문장 복사',
    copied: '복사됨'
  },
  en: {
    title: 'Sentence of the Day | ManyTool',
    desc: 'One practical sentence every day for quick daily practice.',
    h1: 'Sentence of the Day',
    sub: 'One practical sentence, every day.',
    explain: 'Sentence rotates by date automatically.',
    copy: 'Copy sentence',
    copied: 'Copied'
  },
  ja: {
    title: '今日の一文 | ManyTool',
    desc: '毎日1つの実用フレーズを確認して学習できるページです。',
    h1: '今日の一文',
    sub: '短くてもよく使う表現を毎日1つ。',
    explain: '文は日付ベースで自動更新されます。',
    copy: '文をコピー',
    copied: 'コピー完了'
  }
}[locale];

const lines = [
  'Small progress every day beats big plans someday.',
  'Start now, improve while moving.',
  'Consistency makes difficult things simple.',
  'Focus on what you can control today.',
  'Clear priorities reduce stress.',
  'Done is better than delayed perfection.',
  'Practice turns confusion into confidence.',
  'Energy follows action.'
];
---

<Layout title={t.title} description={t.desc}>
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-3xl font-black">{t.h1}</h1>
    <p class="mt-2 text-slate-700">{t.sub}</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-6">
      <p class="text-sm text-slate-500">{t.explain}</p>
      <blockquote id="line" class="mt-3 text-2xl font-bold leading-snug text-slate-900">-</blockquote>
      <button id="copy-line" class="mt-4 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold">{t.copy}</button>
    </section>

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-700">
      <h2 class="text-lg font-bold">사용 방법</h2>
      <p class="mt-2">매일 문장을 확인하고 소리 내어 3번 읽어보세요. 복사해 메모장/노트앱에 저장해도 좋습니다.</p>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline define:vars={{ lines, copiedText: t.copied }}>
    const date = new Date();
    const key = `${date.getFullYear()}-${date.getMonth() + 1}-${date.getDate()}`;
    let hash = 0;
    for (let i = 0; i < key.length; i += 1) hash = (hash * 33 + key.charCodeAt(i)) >>> 0;
    const line = lines[hash % lines.length];
    const lineEl = document.getElementById('line');
    const copyBtn = document.getElementById('copy-line');
    if (lineEl) lineEl.textContent = line;
    copyBtn?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(line);
      if (copyBtn instanceof HTMLButtonElement) copyBtn.textContent = copiedText;
    });
  </script>
</Layout>
