---
import Layout from '../../layouts/Layout.astro';
import AdSense from '../../components/AdSense.astro';
import Recommend from '../../components/Recommend.astro';
---

<Layout title="붕어빵 지도 | ManyTool" description="지도 기반 붕어빵 벤더 탐색/제보 페이지">
  <main class="h-[calc(100vh-0px)] overflow-hidden bg-amber-50 text-slate-900">
    <header class="flex h-16 items-center justify-between border-b border-amber-200 bg-white px-4 lg:px-6">
      <div class="flex items-center gap-3">
        <div class="rounded-lg bg-amber-500 p-2 text-white">🐟</div>
        <h1 class="text-xl font-bold tracking-tight">ManyTool <span class="text-amber-500">Bungeoppang</span></h1>
      </div>
      <div class="hidden flex-1 px-8 md:block">
        <input id="vendor-search" class="w-full rounded-xl border border-slate-200 bg-slate-100 px-4 py-2.5 text-sm" placeholder="지역/가게명 검색" type="text" />
      </div>
      <p id="selected-region" class="rounded-full bg-amber-100 px-3 py-1 text-sm font-semibold text-amber-700">전체</p>
    </header>

    <div class="flex h-[calc(100%-4rem)]">
      <aside class="w-full border-r border-slate-200 bg-white md:w-96">
        <div class="border-b border-slate-100 p-4">
          <div class="mb-3 flex items-center justify-between">
            <h2 class="text-lg font-bold">Nearby Vendors</h2>
            <button id="region-all" class="text-sm font-semibold text-amber-600">전체</button>
          </div>
          <div class="flex gap-2 overflow-x-auto pb-1 text-xs">
            <button class="rounded-full bg-amber-500 px-3 py-1.5 font-semibold text-white">All</button>
            <button class="rounded-full bg-slate-100 px-3 py-1.5">팥</button>
            <button class="rounded-full bg-slate-100 px-3 py-1.5">슈크림</button>
            <button class="rounded-full bg-slate-100 px-3 py-1.5">피자</button>
          </div>
        </div>

        <div id="vendor-list" class="h-[calc(100%-260px)] space-y-3 overflow-y-auto p-4"></div>

        <div class="border-t border-slate-100 bg-slate-50 p-4">
          <h3 class="text-sm font-bold">제보 추가</h3>
          <input id="spot-name" class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="가게명" type="text" />
          <input id="spot-region" class="mt-2 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm" placeholder="지역(지도 선택)" type="text" readonly />
          <input id="spot-flavor" class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="대표 메뉴 (예: 팥/슈크림)" type="text" />
          <button id="spot-add" class="mt-3 w-full rounded-xl bg-amber-500 py-2.5 font-bold text-white">Report a New Vendor</button>
        </div>
      </aside>

      <section class="relative hidden flex-1 md:block">
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-50 via-sky-50 to-slate-100"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(245,158,11,0.15),transparent_40%),radial-gradient(circle_at_70%_70%,rgba(14,165,233,0.14),transparent_40%)]"></div>

        <div class="absolute inset-6 rounded-2xl border border-slate-200 bg-white/70 p-4 backdrop-blur-sm">
          <p class="text-sm font-semibold text-slate-700">지도에서 지역 선택</p>

          <div class="relative mt-3 h-[82%] rounded-xl border border-dashed border-slate-300 bg-white/70">
            <button data-region="서울" class="map-region absolute left-[45%] top-[20%]">서울</button>
            <button data-region="경기" class="map-region absolute left-[45%] top-[30%]">경기</button>
            <button data-region="인천" class="map-region absolute left-[34%] top-[24%]">인천</button>
            <button data-region="강원" class="map-region absolute left-[60%] top-[24%]">강원</button>
            <button data-region="충남" class="map-region absolute left-[36%] top-[44%]">충남</button>
            <button data-region="충북" class="map-region absolute left-[50%] top-[42%]">충북</button>
            <button data-region="대전" class="map-region absolute left-[44%] top-[52%]">대전</button>
            <button data-region="전북" class="map-region absolute left-[34%] top-[58%]">전북</button>
            <button data-region="광주" class="map-region absolute left-[30%] top-[68%]">광주</button>
            <button data-region="전남" class="map-region absolute left-[40%] top-[76%]">전남</button>
            <button data-region="경북" class="map-region absolute left-[60%] top-[53%]">경북</button>
            <button data-region="대구" class="map-region absolute left-[56%] top-[62%]">대구</button>
            <button data-region="경남" class="map-region absolute left-[48%] top-[71%]">경남</button>
            <button data-region="울산" class="map-region absolute left-[65%] top-[71%]">울산</button>
            <button data-region="부산" class="map-region absolute left-[60%] top-[79%]">부산</button>
            <button data-region="제주" class="map-region absolute left-[21%] top-[86%]">제주</button>

            <div id="map-markers"></div>
          </div>
        </div>
      </section>
    </div>

    <section class="mx-auto max-w-5xl px-4 pb-8 pt-4">
      <AdSense slotName="본문 중간" />
      <Recommend />
    </section>
  </main>

  <script is:inline>
    const KEY = 'manytool_fishbread_v3';
    const REGION_POS = {
      서울: { x: 46, y: 22 }, 경기: { x: 45, y: 31 }, 인천: { x: 34, y: 24 }, 강원: { x: 61, y: 24 },
      충남: { x: 36, y: 44 }, 충북: { x: 50, y: 43 }, 대전: { x: 44, y: 52 }, 전북: { x: 34, y: 58 },
      광주: { x: 30, y: 68 }, 전남: { x: 40, y: 76 }, 경북: { x: 60, y: 53 }, 대구: { x: 56, y: 62 },
      경남: { x: 48, y: 71 }, 울산: { x: 65, y: 71 }, 부산: { x: 60, y: 79 }, 제주: { x: 21, y: 86 }
    };

    const seed = [
      { id: 's1', name: '강남역 붕어빵', region: '서울', flavor: '팥, 슈크림', up: 6, down: 1, comments: ['저녁에 오픈'] },
      { id: 's2', name: '서면 붕어빵', region: '부산', flavor: '팥', up: 4, down: 0, comments: ['주말도 운영'] },
      { id: 's3', name: '동성로 붕어빵', region: '대구', flavor: '팥, 치즈', up: 3, down: 1, comments: [] }
    ];

    const load = () => {
      const raw = localStorage.getItem(KEY);
      if (!raw) {
        localStorage.setItem(KEY, JSON.stringify(seed));
        return [...seed];
      }
      try { return JSON.parse(raw); }
      catch { localStorage.setItem(KEY, JSON.stringify(seed)); return [...seed]; }
    };

    const save = (data) => localStorage.setItem(KEY, JSON.stringify(data));

    const searchEl = document.getElementById('vendor-search');
    const selectedRegionEl = document.getElementById('selected-region');
    const regionInputEl = document.getElementById('spot-region');
    const listEl = document.getElementById('vendor-list');
    const markersEl = document.getElementById('map-markers');
    const addBtn = document.getElementById('spot-add');
    const nameEl = document.getElementById('spot-name');
    const flavorEl = document.getElementById('spot-flavor');

    let vendors = load();
    let selectedRegion = '전체';

    const score = (v) => v.up - v.down;

    const setRegion = (region) => {
      selectedRegion = region;
      if (selectedRegionEl) selectedRegionEl.textContent = region;
      if (regionInputEl instanceof HTMLInputElement) regionInputEl.value = region === '전체' ? '' : region;
      render();
    };

    const filteredVendors = () => {
      const q = searchEl instanceof HTMLInputElement ? searchEl.value.trim().toLowerCase() : '';
      return vendors
        .filter((v) => selectedRegion === '전체' || v.region === selectedRegion)
        .filter((v) => q === '' || `${v.name} ${v.region} ${v.flavor}`.toLowerCase().includes(q))
        .sort((a, b) => score(b) - score(a));
    };

    const renderList = (items) => {
      if (!listEl) return;
      if (items.length === 0) {
        listEl.innerHTML = '<p class="rounded-xl bg-slate-100 px-3 py-3 text-sm text-slate-600">조건에 맞는 제보가 없습니다.</p>';
        return;
      }

      listEl.innerHTML = items.map((v) => `
        <article class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <div class="flex items-start justify-between gap-2">
            <div>
              <h3 class="font-bold">${v.name}</h3>
              <p class="text-xs text-slate-500">${v.region} · ${v.flavor}</p>
            </div>
            <p class="text-xs font-semibold text-amber-600">신뢰 ${score(v)}</p>
          </div>
          <div class="mt-2 flex gap-2">
            <button data-act="up" data-id="${v.id}" class="rounded-md border border-slate-300 px-2 py-1 text-xs">추천 ${v.up}</button>
            <button data-act="down" data-id="${v.id}" class="rounded-md border border-slate-300 px-2 py-1 text-xs">비추천 ${v.down}</button>
          </div>
          <div class="mt-2 rounded-md bg-white p-2">
            <ul class="space-y-1 text-xs text-slate-600">
              ${v.comments.slice(-2).map((c) => `<li>- ${c}</li>`).join('') || '<li>- 댓글 없음</li>'}
            </ul>
            <div class="mt-2 flex gap-2">
              <input data-input="comment" data-id="${v.id}" class="flex-1 rounded border border-slate-300 px-2 py-1 text-xs" placeholder="정확/부정확 댓글" />
              <button data-act="comment" data-id="${v.id}" class="rounded bg-slate-900 px-2 py-1 text-xs text-white">등록</button>
            </div>
          </div>
        </article>`).join('');
    };

    const renderMarkers = (items) => {
      if (!markersEl) return;
      markersEl.innerHTML = items
        .slice(0, 10)
        .map((v) => {
          const pos = REGION_POS[v.region] || { x: 45, y: 50 };
          return `<button title="${v.name}" style="left:${pos.x}%;top:${pos.y}%;" class="absolute -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-amber-500 px-2 py-1 text-xs text-white shadow">🐟</button>`;
        })
        .join('');
    };

    const render = () => {
      const items = filteredVendors();
      renderList(items);
      renderMarkers(items);
    };

    document.querySelectorAll('[data-region]').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!(btn instanceof HTMLButtonElement)) return;
        const region = btn.dataset.region;
        if (region) setRegion(region);
      });
    });

    document.getElementById('region-all')?.addEventListener('click', () => setRegion('전체'));

    listEl?.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      const act = target.dataset.act;
      const id = target.dataset.id;
      if (!act || !id) return;

      const item = vendors.find((v) => v.id === id);
      if (!item) return;

      if (act === 'up') item.up += 1;
      if (act === 'down') item.down += 1;
      if (act === 'comment') {
        const input = listEl.querySelector(`input[data-input="comment"][data-id="${id}"]`);
        if (input instanceof HTMLInputElement) {
          const text = input.value.trim();
          if (text) {
            item.comments.push(text);
            input.value = '';
          }
        }
      }

      save(vendors);
      render();
    });

    addBtn?.addEventListener('click', () => {
      const name = nameEl instanceof HTMLInputElement ? nameEl.value.trim() : '';
      const region = regionInputEl instanceof HTMLInputElement ? regionInputEl.value.trim() : '';
      const flavor = flavorEl instanceof HTMLInputElement ? flavorEl.value.trim() : '';
      if (!name || !region) return;

      vendors.push({
        id: `v-${Date.now()}`,
        name,
        region,
        flavor: flavor || '팥',
        up: 0,
        down: 0,
        comments: []
      });

      if (nameEl instanceof HTMLInputElement) nameEl.value = '';
      if (flavorEl instanceof HTMLInputElement) flavorEl.value = '';

      save(vendors);
      render();
    });

    searchEl?.addEventListener('input', render);
    setRegion('전체');
  </script>

  <style>
    .map-region {
      border: 1px solid #cbd5e1;
      border-radius: 0.5rem;
      background: white;
      font-size: 0.75rem;
      line-height: 1;
      padding: 0.2rem 0.45rem;
    }
  </style>
</Layout>
