---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="반응속도 테스트 | FunHub" description="클릭 반응속도를 측정하는 미니게임">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">반응속도 테스트</h1>
    <p class="mt-3 text-slate-700">신호가 뜨는 순간 클릭해서 반응속도를 측정해보세요.</p>
    <AdSense slotName="본문 상단" />
    <div class="mt-4 rounded-lg border bg-white p-6 text-center">Reaction Test Placeholder</div>
    <Recommend />
  </main>
  <Footer />
</Layout>
