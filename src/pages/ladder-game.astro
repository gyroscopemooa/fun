---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="사다리타기 | FunHub" description="이름을 입력하고 사다리타기 랜덤 당첨을 뽑아보세요.">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">사다리타기</h1>
    <p class="mt-3 text-slate-700">참여자 이름을 쉼표로 입력한 뒤 버튼을 누르면 랜덤 당첨자를 뽑습니다.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5">
      <label class="text-sm font-semibold text-slate-700" for="ladder-input">참여자</label>
      <input
        id="ladder-input"
        class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm outline-none focus:border-sky-500"
        placeholder="예: 민수, 지연, 태훈, 수아"
        type="text"
      />
      <label class="mt-3 block text-sm font-semibold text-slate-700" for="ladder-items">걸릴 항목</label>
      <input
        id="ladder-items"
        class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm outline-none focus:border-sky-500"
        placeholder="예: 커피사기, 설거지, 노래하기, 면제"
        type="text"
      />
      <div class="ladder-stage mt-4 overflow-hidden rounded-xl border border-slate-200 bg-slate-950 p-2">
        <canvas id="ladder-map" width="900" height="360" class="w-full rounded-lg"></canvas>
      </div>
      <div class="mt-3 flex gap-2">
        <button id="ladder-start" class="rounded-md bg-sky-600 px-4 py-2 text-sm font-semibold text-white">시작</button>
        <button id="ladder-btn" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">결과 뽑기</button>
        <button id="ladder-reset" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold">초기화</button>
      </div>
      <p id="ladder-result" class="mt-4 rounded-md bg-slate-100 px-3 py-3 text-sm text-slate-700">입력 후 결과 뽑기를 눌러주세요.</p>
    </section>

    <script is:inline>
      const inputEl = document.getElementById('ladder-input');
      const startBtnEl = document.getElementById('ladder-start');
      const drawBtnEl = document.getElementById('ladder-btn');
      const resetBtnEl = document.getElementById('ladder-reset');
      const resultEl = document.getElementById('ladder-result');
      const itemInputEl = document.getElementById('ladder-items');
      const mapCanvas = document.getElementById('ladder-map');
      const mapCtx = mapCanvas instanceof HTMLCanvasElement ? mapCanvas.getContext('2d') : null;

      let lastNames = [];
      let lastWinnerIdx = -1;
      let lastRungs = [];
      let animId = 0;
      const fallbackItems = ['벌칙', '패스', '보너스', '미션'];

      const parseNames = () =>
        (inputEl?.value ?? '')
          .split(',')
          .map((name) => name.trim())
          .filter(Boolean);

      const parseItems = () =>
        (itemInputEl instanceof HTMLInputElement ? itemInputEl.value : '')
          .split(',')
          .map((item) => item.trim())
          .filter(Boolean);

      const getGeometry = (count) => {
        if (!mapCanvas) return null;
        const W = mapCanvas.width;
        const H = mapCanvas.height;
        const top = 42;
        const bottom = H - 42;
        const left = 62;
        const right = W - 62;
        const rows = 9;
        const xStep = count > 1 ? (right - left) / (count - 1) : 0;
        const yStep = (bottom - top) / rows;
        return { W, H, top, bottom, left, right, rows, xStep, yStep };
      };

      const buildRungs = (count) => {
        const rungs = [];
        const rows = 9;
        for (let r = 0; r < rows; r += 1) {
          for (let c = 0; c < count - 1; c += 1) {
            const probability = 0.34 + (r % 2) * 0.08;
            if (Math.random() < probability) {
              rungs.push({ row: r, col: c });
            }
          }
        }
        return rungs;
      };

      const drawLadderMap = (names, winnerIdx, rungs, trace = [], dot = null) => {
        if (!mapCanvas || !mapCtx) return;
        const geo = getGeometry(names.length);
        if (!geo) return;
        const { W, H, top, bottom, left, xStep, yStep } = geo;
        const ctx = mapCtx;
        const items = parseItems();
        const sourceItems = items.length > 0 ? items : fallbackItems;

        const grad = ctx.createLinearGradient(0, 0, 0, H);
        grad.addColorStop(0, '#020617');
        grad.addColorStop(1, '#0f172a');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);

        for (let i = 0; i < names.length; i += 1) {
          const x = left + i * xStep;
          ctx.beginPath();
          ctx.moveTo(x, top);
          ctx.lineTo(x, bottom);
          ctx.strokeStyle = i === winnerIdx ? '#22d3ee' : '#334155';
          ctx.lineWidth = i === winnerIdx ? 4 : 2;
          ctx.shadowColor = i === winnerIdx ? '#22d3ee' : 'transparent';
          ctx.shadowBlur = i === winnerIdx ? 12 : 0;
          ctx.stroke();
        }

        ctx.shadowBlur = 0;
        rungs.forEach((rung) => {
          const y = top + (rung.row + 1) * yStep;
          const x1 = left + rung.col * xStep;
          const x2 = x1 + xStep;
          ctx.beginPath();
          ctx.moveTo(x1, y);
          ctx.lineTo(x2, y);
          ctx.strokeStyle = '#64748b';
          ctx.lineWidth = 2;
          ctx.stroke();
        });

        if (trace.length > 1) {
          ctx.beginPath();
          ctx.moveTo(trace[0].x, trace[0].y);
          for (let i = 1; i < trace.length; i += 1) {
            ctx.lineTo(trace[i].x, trace[i].y);
          }
          ctx.strokeStyle = '#22d3ee';
          ctx.lineWidth = 4;
          ctx.shadowColor = '#22d3ee';
          ctx.shadowBlur = 10;
          ctx.stroke();
          ctx.shadowBlur = 0;
        }

        if (dot) {
          ctx.beginPath();
          ctx.arc(dot.x, dot.y, 7, 0, Math.PI * 2);
          ctx.fillStyle = '#34d399';
          ctx.shadowColor = '#34d399';
          ctx.shadowBlur = 16;
          ctx.fill();
          ctx.shadowBlur = 0;
        }

        names.forEach((name, idx) => {
          const x = left + idx * xStep;
          ctx.fillStyle = idx === winnerIdx ? '#a5f3fc' : '#cbd5e1';
          ctx.font = 'bold 18px sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText(name, x, top - 14);

          const itemText = sourceItems[idx % sourceItems.length];
          ctx.fillStyle = idx === winnerIdx ? '#34d399' : '#64748b';
          ctx.fillRect(x - 24, bottom + 8, 48, 18);
          ctx.fillStyle = '#e2e8f0';
          ctx.font = 'bold 12px sans-serif';
          ctx.fillText(itemText, x, bottom + 40);
        });
      };

      const computePath = (names, rungs, startIdx) => {
        const geo = getGeometry(names.length);
        if (!geo) return [];
        const { top, left, xStep, yStep, rows, bottom } = geo;
        const points = [];
        let lane = startIdx;
        let x = left + lane * xStep;
        points.push({ x, y: top });

        for (let row = 0; row < rows; row += 1) {
          const y = top + (row + 1) * yStep;
          points.push({ x, y });

          const goRight = rungs.some((r) => r.row === row && r.col === lane);
          const goLeft = rungs.some((r) => r.row === row && r.col === lane - 1);
          if (goRight) lane += 1;
          else if (goLeft) lane -= 1;

          x = left + lane * xStep;
          points.push({ x, y });
        }

        points.push({ x, y: bottom });
        return points;
      };

      const animatePath = (names, rungs, startIdx) => {
        if (animId) window.cancelAnimationFrame(animId);
        const path = computePath(names, rungs, startIdx);
        if (path.length < 2) return;

        const segLen = [];
        let total = 0;
        for (let i = 0; i < path.length - 1; i += 1) {
          const dx = path[i + 1].x - path[i].x;
          const dy = path[i + 1].y - path[i].y;
          const len = Math.hypot(dx, dy);
          segLen.push(len);
          total += len;
        }

        const duration = 1400;
        const startedAt = performance.now();

        const step = (now) => {
          const t = Math.min(1, (now - startedAt) / duration);
          const target = total * t;
          let walked = 0;
          let dot = path[0];
          const trace = [path[0]];

          for (let i = 0; i < segLen.length; i += 1) {
            const p0 = path[i];
            const p1 = path[i + 1];
            const len = segLen[i];
            if (walked + len < target) {
              trace.push(p1);
              walked += len;
              continue;
            }
            const remain = target - walked;
            const ratio = len === 0 ? 0 : remain / len;
            dot = { x: p0.x + (p1.x - p0.x) * ratio, y: p0.y + (p1.y - p0.y) * ratio };
            trace.push(dot);
            break;
          }

          drawLadderMap(names, -1, rungs, trace, dot);
          if (t < 1) {
            animId = window.requestAnimationFrame(step);
          } else {
            drawLadderMap(names, -1, rungs, path, path[path.length - 1]);
          }
        };

        animId = window.requestAnimationFrame(step);
      };

      const prepareMap = () => {
        const names = parseNames();
        if (names.length < 2) {
          if (resultEl) resultEl.textContent = '참여자는 2명 이상 입력해 주세요.';
          return null;
        }
        lastNames = names;
        lastRungs = buildRungs(names.length);
        lastWinnerIdx = -1;
        drawLadderMap(lastNames, -1, lastRungs);
        return names;
      };

      startBtnEl?.addEventListener('click', () => {
        const names = prepareMap();
        if (!names) return;
        const startIdx = Math.floor(Math.random() * names.length);
        animatePath(names, lastRungs, startIdx);
      });

      drawBtnEl?.addEventListener('click', () => {
        const names = parseNames();
        if (names.length < 2) {
          if (resultEl) resultEl.textContent = '참여자는 2명 이상 입력해 주세요.';
          return;
        }
        const items = parseItems();
        const sourceItems = items.length > 0 ? items : fallbackItems;
        const prevCount = lastNames.length;
        const winnerIdx = Math.floor(Math.random() * names.length);
        const winner = names[winnerIdx];
        const pickedItem = sourceItems[Math.floor(Math.random() * sourceItems.length)];
        lastNames = names;
        lastWinnerIdx = winnerIdx;
        if (lastRungs.length === 0 || prevCount !== names.length) {
          lastRungs = buildRungs(names.length);
        }
        drawLadderMap(lastNames, lastWinnerIdx, lastRungs);
        if (resultEl) resultEl.textContent = `당첨: ${winner} | 걸린 항목: ${pickedItem}`;
      });

      resetBtnEl?.addEventListener('click', () => {
        if (animId) window.cancelAnimationFrame(animId);
        if (inputEl) inputEl.value = '';
        if (itemInputEl instanceof HTMLInputElement) itemInputEl.value = '';
        if (resultEl) resultEl.textContent = '입력 후 결과 뽑기를 눌러주세요.';
        if (mapCtx && mapCanvas) {
          mapCtx.fillStyle = '#020617';
          mapCtx.fillRect(0, 0, mapCanvas.width, mapCanvas.height);
        }
        lastNames = [];
        lastWinnerIdx = -1;
        lastRungs = [];
      });

      if (mapCtx && mapCanvas) {
        mapCtx.fillStyle = '#020617';
        mapCtx.fillRect(0, 0, mapCanvas.width, mapCanvas.height);
      }
    </script>

    <style>
      .ladder-stage {
        position: relative;
      }
      .ladder-stage::after {
        content: '';
        pointer-events: none;
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 20%, rgba(34, 211, 238, 0.1) 50%, transparent 80%);
        transform: translateX(-120%);
        animation: ladderShine 3.8s linear infinite;
      }
      @keyframes ladderShine {
        to {
          transform: translateX(120%);
        }
      }
    </style>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />
</Layout>
