---
const navItems = [
  { href: '/', label: '홈' },
  { href: '/today-fortune', label: '운세' },
  { href: '/pinball', label: '게임' },
  { href: '/maps/fishbread', label: '붕어빵 지도' },
  { href: '/contact', label: '문의' }
];
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="text-xl font-bold tracking-tight">ManyTool</a>
    <nav class="flex items-center gap-2 text-sm">
      {navItems.map((item) => (
        <a class="rounded-md px-2 py-1 whitespace-nowrap hover:bg-slate-100" href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
