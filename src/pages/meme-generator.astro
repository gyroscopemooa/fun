---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="밈 생성기 | ManyTool" description="이미지와 텍스트로 간단한 밈 이미지를 만드는 도구">
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-8">
    <h1 class="text-3xl font-black">밈 생성기</h1>
    <p class="mt-2 text-slate-700">이미지 업로드 + 상단/하단 텍스트로 밈을 바로 생성합니다.</p>
    <AdSense slotName="본문 상단" />
    <section class="mt-5 grid gap-4 rounded-xl border border-slate-200 bg-white p-6 lg:grid-cols-[320px_1fr]">
      <aside>
        <label class="text-sm font-semibold">이미지 업로드
          <input id="meme-image" type="file" accept="image/*" class="mt-1 block w-full text-sm" />
        </label>
        <label class="mt-3 block text-sm font-semibold">상단 텍스트
          <input id="meme-top" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="TOP TEXT" />
        </label>
        <label class="mt-3 block text-sm font-semibold">하단 텍스트
          <input id="meme-bottom" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="BOTTOM TEXT" />
        </label>
        <div class="mt-4 flex gap-2">
          <button id="meme-render" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">생성</button>
          <button id="meme-download" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold">다운로드</button>
        </div>
      </aside>
      <div class="overflow-auto rounded-lg bg-slate-100 p-3">
        <canvas id="meme-canvas" width="800" height="800" class="mx-auto max-h-[520px] w-auto rounded border border-slate-300 bg-black"></canvas>
      </div>
    </section>
    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />
  <script is:inline>
    const imageEl = document.getElementById('meme-image');
    const topEl = document.getElementById('meme-top');
    const bottomEl = document.getElementById('meme-bottom');
    const renderBtn = document.getElementById('meme-render');
    const downloadBtn = document.getElementById('meme-download');
    const canvas = document.getElementById('meme-canvas');
    const ctx = canvas instanceof HTMLCanvasElement ? canvas.getContext('2d') : null;
    let img = null;

    const drawText = (text, y, baseline) => {
      if (!ctx || !(canvas instanceof HTMLCanvasElement)) return;
      ctx.font = 'bold 54px Arial, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = baseline;
      ctx.fillStyle = 'white';
      ctx.strokeStyle = 'black';
      ctx.lineWidth = 8;
      ctx.strokeText(text, canvas.width / 2, y);
      ctx.fillText(text, canvas.width / 2, y);
    };

    const render = () => {
      if (!ctx || !(canvas instanceof HTMLCanvasElement)) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      if (img) {
        const rw = canvas.width / img.width;
        const rh = canvas.height / img.height;
        const ratio = Math.min(rw, rh);
        const w = img.width * ratio;
        const h = img.height * ratio;
        const x = (canvas.width - w) / 2;
        const y = (canvas.height - h) / 2;
        ctx.drawImage(img, x, y, w, h);
      }
      const top = topEl instanceof HTMLInputElement ? topEl.value.trim().toUpperCase() : '';
      const bottom = bottomEl instanceof HTMLInputElement ? bottomEl.value.trim().toUpperCase() : '';
      if (top) drawText(top, 24, 'top');
      if (bottom) drawText(bottom, canvas.height - 24, 'bottom');
    };

    imageEl?.addEventListener('change', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLInputElement)) return;
      const file = target.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        const i = new Image();
        i.onload = () => { img = i; render(); };
        i.src = String(reader.result);
      };
      reader.readAsDataURL(file);
    });

    renderBtn?.addEventListener('click', render);
    downloadBtn?.addEventListener('click', () => {
      if (!(canvas instanceof HTMLCanvasElement)) return;
      const a = document.createElement('a');
      a.href = canvas.toDataURL('image/png');
      a.download = `manytool-meme-${Date.now()}.png`;
      a.click();
    });

    render();
  </script>
</Layout>
