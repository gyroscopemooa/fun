---
import Layout from '../layouts/Layout.astro';

const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();
const apiBase = rawApiBase.replace(/\/+$/, '');
---

<Layout
  title="AI 펫 언어 분석기 | 강아지 고양이 울음 번역기와 명령기"
  description="강아지와 고양이 소리를 AI로 분석해 사람 말처럼 해석하고, 명령 모드에서는 펫 스타일 음성까지 생성하는 ManyTool AI 펫 언어 분석기입니다."
  keywords="AI 펫 언어 분석기, 강아지 번역기, 고양이 번역기, 펫 명령기, 반려동물 소리 해석, pet translator"
>
  <main class="bg-[radial-gradient(circle_at_top,#fff4ef,transparent_42%),linear-gradient(180deg,#fffaf7_0%,#f7f3ff_100%)] pb-20">
    <section class="mx-auto max-w-[1180px] px-4 pt-10 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="rounded-[32px] border border-rose-100 bg-white/90 p-7 shadow-[0_28px_60px_rgba(92,54,80,0.08)] sm:p-9">
          <p class="inline-flex rounded-full bg-rose-100 px-4 py-2 text-[11px] font-black uppercase tracking-[0.24em] text-rose-700">
            Pet Translator
          </p>
          <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-950 sm:text-5xl">
            AI 펫 언어 분석기, 명령기
          </h1>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">
            강아지와 고양이 소리를 사람 말처럼 짧고 자연스럽게 해석하고, 명령 모드에서는 펫 스타일 음성까지 생성합니다.
            토큰 인증, 일일 사용량 제한, 쿨다운이 포함된 SaaS형 분석기 구조로 붙였습니다.
          </p>
          <div class="mt-6 grid gap-3 sm:grid-cols-3">
            <div class="rounded-[24px] bg-rose-50 p-4">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-rose-600">Analyze</p>
              <p class="mt-2 text-sm leading-6 text-slate-700">3줄 해석으로 감정과 상황을 빠르게 요약합니다.</p>
            </div>
            <div class="rounded-[24px] bg-amber-50 p-4">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-amber-700">Command</p>
              <p class="mt-2 text-sm leading-6 text-slate-700">번역된 문장을 펫 스타일 명령 음성으로 돌려줍니다.</p>
            </div>
            <div class="rounded-[24px] bg-emerald-50 p-4">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-emerald-700">Guardrail</p>
              <p class="mt-2 text-sm leading-6 text-slate-700">토큰, 일일 5회 제한, 5초 쿨다운을 함께 검증합니다.</p>
            </div>
          </div>
        </div>

        <section class="rounded-[32px] border border-white/70 bg-white/85 p-6 shadow-[0_28px_60px_rgba(56,60,94,0.08)] sm:p-8">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Studio Input</p>
              <h2 class="mt-2 text-2xl font-black text-slate-950">소리 업로드</h2>
            </div>
            <span id="pet-readiness" class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
              확인 중
            </span>
          </div>

          <div class="mt-6 space-y-4">
            <label class="block">
              <span class="mb-2 block text-sm font-bold text-slate-800">API 토큰</span>
              <input id="pet-token" type="text" placeholder="pet_live_xxxxx" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-rose-400 focus:ring-4 focus:ring-rose-100" />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-bold text-slate-800">동물 선택</span>
              <select id="pet-animal" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-rose-400 focus:ring-4 focus:ring-rose-100">
                <option value="dog">강아지</option>
                <option value="cat">고양이</option>
              </select>
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-bold text-slate-800">모드 선택</span>
              <select id="pet-mode" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-rose-400 focus:ring-4 focus:ring-rose-100">
                <option value="analyze">언어 분석</option>
                <option value="command">명령 음성 생성</option>
              </select>
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-bold text-slate-800">오디오 파일</span>
              <input id="pet-audio" type="file" accept="audio/*" class="block w-full rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-4 py-4 text-sm text-slate-700 file:mr-4 file:rounded-full file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-sm file:font-bold file:text-white hover:border-slate-400" />
            </label>
          </div>

          <div class="mt-5 rounded-[24px] bg-slate-50 p-4 text-sm leading-6 text-slate-600">
            <p class="font-bold text-slate-900">사용법</p>
            <p class="mt-2">토큰을 넣고 동물과 모드를 고른 뒤 오디오를 업로드하면 됩니다. 분석은 3줄 결과, 명령 모드는 음성까지 같이 돌려줍니다.</p>
          </div>

          <button id="pet-submit" type="button" class="mt-5 w-full rounded-[22px] bg-[linear-gradient(135deg,#d6336c_0%,#7c3aed_100%)] px-5 py-4 text-sm font-black text-white shadow-[0_16px_34px_rgba(124,58,237,0.26)] transition hover:translate-y-[-1px]">
            펫 언어 분석 시작
          </button>
        </section>
      </div>
    </section>

    <section class="mx-auto mt-8 max-w-[1180px] px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-[1fr_0.86fr]">
        <article class="rounded-[32px] border border-white/70 bg-white/88 p-6 shadow-[0_24px_50px_rgba(66,71,105,0.08)] sm:p-8">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Result</p>
              <h2 class="mt-2 text-2xl font-black text-slate-950">번역 결과</h2>
            </div>
            <span id="pet-usage" class="rounded-full bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-700">
              사용량: -
            </span>
          </div>

          <div id="pet-loading" class="mt-6 hidden rounded-[28px] border border-violet-100 bg-violet-50/80 p-5">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 animate-spin rounded-full border-4 border-violet-200 border-t-violet-600"></div>
              <div>
                <p class="text-sm font-black text-violet-900">AI가 펫 소리를 해석 중입니다</p>
                <p class="mt-1 text-sm text-violet-700">음성 전사, 감정 해석, 결과 생성 순서로 처리합니다.</p>
              </div>
            </div>
          </div>

          <p id="pet-status" class="mt-6 text-sm leading-7 text-slate-500">
            아직 결과가 없습니다. 파일을 업로드하고 분석을 시작하세요.
          </p>

          <div class="mt-6 grid gap-4 sm:grid-cols-3">
            <div class="rounded-[24px] bg-rose-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-rose-600">PET SAYS</p>
              <p id="pet-text" class="mt-3 text-lg font-black text-slate-950">-</p>
            </div>
            <div class="rounded-[24px] bg-amber-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-amber-700">EMOTION</p>
              <p id="pet-emotion" class="mt-3 text-lg font-black text-slate-950">-</p>
            </div>
            <div class="rounded-[24px] bg-emerald-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-emerald-700">EXPLANATION</p>
              <p id="pet-description" class="mt-3 text-sm font-semibold leading-6 text-slate-800">-</p>
            </div>
          </div>

          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Transcript</p>
              <p id="pet-transcript" class="mt-3 text-sm leading-6 text-slate-700">-</p>
            </div>
            <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Duration</p>
              <p id="pet-duration" class="mt-3 text-sm leading-6 text-slate-700">-</p>
            </div>
          </div>
        </article>

        <aside class="rounded-[32px] border border-white/70 bg-white/88 p-6 shadow-[0_24px_50px_rgba(66,71,105,0.08)] sm:p-8">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Command Audio</p>
          <h2 class="mt-2 text-2xl font-black text-slate-950">펫 스타일 출력</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            명령 모드일 때 번역된 문장을 음성으로 다시 돌려줍니다. 분석 모드에서는 이 영역이 비활성화됩니다.
          </p>

          <div id="pet-audio-card" class="mt-6 rounded-[28px] bg-[linear-gradient(135deg,#101828_0%,#312e81_100%)] p-5 text-white opacity-50">
            <p class="text-sm font-semibold text-white/70">아직 생성된 음성이 없습니다.</p>
            <audio id="pet-result-audio" class="mt-4 w-full" controls hidden></audio>
            <a id="pet-download" class="mt-4 hidden rounded-full bg-white px-4 py-2 text-sm font-bold text-slate-900" download="pet-command.mp3">음성 다운로드</a>
          </div>

          <div class="mt-6 rounded-[24px] bg-slate-50 p-5">
            <p class="text-sm font-bold text-slate-900">API 응답 형식</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-600">
              <li>`analyze` -> 문장, 감정, 짧은 설명</li>
              <li>`command` -> 생성 음성 base64와 보조 메타</li>
              <li>토큰별 일일 5회, 5초 쿨다운</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <script is:inline define:vars={{ apiBase }}>
      const API_BASE = apiBase;
      const tokenEl = document.getElementById('pet-token');
      const animalEl = document.getElementById('pet-animal');
      const modeEl = document.getElementById('pet-mode');
      const audioEl = document.getElementById('pet-audio');
      const submitEl = document.getElementById('pet-submit');
      const statusEl = document.getElementById('pet-status');
      const loadingEl = document.getElementById('pet-loading');
      const readinessEl = document.getElementById('pet-readiness');
      const usageEl = document.getElementById('pet-usage');
      const textEl = document.getElementById('pet-text');
      const emotionEl = document.getElementById('pet-emotion');
      const descriptionEl = document.getElementById('pet-description');
      const transcriptEl = document.getElementById('pet-transcript');
      const durationEl = document.getElementById('pet-duration');
      const audioCardEl = document.getElementById('pet-audio-card');
      const resultAudioEl = document.getElementById('pet-result-audio');
      const downloadEl = document.getElementById('pet-download');

      const setLoading = (value) => {
        loadingEl?.classList.toggle('hidden', !value);
        submitEl.disabled = value;
        submitEl.textContent = value ? '분석 중...' : '펫 언어 분석 시작';
      };

      const setStatus = (message) => {
        if (statusEl) statusEl.textContent = message;
      };

      const setUsage = (usage) => {
        if (!usageEl) return;
        if (!usage) {
          usageEl.textContent = '사용량: -';
          return;
        }
        usageEl.textContent = `사용량: ${usage.usageCount}/${usage.dailyLimit}`;
      };

      const resetAudioOutput = () => {
        if (resultAudioEl) {
          resultAudioEl.hidden = true;
          resultAudioEl.removeAttribute('src');
        }
        if (downloadEl) {
          downloadEl.hidden = true;
          downloadEl.removeAttribute('href');
        }
        audioCardEl?.classList.add('opacity-50');
      };

      const fileToBase64 = (file) => new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(typeof reader.result === 'string' ? reader.result : '');
        reader.onerror = () => reject(new Error('오디오를 읽지 못했습니다.'));
        reader.readAsDataURL(file);
      });

      const loadConfig = async () => {
        if (!API_BASE) {
          readinessEl.textContent = 'API 없음';
          readinessEl.className = 'rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700';
          return;
        }

        try {
          const response = await fetch(`${API_BASE}/config`);
          const payload = await response.json().catch(() => null);
          const ready = Boolean(payload?.readiness?.petTranslatorReady);
          readinessEl.textContent = ready ? 'API 연결됨' : 'API 준비 필요';
          readinessEl.className = ready
            ? 'rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700'
            : 'rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700';
        } catch {
          readinessEl.textContent = 'API 오류';
          readinessEl.className = 'rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700';
        }
      };

      const renderAnalyzeResult = (payload) => {
        textEl.textContent = payload?.text || '-';
        emotionEl.textContent = payload?.emotion || '-';
        descriptionEl.textContent = payload?.description || '-';
        transcriptEl.textContent = payload?.transcript || '전사 텍스트 없음';
        durationEl.textContent = typeof payload?.durationSeconds === 'number' && payload.durationSeconds > 0
          ? `${payload.durationSeconds}초`
          : '길이 정보 없음';
        setUsage(payload?.usage);
      };

      const renderCommandAudio = (payload) => {
        const base64 = typeof payload?.audio === 'string' ? payload.audio : '';
        const mimeType = payload?.mimeType || 'audio/mpeg';
        if (!base64 || !resultAudioEl || !downloadEl) {
          resetAudioOutput();
          return;
        }
        const audioUrl = `data:${mimeType};base64,${base64}`;
        resultAudioEl.src = audioUrl;
        resultAudioEl.hidden = false;
        downloadEl.href = audioUrl;
        downloadEl.hidden = false;
        audioCardEl?.classList.remove('opacity-50');
      };

      submitEl?.addEventListener('click', async () => {
        const token = tokenEl?.value?.trim() || '';
        const animal = animalEl?.value || 'dog';
        const mode = modeEl?.value || 'analyze';
        const file = audioEl?.files?.[0];

        if (!API_BASE) {
          setStatus('PUBLIC_NODE_API_BASE 설정이 필요합니다.');
          return;
        }
        if (!token) {
          setStatus('토큰을 먼저 입력하세요.');
          return;
        }
        if (!file) {
          setStatus('오디오 파일을 선택하세요.');
          return;
        }

        setLoading(true);
        setStatus('오디오를 업로드하고 있습니다.');
        resetAudioOutput();

        try {
          const audio = await fileToBase64(file);
          const response = await fetch(`${API_BASE}/pet`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              token,
              animal,
              mode,
              audio,
              audioMimeType: file.type || 'audio/webm'
            })
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload) {
            throw new Error(payload?.error || '펫 분석 요청에 실패했습니다.');
          }

          if (mode === 'command') {
            renderAnalyzeResult(payload?.meta ? { ...payload.meta, usage: payload.usage } : payload);
            renderCommandAudio(payload);
            setStatus('명령 음성까지 생성했습니다.');
          } else {
            renderAnalyzeResult(payload);
            setStatus('펫 언어 분석이 완료되었습니다.');
          }
        } catch (error) {
          setStatus(error instanceof Error ? error.message : '펫 분석 요청에 실패했습니다.');
          setUsage(null);
          resetAudioOutput();
        } finally {
          setLoading(false);
        }
      });

      resetAudioOutput();
      loadConfig();
    </script>
  </main>
</Layout>
