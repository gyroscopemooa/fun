---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="이름풀이 | FunHub" description="이름으로 성향 키워드를 확인하는 재미 콘텐츠">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">이름풀이</h1>
    <p class="mt-3 text-slate-700">이름을 입력하면 글자 조합 기반으로 키워드 풀이를 보여줍니다.</p>
    <AdSense slotName="본문 상단" />

    <section class="mt-5 rounded-xl border border-slate-200 bg-white p-5">
      <input id="name-input" class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="이름 입력" type="text" />
      <button id="name-run" class="mt-3 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white">풀이 보기</button>
      <p id="name-result" class="mt-3 rounded-md bg-slate-100 px-3 py-3 text-sm text-slate-700">이름을 입력해 주세요.</p>
    </section>

    <AdSense slotName="본문 하단" />
    <Recommend />
  </main>
  <Footer />

  <script is:inline>
    const inputEl = document.getElementById('name-input');
    const runEl = document.getElementById('name-run');
    const resultEl = document.getElementById('name-result');

    const traits = ['집중력', '공감력', '추진력', '창의성', '도전성', '꾸준함', '현실감각', '대인운'];

    runEl?.addEventListener('click', () => {
      const name = inputEl instanceof HTMLInputElement ? inputEl.value.trim() : '';
      if (!name) {
        if (resultEl) resultEl.textContent = '이름을 입력해 주세요.';
        return;
      }

      let sum = 0;
      for (const ch of name) sum += ch.charCodeAt(0);
      const t1 = traits[sum % traits.length];
      const t2 = traits[(sum + 3) % traits.length];
      if (resultEl) resultEl.textContent = `${name} 님의 키워드: ${t1}, ${t2}`;
    });
  </script>
</Layout>
