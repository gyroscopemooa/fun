---
import Layout from '../layouts/Layout.astro';

const rawApiBase = (import.meta.env.PUBLIC_NODE_API_BASE ?? '').trim();
const apiBase = rawApiBase.replace(/\/+$/, '');
---

<Layout
  title="AI 펫 언어 분석기 | 강아지 고양이 번역기"
  description="강아지와 고양이 소리를 바로 녹음해 분석하고, 짧은 명령은 텍스트로 입력해 음성까지 만드는 ManyTool AI 펫 언어 분석기입니다."
  keywords="AI 펫 번역기, 강아지 번역기, 고양이 번역기, 펫 언어 분석기, 반려동물 명령기, pet translator"
>
  <main class="relative bg-[radial-gradient(circle_at_top,#fff2ef,transparent_38%),linear-gradient(180deg,#fffaf7_0%,#f6f4ff_100%)] pb-20">
    <div id="pet-loading-overlay" class="pointer-events-none fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/55 px-4 backdrop-blur-sm">
      <div class="w-full max-w-md rounded-[32px] border border-white/20 bg-white/95 p-7 text-center shadow-[0_30px_80px_rgba(15,23,42,0.35)]">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-violet-100">
          <div class="h-8 w-8 animate-spin rounded-full border-4 border-violet-200 border-t-violet-600"></div>
        </div>
        <p id="pet-loading-overlay-title" class="mt-5 text-lg font-black text-slate-950">AI가 결과를 만드는 중입니다</p>
        <p id="pet-loading-overlay-message" class="mt-2 text-sm leading-6 text-slate-600">
          잠시만 기다려 주세요. 음성 분석과 결과 생성을 순서대로 처리하고 있습니다.
        </p>
      </div>
    </div>

    <section class="mx-auto max-w-[1180px] px-4 pt-8 sm:px-6 lg:px-8">
      <div id="pet-diagnostic-banner" class="mb-6 hidden rounded-[28px] border border-amber-200 bg-amber-50/95 p-5 shadow-[0_18px_40px_rgba(180,83,9,0.08)]">
        <p id="pet-diagnostic-title" class="text-sm font-black uppercase tracking-[0.18em] text-amber-700">Connection Check</p>
        <p id="pet-diagnostic-message" class="mt-2 text-sm leading-6 text-amber-950">
          API 연결 상태를 확인하는 중입니다.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-[1.04fr_0.96fr]">
        <section class="rounded-[34px] border border-rose-100 bg-white/92 p-7 shadow-[0_28px_60px_rgba(92,54,80,0.08)] sm:p-9">
          <p class="inline-flex rounded-full bg-rose-100 px-4 py-2 text-[11px] font-black uppercase tracking-[0.22em] text-rose-700">
            AI Pet Translator
          </p>
          <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-950 sm:text-5xl">
            반려동물 소리를
            <span class="block bg-[linear-gradient(135deg,#e11d48_0%,#7c3aed_100%)] bg-clip-text text-transparent">
              바로 분석하고 들려주기
            </span>
          </h1>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">
            강아지와 고양이 소리를 바로 눌러서 간단히 녹음하고, 짧은 명령은 텍스트로 빠르게 만들어 전달하는 방식으로 구성했습니다.
            모바일에서도 손쉽게 바로 실행할 수 있고, 불필요한 업로드나 복잡한 입력은 화면에서 최대한 줄였습니다.
          </p>

          <div class="mt-7 grid gap-3 sm:grid-cols-3">
            <div class="rounded-[24px] bg-rose-50 p-4">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-rose-600">빠른 분석</p>
              <p class="mt-2 text-sm leading-6 text-slate-700">길게 준비하지 않고 바로 녹음해도, 짧은 소리면 즉시 분석합니다.</p>
            </div>
            <div class="rounded-[24px] bg-amber-50 p-4">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-amber-700">명령 음성 생성</p>
              <p class="mt-2 text-sm leading-6 text-slate-700">짧은 텍스트 명령을 넣으면 반려동물 톤의 음성으로 바로 만들어 줍니다.</p>
            </div>
            <div class="rounded-[24px] bg-emerald-50 p-4">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-emerald-700">비용 절약</p>
              <p class="mt-2 text-sm leading-6 text-slate-700">짧은 녹음과 텍스트 입력 중심으로 토큰 사용량을 줄였습니다.</p>
            </div>
          </div>
        </section>

        <section class="rounded-[34px] border border-white/70 bg-white/90 p-5 shadow-[0_28px_60px_rgba(56,60,94,0.08)] sm:p-8">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Mobile Studio</p>
              <h2 class="mt-2 text-2xl font-black text-slate-950">바로 녹음하고 바로 실행</h2>
            </div>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-sm font-bold text-slate-800">반려동물</span>
              <select id="pet-animal" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-rose-400 focus:ring-4 focus:ring-rose-100">
                <option value="dog">강아지</option>
                <option value="cat">고양이</option>
              </select>
            </label>

            <div>
              <span class="mb-2 block text-sm font-bold text-slate-800">모드</span>
              <div class="grid grid-cols-2 gap-2 rounded-2xl bg-slate-100 p-1.5">
                <button id="mode-analyze" type="button" class="pet-mode-btn rounded-[18px] bg-white px-4 py-3 text-sm font-black text-slate-900 shadow-sm" data-mode="analyze">
                  언어 분석
                </button>
                <button id="mode-command" type="button" class="pet-mode-btn rounded-[18px] px-4 py-3 text-sm font-black text-slate-500" data-mode="command">
                  명령 음성 생성
                </button>
              </div>
            </div>
          </div>

          <div class="mt-5 rounded-[28px] bg-[linear-gradient(135deg,#fff1f2_0%,#eef2ff_100%)] p-5">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-sm font-black text-slate-900">녹음 상태</p>
                <p id="pet-recorder-status" class="mt-2 text-sm leading-6 text-slate-600">
                  반려동물 소리 버튼을 누르고 있는 동안 바로 녹음합니다. 분석용 녹음은 4초 안쪽으로 짧게 녹음하는 편이 가장 안정적입니다.
                </p>
              </div>
              <div id="pet-live-indicator" class="flex h-14 min-w-14 items-center justify-center rounded-full bg-white px-4 text-sm font-black text-rose-600 shadow-sm">
                READY
              </div>
            </div>

            <div class="mt-5 rounded-[24px] bg-white/90 p-4">
              <div class="flex items-center justify-between gap-3">
                <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Live Meter</p>
                <span id="pet-recording-badge" class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">대기 중</span>
              </div>
              <div class="mt-4 flex h-20 items-end gap-2">
                <span class="pet-bar h-4 flex-1 rounded-full bg-rose-200"></span>
                <span class="pet-bar h-8 flex-1 rounded-full bg-rose-200"></span>
                <span class="pet-bar h-6 flex-1 rounded-full bg-rose-200"></span>
                <span class="pet-bar h-10 flex-1 rounded-full bg-rose-200"></span>
                <span class="pet-bar h-5 flex-1 rounded-full bg-rose-200"></span>
                <span class="pet-bar h-7 flex-1 rounded-full bg-rose-200"></span>
                <span class="pet-bar h-3 flex-1 rounded-full bg-rose-200"></span>
                <span class="pet-bar h-9 flex-1 rounded-full bg-rose-200"></span>
              </div>
            </div>

            <div id="analyze-recorder-panel" class="mt-5">
              <button id="pet-record-hold" type="button" class="flex min-h-[112px] w-full touch-none items-center justify-center rounded-[28px] bg-[linear-gradient(135deg,#e11d48_0%,#fb7185_100%)] px-6 py-6 text-center text-base font-black text-white shadow-[0_18px_40px_rgba(225,29,72,0.28)] transition active:scale-[0.98] sm:text-lg">
                길게 눌러 녹음 시작
              </button>
              <p class="mt-3 text-center text-xs leading-6 text-slate-500">
                누르고 있는 동안만 녹음하고 손을 떼면 바로 분석합니다. 모바일 기준 1초에서 4초 정도가 가장 좋습니다.
              </p>
            </div>

            <div id="command-text-panel" class="mt-5 hidden">
              <label class="block">
                <span class="mb-2 block text-sm font-bold text-slate-800">짧은 명령 텍스트</span>
                <textarea id="pet-command-text" rows="3" maxlength="80" placeholder="예: 이리 와, 기다려, 괜찮아" class="w-full rounded-[24px] border border-slate-200 bg-white px-4 py-3 text-sm leading-6 text-slate-900 outline-none transition focus:border-violet-400 focus:ring-4 focus:ring-violet-100"></textarea>
              </label>
              <div class="mt-3 flex items-center justify-between gap-3 text-xs text-slate-500">
                <p>짧게 입력할수록 더 자연스럽고 비용도 적게 듭니다.</p>
                <span id="pet-command-count">0 / 80</span>
              </div>
              <button id="pet-command-submit" type="button" class="mt-4 w-full rounded-[22px] bg-[linear-gradient(135deg,#7c3aed_0%,#4338ca_100%)] px-5 py-4 text-sm font-black text-white shadow-[0_16px_34px_rgba(79,70,229,0.26)] transition hover:translate-y-[-1px] disabled:cursor-not-allowed disabled:opacity-60">
                텍스트로 명령 음성 만들기
              </button>
            </div>
          </div>

          <div class="mt-5 rounded-[24px] bg-slate-50 p-4 text-sm leading-6 text-slate-600">
            <p class="font-bold text-slate-900">사용 안내</p>
            <ul class="mt-2 space-y-1.5">
              <li>이 번역기는 짧은 소리를 빠르게 분석하도록 설계돼 있어 긴 파일 업로드 없이 바로 시작할 수 있습니다.</li>
              <li>명령 생성은 텍스트 입력을 우선 사용해 STT 비용을 줄이도록 구성했습니다.</li>
              <li>토큰은 화면에 노출하지 않고 URL 또는 로컬 저장 방식으로만 사용합니다.</li>
            </ul>
          </div>
        </section>
      </div>
    </section>

    <section class="mx-auto mt-8 max-w-[1180px] px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-[1fr_0.9fr]">
        <article class="rounded-[32px] border border-white/70 bg-white/90 p-6 shadow-[0_24px_50px_rgba(66,71,105,0.08)] sm:p-8">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Result</p>
              <h2 class="mt-2 text-2xl font-black text-slate-950">번역 결과</h2>
            </div>
            <span id="pet-usage" class="rounded-full bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-700">
              사용량 -
            </span>
          </div>

          <div id="pet-loading" class="mt-6 hidden rounded-[28px] border border-violet-100 bg-violet-50/80 p-5">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 animate-spin rounded-full border-4 border-violet-200 border-t-violet-600"></div>
              <div>
                <p class="text-sm font-black text-violet-900">AI가 소리를 해석 중입니다</p>
                <p class="mt-1 text-sm text-violet-700">음성 전사와 감정 분석, 3줄 결과 생성을 순서대로 처리합니다.</p>
              </div>
            </div>
          </div>

          <p id="pet-status" class="mt-6 text-sm leading-7 text-slate-500">
            아직 결과가 없습니다. 반려동물 소리를 짧게 녹음하거나 짧은 명령 텍스트를 입력해 주세요.
          </p>

          <div class="mt-6 grid gap-4 sm:grid-cols-3">
            <div class="rounded-[24px] bg-rose-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-rose-600">PET SAYS</p>
              <p id="pet-text" class="mt-3 text-lg font-black text-slate-950">-</p>
            </div>
            <div class="rounded-[24px] bg-amber-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-amber-700">EMOTION</p>
              <p id="pet-emotion" class="mt-3 text-lg font-black text-slate-950">-</p>
            </div>
            <div class="rounded-[24px] bg-emerald-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-emerald-700">EXPLANATION</p>
              <p id="pet-description" class="mt-3 text-sm font-semibold leading-6 text-slate-800">-</p>
            </div>
          </div>

          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Transcript</p>
              <p id="pet-transcript" class="mt-3 text-sm leading-6 text-slate-700">-</p>
            </div>
            <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-5">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Duration</p>
              <p id="pet-duration" class="mt-3 text-sm leading-6 text-slate-700">-</p>
            </div>
          </div>
        </article>

        <aside class="rounded-[32px] border border-white/70 bg-white/90 p-6 shadow-[0_24px_50px_rgba(66,71,105,0.08)] sm:p-8">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400">Command Audio</p>
          <h2 class="mt-2 text-2xl font-black text-slate-950">명령 음성 출력</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            명령 음성 생성 모드에서는 짧은 문장을 입력하면 반려동물 톤에 맞춰 다시 들려줍니다. 분석 전용 모드에서는 이 영역이 비활성 상태로 유지됩니다.
          </p>

          <div id="pet-audio-card" class="mt-6 rounded-[28px] bg-[linear-gradient(135deg,#101828_0%,#312e81_100%)] p-5 text-white opacity-50">
            <p id="pet-audio-empty" class="text-sm font-semibold text-white/70">아직 생성된 음성이 없습니다.</p>
            <audio id="pet-result-audio" class="mt-4 w-full" controls hidden></audio>
            <div class="mt-4 flex flex-wrap gap-2">
              <button id="pet-audio-play" type="button" class="hidden rounded-full bg-white px-4 py-2 text-sm font-bold text-slate-900">재생</button>
              <button id="pet-audio-stop" type="button" class="hidden rounded-full border border-white/30 bg-white/10 px-4 py-2 text-sm font-bold text-white">정지</button>
              <a id="pet-download" class="hidden rounded-full bg-white px-4 py-2 text-sm font-bold text-slate-900" download="pet-command.mp3">음성 다운로드</a>
            </div>
          </div>

          <div class="mt-6 rounded-[24px] bg-slate-50 p-5">
            <p class="text-sm font-bold text-slate-900">토큰과 비용 기준</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-600">
              <li>요청 1회마다 사용량 1회가 차감됩니다. 하루 최대 5회까지입니다.</li>
              <li>짧은 녹음일수록 STT 비용이 덜 커집니다. 그래서 1초에서 4초를 권장합니다.</li>
              <li>명령 생성은 텍스트 입력이면 STT를 건너뛰어 더 효율적입니다.</li>
              <li>TTS는 명령 모드에서만 사용합니다.</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <script is:inline define:vars={{ apiBase }}>
      const API_BASE = apiBase || (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost'
        ? 'http://127.0.0.1:8787'
        : 'https://api.manytool.net');
      const TOKEN_STORAGE_KEY = 'manytool.pet.token';
      const ORDER_STORAGE_KEY = 'manytool.pet.orderId';
      const DRAFT_STORAGE_KEY = 'manytool.pet.draft.v1';
      const PARAM_KEYS = ['token', 'petToken'];
      const MODE_ANALYZE = 'analyze';
      const MODE_COMMAND = 'command';
      const ANALYZE_MAX_MS = 4000;
      const PET_PRICE_CENTS = 199;
      const PET_CURRENCY = 'USD';

      const animalEl = document.getElementById('pet-animal');
      const modeButtons = Array.from(document.querySelectorAll('.pet-mode-btn'));
      const analyzePanelEl = document.getElementById('analyze-recorder-panel');
      const commandPanelEl = document.getElementById('command-text-panel');
      const commandTextEl = document.getElementById('pet-command-text');
      const commandCountEl = document.getElementById('pet-command-count');
      const commandSubmitEl = document.getElementById('pet-command-submit');
      const recordHoldEl = document.getElementById('pet-record-hold');
      const statusEl = document.getElementById('pet-status');
      const loadingEl = document.getElementById('pet-loading');
      const loadingOverlayEl = document.getElementById('pet-loading-overlay');
      const loadingOverlayTitleEl = document.getElementById('pet-loading-overlay-title');
      const loadingOverlayMessageEl = document.getElementById('pet-loading-overlay-message');
      const diagnosticBannerEl = document.getElementById('pet-diagnostic-banner');
      const diagnosticTitleEl = document.getElementById('pet-diagnostic-title');
      const diagnosticMessageEl = document.getElementById('pet-diagnostic-message');
      const usageEl = document.getElementById('pet-usage');
      const textEl = document.getElementById('pet-text');
      const emotionEl = document.getElementById('pet-emotion');
      const descriptionEl = document.getElementById('pet-description');
      const transcriptEl = document.getElementById('pet-transcript');
      const durationEl = document.getElementById('pet-duration');
      const recorderStatusEl = document.getElementById('pet-recorder-status');
      const liveIndicatorEl = document.getElementById('pet-live-indicator');
      const recordingBadgeEl = document.getElementById('pet-recording-badge');
      const audioCardEl = document.getElementById('pet-audio-card');
      const audioEmptyEl = document.getElementById('pet-audio-empty');
      const resultAudioEl = document.getElementById('pet-result-audio');
      const playAudioEl = document.getElementById('pet-audio-play');
      const stopAudioEl = document.getElementById('pet-audio-stop');
      const downloadEl = document.getElementById('pet-download');
      const meterBars = Array.from(document.querySelectorAll('.pet-bar'));

      let currentMode = MODE_ANALYZE;
      let recorder = null;
      let recordedChunks = [];
      let recordedBlob = null;
      let recordingStream = null;
      let selectedRecordingMimeType = '';
      let meterTimer = null;
      let autoStopTimer = null;
      let isRecording = false;
      let pressActivated = false;
      let apiReady = false;
      let tokenReady = false;
      let paymentMode = 'mock';
      let orderReady = false;
      let serviceReady = true;
      let currentOrderId = '';
      let shouldAutoResumeAfterPayment = false;

      const getStoredToken = () => {
        const params = new URLSearchParams(window.location.search);
        for (const key of PARAM_KEYS) {
          const value = params.get(key)?.trim();
          if (value) {
            window.localStorage.setItem(TOKEN_STORAGE_KEY, value);
            return value;
          }
        }
        return window.localStorage.getItem(TOKEN_STORAGE_KEY)?.trim() || '';
      };

      const getStoredOrderId = () => window.localStorage.getItem(ORDER_STORAGE_KEY)?.trim() || '';

      const hasPaidAccess = () => tokenReady || paymentMode !== 'polar' || Boolean(currentOrderId);

      const clearPaidOrder = () => {
        currentOrderId = '';
        window.localStorage.removeItem(ORDER_STORAGE_KEY);
      };

      const setStatus = (message) => {
        if (statusEl) statusEl.textContent = message;
      };

      const setRecorderStatus = (message) => {
        if (recorderStatusEl) recorderStatusEl.textContent = message;
      };

      const setUsage = (usage) => {
        if (!usageEl) return;
        if (usage?.usageCount && usage?.dailyLimit) {
          usageEl.textContent = `사용량 ${usage.usageCount}/${usage.dailyLimit}`;
          return;
        }
        if (usage?.orderId) {
          usageEl.textContent = '결제 완료';
          return;
        }
        usageEl.textContent = '사용량 -';
      };

      const setDiagnostic = (visible, title = '', message = '') => {
        if (!diagnosticBannerEl) return;
        diagnosticBannerEl.classList.toggle('hidden', !visible);
        if (diagnosticTitleEl && title) diagnosticTitleEl.textContent = title;
        if (diagnosticMessageEl && message) diagnosticMessageEl.textContent = message;
      };

      const syncCommandButtonState = () => {
        if (!commandSubmitEl) return;
        const hasText = Boolean((commandTextEl?.value || '').trim());
        const blocked = !apiReady || !serviceReady || (paymentMode === 'polar' && !orderReady);
        commandSubmitEl.disabled = currentMode !== MODE_COMMAND || !hasText || blocked;
      };

      const syncRecordButtonState = () => {
        if (!recordHoldEl) return;
        const blocked = !apiReady || !serviceReady || (paymentMode === 'polar' && !orderReady);
        recordHoldEl.disabled = blocked;
        if (!blocked && !isRecording) recordHoldEl.textContent = '길게 눌러 녹음 시작';
      };

      const refreshAvailability = () => {
        apiReady = Boolean(API_BASE);
        tokenReady = Boolean(getStoredToken());
        currentOrderId = getStoredOrderId();
        const blocked = !apiReady || !serviceReady || (paymentMode === 'polar' && !orderReady);

        if (!apiReady) {
          setDiagnostic(true, 'API Missing', '현재 페이지에 PUBLIC_NODE_API_BASE가 연결되지 않았습니다. 프론트 배포 환경 변수 확인이 필요합니다.');
          setStatus('API 서버 주소가 연결되지 않아 요청을 보낼 수 없습니다.');
        } else if (!serviceReady) {
          setDiagnostic(true, 'API Not Ready', 'API 서버는 연결됐지만 펫 번역 기능이 준비되지 않았습니다. OPENAI 설정 또는 서버 상태를 확인해야 합니다.');
          setStatus('펫 번역 API 준비 상태를 확인해 주세요.');
        } else if (paymentMode === 'polar' && !orderReady) {
          setDiagnostic(true, 'Token Missing', '현재 토큰이 없어 요청을 보낼 수 없습니다. URL의 token 또는 petToken 파라미터, 또는 저장된 토큰이 필요합니다.');
          setStatus('사용 가능한 토큰을 먼저 연결해 주세요.');
        } else if (!hasPaidAccess()) {
          setDiagnostic(true, 'Payment Required', '寃곗젣 ?꾨즺 ?먮뒗 湲곗〈 ?좏겙 ?곌껐 ???붿껌??蹂대궪 ???놁뒿?덈떎.');
          setStatus('寃곗젣 ?꾨즺 ?먮뒗 ?좏겙 ?곌껐 ???붿껌??蹂대궪 ???놁뒿?덈떎.');
        } else {
          setDiagnostic(false);
        }

        if (blocked) setRecorderStatus('설정이 완료되기 전까지는 요청을 보낼 수 없습니다.');

        syncRecordButtonState();
        syncCommandButtonState();
      };

      const setLoadingOverlay = (value, title, message) => {
        if (!loadingOverlayEl) return;
        loadingOverlayEl.classList.toggle('hidden', !value);
        loadingOverlayEl.classList.toggle('flex', value);
        loadingOverlayEl.classList.toggle('pointer-events-none', !value);
        if (loadingOverlayTitleEl && title) loadingOverlayTitleEl.textContent = title;
        if (loadingOverlayMessageEl && message) loadingOverlayMessageEl.textContent = message;
        document.body.classList.toggle('overflow-hidden', value);
      };

      const setLoading = (value, label = '분석 중...') => {
        loadingEl?.classList.toggle('hidden', !value);
        if (commandSubmitEl) {
          commandSubmitEl.textContent = value && currentMode === MODE_COMMAND ? label : '텍스트로 명령 음성 만들기';
        }
        if (recordHoldEl) {
          recordHoldEl.textContent = isRecording ? '녹음 중...' : '길게 눌러 녹음 시작';
        }
        if (value) {
          const title = currentMode === MODE_COMMAND ? '명령 음성을 만들고 있습니다' : '반려동물 소리를 분석하고 있습니다';
          const message = currentMode === MODE_COMMAND
            ? '텍스트를 해석하고 음성을 생성하는 중입니다.'
            : '녹음 파일을 분석하고 감정과 설명을 정리하는 중입니다.';
          setLoadingOverlay(true, title, message);
        } else {
          setLoadingOverlay(false);
        }
        syncRecordButtonState();
        syncCommandButtonState();
      };

      const resetAudioOutput = () => {
        if (resultAudioEl) {
          resultAudioEl.hidden = true;
          resultAudioEl.removeAttribute('src');
        }
        if (downloadEl) {
          downloadEl.hidden = true;
          downloadEl.removeAttribute('href');
        }
        if (playAudioEl) playAudioEl.hidden = true;
        if (stopAudioEl) stopAudioEl.hidden = true;
        if (audioEmptyEl) audioEmptyEl.hidden = false;
        audioCardEl?.classList.add('opacity-50');
      };

      const refreshMeter = (active) => {
        meterBars.forEach((bar, index) => {
          const height = active ? 20 + Math.round(Math.random() * 44) : 12 + ((index % 4) * 8);
          bar.style.height = `${height}px`;
          bar.classList.toggle('bg-rose-500', active);
          bar.classList.toggle('bg-rose-200', !active);
        });
      };

      const stopMeter = () => {
        window.clearInterval(meterTimer);
        meterTimer = null;
        refreshMeter(false);
      };

      const startMeter = () => {
        stopMeter();
        refreshMeter(true);
        meterTimer = window.setInterval(() => refreshMeter(true), 180);
      };

      const stopStreamTracks = () => {
        if (!recordingStream) return;
        recordingStream.getTracks().forEach((track) => track.stop());
        recordingStream = null;
      };

      const clearAutoStop = () => {
        window.clearTimeout(autoStopTimer);
        autoStopTimer = null;
      };

      const chooseRecordingMimeType = () => {
        if (typeof MediaRecorder === 'undefined' || typeof MediaRecorder.isTypeSupported !== 'function') {
          return '';
        }

        const candidates = [
          'audio/webm;codecs=opus',
          'audio/webm',
          'audio/mp4',
          'audio/ogg;codecs=opus',
          'audio/ogg'
        ];

        return candidates.find((mimeType) => MediaRecorder.isTypeSupported(mimeType)) || '';
      };

      const inferAudioExtension = (mimeType) => {
        const normalized = String(mimeType || '').toLowerCase();
        if (normalized.includes('wav')) return 'wav';
        if (normalized.includes('mpeg') || normalized.includes('mp3')) return 'mp3';
        if (normalized.includes('ogg')) return 'ogg';
        if (normalized.includes('mp4') || normalized.includes('m4a')) return 'm4a';
        return 'webm';
      };

      const blobToDataUrl = (blob) => new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(typeof reader.result === 'string' ? reader.result : '');
        reader.onerror = () => reject(new Error('녹음 데이터를 읽지 못했습니다.'));
        reader.readAsDataURL(blob);
      });

      const dataUrlToBlob = async (dataUrl) => {
        const response = await fetch(dataUrl);
        return response.blob();
      };

      const buildDraftPayload = async () => {
        const draft = {
          mode: currentMode,
          animal: animalEl?.value || 'dog',
          commandText: commandTextEl?.value || ''
        };

        if (recordedBlob instanceof Blob && currentMode === MODE_ANALYZE) {
          draft.audioDataUrl = await blobToDataUrl(recordedBlob);
          draft.audioMimeType = recordedBlob.type || 'audio/webm';
        }

        return draft;
      };

      const persistDraftForCheckout = async () => {
        const draft = await buildDraftPayload();
        window.sessionStorage.setItem(DRAFT_STORAGE_KEY, JSON.stringify(draft));
      };

      const restoreDraftFromStorage = async () => {
        const raw = window.sessionStorage.getItem(DRAFT_STORAGE_KEY);
        if (!raw) return false;

        try {
          const draft = JSON.parse(raw);
          if (animalEl && draft?.animal) animalEl.value = draft.animal;
          if (typeof draft?.mode === 'string') setMode(draft.mode);
          if (commandTextEl && typeof draft?.commandText === 'string') {
            commandTextEl.value = draft.commandText;
            if (commandCountEl) commandCountEl.textContent = `${draft.commandText.length} / 80`;
          }
          if (draft?.audioDataUrl) {
            recordedBlob = await dataUrlToBlob(draft.audioDataUrl);
            selectedRecordingMimeType = draft.audioMimeType || recordedBlob.type || 'audio/webm';
            setRecordingUi(false);
          }
          syncCommandButtonState();
          return true;
        } catch {
          window.sessionStorage.removeItem(DRAFT_STORAGE_KEY);
          return false;
        }
      };

      const requestPetCheckout = async () => {
        const currentUrl = window.location.href.split('?')[0];
        const response = await fetch(`${API_BASE}/checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            productType: 'ai_pet_translator',
            amount: PET_PRICE_CENTS,
            currency: PET_CURRENCY,
            successUrl: currentUrl,
            returnUrl: currentUrl
          })
        });
        const payload = await response.json().catch(() => null);
        if (!response.ok || !payload) {
          throw new Error(payload?.error || 'checkout failed');
        }
        return payload;
      };

      const verifyExistingOrder = async (orderId) => {
        if (!orderId || !API_BASE) return false;
        try {
          const response = await fetch(`${API_BASE}/order/${encodeURIComponent(orderId)}`);
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload) return false;
          if (payload.status === 'paid' && payload.productType === 'ai_pet_translator' && !payload.petTranslatorUsedAt) {
            currentOrderId = orderId;
            window.localStorage.setItem(ORDER_STORAGE_KEY, orderId);
            return true;
          }
          if (payload.petTranslatorUsedAt) {
            clearPaidOrder();
          }
          return false;
        } catch {
          return false;
        }
      };

      const renderAnalyzeResult = (payload) => {
        textEl.textContent = payload?.text || '-';
        emotionEl.textContent = payload?.emotion || '-';
        descriptionEl.textContent = payload?.description || '-';
        transcriptEl.textContent = payload?.transcript || '전사 텍스트 없음';
        durationEl.textContent = typeof payload?.durationSeconds === 'number' && payload.durationSeconds > 0
          ? `${payload.durationSeconds}초`
          : '길이 정보 없음';
        setUsage(payload?.usage);
      };

      const renderCommandAudio = (payload) => {
        const base64 = typeof payload?.audio === 'string' ? payload.audio : '';
        const mimeType = payload?.mimeType || 'audio/mpeg';
        if (!base64 || !resultAudioEl || !downloadEl) {
          resetAudioOutput();
          return;
        }
        const audioUrl = `data:${mimeType};base64,${base64}`;
        resultAudioEl.src = audioUrl;
        resultAudioEl.hidden = false;
        downloadEl.href = audioUrl;
        downloadEl.hidden = false;
        if (playAudioEl) playAudioEl.hidden = false;
        if (stopAudioEl) stopAudioEl.hidden = false;
        if (audioEmptyEl) audioEmptyEl.hidden = true;
        audioCardEl?.classList.remove('opacity-50');
      };

      const setMode = (nextMode) => {
        currentMode = nextMode === MODE_COMMAND ? MODE_COMMAND : MODE_ANALYZE;
        modeButtons.forEach((button) => {
          const active = button.dataset.mode === currentMode;
          button.className = active
            ? 'pet-mode-btn rounded-[18px] bg-white px-4 py-3 text-sm font-black text-slate-900 shadow-sm'
            : 'pet-mode-btn rounded-[18px] px-4 py-3 text-sm font-black text-slate-500';
        });
        analyzePanelEl?.classList.toggle('hidden', currentMode !== MODE_ANALYZE);
        commandPanelEl?.classList.toggle('hidden', currentMode !== MODE_COMMAND);
        resetAudioOutput();
        syncCommandButtonState();

        if (currentMode === MODE_ANALYZE) {
          setRecorderStatus('반려동물 소리를 바로 눌러서 녹음하고 손을 떼면 즉시 분석합니다.');
          if (apiReady && hasPaidAccess() && serviceReady) setStatus('반려동물 소리를 짧게 녹음해 주세요.');
        } else {
          setRecorderStatus('짧은 명령은 텍스트로 직접 쓰는 편이 더 빠르고 비용도 적게 듭니다.');
          if (apiReady && hasPaidAccess() && serviceReady) setStatus('짧은 명령 문장을 입력하고 음성을 생성해 주세요.');
        }
      };

      const setRecordingUi = (recording) => {
        isRecording = recording;
        if (recordHoldEl) {
          recordHoldEl.textContent = recording ? '손을 떼면 바로 분석' : '길게 눌러 녹음 시작';
          recordHoldEl.classList.toggle('scale-[0.98]', recording);
        }
        if (recordingBadgeEl) {
          recordingBadgeEl.textContent = recording ? '녹음 중' : recordedBlob ? '녹음 완료' : '대기 중';
          recordingBadgeEl.className = recording
            ? 'rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700'
            : recordedBlob
              ? 'rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700'
              : 'rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600';
        }
        if (liveIndicatorEl) {
          liveIndicatorEl.textContent = recording ? 'REC' : recordedBlob ? 'DONE' : 'READY';
          liveIndicatorEl.className = recording
            ? 'flex h-14 min-w-14 items-center justify-center rounded-full bg-rose-100 px-4 text-sm font-black text-rose-700 shadow-sm'
            : recordedBlob
              ? 'flex h-14 min-w-14 items-center justify-center rounded-full bg-emerald-100 px-4 text-sm font-black text-emerald-700 shadow-sm'
              : 'flex h-14 min-w-14 items-center justify-center rounded-full bg-white px-4 text-sm font-black text-rose-600 shadow-sm';
        }
      };

      const finishRecording = async (shouldAutoSubmit = false) => {
        clearAutoStop();
        if (!recordedChunks.length) {
          setRecordingUi(false);
          stopMeter();
          stopStreamTracks();
          return;
        }
        recordedBlob = new Blob(recordedChunks, {
          type: recorder?.mimeType || selectedRecordingMimeType || recordedChunks[0]?.type || 'audio/webm'
        });
        setRecorderStatus('녹음이 끝났습니다. 바로 분석을 시작합니다.');
        setRecordingUi(false);
        stopMeter();
        stopStreamTracks();
        if (shouldAutoSubmit) {
          await submitAnalyze();
        }
      };

      const startRecordingNow = async () => {
        if (!navigator.mediaDevices?.getUserMedia) {
          setRecorderStatus('이 브라우저는 마이크 녹음을 지원하지 않습니다.');
          return;
        }

        recordedBlob = null;
        recordedChunks = [];
        resetAudioOutput();

        try {
          recordingStream = await navigator.mediaDevices.getUserMedia({ audio: true });
          selectedRecordingMimeType = chooseRecordingMimeType();
          recorder = selectedRecordingMimeType
            ? new MediaRecorder(recordingStream, { mimeType: selectedRecordingMimeType })
            : new MediaRecorder(recordingStream);
          recorder.ondataavailable = (event) => {
            if (event.data && event.data.size > 0) recordedChunks.push(event.data);
          };
          recorder.onstop = () => {
            void finishRecording(true);
          };
          recorder.start();
          setRecorderStatus('지금 바로 반려동물 소리를 들려 주세요.');
          setRecordingUi(true);
          startMeter();
          clearAutoStop();
          autoStopTimer = window.setTimeout(() => {
            if (recorder && recorder.state !== 'inactive') {
              recorder.stop();
            }
          }, ANALYZE_MAX_MS);
        } catch (error) {
          setRecorderStatus(error instanceof Error ? error.message : '마이크 권한을 확인해 주세요.');
          setRecordingUi(false);
          stopStreamTracks();
        }
      };

      const stopRecording = () => {
        if (!recorder || recorder.state === 'inactive') return;
        recorder.stop();
        setRecorderStatus('녹음을 정리하고 있습니다.');
        setRecordingUi(false);
      };

      const loadConfig = async () => {
        if (!API_BASE) {
          serviceReady = false;
          orderReady = false;
          refreshAvailability();
          return;
        }

        try {
          const response = await fetch(`${API_BASE}/config`);
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload) throw new Error('config fetch failed');
          serviceReady = Boolean(payload?.readiness?.petTranslatorReady);
          paymentMode = payload?.paymentMode === 'polar' ? 'polar' : 'mock';
          orderReady = paymentMode === 'polar' ? Boolean(payload?.paymentProducts?.ai_pet_translator) : true;
        } catch {
          serviceReady = false;
          orderReady = false;
        }

        refreshAvailability();
      };

      const callPetApi = async (body, loadingLabel) => {
        const token = getStoredToken();
        const animal = animalEl?.value || 'dog';

        if (!API_BASE) {
          setStatus('PUBLIC_NODE_API_BASE 설정이 필요합니다.');
          refreshAvailability();
          return null;
        }
        if (!hasPaidAccess()) {
          try {
            await persistDraftForCheckout();
            const checkout = await requestPetCheckout();
            if (checkout?.orderId) {
              currentOrderId = checkout.orderId;
              window.localStorage.setItem(ORDER_STORAGE_KEY, checkout.orderId);
            }
            if (!checkout?.paid) {
              if (checkout?.checkoutUrl) {
                window.location.href = checkout.checkoutUrl;
                return null;
              }
              throw new Error('checkout url is missing');
            }
          } catch (error) {
            setStatus(error instanceof Error ? error.message : '寃곗젣 ?쒖옉???ㅽ뙣?덉뒿?덈떎.');
            return null;
          }
        }
        if (!token && !currentOrderId) {
          setStatus('사용 가능한 토큰을 찾지 못했습니다. 결제 또는 발급 흐름을 먼저 연결해 주세요.');
          refreshAvailability();
          return null;
        }
        if (!serviceReady) {
          setStatus('펫 번역 API 준비 상태를 먼저 확인해 주세요.');
          refreshAvailability();
          return null;
        }

        setLoading(true, loadingLabel);
        setStatus('AI 서버로 요청을 보내고 있습니다.');
        resetAudioOutput();

        try {
          const hasAudioFile = body?.audioFile instanceof Blob;
          let requestBody = null;
          let headers = null;

          if (hasAudioFile) {
            const formData = new FormData();
            if (currentOrderId) {
              formData.append('orderId', currentOrderId);
            } else {
              formData.append('token', token);
            }
            formData.append('animal', animal);
            formData.append('mode', currentMode);
            formData.append('audioMimeType', body.audioMimeType || body.audioFile.type || 'audio/webm');
            formData.append(
              'audio',
              body.audioFile,
              `pet-recording.${inferAudioExtension(body.audioMimeType || body.audioFile.type)}`
            );
            requestBody = formData;
          } else {
            headers = { 'Content-Type': 'application/json' };
            requestBody = JSON.stringify({
              ...(currentOrderId ? { orderId: currentOrderId } : { token }),
              animal,
              mode: currentMode,
              ...body
            });
          }

          const response = await fetch(`${API_BASE}/api/pet`, {
            method: 'POST',
            ...(headers ? { headers } : {}),
            body: requestBody
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload) {
            throw new Error(payload?.error || '펫 번역 요청에 실패했습니다.');
          }

          if (currentMode === MODE_COMMAND) {
            renderAnalyzeResult(payload?.meta ? { ...payload.meta, usage: payload.usage } : payload);
            renderCommandAudio(payload);
            setStatus('명령 음성이 생성됐습니다.');
          } else {
            renderAnalyzeResult(payload);
            setStatus('펫 언어 분석이 완료됐습니다.');
          }

          if (currentOrderId && !token) {
            clearPaidOrder();
            window.sessionStorage.removeItem(DRAFT_STORAGE_KEY);
          }
          return payload;
        } catch (error) {
          setStatus(error instanceof Error ? error.message : '펫 번역 요청에 실패했습니다.');
          setUsage(null);
          resetAudioOutput();
          if (String(error instanceof Error ? error.message : '').toLowerCase().includes('already been used')) {
            clearPaidOrder();
          }
          return null;
        } finally {
          setLoading(false);
          refreshAvailability();
        }
      };

      const submitAnalyze = async () => {
        if (!recordedBlob) {
          setStatus('먼저 반려동물 소리를 짧게 녹음해 주세요.');
          return;
        }

        await callPetApi({
          audioFile: recordedBlob,
          audioMimeType: recordedBlob.type || 'audio/webm'
        }, '분석 중...');
      };

      const submitCommandText = async () => {
        const textValue = (commandTextEl?.value || '').trim();
        if (!textValue) {
          setStatus('짧은 명령 문장을 먼저 입력해 주세요.');
          syncCommandButtonState();
          commandTextEl?.focus();
          return;
        }

        await callPetApi({ text: textValue }, '명령 생성 중...');
      };

      const handleRecordPressStart = async (event) => {
        event.preventDefault();
        if (currentMode !== MODE_ANALYZE || isRecording || pressActivated || !apiReady || !serviceReady || (paymentMode === 'polar' && !orderReady)) return;
        pressActivated = true;
        await startRecordingNow();
      };

      const handleRecordPressEnd = (event) => {
        event.preventDefault();
        if (!pressActivated) return;
        pressActivated = false;
        if (isRecording) stopRecording();
      };

      const handleRecordButtonClick = async (event) => {
        event.preventDefault();
        if (currentMode !== MODE_ANALYZE || pressActivated || !apiReady || !serviceReady || (paymentMode === 'polar' && !orderReady)) return;
        if (isRecording) {
          stopRecording();
          return;
        }
        await startRecordingNow();
      };

      commandTextEl?.addEventListener('input', () => {
        const length = (commandTextEl.value || '').length;
        if (commandCountEl) commandCountEl.textContent = `${length} / 80`;
        syncCommandButtonState();
      });

      commandTextEl?.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && !event.shiftKey) {
          event.preventDefault();
          if (!commandSubmitEl?.disabled) void submitCommandText();
        }
      });

      modeButtons.forEach((button) => {
        button.addEventListener('click', () => setMode(button.dataset.mode));
      });

      recordHoldEl?.addEventListener('pointerdown', handleRecordPressStart);
      recordHoldEl?.addEventListener('pointerup', handleRecordPressEnd);
      recordHoldEl?.addEventListener('pointercancel', handleRecordPressEnd);
      recordHoldEl?.addEventListener('click', handleRecordButtonClick);
      recordHoldEl?.addEventListener('pointerleave', (event) => {
        if (isRecording) handleRecordPressEnd(event);
      });
      commandSubmitEl?.addEventListener('click', () => {
        if (commandSubmitEl.disabled) {
          refreshAvailability();
          commandTextEl?.focus();
          return;
        }
        void submitCommandText();
      });
      playAudioEl?.addEventListener('click', async () => {
        try {
          await resultAudioEl?.play();
        } catch {
        }
      });
      stopAudioEl?.addEventListener('click', () => {
        if (!resultAudioEl) return;
        resultAudioEl.pause();
        resultAudioEl.currentTime = 0;
      });

      window.addEventListener('storage', (event) => {
        if (event.key === TOKEN_STORAGE_KEY || event.key === ORDER_STORAGE_KEY) refreshAvailability();
      });

      void (async () => {
        if (typeof window === 'undefined') return;
        const params = new URLSearchParams(window.location.search);
        const orderId = params.get('orderId');
        const savedOrderId = orderId || getStoredOrderId();

        if (savedOrderId) {
          const verified = await verifyExistingOrder(savedOrderId);
          if (verified && orderId) {
            shouldAutoResumeAfterPayment = true;
          }
        }

        const restoredDraft = await restoreDraftFromStorage();
        if (shouldAutoResumeAfterPayment && restoredDraft) {
          shouldAutoResumeAfterPayment = false;
          if (currentMode === MODE_COMMAND) {
            await submitCommandText();
          } else if (recordedBlob) {
            await submitAnalyze();
          }
        }

        if (orderId) {
          window.history.replaceState({}, '', window.location.pathname);
        }
      })();

      resetAudioOutput();
      refreshMeter(false);
      setRecordingUi(false);
      setMode(MODE_ANALYZE);
      refreshAvailability();
      loadConfig();
    </script>
  </main>
</Layout>
