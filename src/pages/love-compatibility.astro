---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Recommend from '../components/Recommend.astro';
---

<Layout title="연애 궁합 테스트 | FunHub" description="두 사람의 성향 기반 연애 궁합 테스트">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="text-2xl font-bold">연애 궁합 테스트</h1>
    <p class="mt-3 text-slate-700">간단한 입력으로 궁합 결과를 확인하는 재미형 테스트입니다.</p>
    <AdSense slotName="본문 상단" />
    <div class="mt-4 rounded-lg border bg-white p-6">Love Compatibility Placeholder</div>
    <Recommend />
  </main>
  <Footer />
</Layout>
